diff -r -u -N /home/packages/busybox-1.15.1-15/tile-prepare ./tile-prepare
--- /home/packages/busybox-1.15.1-15/tile-prepare	1969-12-31 19:00:00.000000000 -0500
+++ ./tile-prepare	2015-10-26 22:26:10.601843000 -0400
@@ -0,0 +1,52 @@
+#!/bin/sh -e
+
+# Prepare a build directory for the standard Tilera Busybox.
+
+if [ -n "$TILERA_ROOT" ]; then
+    CC="$TILERA_ROOT"/bin/tile-gcc
+    if [ ! -f "$TILERA_ROOT"/bin/tile-gcc ]; then
+	echo "TILERA_ROOT must point to a per-chip hierarchy of an MDE install tree." >&2
+	exit 1
+    fi
+else
+    CC=gcc
+    ARCH=`uname -m`
+    case "$ARCH" in
+	tile*) ;;
+	*) echo "TILERA_ROOT not set in environment." >&2; exit 1 ;;
+    esac
+fi
+
+# Verify the "source" directory.
+src=${0%/tile-prepare}
+case "$src" in
+/*) ;;
+*) src=$(pwd)/$src ;;
+esac
+config=tile-defconfig
+product=Busybox
+if [ ! -f $src/$config ]; then
+  echo "$0 is not in a $product source directory." >&2
+  exit 1
+fi
+
+# Verify the "build" directory.
+build=`pwd`
+if [ -f $config ]; then
+  echo "$0 must not be run in the $product source directory." >&2
+  echo "Please create a new empty directory to build in, then run" >&2
+  echo "  $build/tile-prepare" >&2
+  echo "from within that directory." >&2
+  exit 1
+fi
+
+if [ ! -f .config ]; then
+    echo "Copying default .config from $src"
+    cat $src/$config >.config
+fi
+
+echo "Running 'make ARCH=tile oldconfig > make-oldconfig.out'"
+make ARCH=tile -C $src O=$build oldconfig > make-oldconfig.out
+
+echo ""
+echo "To build $product, just run 'make' in this directory."
diff -r -u -N /home/packages/busybox-1.15.1-15/tiny/tile-defconfig ./tiny/tile-defconfig
