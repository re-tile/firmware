diff -r -u -N /home/packages/busybox-1.15.1-15/libbb/find_mount_point.c ./libbb/find_mount_point.c
--- /home/packages/busybox-1.15.1-15/libbb/find_mount_point.c	2009-09-12 11:55:36.000000000 -0400
+++ ./libbb/find_mount_point.c	2015-10-26 22:26:10.093818000 -0400
@@ -11,11 +11,45 @@
 #include <mntent.h>
 
 /*
+ * Do a deep copy of a struct mntent, using a secondary buffer to
+ * hold the actual string contents that the string pointers reference.
+ */
+static int copy_mntent(struct mntent *to, const struct mntent *from,
+		       char *buf, size_t bufsize)
+{
+	size_t offset = 0;
+	int rc;
+
+#  define copy_field(field) \
+	to->field = &buf[offset]; \
+	rc = snprintf(&buf[offset], bufsize - offset, "%s", from->field) + 1; \
+	if (rc > bufsize - offset) \
+		return 0; \
+	offset += rc
+
+	copy_field(mnt_fsname);
+	copy_field(mnt_dir);
+	copy_field(mnt_type);
+	copy_field(mnt_opts);
+
+#  undef copy_field
+
+	to->mnt_freq = from->mnt_freq;
+	to->mnt_passno = from->mnt_passno;
+	return 1;
+}
+	
+/*
  * Given a block device, find the mount table entry if that block device
  * is mounted.
  *
  * Given any other file (or directory), find the mount table entry for its
  * filesystem.
+ *
+ * If we match by directory name or by mounted directory device, take
+ * the last entry instead of the first.  In particular this works around
+ * the problem that switch_root leaves the rootfs entry at the top
+ * of /proc/mounts.
  */
 struct mntent* FAST_FUNC find_mount_point(const char *name, int subdir_too)
 {
@@ -24,6 +58,9 @@
 	struct mntent *mountEntry;
 	dev_t devno_of_name;
 	bool block_dev;
+	static struct mntent lastEntry;
+	static char buf[256];
+	int sawEntry = 0;
 
 	if (stat(name, &s) != 0)
 		return NULL;
@@ -39,30 +76,33 @@
 	if (!mtab_fp)
 		return NULL;
 
-	while ((mountEntry = getmntent(mtab_fp)) != NULL) {
-		/* rootfs mount in Linux 2.6 exists always,
-		 * and it makes sense to always ignore it.
-		 * Otherwise people can't reference their "real" root! */
-		if (strcmp(mountEntry->mnt_fsname, "rootfs") == 0)
-			continue;
+	while ((mountEntry = getmntent(mtab_fp)) != 0) {
 
-		if (strcmp(name, mountEntry->mnt_dir) == 0
-		 || strcmp(name, mountEntry->mnt_fsname) == 0
-		) { /* String match. */
+		/* If the fsname's rdev matches the device, it's good. */
+		if (strchr(mountEntry->mnt_fsname, '/')
+		    && stat(mountEntry->mnt_fsname, &s) == 0
+		    && s.st_rdev == devno_of_name) {
 			break;
 		}
 
 		if (!(subdir_too || block_dev))
 			continue;
 
-		/* Is device's dev_t == name's dev_t? */
-		if (stat(mountEntry->mnt_fsname, &s) == 0 && s.st_rdev == devno_of_name)
-			break;
-		/* Match the directory's mount point. */
-		if (stat(mountEntry->mnt_dir, &s) == 0 && s.st_dev == devno_of_name)
-			break;
+		/*
+		 * Otherwise, if the name or mount directory device
+		 * matches, it's a candidate; remember the last one.
+		 */
+		if (strcmp(name, mountEntry->mnt_dir) == 0
+		    || strcmp(name, mountEntry->mnt_fsname) == 0
+		    || (stat(mountEntry->mnt_dir, &s) == 0
+			&& s.st_dev == devno_of_name)) {
+			sawEntry = copy_mntent(&lastEntry, mountEntry,
+					      buf, sizeof(buf));
+		}
 	}
 	endmntent(mtab_fp);
 
+	if (mountEntry == NULL && sawEntry)
+		mountEntry = &lastEntry;
 	return mountEntry;
 }
