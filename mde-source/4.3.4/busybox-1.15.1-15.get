diff -r -u -N /home/packages/busybox-1.15.1-15/modutils/modutils-24.c ./modutils/modutils-24.c
--- /home/packages/busybox-1.15.1-15/modutils/modutils-24.c	2009-09-12 11:55:36.000000000 -0400
+++ ./modutils/modutils-24.c	2015-10-26 22:26:10.158825000 -0400
@@ -289,6 +289,23 @@
 #define ELFCLASSM	ELFCLASS64
 #endif
 
+/* tile  */
+#if defined(__tile__)
+#include <arch/chip.h>
+#define MATCH_MACHINE(x) (x == CHIP_ELF_TYPE() || x == CHIP_COMPAT_ELF_TYPE())
+#define SHT_RELM	SHT_RELA
+#define USE_GOT_ENTRIES
+#define GOT_ENTRY_SIZE 8
+#define USE_SINGLE
+#if CHIP_WORD_SIZE() == 32
+#define Elf32_RelM	Elf32_Rela
+#define ELFCLASSM	ELFCLASS32
+#else
+#define Elf64_RelM	Elf64_Rela
+#define ELFCLASSM	ELFCLASS64
+#endif
+#endif
+
 #ifndef SHT_RELM
 #error Sorry, but insmod.c does not yet support this architecture...
 #endif
diff -r -u -N /home/packages/busybox-1.15.1-15/networking/route.c ./networking/route.c
--- /home/packages/busybox-1.15.1-15/networking/route.c	2009-09-12 11:55:36.000000000 -0400
+++ ./networking/route.c	2015-10-26 22:26:10.195808000 -0400
@@ -491,7 +491,10 @@
 			netstatfmt ? "  MSS Window  irtt" : "Metric Ref    Use");
 
 	if (fscanf(fp, "%*[^\n]\n") < 0) { /* Skip the first line. */
-		goto ERROR;		   /* Empty or missing line, or read error. */
+		/* Empty or missing line, or read error. */
+		if (feof(fp))
+			return;
+		goto ERROR;
 	}
 	while (1) {
 		int r;
diff -r -u -N /home/packages/busybox-1.15.1-15/networking/udhcp/clientpacket.c ./networking/udhcp/clientpacket.c
--- /home/packages/busybox-1.15.1-15/networking/udhcp/clientpacket.c	2009-09-12 11:55:36.000000000 -0400
+++ ./networking/udhcp/clientpacket.c	2015-10-26 22:26:10.221822000 -0400
@@ -47,8 +47,13 @@
 		add_option_string(packet->options, client_config.hostname);
 	if (client_config.fqdn)
 		add_option_string(packet->options, client_config.fqdn);
-	if ((type != DHCPDECLINE) && (type != DHCPRELEASE))
+	if ((type != DHCPDECLINE) && (type != DHCPRELEASE)) {
 		add_option_string(packet->options, client_config.vendorclass);
+#ifdef __tile__
+		if (client_config.send_archtype)
+			add_simple_option(packet->options, DHCP_CLIENT_ARCH, client_config.archtype);
+#endif
+	}
 }
 
 
@@ -138,7 +143,9 @@
 
 	add_param_req_option(&packet);
 
+#ifndef __tile__
 	bb_info_msg("Sending discover...");
+#endif
 	return raw_bcast_from_client_config_ifindex(&packet);
 }
 
diff -r -u -N /home/packages/busybox-1.15.1-15/networking/udhcp/dhcpc.c ./networking/udhcp/dhcpc.c
--- /home/packages/busybox-1.15.1-15/networking/udhcp/dhcpc.c	2009-09-12 11:55:36.000000000 -0400
+++ ./networking/udhcp/dhcpc.c	2015-10-26 22:26:10.257809000 -0400
@@ -158,6 +158,9 @@
 	struct timeval tv;
 	struct dhcp_packet packet;
 	fd_set rfds;
+#ifdef __tile__
+	unsigned int archtype;
+#endif
 
 #if ENABLE_LONG_OPTS
 	static const char udhcpc_longopts[] ALIGN1 =
@@ -184,6 +187,10 @@
 		"background\0"     No_argument       "b"
 		IF_FEATURE_UDHCPC_ARPING("arping\0"	No_argument       "a")
 		IF_FEATURE_UDHCP_PORT("client-port\0"	Required_argument "P")
+#ifdef __tile__
+		/* Will not be public in udhcpc usage() */
+		"archtype\0"       Required_argument "Y"
+#endif
 		;
 #endif
 	enum {
@@ -212,6 +219,10 @@
 		USE_FOR_MMU(             OPTBIT_b,)
 		IF_FEATURE_UDHCPC_ARPING(OPTBIT_a,)
 		IF_FEATURE_UDHCP_PORT(   OPTBIT_P,)
+#ifdef __tile__
+		OPTBIT_Y,
+		OPT_Y = 1 << OPTBIT_Y,
+#endif
 		USE_FOR_MMU(             OPT_b = 1 << OPTBIT_b,)
 		IF_FEATURE_UDHCPC_ARPING(OPT_a = 1 << OPTBIT_a,)
 		IF_FEATURE_UDHCP_PORT(   OPT_P = 1 << OPTBIT_P,)
@@ -222,10 +233,14 @@
 	IF_FEATURE_UDHCP_PORT(CLIENT_PORT = 68;)
 	client_config.interface = "eth0";
 	client_config.script = DEFAULT_SCRIPT;
+#ifdef __tile__
+	client_config.send_archtype = 0;
+	archtype = 0xffff;
+#endif
 
 	/* Parse command line */
 	/* Cc: mutually exclusive; O: list; -T,-t,-A take numeric param */
-	opt_complementary = "c--C:C--c:O::T+:t+:A+"
+	opt_complementary = "c--C:C--c:O::T+:t+:A+:Y+"
 #if defined CONFIG_UDHCP_DEBUG && CONFIG_UDHCP_DEBUG >= 1
 		":vv"
 #endif
@@ -235,17 +250,36 @@
 		USE_FOR_MMU("b")
 		IF_FEATURE_UDHCPC_ARPING("a")
 		IF_FEATURE_UDHCP_PORT("P:")
+#ifdef __tile__
+		"Y:"
+#endif
+#if defined CONFIG_UDHCP_DEBUG && CONFIG_UDHCP_DEBUG >= 1
 		"v"
+#endif
 		, &str_c, &str_V, &str_h, &str_h, &str_F
 		, &client_config.interface, &client_config.pidfile, &str_r /* i,p */
 		, &client_config.script /* s */
 		, &discover_timeout, &discover_retries, &tryagain_timeout /* T,t,A */
 		, &list_O
 		IF_FEATURE_UDHCP_PORT(, &str_P)
+#ifdef __tile__
+		, &archtype
+#endif
 #if defined CONFIG_UDHCP_DEBUG && CONFIG_UDHCP_DEBUG >= 1
 		, &dhcp_verbose
 #endif
 		);
+
+#ifdef __tile__
+	/*
+	 * Users need to specify an unused tag since we do not have
+	 * standard values for tile.
+	 */
+	if (opt & OPT_Y) {
+		client_config.send_archtype = 1;
+		client_config.archtype = htons((uint16_t)archtype);
+	}
+#endif
 	if (opt & OPT_c)
 		client_config.clientid = alloc_dhcp_option(DHCP_CLIENT_ID, str_c, 0);
 	if (opt & OPT_V)
@@ -312,6 +346,9 @@
 	write_pidfile(client_config.pidfile);
 
 	/* Goes to stdout (unless NOMMU) and possibly syslog */
+#ifdef __tile__
+	if (getenv("TLR_QUIET") == NULL)
+#endif
 	bb_info_msg("%s (v"BB_VER") started", applet_name);
 
 	/* If not set, and not suppressed, set up the default client ID */
diff -r -u -N /home/packages/busybox-1.15.1-15/networking/udhcp/dhcpc.h ./networking/udhcp/dhcpc.h
--- /home/packages/busybox-1.15.1-15/networking/udhcp/dhcpc.h	2009-09-12 11:55:36.000000000 -0400
+++ ./networking/udhcp/dhcpc.h	2015-10-26 22:26:10.276812000 -0400
@@ -19,6 +19,10 @@
 	uint8_t *vendorclass;           /* Optional vendor class-id to use */
 	uint8_t *hostname;              /* Optional hostname to use */
 	uint8_t *fqdn;                  /* Optional fully qualified domain name to use */
+#ifdef __tile__
+	int send_archtype;              /* Send dhcp option "system arch type"? */
+	uint16_t archtype;              /* dhcp option "system arch type" */
+#endif
 };
 
 /* server_config sits in 1st half of bb_common_bufsiz1 */
diff -r -u -N /home/packages/busybox-1.15.1-15/networking/udhcp/options.c ./networking/udhcp/options.c
--- /home/packages/busybox-1.15.1-15/networking/udhcp/options.c	2013-01-16 15:08:35.160954000 -0500
+++ ./networking/udhcp/options.c	2015-10-26 22:26:10.296816000 -0400
@@ -46,7 +46,7 @@
 	{ OPTION_STRING                           , 0x43 }, /* bootfile           */
 	{ OPTION_STRING                           , 0x4D }, /* userclass          */
 #if ENABLE_FEATURE_UDHCP_RFC3397
-	{ OPTION_STR1035 | OPTION_LIST            , 0x77 }, /* search             */
+	{ OPTION_STR1035 | OPTION_LIST | OPTION_REQ, 0x77 }, /* search             */
 #endif
 	{ OPTION_STATIC_ROUTES                    , 0x79 }, /* DHCP_STATIC_ROUTES */
 	/* MSIE's "Web Proxy Autodiscovery Protocol" support */
@@ -57,6 +57,7 @@
 	 * with "option XXX YYY" syntax in dhcpd config file. */
 
 	{ OPTION_U16                              , 0x39 }, /* DHCP_MAX_SIZE      */
+	{ OPTION_U16                              , 0x5d }, /* DHCP_CLIENT_ARCH   */
