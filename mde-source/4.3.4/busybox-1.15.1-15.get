#!/bin/bash -ex

# Run this script to create the corresponding source subdir in the CWD.

me=$(basename $0)
DIR=$(basename $0 .get)
if [ -d $DIR ]; then
    echo "$me: Cannot replace existing directory '$DIR'." >&2
    exit 1
fi

MD5SUM=aea19430e3aaef415e5b060a76398152
FROM=http://vault.centos.org/6.3/os/Source/SPackages
ORIG=busybox-1.15.1-15.el6.src.rpm
ODIR=$(pwd)
if [ ! -f $ORIG ]; then
    if [ -n "$DOWNLOAD_CACHE" -a -f "$DOWNLOAD_CACHE/$ORIG" ]; then
        ODIR=$DOWNLOAD_CACHE
    else
        curl -L $FROM/$ORIG > $ORIG.tmp
        mv $ORIG.tmp $ORIG
    fi
fi

if [ $MD5SUM != `md5sum $ODIR/$ORIG | cut -f1 -d' '` ]; then
    echo "$me: Wrong md5sum for '$ORIG'." >&2
    exit 1
fi

mkdir -p $DIR/SRPM
cd $DIR/SRPM
rpm2cpio $ODIR/$ORIG | cpio -idv
tar -C .. --strip-components 1 -xjf busybox-1.15.1.tar.bz2
patch -d .. -p1 -s < busybox-1.10.1-hwclock.patch
patch -d .. -p1 -s < busybox-1.15.1-man.patch
patch -d .. -p1 -s < busybox-1.15.1-uname.patch
patch -d .. -p1 -s < busybox-1.15.1-xz.patch
patch -d .. -p1 -s < busybox-1.15.1-hush.patch
patch -d .. -p1 -s < busybox-1.15.1-cpio.patch
patch -d .. -p1 -s < busybox-1.15.1-awk.patch
patch -d .. -p1 -s < busybox-1.15.1-hush2.patch
patch -d .. -p1 -s < busybox-1.15.1-grep.patch
patch -d .. -p1 -s < busybox-1.15.1-btrfs.patch
patch -d .. -p1 -s < busybox-1.15.1-hush3.patch
patch -d .. -p1 -s < busybox-1.15.1-udhcp.patch
patch -d .. -p1 -s < busybox-1.15.1-uncompress.patch
patch -d .. -p1 -s < busybox-1.15.1-hush4.patch
cd ..
find . -type f -size 0 -o -name "*.orig" -exec rm -f {} \;
cd ..
rm -rf $DIR/SRPM

cat $0 | patch -d $DIR -p1 -s

chmod +x $DIR/tile-prepare

exit 0

# The actual Tilera patch starts here.

diff -r -u -N /home/packages/busybox-1.15.1-15/arch/tile/Makefile ./arch/tile/Makefile
--- /home/packages/busybox-1.15.1-15/arch/tile/Makefile	1969-12-31 19:00:00.000000000 -0500
+++ ./arch/tile/Makefile	2015-10-26 22:26:09.786817000 -0400
@@ -0,0 +1,11 @@
+# Tilera-specific flags
+
+ifdef TILERA_ROOT
+CROSS_COMPILE = $(TILERA_ROOT)/bin/tile-
+endif
+
+# Some things in busybox break strict-aliasing rules.
+CFLAGS += -fno-strict-aliasing
+
+# Allow passing in -fdebug-prefix-map or other useful options.
+CFLAGS += $(TILERA_CFLAGS)
