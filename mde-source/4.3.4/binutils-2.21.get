+ +\[ 1\] .text +PROGBITS +00000000 000038 000008 00 +AX +0 +0 +8
+ +\[ 2\] .rel.+text +REL. +0+ 0+.* 00000. 0. +. +1 +4
+ +\[ .\] .data +PROGBITS +00000000 000040 000004 00 +WA +0 +0 +1
+ +\[ .\] .bss +NOBITS +00000000 000044 000000 00 +WA +0 +0 +1
+ +\[ .\] .shstrtab +STRTAB +00000000 0+.* 0+.* 00 +0 +0 +1
+ +\[ .\] .symtab +SYMTAB +00000000 0+.* 0+.* 10 +.. +. +4
+ +\[..\] .strtab +STRTAB +00000000 0+.* 0+.* 00 +0 +0 +1
+Key to Flags:
+#...
