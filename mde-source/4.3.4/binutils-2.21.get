+++ ./elfcpp/elfcpp.h	2015-10-26 22:23:17.418476000 -0400
@@ -269,6 +269,7 @@
   EM_UNICORE = 110,
   EM_ALTERA_NIOS2 = 113,
   EM_CRX = 114,
+  EM_TILEGX = 191,
   // The Morph MT.
   EM_MT = 0x2530,
   // DLX.
diff -r -u -N /home/packages/binutils-2.23.2/elfcpp/tilegx.h ./elfcpp/tilegx.h
