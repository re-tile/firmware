diff -x gold -x elfcpp -x dwarf2.def -r -u -N /home/packages/binutils-2.21/gas/doc/as.texinfo ./gas/doc/as.texinfo
--- /home/packages/binutils-2.21/gas/doc/as.texinfo	2010-11-02 10:36:36.000000000 -0400
+++ ./gas/doc/as.texinfo	2015-10-26 22:23:17.826473000 -0400
@@ -479,6 +479,14 @@
    [@b{-mbig-endian}|@b{-mlittle-endian}] [@b{-mdsbt}|@b{-mno-dsbt}]
    [@b{-mpid=no}|@b{-mpid=near}|@b{-mpid=far}] [@b{-mpic}|@b{-mno-pic}]
 @end ifset
+@ifset TILEGX
+
+@emph{Target TILE-Gx options:}
+   [@b{-m32}|@b{-m64}][@b{-EB}][@b{-EL}]
+@end ifset
+@ifset TILEPRO
+@c TILEPro has no machine-dependent assembler options
+@end ifset
 
 @ifset Z80
 
@@ -1326,6 +1334,19 @@
 
 @end ifset
 
+@ifset TILEGX
+The following options are available when @value{AS} is configured for
+a TILE-Gx processor.
+
+@table @gcctabopt
+@item -m32 | -m64
+Select the word size, either 32 bits or 64 bits.
+
+@item -EB | -EL
+Select the endianness, either big-endian (-EB) or little-endian (-EL).
+@end table
+@end ifset
+
 @ifset XTENSA
 The following options are available when @value{AS} is configured for
 an Xtensa processor.
@@ -2399,6 +2420,12 @@
 @ifset TIC6X
 @samp{;} on the TMS320C6X;
 @end ifset
+@ifset TILEGX
+@samp{#} on TILE-Gx;
+@end ifset
+@ifset TILEPRO
+@samp{#} on TILEPro;
+@end ifset
 @ifset VAX
 @samp{#} on the Vax;
 @end ifset
@@ -6962,6 +6989,12 @@
 @ifset TIC6X
 * TIC6X-Dependent ::            TI TMS320C6x Dependent Features
 @end ifset
+@ifset TILEGX
+* TILE-Gx-Dependent ::          Tilera TILE-Gx Dependent Features
+@end ifset
+@ifset TILEPRO
+* TILEPro-Dependent ::          Tilera TILEPro Dependent Features
+@end ifset
 @ifset V850
 * V850-Dependent::              V850 Dependent Features
 @end ifset
@@ -7157,6 +7190,14 @@
 @include c-tic6x.texi
 @end ifset
 
+@ifset TILEGX
+@include c-tilegx.texi
+@end ifset
+
+@ifset TILEPRO
