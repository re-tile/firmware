+/* Map BFD reloc types to TILEPRO ELF reloc types.  */
+
+typedef struct tilepro_reloc_map
+{
+  bfd_reloc_code_real_type  bfd_reloc_val;
+  unsigned int              tilepro_reloc_val;
+  reloc_howto_type *        table;
+} reloc_map;
