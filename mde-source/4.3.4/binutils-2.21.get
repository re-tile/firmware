+#endif
+  },
+  { "move", TILEGX_OPC_MOVE, 0xf, 0x0, 2, TREG_ZERO, 1,
+    { { 8, 9 }, { 6, 7 }, { 10, 11 }, { 12, 13 }, { 0, } },
+#ifndef DISASM_ONLY
