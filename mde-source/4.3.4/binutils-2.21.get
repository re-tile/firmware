diff -x gold -x elfcpp -x dwarf2.def -r -u -N /home/packages/binutils-2.21/bfd/cpu-tilegx.c ./bfd/cpu-tilegx.c
--- /home/packages/binutils-2.21/bfd/cpu-tilegx.c	1969-12-31 19:00:00.000000000 -0500
+++ ./bfd/cpu-tilegx.c	2015-10-26 22:23:16.413490000 -0400
@@ -0,0 +1,55 @@
+/* BFD support for the TILE-Gx processor.
+   Copyright 2011 Free Software Foundation, Inc.
