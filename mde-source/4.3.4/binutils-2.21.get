+#endif
+  },
+  { "ld_tls", TILEGX_OPC_LD_TLS, 0x2, 0x0, 3, TREG_ZERO, 1,
+    { { 0, }, { 6, 7, 1 }, { 0, }, { 0, }, { 0, } },
+#ifndef DISASM_ONLY
+    {
+      0ULL,
+      0xfffff80000000000ULL,
