#!/bin/bash -ex

# Run this script to create the corresponding source subdir in the CWD.

DIR=$(basename $0 .get)
if [ -d $DIR ]; then
    echo "$(basename $0): Cannot replace existing directory '$DIR'." >&2
    exit 1
fi

function get_tarball_verify_and_extract() {
  if [ ! -f $1 ]; then
      if [ -n "$DOWNLOAD_CACHE" -a -f "$DOWNLOAD_CACHE/$1" ]; then
          DEST="$DOWNLOAD_CACHE/$1"
      else
          curl -L $FROM/$1 > $1.tmp
          mv $1.tmp $1
          DEST=$1
      fi
  else
      DEST=$1
  fi

  if [ $2 != `md5sum $DEST | cut -f1 -d' '` ]; then
      echo "$me: Wrong md5sum for '$DEST.tmp'." >&2
      exit 1
  fi

  tar xf $DEST
}

# Unfortunately gnu.org does not reliably host older versions.
FROM=http://www.kernel.org/pub/tools/crosstool/files/src/
MD5SUM=c84c5acc9d266f1a7044b51c85a823f5
ORIG=$DIR.tar.bz2
get_tarball_verify_and_extract $ORIG $MD5SUM


# TILE-Gx gold linker's initial port is based on around binutils 2.23.2
# so we extract the source code there.
# After official binutils contains TILE-Gx gold, we should remove
# the following ORIG2 related hacks.
DIR2=binutils-2.23.2
ORIG2=$DIR2.tar.bz2
MD5SUM2=4f8fa651e35ef262edc01d60fb45702e
FROM=http://ftp.gnu.org/gnu/binutils/
get_tarball_verify_and_extract $ORIG2 $MD5SUM2

rm -rf $DIR/gold $DIR/elfcpp
mv $DIR2/elfcpp $DIR/
mv $DIR2/gold $DIR/
mv $DIR2/include/dwarf2.def $DIR/include
rm -rf $DIR2

cat $0 | patch -d $DIR -p1 -s

exit 0

# The actual Tilera patch starts here.

diff -x gold -x elfcpp -x dwarf2.def -r -u -N /home/packages/binutils-2.21/Makefile.in ./Makefile.in
--- /home/packages/binutils-2.21/Makefile.in	2010-12-08 03:37:52.000000000 -0500
+++ ./Makefile.in	2015-10-26 22:23:16.147468000 -0400
@@ -372,7 +372,7 @@
 # sub-makes.  It lets flags be given on the command line while still
 # using the makeinfo from the object tree.
 # (Default to avoid splitting info files by setting the threshold high.)
-MAKEINFOFLAGS = --split-size=5000000
+MAKEINFOFLAGS = --split-size=5000000 --no-split
 
 # ---------------------------------------------
 # Programs producing files for the HOST machine
@@ -1496,7 +1496,7 @@
 html-host: maybe-html-byacc
 html-host: maybe-html-bzip2
 html-host: maybe-html-cgen
-html-host: maybe-html-dejagnu
+#html-host: maybe-html-dejagnu
 html-host: maybe-html-diff
 html-host: maybe-html-dosutils
 html-host: maybe-html-etc
@@ -1539,14 +1539,14 @@
 html-host: maybe-html-perl
 html-host: maybe-html-prms
 html-host: maybe-html-rcs
-html-host: maybe-html-readline
+#html-host: maybe-html-readline
 html-host: maybe-html-release
 html-host: maybe-html-recode
 html-host: maybe-html-sed
 html-host: maybe-html-send-pr
 html-host: maybe-html-shellutils
 html-host: maybe-html-sid
-html-host: maybe-html-sim
+#html-host: maybe-html-sim
 html-host: maybe-html-tar
 html-host: maybe-html-texinfo
 html-host: maybe-html-textutils
