+  RELOC_NUMBER (R_TILEGX_SHAMT_Y0,          34)
+  RELOC_NUMBER (R_TILEGX_SHAMT_Y1,          35)
+
+  RELOC_NUMBER (R_TILEGX_IMM16_X0_HW0,       36)
+  RELOC_NUMBER (R_TILEGX_IMM16_X1_HW0,       37)
+  RELOC_NUMBER (R_TILEGX_IMM16_X0_HW1,       38)
