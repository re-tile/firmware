 obj-y += e1000.o
 
+ifneq ($(TARGET_ARCH), tilegx)
 # Inter-VM PCI shared memory
 obj-$(CONFIG_KVM) += ivshmem.o
+endif
 
 # Hardware support
 obj-i386-y += vga.o
@@ -326,6 +335,8 @@
 
 obj-s390x-y = s390-virtio-bus.o s390-virtio.o
 
+obj-tilegx-y = tile-virtio-bus.o tile-virtio.o glue_data.o libkvm.o
+
 obj-alpha-y = alpha_palcode.o
 
 ifeq ($(TARGET_ARCH), ia64)
diff -r -u -N /home/packages/qemu-kvm-0.13.0/arch_init.c ./arch_init.c
--- /home/packages/qemu-kvm-0.13.0/arch_init.c	2010-10-14 11:06:47.000000000 -0400
+++ ./arch_init.c	2015-10-26 22:26:22.207915000 -0400
