 done
 
diff -r -u -N /home/packages/qemu-kvm-0.13.0/cpu-common.h ./cpu-common.h
--- /home/packages/qemu-kvm-0.13.0/cpu-common.h	2010-10-14 11:06:47.000000000 -0400
+++ ./cpu-common.h	2015-10-26 22:26:22.235922000 -0400
@@ -3,6 +3,14 @@
 
 /* CPU interfaces that are target indpendent.  */
 
+/*
+ * We should have enabled this on tilegx, however enabling this makes
+ * virtio-net always break. The guest always exits during virtio network
+ * testing with error message like "Guest moved used index from 46573 to 46592".
+ * This is due to non-atomic data access of some variables which leads to race
+ * condition. We do not set WORDS_ALIGNED so that those variables can be
+ * directly thus atomically accessed.
+ */
 #if defined(__arm__) || defined(__sparc__) || defined(__mips__) || defined(__hppa__) || defined(__ia64__)
 #define WORDS_ALIGNED
 #endif
