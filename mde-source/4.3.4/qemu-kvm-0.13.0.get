#!/bin/bash -ex

# Run this script to create the corresponding source subdir in the CWD.

DIR=$(basename $0 .get)
if [ -d $DIR ]; then
    echo "$(basename $0): Cannot replace existing directory '$DIR'." >&2
    exit 1
fi

MD5SUM=68d100da381284a3dee486d3b9690e6d
ORIG=$DIR.tar.gz
if [ ! -f $ORIG ]; then
    if [ -n "$DOWNLOAD_CACHE" -a -f "$DOWNLOAD_CACHE/$ORIG" ]; then
        ORIG="$DOWNLOAD_CACHE/$ORIG"
    else
        path=$(echo $DIR | sed 's,qemu-kvm-,qemu-kvm/,')
        curl -L http://iweb.dl.sourceforge.net/project/kvm/$path/$ORIG > $ORIG.tmp
        mv $ORIG.tmp $ORIG
    fi
fi

if [ $MD5SUM != `md5sum $ORIG | cut -f1 -d' '` ]; then
    echo "$me: Wrong md5sum for '$ORIG.tmp'." >&2
    exit 1
fi

tar xf $ORIG

cat $0 | patch -d $DIR -p1 -s

chmod +x $DIR/tile-prepare

exit 0

# The actual Tilera patch starts here.

diff -r -u -N /home/packages/qemu-kvm-0.13.0/Makefile.target ./Makefile.target
--- /home/packages/qemu-kvm-0.13.0/Makefile.target	2010-10-14 11:06:47.000000000 -0400
+++ ./Makefile.target	2015-10-26 22:26:22.194909000 -0400
@@ -59,8 +59,10 @@
 endif
 libobj-$(CONFIG_NEED_MMU) += mmu.o
 
+ifeq ($(TARGET_BASE_ARCH), i386)
 libobj-$(CONFIG_KVM) += kvm-tpr-opt.o
 libobj-$(CONFIG_KVM) += qemu-kvm-helper.o
+endif
 
 libobj-$(TARGET_ARM) += neon_helper.o iwmmxt_helper.o
 
@@ -182,11 +184,16 @@
 obj-$(CONFIG_VIRTFS) += virtio-9p.o
 obj-y += rwhandler.o
 obj-$(CONFIG_KVM) += kvm.o kvm-all.o
+ifeq ($(TARGET_ARCH), tilegx)
+obj-$(CONFIG_KVM) += hcall.o
+endif
 obj-$(CONFIG_NO_KVM) += kvm-stub.o
 
+ifneq ($(TARGET_ARCH), tilegx)
 # MSI-X depends on kvm for interrupt injection,
 # so moved it from Makefile.objs to Makefile.target for now
 obj-y += msix.o
+endif
 
 LIBS+=-lz
 
@@ -205,8 +212,10 @@
