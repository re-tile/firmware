diff -r -u -N /home/packages/qemu-kvm-0.13.0/cache-utils.h ./cache-utils.h
--- /home/packages/qemu-kvm-0.13.0/cache-utils.h	2010-10-14 11:06:47.000000000 -0400
+++ ./cache-utils.h	2015-10-26 22:26:22.224904000 -0400
@@ -52,6 +52,16 @@
 }
 #define dma_flush_range(start, end) flush_icache_range(start, end)
 #define qemu_cache_utils_init(envp) do { (void) (envp); } while (0)
+#elif defined(__tile__)
