diff -r -u -N /home/packages/qemu-kvm-0.13.0/target-tilegx/cpu.h ./target-tilegx/cpu.h
--- /home/packages/qemu-kvm-0.13.0/target-tilegx/cpu.h	1969-12-31 19:00:00.000000000 -0500
+++ ./target-tilegx/cpu.h	2015-10-26 22:26:22.396938000 -0400
@@ -0,0 +1,94 @@
+/*
+ * TILE-Gx virtual CPU header
+ *
+ * Copyright 2014 Tilera Corporation. All Rights Reserved.
+ *
+ *   This program is free software; you can redistribute it and/or
+ *   modify it under the terms of the GNU Lesser General Public License
+ *   as published by the Free Software Foundation, version 2.1.
+ *
+ *   This program is distributed in the hope that it will be useful, but
+ *   WITHOUT ANY WARRANTY; without even the implied warranty of
+ *   MERCHANTABILITY OR FITNESS FOR A PARTICULAR PURPOSE, GOOD TITLE or
+ *   NON INFRINGEMENT.  See the GNU Lesser General Public License for
+ *   more details.
+ */
+
+#ifndef CPU_TILE_H
+#define CPU_TILE_H
+
+#include "config.h"
+
+#define TARGET_LONG_BITS 64
+
+#define TARGET_PAGE_BITS 16
+
+#define TARGET_HPAGE_BITS 24
+#define TARGET_HPAGE_SIZE (1 << TARGET_HPAGE_BITS)
+#define TARGET_HPAGE_MASK ~(TARGET_HPAGE_SIZE - 1)
+#define TARGET_HPAGE_ALIGN(addr) \
+	(((addr) + TARGET_HPAGE_SIZE - 1) & TARGET_HPAGE_MASK)
+
+#define ELF_MACHINE EM_TILEGX
+
+// FIXME-TILE This may be wrong; may need to be 4 (1 per PL) or 8 (I/D per
+// PL)
+#define NB_MMU_MODES 2
+
+#define CPUState struct CPUTileState
+
+#include "cpu-defs.h"
+
+#include "softfloat.h"
+
+#include <linux/types.h>
+#include <linux/ptrace.h>
+
+typedef struct CPUTileState {
+    struct pt_regs regs;
+
+    __u32 inject_irq;
+
+    CPU_COMMON
+} CPUTileState;
+
+#define TARGET_PHYS_ADDR_SPACE_BITS 40
+#define TARGET_VIRT_ADDR_SPACE_BITS 42
+
+#ifndef CONFIG_USER_ONLY
+extern void kvm_tile_virtio_irq(CPUState *env, __u32 irq);
+extern CPUState *tile_cpu_addr2state(uint16_t cpu_addr);
+#endif
+
+#define cpu_init cpu_tile_init
+#define cpu_exec cpu_tile_exec
+#define cpu_gen_code cpu_tile_gen_code
+
+CPUTileState *cpu_tile_init(const char *cpu_model);
+int cpu_tile_exec(CPUTileState *state);
+
+static inline int cpu_mmu_index (CPUState *env)
+{
+    // FIXME-TILE looks like this should extract the PL from the CPU state; but
+    // what about ITLB vs. DTLB?
+    return 0;
+}
+
+#include "cpu-all.h"
+#include "exec-all.h"
+
+static inline void cpu_pc_from_tb(CPUState *env, TranslationBlock* tb)
+{
+    // FIXME-TILE sets PC in *env from tb->pc
+}
+
+static inline void cpu_get_tb_cpu_state(CPUState* env, target_ulong *pc,
+                                        target_ulong *cs_base, int *flags)
+{
+    // FIXME-TILE extracts pc, cs_base, flags from *env
+    *pc = env->regs.pc;
+    *cs_base = 0;
+    *flags = 0;
+}
+
+#endif
diff -r -u -N /home/packages/qemu-kvm-0.13.0/target-tilegx/exec.h ./target-tilegx/exec.h
--- /home/packages/qemu-kvm-0.13.0/target-tilegx/exec.h	1969-12-31 19:00:00.000000000 -0500
+++ ./target-tilegx/exec.h	2015-10-26 22:26:22.396928000 -0400
@@ -0,0 +1,73 @@
+/*
+ * Tile execution defines
+ *
+ * Copyright 2014 Tilera Corporation. All Rights Reserved.
+ *
+ *   This program is free software; you can redistribute it and/or
+ *   modify it under the terms of the GNU Lesser General Public License
+ *   as published by the Free Software Foundation, version 2.1.
+ *
+ *   This program is distributed in the hope that it will be useful, but
+ *   WITHOUT ANY WARRANTY; without even the implied warranty of
+ *   MERCHANTABILITY OR FITNESS FOR A PARTICULAR PURPOSE, GOOD TITLE or
+ *   NON INFRINGEMENT.  See the GNU Lesser General Public License for
+ *   more details.
+ */
+
+#ifndef EXEC_TILE_H
+#define EXEC_TILE_H
+
+// FIXME-TILE does stuffing this in a register make sense here?  Other archs
+// do it.
+// register struct CPUTileState *env asm(AREG0);
+extern struct CPUTileState *env;
+
+#include "config.h"
+#include "cpu.h"
+#include "exec-all.h"
+
+// FIXME not including dyngen-exec.h here
+typedef void * host_reg_t;
+
+#define tcg_qemu_tb_exec(tb_ptr) 0
+
+#if !defined(CONFIG_USER_ONLY)
+#include "softmmu_exec.h"
+#endif /* !defined(CONFIG_USER_ONLY) */
+
+static inline int cpu_has_work(CPUState *env)
+{
+    // FIXME-TILE what does 'has work' mean?
+
+    return 0;
+}
+
+static inline void regs_to_env(void)
+{
+fprintf(stderr, "tile regs_to_env\n");
+}
+
+static inline void env_to_regs(void)
+{
+fprintf(stderr, "tile env_to_regs\n");
+}
+
+void do_interrupt(CPUState *env);
+
+static inline int cpu_halted(CPUState *env)
+{
+    // FIXME-TILE not sure what this means on other processors; may be the
+    // moral equivalent of a nap(), instead of halting the cpu for good.
+    // (in which case we might need a pv version of it in the kernel.)
+
+    if (!env->halted)
+        return 0;
+
+    if (cpu_has_work(env)) {
+        env->halted = 0;
+        return 0;
+    }
+    return EXCP_HALTED;
+}
+
+#endif
diff -r -u -N /home/packages/qemu-kvm-0.13.0/target-tilegx/fake-exec.c ./target-tilegx/fake-exec.c
