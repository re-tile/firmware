+                 return clock_gettime(id, NULL) +
+                        timer_create(id, NULL, NULL); }
 EOF
 
 if compile_prog "" "" ; then
@@ -2348,7 +2353,7 @@
 echo "confdir=$confdir" >> $config_host_mak
 
 case "$cpu" in
-  i386|x86_64|alpha|cris|hppa|ia64|m68k|microblaze|mips|mips64|ppc|ppc64|s390|s390x|sparc|sparc64)
+  i386|x86_64|alpha|cris|hppa|ia64|m68k|microblaze|mips|mips64|ppc|ppc64|s390|s390x|sparc|sparc64|tilegx)
     ARCH=$cpu
   ;;
   armv4b|armv4l)
@@ -2824,6 +2829,9 @@
