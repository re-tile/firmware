+#include "cpu.h"
+#include "exec-all.h"
+#include "qemu-common.h"
+
+
+void cpu_reset(CPUTileState *env)
+{
+    // FIXME-TILE - is there other stuff to be done here?
+
+    if (qemu_loglevel_mask(CPU_LOG_RESET)) {
+        qemu_log("CPU Reset (CPU %d)\n", env->cpu_index);
+        log_cpu_state(env, 0);
+    }
+
+    tlb_flush(env, 1);
+}
+
+CPUTileState *cpu_tile_init(const char *cpu_model)
+{
+    CPUTileState *env;
+
+    env = qemu_mallocz(sizeof(CPUTileState));
+    cpu_exec_init(env);
+    env->cpu_model_str = cpu_model;
+    cpu_reset(env);
+    qemu_init_vcpu(env);
+    return env;
+}
+
+#if defined(CONFIG_USER_ONLY)
+
+target_phys_addr_t cpu_get_phys_page_debug(CPUState *env, target_ulong addr)
+{
+    return addr;
+}
+
+#else
+
+target_phys_addr_t cpu_get_phys_page_debug(CPUState *env, target_ulong addr)
+{
+    // FIXME-TILE
+    return 0;
+}
+
+#endif
diff -r -u -N /home/packages/qemu-kvm-0.13.0/target-tilegx/kvm.c ./target-tilegx/kvm.c
--- /home/packages/qemu-kvm-0.13.0/target-tilegx/kvm.c	1969-12-31 19:00:00.000000000 -0500
+++ ./target-tilegx/kvm.c	2015-10-26 22:26:22.532906000 -0400
@@ -0,0 +1,161 @@
+/*
+ * QEMU Tile KVM implementation
+ * 
+ * Copyright 2014 Tilera Corporation. All Rights Reserved.
+ *
+ *   This program is free software; you can redistribute it and/or
+ *   modify it under the terms of the GNU Lesser General Public License
+ *   as published by the Free Software Foundation, version 2.1.
+ *
+ *   This program is distributed in the hope that it will be useful, but
+ *   WITHOUT ANY WARRANTY; without even the implied warranty of
+ *   MERCHANTABILITY OR FITNESS FOR A PARTICULAR PURPOSE, GOOD TITLE or
+ *   NON INFRINGEMENT.  See the GNU Lesser General Public License for
+ *   more details.
+ */
+
+/*
+ * Originally derived from:
+ *
+ * PowerPC implementation of KVM hooks
+ *
+ * Copyright IBM Corp. 2007
+ *
+ * Authors:
+ *  Jerone Young <jyoung5@us.ibm.com>
+ *  Christian Ehrhardt <ehrhardt@linux.vnet.ibm.com>
+ *  Hollis Blanchard <hollisb@us.ibm.com>
+ *
+ * This work is licensed under the terms of the GNU GPL, version 2 or later.
+ * See the COPYING file in the top-level directory.
+ *
+ */
+
+#include <sys/types.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+
+#include <linux/kvm.h>
+
+#include "qemu-common.h"
+#include "qemu-timer.h"
+#include "sysemu.h"
+#include "kvm.h"
+#include "cpu.h"
+#include "device_tree.h"
+
+//#define DEBUG_KVM
+
+#ifdef DEBUG_KVM
+#define dprintf(fmt, ...) \
+    do { fprintf(stderr, fmt, ## __VA_ARGS__); } while (0)
+#else
+#define dprintf(fmt, ...) \
+    do { } while (0)
+#endif
+
+int kvm_arch_init(KVMState *s, int smp_cpus)
+{
+    return 0;
+}
+
+int kvm_arch_init_vcpu(CPUState *env)
+{
+    kvm_arch_reset_vcpu(env);
+
+    return 0;
+}
+
+void kvm_arch_reset_vcpu(CPUState *env)
+{
+    struct kvm_sregs sregs;
+
+    /*
+     * The real hardware starts at address zero, but the paravirtualized
+     * environment assumes a hypervisor that has loaded the image with
+     * the interrupt region at 0x00000, the glue at 0x10000, and the
+     * start address at 0x20000, starting at PL1.
+     */
+    env->regs.pc = 0x20000;
+    env->regs.ex1 = 1;   /* PL1 */
+
+    /* Clear SPRs and reset the few that have special values. */
+    memset(&sregs, 0, sizeof(sregs));
+    sregs.IPI_MASK_1 = -1UL;
+    sregs.INTERRUPT_MASK_1 = -1UL;
+    sregs.INTERRUPT_VECTOR_BASE_1 = 0xfd000000;
+    kvm_vcpu_ioctl(env, KVM_SET_SREGS, &sregs);
+}
+
+int kvm_arch_put_registers(CPUState *env, int level)
+{
+    struct kvm_regs regs;
+    int ret;
+
+    regs.regs = env->regs;
+    ret = kvm_vcpu_ioctl(env, KVM_SET_REGS, &regs);
+    if (ret < 0)
+        return ret;
+
+    return ret;
+}
+
+int kvm_arch_get_registers(CPUState *env)
+{
+    struct kvm_regs regs;
+    int ret;
+
+    ret = kvm_vcpu_ioctl(env, KVM_GET_REGS, &regs);
+    if (ret < 0)
+        return ret;
+
+    env->regs = regs.regs;
+    return 0;
+}
+
+int kvm_arch_pre_run(CPUState *env, struct kvm_run *run)
+{
+    /* Try to inject an interrupt if the guest can accept it */
+    if (run->ready_for_interrupt_injection &&
+        (env->interrupt_request & CPU_INTERRUPT_HARD)) {
+        int irq;
+
+        env->interrupt_request &= ~CPU_INTERRUPT_HARD;
+        irq = env->inject_irq;
+        if (irq >= 0) {
+            struct kvm_interrupt intr;
+            intr.irq = irq;
+            dprintf("injected interrupt %d\n", irq);
+            kvm_vcpu_ioctl(env, KVM_INTERRUPT, &intr);
+        }
+    }
+
+    return 0;
+}
+
+int kvm_arch_post_run(CPUState *env, struct kvm_run *run)
+{
+    return 0;
+}
+
+void kvm_arch_process_irqchip_events(CPUState *env)
+{
+}
+
+int kvm_arch_handle_exit(CPUState *env, struct kvm_run *run)
+{
+    return 0;
+}
+
+bool kvm_arch_stop_on_emulation_error(CPUState *env)
+{
+    return true;
+}
+
+void kvm_tile_virtio_irq(CPUState *env, __u32 irq)
+{
+    struct kvm_interrupt intr;
+    intr.irq = irq;
+
+    kvm_vcpu_ioctl(env, KVM_INTERRUPT, &intr);
+}
diff -r -u -N /home/packages/qemu-kvm-0.13.0/target-tilegx/libkvm.c ./target-tilegx/libkvm.c
--- /home/packages/qemu-kvm-0.13.0/target-tilegx/libkvm.c	1969-12-31 19:00:00.000000000 -0500
+++ ./target-tilegx/libkvm.c	2015-10-26 22:26:22.528923000 -0400
@@ -0,0 +1,104 @@
+/*
+ * libkvm.c :Kernel-based Virtual Machine control library for tile.
+ *
+ * This library provides an API to control the kvm hardware virtualization
+ * module.
+ *
+ * Copyright (C) 2006 Qumranet
+ *
+ * Authors:
+ *
+ *  Avi Kivity <avi@qumranet.com>
+ *  Yaniv Kamay <yaniv@qumranet.com>
+ *
+ * Copyright 2014 Tilera Corporation. All Rights Reserved.
+ *
+ *   This program is free software; you can redistribute it and/or
+ *   modify it under the terms of the GNU Lesser General Public License
+ *   as published by the Free Software Foundation, version 2.1.
+ *
+ *   This program is distributed in the hope that it will be useful, but
+ *   WITHOUT ANY WARRANTY; without even the implied warranty of
+ *   MERCHANTABILITY OR FITNESS FOR A PARTICULAR PURPOSE, GOOD TITLE or
+ *   NON INFRINGEMENT.  See the GNU Lesser General Public License for
+ *   more details.
+ */
+
+#include "qemu-kvm.h"
+#include "sysemu.h"
+#include <stdio.h>
+
+extern int handle_hypercall(CPUState *env);
+
+int kvm_arch_create(kvm_context_t kvm, unsigned long phys_mem_bytes,
+		    void **vm_mem)
+{
+	return 0;
+}
+
+int kvm_arch_qemu_create_context(void)
+{
+	return 0;
+}
+
+int kvm_arch_run(CPUState *env)
+{
+	if (env->kvm_run->exit_reason != KVM_EXIT_HYPERCALL)
+		return 1;
+
+	cpu_synchronize_state(env);
+	return handle_hypercall(env);
+}
+
+void kvm_arch_load_regs(CPUState *env, int level)
+{
+	/* To avoid type complaints, we stage the registers through a temp. */
+	struct kvm_regs regs;
+	regs.regs = env->regs;
+	kvm_set_regs(env, &regs);
+}
+
+
+void kvm_arch_save_regs(CPUState *env)
+{
+	/* To avoid type complaints, we stage the registers through a temp. */
+	struct kvm_regs regs;
+	kvm_get_regs(env, &regs);
+	env->regs = regs.regs;
+}
+
+int kvm_arch_has_work(CPUState *env)
+{
+	return 1;
+}
+
+int kvm_arch_try_push_interrupts(void *opaque)
+{
+	return 1;
+}
+
+void kvm_show_code(CPUState *env)
+{
+	fprintf(stderr, "kvm_show_code not supported yet!\n");
+}
+
+void kvm_show_regs(CPUState *env)
+{
+	fprintf(stderr,"kvm_show_regs not supportted today!\n");
+}
+
+int kvm_arch_halt(CPUState *env)
+{
+	fprintf(stderr,"Error: No halt support on the tile platform\n");
+
+	return -EINVAL;
+}
+
+void kvm_arch_cpu_reset(CPUState *env)
+{
+	env->halted = 1;
+	/* FIXME: reboot not working! */
+#if 0
+	kvm_arch_reset_vcpu(env);
+#endif
+}
diff -r -u -N /home/packages/qemu-kvm-0.13.0/target-tilegx/libkvm.h ./target-tilegx/libkvm.h
