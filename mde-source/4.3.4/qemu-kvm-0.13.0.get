 #if defined(CPU_SAVE_VERSION) && !defined(CONFIG_USER_ONLY)
@@ -4218,8 +4220,10 @@
     cpu_fprintf(f, "TB invalidate count %d\n", tb_phys_invalidate_count);
     cpu_fprintf(f, "TLB flush count     %d\n", tlb_flush_count);
