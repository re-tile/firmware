diff -r -u -N /home/packages/qemu-kvm-0.13.0/kvm/include/tilegx/asm/kvm_virtio.h ./kvm/include/tilegx/asm/kvm_virtio.h
--- /home/packages/qemu-kvm-0.13.0/kvm/include/tilegx/asm/kvm_virtio.h	1969-12-31 19:00:00.000000000 -0500
+++ ./kvm/include/tilegx/asm/kvm_virtio.h	2015-10-26 22:26:23.178918000 -0400
@@ -0,0 +1,62 @@
+/*
