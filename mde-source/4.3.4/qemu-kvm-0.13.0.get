diff -r -u -N /home/packages/qemu-kvm-0.13.0/tile-prepare ./tile-prepare
--- /home/packages/qemu-kvm-0.13.0/tile-prepare	1969-12-31 19:00:00.000000000 -0500
+++ ./tile-prepare	2015-10-26 22:26:22.348916000 -0400
@@ -0,0 +1,55 @@
+#!/bin/sh -e
+
+# Prepare a build directory for QEMU.
+#
+# Please consult the System Programmer's Guide for more information
+# on configuring and building QEMU.
+#
+
+# Verify the "source" directory.
+src=${0%/tile-prepare}
+version=VERSION
+product=QEMU
+if [ ! -f $src/$version ]; then
+    echo "$0 is not in a $product source directory." >&2
+    exit 1
+fi
+
+# Verify the "build" directory.
+build=`pwd`
+if [ $(ls -a | wc -l) -gt 2 ]; then
+    echo "Please create a new empty directory to build in, then run" >&2
+    echo "  $0" >&2
+    echo "from within that directory." >&2
+    exit 1
+fi
+
+# Configure options from RHEL 6 spec file, much edited.
+echo "Configuring qemu..."
+$src/configure --target-list=tilegx-softmmu \
+            --disable-cpu-emulation \
+            --prefix=/usr \
+            --sysconfdir=/etc \
+            --disable-strip \
+            --extra-ldflags="-Wl,--build-id -pie -Wl,-z,relro -Wl,-z,now" \
+            --extra-cflags="-O2 -fPIE -DPIE" \
+            --disable-xen \
+            --disable-debug-tcg \
+            --disable-sparse \
+            --enable-werror \
+            --disable-sdl \
+            --disable-curses \
+            --disable-curl \
+            --disable-check-utests \
+            --enable-vnc-tls \
+            --enable-vnc-sasl \
+            --disable-brlapi \
+            --disable-bluez \
+            --enable-docs \
+            --disable-vde \
+            --enable-linux-aio \
+            --disable-kvm-pit \
+            --enable-kvm
+
+echo ""
+echo "To build $product, just run 'make' in this directory."
diff -r -u -N /home/packages/qemu-kvm-0.13.0/translate-all.c ./translate-all.c
--- /home/packages/qemu-kvm-0.13.0/translate-all.c	2010-10-14 11:06:47.000000000 -0400
+++ ./translate-all.c	2015-10-26 22:26:22.359932000 -0400
@@ -28,9 +28,12 @@
 #include "cpu.h"
 #include "exec-all.h"
 #include "disas.h"
+#ifndef TARGET_TILEGX
 #include "tcg.h"
+#endif
 #include "qemu-timer.h"
 
+#ifndef TARGET_TILEGX
 /* code generation context */
 TCGContext tcg_ctx;
 
@@ -40,12 +43,15 @@
 target_ulong gen_opc_pc[OPC_BUF_SIZE];
 uint16_t gen_opc_icount[OPC_BUF_SIZE];
 uint8_t gen_opc_instr_start[OPC_BUF_SIZE];
+#endif
 
 void cpu_gen_init(void)
 {
+#ifndef TARGET_TILEGX
     tcg_context_init(&tcg_ctx); 
     tcg_set_frame(&tcg_ctx, TCG_AREG0, offsetof(CPUState, temp_buf),
                   CPU_TEMP_BUF_NLONGS * sizeof(long));
+#endif
 }
 
 /* return non zero if the very first instruction is invalid so that
@@ -56,6 +62,7 @@
 */
 int cpu_gen_code(CPUState *env, TranslationBlock *tb, int *gen_code_size_ptr)
 {
+#ifndef TARGET_TILEGX
     TCGContext *s = &tcg_ctx;
     uint8_t *gen_code_buf;
     int gen_code_size;
@@ -106,6 +113,7 @@
         qemu_log_flush();
     }
 #endif
+#endif
     return 0;
 }
 
@@ -115,6 +123,7 @@
                       CPUState *env, unsigned long searched_pc,
                       void *puc)
 {
+#ifndef TARGET_TILEGX
     TCGContext *s = &tcg_ctx;
     int j;
     unsigned long tc_ptr;
@@ -163,5 +172,6 @@
     s->restore_time += profile_getclock() - ti;
     s->restore_count++;
 #endif
+#endif
     return 0;
 }
