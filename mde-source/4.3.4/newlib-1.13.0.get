diff -r -u -N /home/packages/newlib-1.13.0/newlib/libc/stdio/makebuf.c ./newlib/libc/stdio/makebuf.c
--- /home/packages/newlib-1.13.0/newlib/libc/stdio/makebuf.c	2004-04-23 16:01:55.000000000 -0400
+++ ./newlib/libc/stdio/makebuf.c	2015-10-26 22:26:08.627800000 -0400
@@ -24,6 +24,29 @@
 #include <sys/unistd.h>
 #include "local.h"
 
+/* See if "fd" has dev/ino equal to the values in the STDIO_LBF_DEV_INO
+   environment variable. */
+static int is_lbf_fd(int fd)
+{
+  const char* env = getenv("STDIO_LBF_DEV_INO");
+  if (env == NULL)
+    return 0;
+
+  char* end;
+  unsigned long dev = strtoul(env, &end, 0);
+  if (end == env || *end != ':')
+    return 0;
+  env = end + 1;
+  unsigned long ino = strtoul(env, &end, 0);
+  if (end == env || *end != '\0')
+    return 0;
+  struct stat s;
+  if (fstat(fd, &s) != 0)
+    return 0;
+  return (ino == (unsigned long) s.st_ino &&
+          dev == (unsigned long) s.st_dev);
+}
+
 /*
  * Allocate a file buffer, or switch to unbuffered I/O.
  * Per the ANSI C standard, ALL tty devices default to line buffered.
@@ -93,7 +116,7 @@
       fp->_flags |= __SMBF;
       fp->_bf._base = fp->_p = (unsigned char *) p;
       fp->_bf._size = size;
-      if (couldbetty && isatty (fp->_file))
-	fp->_flags |= __SLBF;
+      if ((couldbetty && isatty (fp->_file)) || is_lbf_fd(fp->_file))
+        fp->_flags |= __SLBF;
     }
 }
