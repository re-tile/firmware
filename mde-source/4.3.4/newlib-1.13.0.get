+
+static __inline int sigdelset(sigset_t* what, int sig)
+{
+  what->sig[sig / _NSIG_BPW] &= ~(1UL << (sig % _NSIG_BPW));
+  return 0;
+}
+
+static __inline int sigismember(const sigset_t* what, int sig)
+{
