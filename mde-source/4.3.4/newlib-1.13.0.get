@@ -65,13 +65,13 @@
 int
 _DEFUN(iswspace,(c), wint_t c)
 {
+#ifdef _MB_CAPABLE
   int unicode = 0;
   if (__lc_ctype[0] == 'C' && __lc_ctype[1] == '\0')
     {
       unicode = 0;
       /* fall-through */ 
     }
-#ifdef _MB_CAPABLE
   else if (!strcmp (__lc_ctype, "C-JIS"))
     {
       c = __jp2uc (c, JP_JIS);
