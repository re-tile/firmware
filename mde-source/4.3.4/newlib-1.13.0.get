diff -r -u -N /home/packages/newlib-1.13.0/newlib/libc/include/sys/select.h ./newlib/libc/include/sys/select.h
--- /home/packages/newlib-1.13.0/newlib/libc/include/sys/select.h	1969-12-31 19:00:00.000000000 -0500
+++ ./newlib/libc/include/sys/select.h	2015-10-26 22:26:08.474818000 -0400
@@ -0,0 +1,55 @@
+#ifndef _SYS_SELECT_H
+#define _SYS_SELECT_H
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#include <_ansi.h>
+#include <sys/time.h>
+
+#ifndef NBBY
+#  define	NBBY	8		/* number of bits in a byte */
+#endif
+
+/*
+ * Select uses bit masks of file descriptors in longs.
+ * These macros manipulate such bit fields (the filesystem macros use chars).
+ * FD_SETSIZE may be defined by the user, but the default here
+ * should be >= NOFILE (param.h).
+ */
+#  ifndef	FD_SETSIZE
+#	define	FD_SETSIZE	64
+#  endif
+
+typedef	long	fd_mask;
+#  define	NFDBITS	(sizeof (fd_mask) * NBBY)	/* bits per mask */
+#  ifndef	howmany
+#	define	howmany(x,y)	(((x)+((y)-1))/(y))
+#  endif
+
+/* We use a macro for fd_set so that including Sockets.h afterwards
+   can work.  */
+typedef	struct _types_fd_set {
+	fd_mask	fds_bits[howmany(FD_SETSIZE, NFDBITS)];
+} _types_fd_set;
+
+#define fd_set _types_fd_set
+
+#  define	FD_SET(n, p)	((p)->fds_bits[(n)/NFDBITS] |= (1L << ((n) % NFDBITS)))
+#  define	FD_CLR(n, p)	((p)->fds_bits[(n)/NFDBITS] &= ~(1L << ((n) % NFDBITS)))
+#  define	FD_ISSET(n, p)	((p)->fds_bits[(n)/NFDBITS] & (1L << ((n) % NFDBITS)))
+#  define	FD_ZERO(p)	(__extension__ (void)({ \
+     size_t __i; \
+     char *__tmp = (char *)p; \
+     for (__i = 0; __i < sizeof (*(p)); ++__i) \
+       *__tmp++ = 0; \
+}))
+
+int _EXFUN(select, (int n, fd_set *readfds, fd_set *writefds, fd_set *exceptfds, struct timeval *timeout));
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* _SYS_SELECT_H */
diff -r -u -N /home/packages/newlib-1.13.0/newlib/libc/include/sys/signal.h ./newlib/libc/include/sys/signal.h
--- /home/packages/newlib-1.13.0/newlib/libc/include/sys/signal.h	2004-10-28 11:06:47.000000000 -0400
+++ ./newlib/libc/include/sys/signal.h	2015-10-26 22:26:08.477797000 -0400
@@ -8,14 +8,23 @@
 
 #include "_ansi.h"
 #include <sys/features.h>
+#include <sys/types.h>
 
 /* #ifndef __STRICT_ANSI__*/
 
-#if defined(_POSIX_THREADS)
-#include <sys/types.h>   /* for pthread data types */
-#endif
+#ifdef __tile__
+#include <asm/sigcontext.h>
+#define _NSIG		64
+#define _NSIG_BPW	(8 * sizeof(unsigned long))
+#define _NSIG_WORDS	(_NSIG / _NSIG_BPW)
 
+typedef struct {
+  unsigned long sig[_NSIG_WORDS];
+} sigset_t;
+
+#else
 typedef unsigned long sigset_t;
+#endif
 
 #if defined(__rtems__)
 
@@ -103,6 +112,44 @@
 #define sa_sigaction  _signal_handlers._sigaction
 #endif
 
+#elif defined(__tile__)
+#define SA_NOCLDSTOP    1
