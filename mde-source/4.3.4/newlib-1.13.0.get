+
+set stdio_output {
+"hello!"
+}
+
+newlib_check_output "stdio.c" "$stdio_output"
+
+set manyargs_output {
+"0x1 0x2 0x3 0x4 0x5 0x6 0x7 0x8 0x9 0xa 0xb 0xc 0xd 0xe 0xf 0x10"
+}
+
+newlib_check_output "manyargs.c" "$manyargs_output"
+
+set longlong_output {
+"0x123456789abcdef 0xfedcba9876543210 81985529216486895 -81985529216486896"
+}
+
+newlib_check_output "longlong.c" "$longlong_output"
diff -r -u -N /home/packages/newlib-1.13.0/newlib/testsuite/newlib.stdlib/env.c ./newlib/testsuite/newlib.stdlib/env.c
--- /home/packages/newlib-1.13.0/newlib/testsuite/newlib.stdlib/env.c	1969-12-31 19:00:00.000000000 -0500
+++ ./newlib/testsuite/newlib.stdlib/env.c	2015-10-26 22:26:08.895815000 -0400
@@ -0,0 +1,16 @@
+/* Validate that the environment and Elf auxv values are set right. */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <unistd.h>
+
+/* Note that crt0.S extracts AT_PAGESZ "by hand", but nothing else. */
+
+int main()
+{
+  printf("HOME: %s\n", getenv("HOME"));
+  printf("pagesize: %splausible\n",
+         (getpagesize() == 4096 || getpagesize() == 16384 ||
+          getpagesize() == 65536) ? "" : "im");
+  return 0;
+}
