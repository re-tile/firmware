diff -r -u -N /home/packages/newlib-1.13.0/newlib/libc/sys/tilepro/getreent.S ./newlib/libc/sys/tilepro/getreent.S
--- /home/packages/newlib-1.13.0/newlib/libc/sys/tilepro/getreent.S	1969-12-31 19:00:00.000000000 -0500
+++ ./newlib/libc/sys/tilepro/getreent.S	2015-10-26 22:26:09.124795000 -0400
@@ -0,0 +1,39 @@
