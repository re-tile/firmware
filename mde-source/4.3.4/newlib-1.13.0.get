diff -r -u -N /home/packages/newlib-1.13.0/newlib/testsuite/newlib.stdlib/malloc_test.c ./newlib/testsuite/newlib.stdlib/malloc_test.c
--- /home/packages/newlib-1.13.0/newlib/testsuite/newlib.stdlib/malloc_test.c	1969-12-31 19:00:00.000000000 -0500
+++ ./newlib/testsuite/newlib.stdlib/malloc_test.c	2015-10-26 22:26:08.901814000 -0400
@@ -0,0 +1,91 @@
+/* Copyright (C) 1997 DJ Delorie, see COPYING.DJ for details */
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <time.h>
+#include <unistd.h>
+#include <limits.h>
+#include <sys/types.h>
+#include <sys/times.h>
+#include <sys/mman.h>
+
+#define MAXP	100
+#define SUBP	10
+#define NPASS	10
+#define NLOOP	2
+
+char *pointers[MAXP];
+int size[MAXP];
+
+int rsize(void)
+{
+  int rv = 8 << (lrand48() % 15);
+  rv = lrand48() & (rv-1);
+  return rv;
+}
+
+int main(int argc, char **argv)
+{
+  int i, r, loop, pass, subpass;
+  int absmax=0, curmax=0;
+  int realloc_mask = -1;
+
+  if (argc > 1 && strcmp(argv[1], "-r") == 0)
+  {
+    realloc_mask = 48;
+  }
+
+  setbuf(stdout, 0);
+  memset(pointers, 0, MAXP*sizeof(pointers[0]));
+
+  for (loop=0; loop<NLOOP; loop++)
+  {
+    for (pass=0; pass<NPASS; pass++)
+    {
+      for (subpass=0; subpass<SUBP; subpass++)
+      {
+	for (i=0; i<MAXP; i++)
+	{
+	  int rno = lrand48();
+	  if (rno & 8)
+	  {
+	    if (pointers[i])
+	    {
+	      if (!(rno & realloc_mask))
+	      {
+		r = rsize();
+		curmax -= size[i];
+		curmax += r;
+		pointers[i] = realloc(pointers[i], rsize());
+		size[i] = r;
+		if (absmax < curmax) absmax = curmax;
+	      }
+	      else
+	      {
+		curmax -= size[i];
+		free(pointers[i]);
+		pointers[i] = 0;
+	      }
+	    }
+	    else
+	    {
+	      r = rsize();
+	      curmax += r;
+	      pointers[i] = malloc(r);
+	      size[i] = r;
+	      if (absmax < curmax) absmax = curmax;
+	    }
+	  }
+	}
+      }
+    }
+
+    printf("%dKB\n", absmax/1024);
+  }
+
+  for (i=0; i<MAXP; i++)
+    if (pointers[i])
+      free(pointers[i]);
+
+  return 0;
+}
diff -r -u -N /home/packages/newlib-1.13.0/newlib/testsuite/newlib.stdlib/times.c ./newlib/testsuite/newlib.stdlib/times.c
--- /home/packages/newlib-1.13.0/newlib/testsuite/newlib.stdlib/times.c	1969-12-31 19:00:00.000000000 -0500
+++ ./newlib/testsuite/newlib.stdlib/times.c	2015-10-26 22:26:08.907811000 -0400
@@ -0,0 +1,58 @@
+#include <stdio.h>
+
+#include <sys/times.h>
+#include <sys/time.h>
+
+#include <arch/cycle.h>
+
+
+// A simple test to validate that timing stuff basically works.
+
+int main()
+{
+  // Some small amount of time should pass between each "gettimeofday()".
+
+  struct timeval tv1, tv2;
+
+  gettimeofday(&tv1, NULL);
+
+  // Spin for 1000 cycles to ensure some time has passed.
+  unsigned long long done = get_cycle_count() + 1000;
+  while (get_cycle_count() < done)
+    ;
+
+  gettimeofday(&tv2, NULL);
+
+  long d_sec = tv2.tv_sec - tv1.tv_sec;
+  long d_usec = tv2.tv_usec - tv1.tv_usec;
+
+  if (d_usec < 0)
+  {
+    d_usec += 10000000;
+    d_sec--;
+  }
+
+  if (d_sec != 0 || d_usec == 0 || d_usec >= 1000)
+  {
+    printf("Elapsed time = %ld.%06ld!\n", d_sec, d_usec);
+    return 1;
+  }
+
+
+  // Zero (or occasionally one) tick should pass between each "times()".
+
+  struct tms t1, t2;
+
+  times(&t1);
+  times(&t2);
+
+  if (t1.tms_utime > t2.tms_utime)
+  {
+    printf("Negative elapsed user time!\n");
+    return 1;
+  }
+
+
+  printf("OK\n");
+  return 0;
+}
