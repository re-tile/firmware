diff -r -u -N /home/packages/newlib-1.13.0/newlib/libc/sys/tilegx/fork.c ./newlib/libc/sys/tilegx/fork.c
--- /home/packages/newlib-1.13.0/newlib/libc/sys/tilegx/fork.c	1969-12-31 19:00:00.000000000 -0500
+++ ./newlib/libc/sys/tilegx/fork.c	2015-10-26 22:26:09.429808000 -0400
@@ -0,0 +1,2 @@
