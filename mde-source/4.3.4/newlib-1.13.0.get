diff -r -u -N /home/packages/newlib-1.13.0/newlib/libc/include/sys/reg.h ./newlib/libc/include/sys/reg.h
--- /home/packages/newlib-1.13.0/newlib/libc/include/sys/reg.h	1969-12-31 19:00:00.000000000 -0500
