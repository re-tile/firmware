 LINK = $(LIBTOOL) --mode=link $(CCLD) $(AM_CFLAGS) $(CFLAGS) $(LDFLAGS) -o $@
 DATA =  $(noinst_DATA)
 
+# TILE does not have <dirent.h>, so we don't support:
+# scandir, seekdir, closedir, opendir, readdir, readdir_r, rewinddir, telldir,
+# execlp, execvp.
+LIB_OBJS = 
+lib_a_OBJECTS = execl.$(oext) execle.$(oext) execv.$(oext) popen.$(oext)
+
 DIST_COMMON =  Makefile.am Makefile.in
 
 
