--- /home/packages/newlib-1.13.0/newlib/libc/stdio/fread.c	2004-12-13 14:42:16.000000000 -0500
+++ ./newlib/libc/stdio/fread.c	2015-10-26 22:26:08.615829000 -0400
@@ -157,9 +157,9 @@
 	  void * old_p = fp->_p;
 	  int old_size = fp->_bf._size;
 	  /* allow __refill to use user's buffer */
-	  fp->_bf._base = p;
+	  fp->_bf._base = (unsigned char*) p;
 	  fp->_bf._size = resid;
-	  fp->_p = p;
+	  fp->_p = (unsigned char*) p;
 	  rc = __srefill (fp);
 	  /* restore fp buffering back to original state */
 	  fp->_bf._base = old_base;
