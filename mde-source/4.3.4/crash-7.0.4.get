+#define PTREGS_OFFSET_REG(n)    ((n)*8)
+#define PTREGS_SIZE             PTREGS_OFFSET_REG(64)
+typedef unsigned long tilegx_pt_reg_t;
+struct tilegx_pt_regs {
+	/* Saved main processor registers; 56..63 are special. */
+	/* tp, sp, and lr must immediately follow regs[] for aliasing. */
+	tilegx_pt_reg_t regs[53];
+	tilegx_pt_reg_t tp;		/* aliases regs[TREG_TP] */
+	tilegx_pt_reg_t sp;		/* aliases regs[TREG_SP] */
+	tilegx_pt_reg_t lr;		/* aliases regs[TREG_LR] */
+
+	/* Saved special registers. */
+	tilegx_pt_reg_t pc;		/* stored in EX_CONTEXT_K_0 */
+	tilegx_pt_reg_t ex1;		/* stored in EX_CONTEXT_K_1 (PL and ICS bit) */
+	tilegx_pt_reg_t faultnum;	/* fault number (INT_SWINT_1 for syscall) */
+	tilegx_pt_reg_t orig_r0;	/* r0 at syscall entry, else zero */
+	tilegx_pt_reg_t flags;
+	tilegx_pt_reg_t cmpexch;	/* value of CMPEXCH_VALUE SPR at interrupt */
+	tilegx_pt_reg_t pad[2];
+};
+
+#define MACHINE_TYPE		"TILEGX"
+
+#define CHIP_VA_WIDTH()		42
+#define MAX_VA_WIDTH		CHIP_VA_WIDTH()
+#define PAGE_OFFSET		(-(1UL << (MAX_VA_WIDTH - 1)))
+#define KERNEL_HIGH_VADDR	0xfffffff800000000UL  /* high 32GB */
+
+#define FIXADDR_BASE		(KERNEL_HIGH_VADDR - 0x300000000) /* 4 GB */
+#define FIXADDR_TOP		(KERNEL_HIGH_VADDR - 0x200000000) /* 4 GB */
+#define _VMALLOC_START		FIXADDR_TOP
+#define MEM_SV_START		(KERNEL_HIGH_VADDR - 0x100000000) /* 256 MB */
+#define MEM_MODULE_START	(MEM_SV_START + (256*1024*1024)) /* 256 MB */
+#define MEM_MODULE_END		(MEM_MODULE_START + (256*1024*1024))
+
+#define _VMALLOC_END		MEM_SV_START
+#define VMALLOC_END		_VMALLOC_END
+#define VMALLOC_START		_VMALLOC_START
+
+#define PAGEBASE(X)		(((ulong)(X)) & (ulong)machdep->pagemask)
+
+#define PTOV(X)			((unsigned long)(X)+(machdep->kvbase))
+#define VTOP(X)			tilegx_VTOP((ulong)X)
+#define IS_VMALLOC_ADDR(X)	tilegx_is_vmalloc_addr((ulong)(X))
+
+#define	MAX_NUMNODES	4
+
+#define HPAGE_SHIFT	HV_LOG2_DEFAULT_PAGE_SIZE_LARGE
+#define PGDIR_SHIFT	HV_LOG2_L1_SPAN
+#define PGDIR_SIZE	HV_L1_SPAN
+#define PTRS_PER_PGD	HV_L0_ENTRIES
+#define PMD_SHIFT	HPAGE_SHIFT
+#define PTRS_PER_PMD	_HV_L1_ENTRIES(HPAGE_SHIFT)
+
+#define pgd_index(vaddr)	(((vaddr) >> PGDIR_SHIFT) & (PTRS_PER_PGD - 1))
+#define pud_ptfn(val)		(val >> HV_PTE_INDEX_PTFN)
+#define pmd_index(vaddr)	(((vaddr) >> PMD_SHIFT) & (PTRS_PER_PMD - 1))
+#define pte_ptfn(val)		(val >> HV_PTE_INDEX_PTFN)
+
+#define pud_present(val)	(val & HV_PTE_PRESENT)
+#define pud_huge_page(val)	(val & HV_PTE_PAGE)
+#define pmd_present(val)	(val & HV_PTE_PRESENT)
+#define pmd_huge_page(val)	(val & HV_PTE_PAGE)
+#define pte_present(val)	(val & HV_PTE_PRESENT)
+#define pte_super_page(val)	(val & HV_PTE_SUPER)
+
+#define pte_file(pte)		(hv_pte_get_client1(pte) && \
+				!hv_pte_get_client0(pte))
+
+/* Return the page-table frame number (ptfn) that a pmd_t points at. */
+#define pmd_pte(pmd)	((HV_PTE) {.val = (pmd)})
+#define pmd_ptfn(pmd)	(hv_pte_get_ptfn(pmd_pte(pmd)))
+#define PAGE_SHIFT	(machdep->pageshift)
+#define PAGE_SIZE	(machdep->pagesize)
+#define PTRS_PER_PTE	_HV_L2_ENTRIES(HPAGE_SHIFT, PAGE_SHIFT)
+
+#define PFN_DOWN(x)	((x) >> PAGE_SHIFT)
+#define PFN_PHYS(x)	((x) << PAGE_SHIFT)
+
+static inline ulong pte_pfn(ulong x)
+{
+	HV_PTE pte;
+
+	pte.val = x;
+	return PFN_DOWN(hv_pte_get_pa(pte));
+}
+
+static inline ulong pte_index(unsigned long address)
+{
+	return (address >> PAGE_SHIFT) & (PTRS_PER_PTE - 1);
+}
+
+#define TIF_SIGPENDING		0
+
+#define SWP_TYPE(entry)		(((entry) >> 32) & 0x1f)
+#define SWP_OFFSET(entry)	((entry) >> 37)
+#define __swp_type(entry)	SWP_TYPE(entry)
+#define __swp_offset(entry)	SWP_OFFSET(entry)
+
+struct tilegx_stackframe_info {
+	unsigned long pc;
+	unsigned long sp;
+	unsigned long lr;
+	unsigned long fp;
+};
+
+/* Useless so far */
+struct machine_specific {
+	unsigned long kernel_text_start;
+	unsigned long kernel_text_end;
+};
+
+#define	KSYMS_START	(0x1)
+
+void tilegx_init(int);
+void tilegx_dump_machdep_table(ulong);
+void tilegx_dump_backtrace_entry(struct bt_info *, int, ulong, ulong, ulong);
+int tilegx_valid_fault_frame(struct bt_info *, ulong, struct tilegx_pt_regs *);
+void tilegx_dump_fault_stack(ulong sp, struct tilegx_pt_regs *);
+
+#define display_idt_table() \
+        error(FATAL, "-d option is not applicable to TILEGX architecture\n")
+
