+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+ * GNU General Public License for more details.
+ */
+
+#ifdef TILEGX
+
+#include "defs.h"
+
+static int tilegx_verify_symbol(const char *, ulong, char);
+static void tilegx_parse_cmdline_args(void);
+static int tilegx_eframe_search(struct bt_info *);
+static void tilegx_back_trace_cmd(struct bt_info *);
+static ulong tilegx_processor_speed(void);
+static ulong tilegx_vmalloc_start(void);
+static int tilegx_uvtop(struct task_context *, ulong, physaddr_t *, int);
+static int tilegx_kvtop(struct task_context *, ulong, physaddr_t *, int);
+static ulong tilegx_get_task_pgd(ulong);
+static void tilegx_get_stack_frame(struct bt_info *, ulong *, ulong *);
+static int tilegx_translate_pte(ulong, void *, ulonglong);
+static int tilegx_is_task_addr(ulong);
+static int tilegx_dis_filter(ulong, char *, unsigned int);
+static void tilegx_cmd_mach(void);
+static int tilegx_get_smp_cpus(void);
+static int tilegx_get_kvaddr_ranges(struct vaddr_range *);
+static void tilegx_init_machspec(void);
+
+static struct line_number_hook tilegx_line_number_hooks[];
+static struct machine_specific tilegx_machine_specific;
+
+/*
+ * Initialize TileGX specific stuff.
+ */
+static void
+tilegx_init_machspec(void)
+{
+	struct machine_specific *ms = machdep->machspec;
+	ulong phys_base;
+
+	if (symbol_exists("_stext") && symbol_exists("_etext")) {
+		ms->kernel_text_start = symbol_value("_stext");
+		ms->kernel_text_end = symbol_value("_etext");
+	}
+}
+
+/*
+ * Do all necessary machine-specific setup here. This is called several times
+ * during initialization.
+ */
+void
+tilegx_init(int when)
+{
+	switch (when)
+	{
+	case SETUP_ENV:
+		machdep->process_elf_notes = process_elf64_notes;
+		break;
+
+	case PRE_SYMTAB:
+		machdep->verify_symbol = tilegx_verify_symbol;
+		machdep->machspec = &tilegx_machine_specific;
+		if (pc->flags & KERNEL_DEBUG_QUERY)
+			return;
+
+		machdep->pagesize = memory_page_size();
+		machdep->pageshift = ffs(machdep->pagesize) - 1;
+		machdep->pageoffset = machdep->pagesize - 1;
+		machdep->pagemask = ~((ulonglong)machdep->pageoffset);
+		machdep->stacksize = machdep->pagesize < 8192 ?
+			 (machdep->pagesize << (13 - machdep->pageshift)) :
+			 machdep->pagesize;
+		machdep->last_pgd_read = 0;
+		machdep->last_pmd_read = 0;
+		machdep->last_ptbl_read = 0;
+		machdep->verify_paddr = generic_verify_paddr;
+		machdep->ptrs_per_pgd = PTRS_PER_PGD;
+
+		if (machdep->cmdline_args[0])
+			tilegx_parse_cmdline_args();
+		break;
+
+	case PRE_GDB:
+		if ((machdep->pgd = (char *)malloc(PAGESIZE())) == NULL)
+			error(FATAL, "cannot malloc pgd space.");
+		if ((machdep->pmd = (char *)malloc(PAGESIZE())) == NULL)
+			error(FATAL, "cannot malloc pmd space.");
+		if ((machdep->ptbl = (char *)malloc(PAGESIZE())) == NULL)
+			error(FATAL, "cannot malloc ptbl space.");
+		machdep->kvbase = (ulong) PAGE_OFFSET;
+		machdep->identity_map_base = machdep->kvbase;
+		machdep->is_kvaddr = generic_is_kvaddr;
+		machdep->is_uvaddr = generic_is_uvaddr;
+		machdep->eframe_search = tilegx_eframe_search;
+		machdep->back_trace = tilegx_back_trace_cmd;
+		machdep->processor_speed = tilegx_processor_speed;
+		machdep->vmalloc_start = tilegx_vmalloc_start;
+		machdep->uvtop = tilegx_uvtop;
+		machdep->kvtop = tilegx_kvtop;
+		machdep->get_task_pgd = tilegx_get_task_pgd;
+		machdep->get_stack_frame = tilegx_get_stack_frame;
+		machdep->get_stackbase = generic_get_stackbase;
+		machdep->get_stacktop = generic_get_stacktop;
+		machdep->translate_pte = tilegx_translate_pte;
+		machdep->memory_size = generic_memory_size;
+		machdep->is_task_addr = tilegx_is_task_addr;
+		machdep->dis_filter = tilegx_dis_filter;
+		machdep->cmd_mach = tilegx_cmd_mach;
+		machdep->get_smp_cpus = tilegx_get_smp_cpus;
+		machdep->line_number_hooks = tilegx_line_number_hooks;
+		machdep->value_to_symbol = generic_machdep_value_to_symbol;
+		machdep->init_kernel_pgd = NULL;
+		machdep->get_kvaddr_ranges = tilegx_get_kvaddr_ranges;
+		machdep->dump_irq = generic_dump_irq;
+		machdep->get_irq_affinity = generic_get_irq_affinity;
+		machdep->show_interrupts = generic_show_interrupts;
+
+		tilegx_init_machspec();
+		break;
+
+	case POST_GDB:
+		if (symbol_exists("irq_desc")) {
+			ARRAY_LENGTH_INIT(machdep->nr_irqs, irq_desc,
+				"irq_desc", NULL, 0);
+		} else if (kernel_symbol_exists("nr_irqs"))
+			get_symbol_data("nr_irqs", sizeof(unsigned int),
+				&machdep->nr_irqs);
+		else
+			machdep->nr_irqs = 0;
+
+		STRUCT_SIZE_INIT(note_buf, "note_buf_t");
+		STRUCT_SIZE_INIT(elf_prstatus, "elf_prstatus");
+		MEMBER_OFFSET_INIT(elf_prstatus_pr_reg, "elf_prstatus",
+				   "pr_reg");
+		break;
+
+	case POST_VM:
+		init_unwind_table();
+		break;
+
+	case POST_INIT:
+		break;
+	}
+}
+
+void
+tilegx_dump_machdep_table(ulong arg)
+{
+	int c, i, cpus;
+        int others; 
+
+        others = 0;
+        fprintf(fp, "              flags: %lx (", machdep->flags);
+        fprintf(fp, ")\n");
+
+	fprintf(fp, "             kvbase: %lx\n", machdep->kvbase);
+	fprintf(fp, "  identity_map_base: %lx\n", machdep->identity_map_base);
+        fprintf(fp, "           pagesize: %d\n", machdep->pagesize);
+        fprintf(fp, "          pageshift: %d\n", machdep->pageshift);
+        fprintf(fp, "           pagemask: %llx\n", machdep->pagemask);
+        fprintf(fp, "         pageoffset: %lx\n", machdep->pageoffset);
+	fprintf(fp, "          stacksize: %ld\n", machdep->stacksize);
+        fprintf(fp, "                 hz: %d\n", machdep->hz);
+        fprintf(fp, "                mhz: %ld\n", machdep->mhz);
+        fprintf(fp, "            memsize: %llu (0x%llx)\n", 
+		(ulonglong)machdep->memsize, (ulonglong)machdep->memsize);
+	fprintf(fp, "               bits: %d\n", machdep->bits);
+	fprintf(fp, "            nr_irqs: %d\n", machdep->nr_irqs);
+        fprintf(fp, "      eframe_search: tilegx_eframe_search()\n");
+        fprintf(fp, "         back_trace: tilegx_back_trace_cmd()\n");
+        fprintf(fp, "    processor_speed: tilegx_processor_speed()\n");
+        fprintf(fp, "              uvtop: tilegx_uvtop()\n");
+        fprintf(fp, "              kvtop: tilegx_kvtop()\n");
+        fprintf(fp, "       get_task_pgd: tilegx_get_task_pgd()\n");
+	fprintf(fp, "           dump_irq: generic_dump_irq()\n");
+	fprintf(fp, "   get_irq_affinity: generic_get_irq_affinity()\n");
+	fprintf(fp, "    show_interrupts: generic_show_interrupts()\n");
+        fprintf(fp, "    get_stack_frame: tilegx_get_stack_frame()\n");
+        fprintf(fp, "      get_stackbase: generic_get_stackbase()\n");
+        fprintf(fp, "       get_stacktop: generic_get_stacktop()\n");
+        fprintf(fp, "      translate_pte: tilegx_translate_pte()\n");
+	fprintf(fp, "        memory_size: generic_memory_size()\n");
+	fprintf(fp, "      vmalloc_start: tilegx_vmalloc_start()\n");
+	fprintf(fp, "       is_task_addr: tilegx_is_task_addr()\n");
+	fprintf(fp, "      verify_symbol: tilegx_verify_symbol()\n");
+	fprintf(fp, "         dis_filter: tilegx_dis_filter()\n");
+	fprintf(fp, "           cmd_mach: tilegx_cmd_mach()\n");
+	fprintf(fp, "       get_smp_cpus: tilegx_get_smp_cpus()\n");
+        fprintf(fp, "          is_kvaddr: generic_is_kvaddr()\n");
+        fprintf(fp, "          is_uvaddr: generic_is_uvaddr()\n");
+        fprintf(fp, "       verify_paddr: generic_verify_paddr()\n");
+        fprintf(fp, "  get_kvaddr_ranges: tilegx_get_kvaddr_ranges()\n");
+        fprintf(fp, "    init_kernel_pgd: NULL\n");
+        fprintf(fp, "clear_machdep_cache: NULL\n");
+	fprintf(fp, "  line_number_hooks: tilegx_line_number_hooks\n");
+        fprintf(fp, "    value_to_symbol: generic_machdep_value_to_symbol()\n");
+        fprintf(fp, "      last_pgd_read: %lx\n", machdep->last_pgd_read);
+        fprintf(fp, "      last_pmd_read: %lx\n", machdep->last_pmd_read);
+        fprintf(fp, "     last_ptbl_read: %lx\n", machdep->last_ptbl_read);
+        fprintf(fp, "                pgd: %lx\n", (ulong)machdep->pgd);
+        fprintf(fp, "                pmd: %lx\n", (ulong)machdep->pmd);
+        fprintf(fp, "               ptbl: %lx\n", (ulong)machdep->ptbl);
+	fprintf(fp, "       ptrs_per_pgd: %d\n", machdep->ptrs_per_pgd);
+        fprintf(fp, "  sections_per_root: %ld\n", machdep->sections_per_root);
+
+	for (i = 0; i < MAX_MACHDEP_ARGS; i++) {
+		fprintf(fp, "    cmdline_args[%d]: %s\n", 
+			i, machdep->cmdline_args[i] ? 
+			machdep->cmdline_args[i] : "(unused)");
+	}
+}
+
+static int
+tilegx_verify_symbol(const char *name, ulong value, char type)
+{
+	if (STREQ(name, "_start") || STREQ(name, "_stext"))
+		machdep->flags |= KSYMS_START;
+
+	if (!name || !strlen(name))
+		return FALSE;
+
+	return TRUE;
+}
+
+/* Parse machine dependent command line arguments. */
+static void
+tilegx_parse_cmdline_args(void)
+{
+	/* Nothing to do by now : (crash -m option=value) */
+}
+
+static int
+tilegx_eframe_search(struct bt_info *bt_in)
+{
+	return error(FATAL, "%s(): N/A\n", __func__);
+}
+
+static ulong
+tilegx_vmalloc_start(void)
+{
+	return ((ulong)VMALLOC_START);
+}
+
+ulong
+tilegx_VTOP(ulong vaddr)
+{
+	if (vaddr >= MEM_SV_START)
+		return (vaddr - MEM_SV_START);
+	else
+		return (vaddr - machdep->kvbase);
+}
+
+/* Include vmalloc + vmap of huge pages + module address space. */
+int
+tilegx_is_vmalloc_addr(ulong vaddr)
+{
+	return ((vaddr >= VMALLOC_START && vaddr < VMALLOC_END) ||
+		(vaddr >= MEM_MODULE_START && vaddr < MEM_MODULE_END));
+}
+
+/*
+ * Virtual to physical memory translation. This function will be called
+ * by both tilegx_kvtop() and tilegx_uvtop().
+ */
+static int
+tilegx_vtop(ulong vaddr, ulong *pgd, physaddr_t *paddr, int verbose)
+{
+	ulong pgd_va, pmd_pa, pte_pa;
+	ulong pud, pmd, pte;
+
+	if (verbose)
+		fprintf(fp, "PAGE DIRECTORY: %lx\n", (ulong)pgd);
+	
+	/* pud */
+	pgd_va =  (ulong)pgd + pgd_index(vaddr) * sizeof(HV_PTE);
+	FILL_PGD(PAGEBASE(pgd_va), KVADDR, machdep->pagesize);
+	pud = ULONG(machdep->pgd + PAGEOFFSET(pgd_va));
+
+	if (!pud_present(pud))
+		return FALSE;
+
+	if (pud_huge_page(pud)) {
+		if (pte_super_page(pud))
+			return FALSE;
+		pte = pud;
+		goto pte_ok;
+	}
+
+	/* pmd = pmd_offset(pud, vaddr) */
+	pmd_pa = (pud_ptfn(pud) << HV_LOG2_PAGE_TABLE_ALIGN) +
+		pmd_index(vaddr) * sizeof(HV_PTE);
+	FILL_PMD(PAGEBASE(pmd_pa), PHYSADDR, PAGESIZE());
+	pmd = ULONG(machdep->pmd + PAGEOFFSET(pmd_pa));
+
+	if (!pmd_present(pmd))
+		return FALSE;
+
+	if (pmd_huge_page(pmd)) {
+		/* FIXME */
+		if (pte_super_page(pmd))
+			return FALSE;
+		pte = pmd;
+		goto pte_ok;
+	}
+
+	/* pte = pte_offset_kernel(pmd, vaddr)  */
+	pte_pa = (pmd_ptfn(pmd) << HV_LOG2_PAGE_TABLE_ALIGN) +
+		pte_index(vaddr) * sizeof(HV_PTE);
+	FILL_PTBL(PAGEBASE(pte_pa), PHYSADDR, PAGESIZE());
+	pte = ULONG(machdep->ptbl + PAGEOFFSET(pte_pa));
+
+pte_ok:
+	if (!pte_present(pte))
+		return FALSE;
+
+	*paddr = PFN_PHYS(pte_pfn(pte)) + PAGEOFFSET(vaddr);
+
+	return TRUE;
+}
+
+/*
+ * Translates a user virtual address to its physical address. cmd_vtop() sets
+ * the verbose flag so that the pte translation gets displayed; all other
+ * callers quietly accept the translation.
+ */
+static int
+tilegx_uvtop(struct task_context *tc, ulong uvaddr, physaddr_t *paddr, int verbose)
+{
+	ulong *pgd, mm;
+
+	if (!tc)
+		error(FATAL, "current context invalid\n");
+
+	*paddr = 0;
+
+	if (IS_KVADDR(uvaddr))
+		return tilegx_kvtop(tc, uvaddr, paddr, verbose);
+
+	mm = task_mm(tc->task, TRUE);
+	if (mm)
+		pgd = ULONG_PTR(tt->mm_struct + OFFSET(mm_struct_pgd));
+	else
+		readmem(tc->mm_struct + OFFSET(mm_struct_pgd), KVADDR, &pgd,
+			sizeof(long), "mm_struct pgd", FAULT_ON_ERROR);
+	
+	return tilegx_vtop(uvaddr, pgd, paddr, verbose);
+}
+
+/*
+ *  Translates a kernel virtual address to its physical address.  cmd_vtop()
+ *  sets the verbose flag so that the pte translation gets displayed; all
+ *  other callers quietly accept the translation.
+ */
+static int
+tilegx_kvtop(struct task_context *tc, ulong kvaddr,
+	     physaddr_t *paddr, int verbose)
+{
+	if (!IS_KVADDR(kvaddr))
+		return FALSE;
+
+	/* fixmap */
+	if (kvaddr >= FIXADDR_BASE && kvaddr < FIXADDR_TOP)
+		return tilegx_vtop(kvaddr, (ulong *)vt->kernel_pgd[0], 
+				   paddr, verbose);
+
+	if (!vt->vmalloc_start) {
+		*paddr = VTOP(kvaddr);
+		return TRUE;
+	}
+
+	if (!IS_VMALLOC_ADDR(kvaddr)) {
+		*paddr = VTOP(kvaddr);
+		if (!verbose)
+			return TRUE;
+	}
+
+	return tilegx_vtop(kvaddr, (ulong *)vt->kernel_pgd[0], 
+			   paddr, verbose);
+}
+
+static void
+tilegx_display_full_frame(struct bt_info *bt, ulong sp, ulong prev_sp)
+{
+	ulong words, addr;
+	ulong *up;
+	char buf[BUFSIZE];
+	int i, u_idx;
+
+	if (!INSTACK(sp, bt) || !INSTACK(prev_sp, bt))
+		return;
+
+	addr = prev_sp;
+	words = (sp - prev_sp) / sizeof(ulong);
+	u_idx = (prev_sp - bt->stackbase) / sizeof(ulong);
+
+	for (i = 0; i < words; i++, u_idx++) {
+		if (!(i & 1))
+			fprintf(fp, "%s    %lx: ", i ? "\n" : "", addr);
+
+		up = (ulong *)(&bt->stackbuf[u_idx * sizeof(ulong)]);
+		fprintf(fp, "%s ", format_stack_entry(bt, buf, *up, 0));
+		addr += sizeof(ulong);
+	}
+
+	if (words)
+		fprintf(fp, "\n");
+}
+
+static int in_kernel_stack(struct bt_info *bt, ulong sp)
+{
+	ulong high_memory, vaddr;
+
+	if (bt->stackbase == 0) {
+		vaddr = symbol_value("high_memory");
+		if (!readmem(vaddr, KVADDR, (void *)high_memory, sizeof(ulong),
+		    "ulong", FAULT_ON_ERROR)) {
+			error(WARNING, "cannot read memory at symbol: high_memory\n");
+			return 0;
+		}
+
+		return sp >= PAGE_OFFSET && sp < high_memory;
+	}
+
+	return INSTACK(sp, bt);
+}
+
+int
+tilegx_valid_fault_frame(struct bt_info *bt, ulong sp, struct tilegx_pt_regs *p)
+{
+	if (sp % sizeof(long) != 0)
+		return 0;
+	if (!in_kernel_stack(bt, sp))
+		return 0;
+	if (!in_kernel_stack(bt, sp + C_ABI_SAVE_AREA_SIZE + PTREGS_SIZE - 1))
+		return 0;
+
+	if (!readmem(sp + C_ABI_SAVE_AREA_SIZE, KVADDR,
+		p, sizeof(struct tilegx_pt_regs),
+		"struct pt_regs", FAULT_ON_ERROR))
+		return 0;
+
+	return 1;
+}
+
+void
+tilegx_dump_fault_stack(ulong sp, struct tilegx_pt_regs *p)
+{
+	int i;
+
+	fprintf(fp, "<fault frame at : %#lx>\n", sp);
+	for (i = 0; i < 17; i++)
+		fprintf(fp, "    r%-2d: %#18lx" " r%-2d: %#18lx" " r%-2d: %#18lx" "\n",
+			i, p->regs[i],
+			i + 18, p->regs[i + 18],
+			i + 36, p->regs[i + 36]);
+
+	fprintf(fp, "    r18: %#18lx" " r35: %#18lx" " tp : %#18lx" "\n",
+		p->regs[18], p->regs[35], p->tp);
+	fprintf(fp, "    sp : %#18lx" " lr : %#18lx" "\n",
+		p->sp, p->lr);
+
+	fprintf(fp, "    pc : %#18lx" " ex1 : %ld faultnum: %ld\n",
+		p->pc, p->ex1, p->faultnum);
+}
+
+void
+tilegx_dump_backtrace_entry(struct bt_info *bt, int level,
+	ulong at, ulong sp, ulong prev_sp)
+{
+	struct load_module *lm;
+	struct syment *sym;
+	ulong offset;
+	char buf[BUFSIZE];
+	char *name, *name_plus_offset;
+
+	offset = 0;
+	sym = value_search(at, &offset);
+	name = sym->name;
+
+	if (!sym)
+		return;
+
+	name_plus_offset = NULL;
+	if ((bt->flags & BT_SYMBOL_OFFSET) && offset)
+		name_plus_offset =
+			value_to_symstr(at, buf, bt->radix);
+
+	if (module_symbol(at, NULL, &lm, NULL, 0)) {
+		fprintf(fp, "%s#%d %08lx %s [%s] (sp %08lx)\n",
+			level < 10 ? " " : "",
+			level, at,
+			name_plus_offset ? name_plus_offset : name,
+			lm->mod_name, sp);
+	} else {
+		fprintf(fp, "%s#%d %08lx %s (sp %08lx)\n",
+			level < 10 ? " " : "",
+			level, at,
+			name_plus_offset ? name_plus_offset : name,
+			sp);
+	}
+
+	if (bt->flags & BT_LINE_NUMBERS) {
+		get_line_number(at, buf, FALSE);
+		if (strlen(buf))
+			fprintf(fp, "    %s\n", buf);
+	}
+
+	if (bt->flags & BT_FULL) {
+		if (kt->flags & DWARF_UNWIND) {
+			fprintf(fp, "    "
+			"[PC: %#08lx  SP: %#08lx  SIZE: %ld]\n",
+			at, sp, sp - prev_sp);
+		}
+
+		tilegx_display_full_frame(bt, sp, prev_sp);
+	}
+}
+
+static void
+tilegx_back_trace_cmd(struct bt_info *bt)
+{
+	if (kt->flags & DWARF_UNWIND) {
+		dwarf_backtrace(bt);
+	} else
+		error(FATAL, "unwind isn't configured to do backtrace.\n"
+			"	run \"set unwind on\" to enable unwind.\n");
+}
+
+static ulong
+tilegx_processor_speed(void)
+{
+	unsigned long cycles_per_sec = 0;
+	ulong vaddr;
+
+	if (machdep->mhz)
+		return (machdep->mhz);
+
+	if (symbol_exists("cycles_per_sec")) {
+		get_symbol_data("cycles_per_sec", sizeof(ulong),
+			&cycles_per_sec);
+		machdep->mhz = cycles_per_sec / 1000000;
+	} else
+			machdep->mhz = 0;
+
+	return machdep->mhz;
+}
+
+static ulong
+tilegx_get_task_pgd(ulong task)
+{
+	return (error(FATAL, "%s(): N/A\n", __func__));
+}
+
+static int
+tilegx_get_dumpfile_stack_frame(struct bt_info *bt,
+	struct tilegx_stackframe_info *si)
+{
+	struct tilegx_pt_regs *pt_regs;
+
+	pt_regs = (struct tilegx_pt_regs *)bt->machdep;
+	if (!pt_regs)
+		return FALSE;
+
+	si->pc = pt_regs->pc;
+	si->sp = pt_regs->sp;
+	si->lr = pt_regs->lr;
+	si->fp = pt_regs->regs[TREG_FP];
+
+	return TRUE;
+}
+
+static int
+tilegx_get_other_stack_frame(struct bt_info *bt,
+	struct tilegx_stackframe_info *si)
+{
+	if (VALID_MEMBER(task_struct_thread)) {
+		ulong vaddr;
+
+		vaddr = bt->task + OFFSET(task_struct_thread);
+		readmem(vaddr + MEMBER_OFFSET("thread_struct", "ksp"), KVADDR,
+			&si->sp, sizeof(long *),
+			"thread_struct ksp", FAULT_ON_ERROR);
+		readmem(vaddr + MEMBER_OFFSET("thread_struct", "pc"), KVADDR,
+			&si->lr, sizeof(long *),
+			"thread_struct pc", FAULT_ON_ERROR);
+
+		/* Load the fp from the stack. See kernel: stack.c */
+		readmem(si->sp + C_ABI_SAVE_AREA_SIZE +
+			INT_REG_BITS * (TREG_FP - 30),
+			KVADDR, &si->fp, sizeof(long *),
+			"fp", FAULT_ON_ERROR);
+
+		if (kernel_symbol_exists("__switch_to_pc")) {
+			vaddr = symbol_value("__switch_to_pc");
+			readmem(vaddr, KVADDR, &si->pc, sizeof(long *),
+			"__switch_to_pc", FAULT_ON_ERROR);
+
+			return TRUE;
+		} else
+			return FALSE;
+	}
+
+	return FALSE;
+}
+
+/*
+ *  Get a stack frame combination of pc and sp from the most relevent spot.
+ */
+static void
+tilegx_get_stack_frame(struct bt_info *bt, ulong *pcp, ulong *spp)
+{
+	struct tilegx_stackframe_info si;
+	int ret;
+
+	if (DUMPFILE() && is_task_active(bt->task))
+		ret = tilegx_get_dumpfile_stack_frame(bt, &si);
+	else
+		ret = tilegx_get_other_stack_frame(bt, &si);
+
+	if (ret == FALSE) {
+		error(WARNING, "cannot get stack frame for task\n");
+		return;
+	}
+
+	if (pcp)
+		*pcp = si.pc;
+	if (spp)
+		*spp = si.sp;
+	bt->frameptr = si.fp;
+	bt->lrptr = si.lr;
+}
+
+/*
+ *  Translate a PTE, returning TRUE if the page is present.
+ *  If a physaddr pointer is passed in, don't print anything.
+ */
+static int
+tilegx_translate_pte(ulong pte_val, void *physaddr, ulonglong unused)
+{
+	HV_PTE pte;
+	ulong paddr;
+	int c, page_present, others, len1, len2, len3;
+	char ptebuf[BUFSIZE], buf[BUFSIZE], buf2[BUFSIZE], buf3[BUFSIZE];
+	char *arglist[MAXARGS], physbuf[BUFSIZE];
+
+	pte.val = pte_val;
+	page_present = hv_pte_get_present(pte);
+	paddr = hv_pte_get_pa(pte);
+
+	if (physaddr) {
+		*((ulong *)physaddr) = paddr;
+		return page_present;
+	}
+
+	fprintf(fp, ptebuf, "%lx", pte.val);
+	len1 = MAX(strlen(ptebuf), strlen("PTE"));
+	fprintf(fp, "%s  ", mkstring(buf, len1, CENTER|LJUST, "PTE"));
+
+	if (!page_present && pte_file(pte)) {
+		swap_location(pte.val, buf);
+		if ((c = parse_line(buf, arglist)) != 3)
+			error(FATAL, "cannot determine swap location\n");
+
+		len2 = MAX(strlen(arglist[0]), strlen("SWAP"));
+		len3 = MAX(strlen(arglist[2]), strlen("OFFSET"));
+
+		fprintf(fp, "%s  %s\n",
+			mkstring(buf2, len2, CENTER|LJUST, "SWAP"),
+			mkstring(buf3, len3, CENTER|LJUST, "OFFSET"));
+
+		strcpy(buf2, arglist[0]);
+		strcpy(buf3, arglist[2]);
+		fprintf(fp, "%s  %s  %s\n",
+			mkstring(ptebuf, len1, CENTER|RJUST, NULL),
+			mkstring(buf2, len2, CENTER|RJUST, NULL),
+			mkstring(buf3, len3, CENTER|RJUST, NULL));
+
+		return page_present;
+	}
+
+	sprintf(physbuf, "%lx", paddr);
+	len2 = MAX(strlen(physbuf), strlen("PHYSICAL"));
+	fprintf(fp, "%s  ", mkstring(buf, len2, CENTER|LJUST, "PHYSICAL"));
+
+	fprintf(fp, "FLAGS\n");
+
+	fprintf(fp, "%s  %s  ",
+	mkstring(ptebuf, len1, CENTER|RJUST, NULL),
+	mkstring(physbuf, len2, CENTER|RJUST, NULL));
+	fprintf(fp, "(");
+	others = 0;
+
+	if (pte.val) {
+		if (hv_pte_get_present(pte))
+			fprintf(fp, "%sPRESENT", others++ ? "|" : "");
+
+		if (hv_pte_get_page(pte))
+			fprintf(fp, "%sHUGE_PAGE", others++ ? "|" : "");
+
+		if (hv_pte_get_super(pte))
+			fprintf(fp, "%sSUPER_PAGE", others++ ? "|" : "");
+
+		if (hv_pte_get_client0(pte))
+			fprintf(fp, "%sCLIENT0", others++ ? "|" : "");
+
+		if (hv_pte_get_client1(pte))
+			fprintf(fp, "%sCLIENT1", others++ ? "|" : "");
+
+		if (hv_pte_get_client2(pte))
+			fprintf(fp, "%sCLIENT2", others++ ? "|" : "");
+
+		if (hv_pte_get_migrating(pte))
+			fprintf(fp, "%sMIGRATING", others++ ? "|" : "");
+
+		if (hv_pte_get_nc(pte))
+			fprintf(fp, "%sNC", others++ ? "|" : "");
+
+		if (hv_pte_get_readable(pte))
+			fprintf(fp, "%sREADABLE", others++ ? "|" : "");
+
+		if (hv_pte_get_writable(pte))
+			fprintf(fp, "%sWRITABLE", others++ ? "|" : "");
+
+		if (hv_pte_get_executable(pte))
+			fprintf(fp, "%sEXECUTABLE", others++ ? "|" : "");
+
+		if (hv_pte_get_accessed(pte))
+			fprintf(fp, "%sACCESSED", others++ ? "|" : "");
+
+		if (hv_pte_get_dirty(pte))
+			fprintf(fp, "%sDIRTY", others++ ? "|" : "");
+
+		if (hv_pte_get_no_alloc_l1(pte))
+			fprintf(fp, "%sNO_ALLOC_L1", others++ ? "|" : "");
+
+		if (hv_pte_get_no_alloc_l2(pte))
+			fprintf(fp, "%sNO_ALLOC_L2", others++ ? "|" : "");
+
+		if (hv_pte_get_cached_priority(pte))
+			fprintf(fp, "%sCACHED_PRIORITY", others++ ? "|" : "");
+
+		if (hv_pte_get_global(pte))
+			fprintf(fp, "%sGLOBAL", others++ ? "|" : "");
+
+		if (hv_pte_get_user(pte))
+			fprintf(fp, "%sUSER", others++ ? "|" : "");
+	} else {
+		fprintf(fp, "no mapping");
+	}
+
+	fprintf(fp, ")\n");
+
+	return (page_present);
+}
+
+static int
+tilegx_is_task_addr(ulong task)
+{
+	int i;
+
+	if (tt->flags & THREAD_INFO)
+		return IS_KVADDR(task);
+
+	return (IS_KVADDR(task) && ALIGNED_STACK_OFFSET(task) == 0);
+}
+
+/*
+ *  Filter disassembly output if the output radix is not gdb's default 10
+ */
+static int
+tilegx_dis_filter(ulong vaddr, char *inbuf, unsigned int output_radix)
+{
+	char buf1[BUFSIZE];
+	char buf2[BUFSIZE];
+	char *colon, *p1;
+	int argc;
+	char *argv[MAXARGS];
+	ulong value;
+
+	if (!inbuf)
+		return TRUE;
+/*
+ *  For some reason gdb can go off into the weeds translating text addresses,
+ *  (on alpha -- not necessarily seen on tilegx) so this routine both fixes the
+ *  references as well as imposing the current output radix on the translations.
+ */
+	console("IN: %s", inbuf);
+
+	colon = strstr(inbuf, ":");
+
+	if (colon) {
+		sprintf(buf1, "0x%lx <%s>", vaddr,
+			value_to_symstr(vaddr, buf2, output_radix));
+		sprintf(buf2, "%s%s", buf1, colon);
+		strcpy(inbuf, buf2);
+	}
+
+	strcpy(buf1, inbuf);
+	argc = parse_line(buf1, argv);
+
+	if ((FIRSTCHAR(argv[argc-1]) == '<') &&
+	    (LASTCHAR(argv[argc-1]) == '>')) {
+		p1 = rindex(inbuf, '<');
+		while ((p1 > inbuf) && !STRNEQ(p1, " 0x"))
+			p1--;
+
+		if (!STRNEQ(p1, " 0x"))
+			return FALSE;
+		p1++;
+
+		if (!extract_hex(p1, &value, NULLCHAR, TRUE))
+			return FALSE;
+
+		sprintf(buf1, "0x%lx <%s>\n", value,
+			value_to_symstr(value, buf2, output_radix));
+
+		sprintf(p1, "%s",  buf1);
+	}
+
+	console("    %s", inbuf);
+
+	return TRUE;
+}
+
+static void
+tilegx_display_machine_stats(void)
+{
+	struct new_utsname *uts;
+	char buf[BUFSIZE];
+	ulong mhz;
+
+	uts = &kt->utsname;
+
+	fprintf(fp, "       MACHINE TYPE: %s\n", uts->machine);
+	fprintf(fp, "        MEMORY SIZE: %s\n", get_memory_size(buf));
+	fprintf(fp, "               CPUS: %d\n", kt->cpus);
+	fprintf(fp, "    PROCESSOR SPEED: ");
+	if ((mhz = machdep->processor_speed()))
+		fprintf(fp, "%ld Mhz\n", mhz);
+	else
+		fprintf(fp, "(unknown)\n");
+	fprintf(fp, "                 HZ: %d\n", machdep->hz);
+	fprintf(fp, "          PAGE SIZE: %d\n", PAGESIZE());
+	fprintf(fp, "KERNEL VIRTUAL BASE: %lx\n", machdep->kvbase);
+	fprintf(fp, "KERNEL MODULES BASE: %lx\n", MEM_MODULE_START);
+	fprintf(fp, "KERNEL VMALLOC BASE: %lx\n", vt->vmalloc_start);
+	fprintf(fp, "  KERNEL STACK SIZE: %ld\n", STACKSIZE());
+
+}
+
+static void
+tilegx_cmd_mach(void)
+{
+	int c;
+
+	while ((c = getopt(argcnt, args, "cm")) != EOF) {
+		switch(c)
+		{
+		case 'c':
+		case 'm':
+			fprintf(fp, "TILEGX: '-%c' option is not supported.\n",
+				c);
+			return;
+
+		default:
+			argerrs++;
+			break;
+		}
+	}
+
+	if (argerrs)
+		cmd_usage(pc->curcmd, SYNOPSIS);
+
+	tilegx_display_machine_stats();
+}
+
+static int
+tilegx_get_smp_cpus(void)
+{
+	return MAX(get_cpus_online(), get_highest_cpu_online()+1);
+}
+
+static const char *hook_files[] = {
+        "arch/tile/kernel/intvec_64.S",
+        "arch/tile/kernel/entry.S",
+        "arch/tile/kernel/head_64.S",
+        "arch/tile/kernel/reg_64.S",
+};
+
+#define INTVEC_S    ((char **)&hook_files[0])
+#define ENTRY_S    ((char **)&hook_files[1])
+#define HEAD_S    ((char **)&hook_files[2])
+#define REG_S    ((char **)&hook_files[2])
+
+static struct line_number_hook tilegx_line_number_hooks[] = {
+        { "__start_unalign_asm_code", INTVEC_S },
+        { "__end_unalign_asm_code", INTVEC_S },
+        { "interrupt_return", INTVEC_S },
+        { "handle_syscall_link_address", INTVEC_S },
+        { "ret_from_fork", INTVEC_S },
+        { "_kernel_double_fault", INTVEC_S },
+        { "bad_intr", INTVEC_S },
+        { "_sys_clone", INTVEC_S },
+        { "_sys_execve", INTVEC_S },
+        { "_sys_sigaltstack", INTVEC_S },
+        { "_sys_rt_sigreturn", INTVEC_S },
+        { "fill_ra_stack", INTVEC_S },
+
+        { "current_text_addr", ENTRY_S },
+        { "kernel_execve", ENTRY_S },
+        { "dump_stack", ENTRY_S },
+        { "KBacktraceIterator_init_current", ENTRY_S },
+        { "cpu_idle_on_new_stack", ENTRY_S },
+        { "smp_nap", ENTRY_S },
+        { "_cpu_idle", ENTRY_S },
+
+        { "_start", HEAD_S },
+
+	{ "__switch_to", REG_S },
+	{ "get_pt_regs", REG_S },
+
+	{NULL, NULL}    /* list must be NULL-terminated */
+};
+
+static int
+compare_kvaddr(const void *v1, const void *v2)
+{
+	struct vaddr_range *r1, *r2;
+
+	r1 = (struct vaddr_range *)v1;
+	r2 = (struct vaddr_range *)v2;
+
+	return (r1->start < r2->start ? -1 :
+		r1->start == r2->start ? 0 : 1);
+}
+
+static int
+tilegx_get_kvaddr_ranges(struct vaddr_range *vrp)
+{
+	int cnt;
+	ulong start;
+
+	cnt = 0;
+
+	vrp[cnt].type = KVADDR_UNITY_MAP;
+	vrp[cnt].start = machdep->kvbase;
+	vrp[cnt++].end = vt->high_memory;
+
+	vrp[cnt].type = KVADDR_START_MAP;
+	vrp[cnt].start = MEM_SV_START;
+	vrp[cnt++].end = kt->end;
+
+	vrp[cnt].type = KVADDR_VMALLOC;
+	vrp[cnt].start = VMALLOC_START;
+	vrp[cnt++].end = VMALLOC_END;
+
+	/*
+	 *  Verify that this region stand alone.
+	 */
+	if (st->mods_installed) {
+		vrp[cnt].type = KVADDR_MODULES;
+		vrp[cnt].start = MEM_MODULE_START;
+		vrp[cnt++].end = MEM_MODULE_END;
+	}
+
+	qsort(vrp, cnt, sizeof(struct vaddr_range), compare_kvaddr);
+
+	return cnt;
+}
+
+#endif
diff -r -u -N /home/packages/crash-7.0.4/unwind_tilegx.c ./unwind_tilegx.c
--- /home/packages/crash-7.0.4/unwind_tilegx.c	1969-12-31 19:00:00.000000000 -0500
+++ ./unwind_tilegx.c	2015-10-26 22:26:22.191915000 -0400
@@ -0,0 +1,1235 @@
+/*
