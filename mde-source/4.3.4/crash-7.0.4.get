#!/bin/bash -ex

# Run this script to create the corresponding source subdir in the CWD.

DIR=$(basename $0 .get)
if [ -d $DIR ]; then
    echo "$(basename $0): Cannot replace existing directory '$DIR'." >&2
    exit 1
fi

MD5SUM=2b170cd9a82dee90ecf74e8bfb37f17e
ORIG=$DIR.tar.gz
if [ ! -f $ORIG ]; then
    if [ -n "$DOWNLOAD_CACHE" -a -f "$DOWNLOAD_CACHE/$ORIG" ]; then
        ORIG="$DOWNLOAD_CACHE/$ORIG"
    else
	curl -kL https://github.com/crash-utility/crash/archive/$ORIG > $ORIG.tmp
	mv $ORIG.tmp $ORIG
    fi
fi

if [ $MD5SUM != `md5sum $ORIG | cut -f1 -d' '` ]; then
    echo "$me: Wrong md5sum for '$ORIG.tmp'." >&2
    exit 1
fi

tar xf $ORIG

# crash specific
NAME=`echo $DIR | awk -F- '{print $1}'`
if [ -d $NAME-$DIR ]; then
    mv $NAME-$DIR $DIR
fi

cat $0 | patch -d $DIR -p1 -s

exit 0

# The actual Tilera patch starts here.
