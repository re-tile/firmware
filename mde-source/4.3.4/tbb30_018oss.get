+#ifndef __TBB_machine_H
+#error Do not include this file directly; include tbb_machine.h instead
+#endif
+
+#include "linux_common.h"
+#include <arch/atomic.h>
+
+#ifdef __LP64__
+#define __TBB_WORDSIZE 8
+#else
+#define __TBB_WORDSIZE 4
+#endif
+
+#define __TBB_BIG_ENDIAN 0
+
+static inline uint32_t __TBB_machine_cmpswp4(volatile void* ptr, uint32_t value,
+                                             uint32_t comparand )
+{
+  arch_atomic_compiler_barrier();
+  return arch_atomic_val_compare_and_exchange((uint32_t*)ptr, comparand, value);
+}
+
+static inline uint64_t __TBB_machine_cmpswp8(volatile void* ptr, uint64_t value,
+                                             uint64_t comparand )
+{
+  arch_atomic_compiler_barrier();
+  return arch_atomic_val_compare_and_exchange((uint64_t*)ptr, comparand, value);
+}
+
+
+#define __TBB_CompareAndSwap4(P,V,C) __TBB_machine_cmpswp4(P,V,C)
+#define __TBB_CompareAndSwap8(P,V,C) __TBB_machine_cmpswp8(P,V,C)
+
+#ifdef __LP64__
+#define __TBB_CompareAndSwapW(P,V,C) __TBB_machine_cmpswp8(P,V,C)
+#else
+#define __TBB_CompareAndSwapW(P,V,C) __TBB_machine_cmpswp4(P,V,C)
+#endif
+
+#define __TBB_Store8(P,V) arch_atomic_write((P), (V))
+#define __TBB_Load8(P) *(P)
+
+#define __TBB_release_consistency_helper() __insn_mf()
+#define __TBB_rel_acq_fence() __insn_mf()
