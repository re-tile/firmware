+#include "opts.h"
 
 /* SYMBOL_REF for GOT */
 static GTY(()) rtx g_got_symbol = NULL;
@@ -93,6 +94,9 @@ tilegx_option_override (void)
      scheduler for bundling.  */
   if (flag_modulo_sched)
     flag_resched_modulo_sched = 1;
