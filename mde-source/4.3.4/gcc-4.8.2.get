+                  "   __post_inc_store(swadd, int, p, v, i) ");        \
+                                                                       \
+  builtin_define (" __post_inc_load(o, t, p, c)= "                     \
+                  " ({ long res; "                                     \
+                     " __asm__ ( #o \" %0, %1, %3\" "                  \
+                               " : \"=r\" (res), \"+r\" (p) "          \
+                               " : \"m\" (*(t *)p), \"i\" (c) ); "     \
+                     " res; }) ");                                     \
+                                                                       \
+  builtin_define (" __insn_lbadd(p, i) = "                             \
+                  "   __post_inc_load(lbadd,    char, p, i) ");        \
+  builtin_define (" __insn_lbadd_u(p, i) = "                           \
