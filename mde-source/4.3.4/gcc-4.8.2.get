+/* Return 1 if hard register REGNO can hold a value of machine-mode
+   MODE.  If mode is 16-bytes, require that REGNO is a register pair,
+   otherwise return true.  */
+bool tilegx_hard_regno_mode_ok (int regno, enum machine_mode mode)
+{
