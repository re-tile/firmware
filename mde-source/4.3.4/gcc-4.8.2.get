+LIB2FUNCS_EXCLUDE += \
+  _fixdfsi \
+  _fixsfsi \
+  _fixunssfsi \
+  _fixunsdfsi
+
+FPBIT_FUNCS := $(filter-out \
+  _addsub_sf _mul_sf _div_sf _negate_sf \
+  _eq_sf _ne_sf _le_sf _lt_sf _ge_sf _gt_sf \
+  _sf_to_di _sf_to_si _sf_to_udi _sf_do_usi \
+  _di_to_sf _si_to_sf _udi_to_sf _usi_to_sf, \
+  $(FPBIT_FUNCS))
+
+DPBIT_FUNCS := $(filter-out \
+  _addsub_df _mul_df _div_df _negate_df \
+  _eq_df _ne_df _le_df _lt_df _ge_df _gt_df \
+  _df_to_di _df_to_si _df_to_udi _df_do_usi \
+  _di_to_df _si_to_df _udi_to_df _usi_to_df, \
+  $(DPBIT_FUNCS))
+
+SOFTFLOAT_FUNCS := \
+  _estimate_div128_to_64 \
+  _float32_add \
+  _float32_div \
+  _float32_mul \
+  _float32_neg \
+  _float32_sub \
+  _float32_to_float64 \
+  _float32_to_int32_round_to_zero \
+  _float32_to_int64_round_to_zero \
+  _float32_to_uint32_round_to_zero \
+  _float32_to_uint64_round_to_zero \
+  _float64_add \
+  _float64_div \
+  _float64_mul \
+  _float64_neg \
+  _float64_sub \
+  _float64_to_float32 \
+  _float64_to_int32_round_to_zero \
+  _float64_to_int64_round_to_zero \
+  _float64_to_uint32_round_to_zero \
+  _float64_to_uint64_round_to_zero \
+  _int32_to_float32 \
+  _int32_to_float64 \
+  _int64_to_float32 \
+  _int64_to_float64 \
+  _round_and_pack_float32 \
+  _round_and_pack_float64 \
+  _uint32_to_float32 \
+  _uint32_to_float64 \
+  _uint64_to_float32 \
+  _uint64_to_float64 \
+  _float64_cmp \
+  _float64_eq \
+  _float64_ne \
+  _float64_gt \
+  _float64_ge \
+  _float64_lt \
+  _float64_le \
+  _float32_cmp \
+  _float32_eq \
+  _float32_ne \
+  _float32_gt \
+  _float32_ge \
+  _float32_lt \
+  _float32_le
+
+softfloat-o = $(patsubst %,%$(objext),$(SOFTFLOAT_FUNCS))
+$(softfloat-o): %$(objext): $(srcdir)/config/tilepro/softfloat.c
+	$(gcc_compile) -ffunction-sections -DMAYBE_STATIC= -DL$* -c $< \
+	  $(vis_hide)
+libgcc-objects += $(softfloat-o)
+
+ifeq ($(enable_shared),yes)
+softfloat-s-o = $(patsubst %,%_s$(objext),$(SOFTFLOAT_FUNCS))
+$(softfloat-s-o): %_s$(objext): $(srcdir)/config/tilepro/softfloat.c
+	$(gcc_s_compile) -ffunction-sections -DMAYBE_STATIC= -DL$* -c $<
+libgcc-s-objects += $(softfloat-s-o)
+endif
