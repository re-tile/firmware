+/* Expand a builtin 16-byte vector binary op with a shift operand.  */
+void
+tilegx_expand_builtin_vector16_op2shift (rtx (*gen16) (rtx, rtx, rtx),
+					 rtx (*gen8) (rtx, rtx, rtx),
+					 enum machine_mode dest_mode16,
+					 enum machine_mode dest_mode8,
+					 rtx dest,
+					 enum machine_mode src_mode16,
+					 enum machine_mode src_mode8,
+					 rtx src0, rtx src1)
+{
+  rtx dest_lo, dest_hi, src0_lo, src0_hi;
+  rtx shift_amt;
+
+  dest_lo = simplify_gen_subreg (dest_mode8, dest, TImode, 0);
+  dest_hi = simplify_gen_subreg (dest_mode8, dest, TImode, 8);
+  src0_lo = simplify_gen_subreg (src_mode8, src0, TImode, 0);
+  src0_hi = simplify_gen_subreg (src_mode8, src0, TImode, 8);
+
+  emit_insn (gen8 (dest_lo, src0_lo, src1));
+  emit_insn (gen8 (dest_hi, src0_hi, src1));
+}
