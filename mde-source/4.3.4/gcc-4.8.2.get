@@ -1390,6 +1390,11 @@ Returns true if the target supports deci
 Returns true if the target supports fixed-point arithmetic.
 @end deftypefn
 
+@deftypefn {Target Hook} void TARGET_PRE_UNROLLING_AND_PEELING_HOOK (void)
+This target hook performs any target specific initialization before loop
+unrolling and peeling, such as parsing unroll pragmas.
+@end deftypefn
+
 @deftypefn {Target Hook} void TARGET_EXPAND_TO_RTL_HOOK (void)
 This hook is called just before expansion into rtl, allowing the target
 to perform additional initializations or analysis before the expansion.
@@ -1399,6 +1404,33 @@ registers whenever the function being ex
 usage.
 @end deftypefn
 
+@deftypefn {Target Hook} void TARGET_POST_EXPAND_TO_RTL_HOOK (void)
+This hook is called just after expansion into rtl, allowing the target
+to perform analysis or transformation after the expansion.
+@end deftypefn
+
+@deftypefn {Target Hook} bool TARGET_GATE_HANDLE_TARGET_PEEPHOLE (void)
+This hook specifies whether to do sign extension propagation optimization.
+@end deftypefn
+
+@deftypefn {Target Hook} int TARGET_REST_OF_HANDLE_TARGET_PEEPHOLE (void)
+This hook specifies how to do sign extension propagation optimization.
+@end deftypefn
+
+@deftypefn {Target Hook} bool TARGET_GATE_HANDLE_EXTEND_PROPAGATION (void)
+This hook specifies whether to do sign extension propagation
+optimization.
+@end deftypefn
+
+@deftypefn {Target Hook} int TARGET_REST_OF_HANDLE_EXTEND_PROPAGATION (void)
+This hook specifies how to do sign extension propagation optimization.
+@end deftypefn
+
+@deftypefn {Target Hook} rtx TARGET_MOVE_BY_PIECES (rtx, @var{rtx}, unsigned @var{HOST_WIDE_INT}, unsigned @var{int}, @var{int})
+This target hook allows target-specific code generation for
+move_by_pieces, used for inlined memcpy, etc.
+@end deftypefn
+
 @deftypefn {Target Hook} void TARGET_INSTANTIATE_DECLS (void)
 This hook allows the backend to perform additional instantiations on rtl
 that are not actually in any insns yet, but will be later.
