--- /home/packages/gcc-4.8.2/gcc/common/config/tilegx/tilegx-common.c	2013-01-10 15:38:27.000000000 -0500
+++ ./gcc/common/config/tilegx/tilegx-common.c	2015-10-26 22:26:35.419015000 -0400
@@ -28,7 +28,17 @@
 #include "opts.h"
 #include "flags.h"
 
+static const char default_tilegx_data_file[] = "/tmp/gcc_data_file";
+
 static const struct default_options tilegx_option_optimization_table[] = {
+  {OPT_LEVELS_ALL, OPT_Wunmatched_loop_pragmas, NULL, 1},
+  {OPT_LEVELS_ALL, OPT_mexpand_asm, NULL, 1},
+  {OPT_LEVELS_ALL, OPT_mextend_opt, NULL, 1},
+  {OPT_LEVELS_1_PLUS_SPEED_ONLY, OPT_mhazard_opt_, NULL, 2},
+  /* Vectorization is generating bad code silently.  */
+  {OPT_LEVELS_ALL, OPT_ftree_vectorize, NULL, 0},
+  /* Scalar Reduction of Aggregates generates bad code for packed structs.  */
+  {OPT_LEVELS_ALL, OPT_fipa_sra, NULL, 0},
   {OPT_LEVELS_1_PLUS, OPT_fomit_frame_pointer, NULL, 1},
   /* Scheduling and bundling are super important for our architecture, so
      enable them at -O1. */
@@ -42,9 +52,15 @@ static void
 tilegx_option_init_struct (struct gcc_options *opts)
 {
   opts->x_flag_asynchronous_unwind_tables = 1;
+  opts->x_tilegx_data_file = default_tilegx_data_file;
 }
 
 
+#undef  TARGET_DEFAULT_TARGET_FLAGS
+#define TARGET_DEFAULT_TARGET_FLAGS \
+  (TARGET_DEFAULT		    \
+   | TARGET_ENDIAN_DEFAULT)
+
 #undef  TARGET_OPTION_OPTIMIZATION_TABLE
 #define TARGET_OPTION_OPTIMIZATION_TABLE tilegx_option_optimization_table
 
