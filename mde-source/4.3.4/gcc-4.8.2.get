+
+   GCC is distributed in the hope that it will be useful, but WITHOUT
+   ANY WARRANTY; without even the implied warranty of MERCHANTABILITY
+   or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU General Public
+   License for more details.
+
+   You should have received a copy of the GNU General Public License
+   along with GCC; see the file COPYING3.  If not see
+   <http://www.gnu.org/licenses/>.  */
+
+/* Functions to support scheduling of network register operations.  */
+
+
+/* Return the ordering register corresponding to the port.  */
+static int
+get_ordering_reg (int unspec_num, rtx netreg)
+{
+  int netreg_num;
+  gcc_assert (CONST_INT_P (netreg));
+  netreg_num = INTVAL (netreg);
+
+  if (unspec_num == UNSPEC_NETWORK_RECEIVE)
+    {
+      switch (netreg_num)
+	{
+	case TILEPRO_NETREG_IDN0:
+	  return TILEPRO_NETORDER_IDN0_RECEIVE_REGNUM;
+	case TILEPRO_NETREG_IDN1:
+	  return TILEPRO_NETORDER_IDN1_RECEIVE_REGNUM;
+	case TILEPRO_NETREG_SN:
+	  return TILEPRO_NETORDER_SN_RECEIVE_REGNUM;
+	case TILEPRO_NETREG_UDN0:
+	  return TILEPRO_NETORDER_UDN0_RECEIVE_REGNUM;
+	case TILEPRO_NETREG_UDN1:
+	  return TILEPRO_NETORDER_UDN1_RECEIVE_REGNUM;
+	case TILEPRO_NETREG_UDN2:
+	  return TILEPRO_NETORDER_UDN2_RECEIVE_REGNUM;
+	case TILEPRO_NETREG_UDN3:
+	  return TILEPRO_NETORDER_UDN3_RECEIVE_REGNUM;
+	}
+    }
+  else				/* UNSPEC_NETWORK_SEND */
+    {
+      switch (netreg_num)
+	{
+	case TILEPRO_NETREG_IDN0:
+	  return TILEPRO_NETORDER_IDN0_SEND_REGNUM;
+	case TILEPRO_NETREG_SN:
+	  return TILEPRO_NETORDER_SN_SEND_REGNUM;
+	case TILEPRO_NETREG_UDN0:
+	  return TILEPRO_NETORDER_UDN0_SEND_REGNUM;
+	}
+    }
+
+  return 0;
+}
+
+
+/* Specialize or generalize the ordering operand, depending on the
+   input pattern.  If the input pattern contains
+   TILEPRO_NETORDER_REGNUM, then specialize it.  If it contains a port
+   specific ordering reg, then generalize it to
+   TILEPRO_NETORDER_REGNUM.  Changes are made in two places: in the
+   ordering operand inside the unspec, and in the corresponding
+   clobber expression.  */
+static void
+replace_ordering_operands (rtx pattern, rtx last_parallel)
+{
+  int opnd;
+  int i;
+  int ordering_reg;
+  int from_reg;
+  int to_reg;
+  enum machine_mode mode;
+  rtx temp;
+
+  if (XINT (pattern, 1) == UNSPEC_NETWORK_RECEIVE)
+    opnd = 1;
+  else				/* UNSPEC_NETWORK_SEND */
+    opnd = 2;
+
+  ordering_reg =
+    get_ordering_reg (XINT (pattern, 1), XVECEXP (pattern, 0, 0));
+
+  from_reg = REGNO (XVECEXP (pattern, 0, opnd));
+
+  if (from_reg == TILEPRO_NETORDER_REGNUM)
+    {
+      to_reg = ordering_reg;
+    }
+  else
+    {
+      gcc_assert (from_reg == ordering_reg);
+      to_reg = TILEPRO_NETORDER_REGNUM;
+    }
+
+  mode = GET_MODE (XVECEXP (pattern, 0, opnd));
+  temp = gen_rtx_REG (mode, to_reg);
+
+  XVECEXP (pattern, 0, opnd) = temp;
+
+  for (i = 0; i < XVECLEN (last_parallel, 0); i++)
+    {
+      rtx expr = XVECEXP (last_parallel, 0, i);
+
+      if (GET_CODE (expr) == CLOBBER
+	  && REG_P (XEXP (expr, 0))
+	  && REGNO (XEXP (expr, 0)) == (unsigned) from_reg)
+	{
+	  /* gcc defines a single clobber expression for each register
+	     and reuses them, and it can be accessed via
+	     gen_hard_reg_clobber ().  */
+	  XVECEXP (last_parallel, 0, i) = gen_hard_reg_clobber (mode, to_reg);
+	  break;
+	}
+    }
+
+  /* check that we've found a corresponding clobber expression.  */
+  gcc_assert (i < XVECLEN (last_parallel, 0));
+}
+
+
+/* This routine is used to modify the network instructions before
+   scheduling so that they can be bundled, and also to reverse the
+   transformation after scheduling.  Two changes are made:
+
+   1. Replace the rtx_code FROM with TO.  Before scheduling, we're
+      replacing UNSPEC_VOLATILE with UNSPEC.  After scheduling, we're
+      replacing UNSPEC with UNSPEC_VOLATILE.
+
+   2. Specialize the ordering operands before scheduling, from the
+      generic TILEPRO_NETORDER_REGNUM to a per-port ordering register.
+      Also reverse this transformation after scheduling.
+
+   For debug_insn, we only do item 1.  */
+static void
+replace_network_unspec (rtx pattern, rtx last_parallel, RTX_CODE from,
+			RTX_CODE to, bool is_debug_insn)
+{
+  const char *fmt;
+  int i, j;
+
+  /* As we recurse, keep track of the last parallel construct as
+     that's where we expect to find the clobber expressions
+     corresponding to the nework operation.  */
+  if (GET_CODE (pattern) == PARALLEL)
+    last_parallel = pattern;
+
+  if (GET_CODE (pattern) == from)
+    {
+      /* We've found a network operation.  Do the transformation.  */
+      if (XINT (pattern, 1) == UNSPEC_NETWORK_RECEIVE
+	  || XINT (pattern, 1) == UNSPEC_NETWORK_SEND)
+	{
+	  PUT_CODE (pattern, to);
+	  if (!is_debug_insn)
+	    replace_ordering_operands (pattern, last_parallel);
+	}
+    }
+
+  fmt = GET_RTX_FORMAT (GET_CODE (pattern));
+  for (i = 0; i < GET_RTX_LENGTH (GET_CODE (pattern)); i++)
+    {
+      if (fmt[i] == 'e')
+	{
+	  replace_network_unspec (XEXP (pattern, i), last_parallel, from, to,
+				  is_debug_insn);
+	}
+      else if (fmt[i] == 'E')
+	{
+	  for (j = 0; j < XVECLEN (pattern, i); j++)
+	    {
+	      replace_network_unspec (XVECEXP (pattern, i, j), last_parallel,
+				      from, to, is_debug_insn);
+	    }
+	}
+    }
+}
+
+
+/* Implement TARGET_SCHED_INIT_GLOBAL.  */
+static void
+tilepro_sched_init_global (FILE *dump ATTRIBUTE_UNUSED,
+			   int sched_verbose ATTRIBUTE_UNUSED,
+			   int max_ready ATTRIBUTE_UNUSED)
+{
+  basic_block bb;
+  FOR_EACH_BB (bb)
+    {
+      rtx insn, next;
+
+      FOR_BB_INSNS_SAFE (bb, insn, next)
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  /* We need to delete any loop pragmas before we schedule,
+	     because any bundle markers on them will be lost.  */
+	  if (recog_memoized (insn) == CODE_FOR_tilepro_pragma_unroll
+	      || recog_memoized (insn) == CODE_FOR_tilepro_pragma_must_iterate)
+	    {
+	      delete_insn (insn);
+	    }
+	  else
+	    {
+	      /* Modify the instructions that touch the network so
+		 they can be bundled.  */
+	      replace_network_unspec (PATTERN (insn), NULL, UNSPEC_VOLATILE,
+				      UNSPEC, DEBUG_INSN_P (insn));
+	    }
+	}
+    }
+}
+
+
+/* Implement TARGET_SCHED_FINISH_GLOBAL.  */
+static void
+tilepro_sched_finish_global (FILE *dump ATTRIBUTE_UNUSED,
+			     int sched_verbose ATTRIBUTE_UNUSED)
+{
+  basic_block bb;
+  FOR_EACH_BB (bb)
+    {
+      rtx insn;
+
+      FOR_BB_INSNS (bb, insn)
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  /* Change accesses to the network back to the form before
+	     scheduling.  */
+	  replace_network_unspec (PATTERN (insn), NULL, UNSPEC,
+				  UNSPEC_VOLATILE, DEBUG_INSN_P (insn));
+	}
+    }
+}
+
+
+
+/* Loop pragmas support.  */
+
+
+/* Keep track of whether a function has emitted a header for pragma
+   warnings.  */
+static bool emitted_pragma_warning_header;
+
+
+static void
+emit_pragma_warning_header (const char *file)
+{
+  if (!emitted_pragma_warning_header)
+    {
+      fprintf (stderr, "%s: In function '%s':\n", file,
+	       current_function_name ());
+
+      emitted_pragma_warning_header = true;
+    }
+}
+
+
+/* Emit warning for loop pragmas that do not have corresponding loops.  */
+static void
+warn_unmatched_loop_pragma (rtx insn, VEC(int, heap) *warned_locations)
+{
+  size_t i;
+  int loc;
+  const char *file;
+  int line;
+
+  if (!TARGET_WARN_UNMATCHED_LOOP_PRAGMAS)
+    return;
+
+  loc = INSN_LOCATOR (insn);
+
+  file = locator_file (loc);
+  line = locator_line (loc);
+
+  /* Check to see if we've warned about this pragma already.  This is
+     N^2, but we don't expect many pragmas.  */
+  for (i = 0; i < VEC_length (int, warned_locations); i++)
+    {
+      int warned_loc = VEC_index (int, warned_locations, i);
+      if (strcmp (file, locator_file (warned_loc)) == 0
+	  && line == locator_line (warned_loc))
+	return;
+    }
+
+  emit_pragma_warning_header (file);
+
+  fprintf (stderr, "%s:%d: warning: loop pragma without matching loop\n",
+	   file, line);
+
+  VEC_quick_push (int, warned_locations, loc);
+}
+
+
+/* Requires that unroll_pragma is an unroll pragma; returns the unroll
+   factor. */
+static unsigned
+get_unroll_factor (rtx unroll_pragma)
+{
+  rtx pattern;
+  rtx constant;
+
+  pattern = PATTERN (unroll_pragma);
+  constant = XVECEXP (pattern, 0, 0);
+  return (unsigned) XINT (constant, 0);
+}
+
+
+/* For each inner loop, pick an instruction in it and insert it into
+   the INSNS.  Returns the vector of instructions.  */
+static
+VEC(rtx, gc) *
+get_inner_loop_insns (VEC(rtx, gc) *insns)
+{
+  struct loop *loop;
+  loop_iterator li;
+  FOR_EACH_LOOP (li, loop, LI_ONLY_INNERMOST)
+    {
+      basic_block header = loop->header;
+      bool found = false;
+      rtx insn;
+
+      FOR_BB_INSNS (header, insn)
+	{
+	  if (NONDEBUG_INSN_P (insn))
+	    {
+	      found = true;
+	      break;
+	    }
+	}
+
+      /* If header has no instruction, ignore loop for now.  FIXME: should look
+	 in other blocks in loop.  */
+      if (found)
+	VEC_safe_push (rtx, gc, insns, insn);
+    }
+
+  return insns;
+}
+
+
+/* Find all the unroll pragmas in the function and insert them into
+   the INSNS.  Returns the vector of pragmas.  */
+static
+VEC(rtx, gc) *
+get_loop_pragmas (VEC(rtx, gc) *insns, enum insn_code code)
+{
+  basic_block bb;
+
+  FOR_EACH_BB (bb)
+    {
+      rtx insn;
+
+      FOR_BB_INSNS (bb, insn)
+	{
+	  if (NONDEBUG_INSN_P (insn) && recog_memoized (insn) == (int) code)
+	    VEC_safe_push (rtx, gc, insns, insn);
+	}
+    }
+
+  return insns;
+}
+
+
+/* Sort function that orders higher line numbers first. */
+static int
+insn_location_compare (const void *b, const void *a)
+{
+  const rtx insn_a = *((const rtx *) a);
+  const rtx insn_b = *((const rtx *) b);
+
+  int loc_a = INSN_LOCATOR (insn_a);
+  int loc_b = INSN_LOCATOR (insn_b);
+
+  const char *file_a = locator_file (loc_a);
+  const char *file_b = locator_file (loc_b);
+
+  int line_a = insn_line (insn_a);
+  int line_b = insn_line (insn_b);
+
+  int file_compare;
+
+  int loop_depth_a;
+  int loop_depth_b;
+
+  if (loc_a == 0)
+    if (loc_b == 0)
+      return 0;
+    else
+      return -1;
+  else if (loc_b == 0)
+    return 1;
+
+  file_compare = strcmp (file_a, file_b);
+
+  if (file_compare != 0)
+    return file_compare;
+
+  if (line_a < line_b)
+    return -1;
+  else if (line_a > line_b)
+    return 1;
+
+  loop_depth_a = BLOCK_FOR_INSN (insn_a)->loop_depth;
+  loop_depth_b = BLOCK_FOR_INSN (insn_b)->loop_depth;
+
+  if (loop_depth_a < loop_depth_b)
+    return -1;
+  else if (loop_depth_a > loop_depth_b)
+    return 1;
+
+  return 0;
+}
+
+
+static void
+update_desc_for_unroll_pragma (struct niter_desc *desc, rtx pragma)
+{
+  unsigned unroll_factor = get_unroll_factor (pragma);
+
+  /* If unroll factor is 0, it really means "don't unroll" which is
+     the same as setting unroll factor to 1.  */
+  if (unroll_factor == 0)
+    unroll_factor = 1;
+
+  desc->pragma_unroll_factor = unroll_factor;
+}
+
+
+static void
+update_desc_for_must_iterate_pragma (struct niter_desc *desc, rtx pragma)
+{
+  rtx pattern = PATTERN (pragma);
+  unsigned HOST_WIDE_INT pragma_niter_min = XINT (XVECEXP (pattern, 0, 0), 0);
+  unsigned HOST_WIDE_INT pragma_niter_max = XINT (XVECEXP (pattern, 0, 1), 0);
+  unsigned HOST_WIDE_INT pragma_niter_multiple =
+    XINT (XVECEXP (pattern, 0, 2), 0);
+
+  desc->has_must_iterate_pragma = true;
+  desc->pragma_niter_min = pragma_niter_min;
+  desc->pragma_niter_max = pragma_niter_max;
+  desc->pragma_niter_multiple = pragma_niter_multiple;
+
+  /* FIXME: don't really understand desc->noloop_assumptions and how to
+     initialize it.  */
+
+  if (pragma_niter_max != (unsigned HOST_WIDE_INT) -1)
+    {
+      desc->niter_max = pragma_niter_max - 1;
+      desc->infinite = NULL_RTX;
+    }
+
+  if (pragma_niter_min == pragma_niter_max)
+    {
+      if (desc->const_iter && (desc->niter != pragma_niter_min - 1))
+	{
+	  const char *file = insn_file (pragma);
+	  int line = insn_line (pragma);
+	  emit_pragma_warning_header (file);
+
+	  fprintf (stderr,
+		   "%s:%d: warning: must_iterate iteration count (%lld) "
+		   "is inconsistent with actual iteration count (%lld).\n",
+		   file, line, pragma_niter_min, desc->niter + 1);
+	}
+
+      desc->pragma_niter_multiple = pragma_niter_min;
+
+      /* We can set the constant iteration info based on pragmas, but don't
+         bother since it doesn't lead to more optimizations at the moment.  */
+    }
+}
+
+
+static void
+match_pragmas_with_loops (VEC(rtx, gc) *loop_insns, VEC(rtx, gc) *pragmas,
+			  void (*update_desc) (struct niter_desc *, rtx))
+{
+  VEC(int, heap) *warned_locations;
+  size_t li;
+  size_t ui;
+
+  warned_locations = VEC_alloc (int, heap, VEC_length (rtx, pragmas));
+
+  qsort (VEC_address (rtx, loop_insns), VEC_length (rtx, loop_insns),
+	 sizeof (rtx), insn_location_compare);
+
+  qsort (VEC_address (rtx, pragmas), VEC_length (rtx, pragmas),
+	 sizeof (rtx), insn_location_compare);
+
+  li = 0;
+  ui = 0;
+
+  while (ui < VEC_length (rtx, pragmas))
+    {
+      rtx pragma = VEC_index (rtx, pragmas, ui++);
+      size_t start_li = li;
+
+      /* Find the nearest loop_insn following the pragma.  */
+      rtx nearest_loop_insn = NULL;
+      for (; li < VEC_length (rtx, loop_insns); li++)
+	{
+	  rtx loop_insn = VEC_index (rtx, loop_insns, li);
+
+	  int cmp = insn_location_compare (&pragma, &loop_insn);
+
+	  /* pragma precedes loop_insn ==> possible match.  */
+	  if (cmp == 1)
+	    nearest_loop_insn = loop_insn;
+	  else
+	    break;
+	}
+
+      if (nearest_loop_insn != NULL)
+	{
+	  const char *file_loop = insn_file (nearest_loop_insn);
+	  const char *file_pragma = insn_file (pragma);
+
+	  if (dump_file)
+	    {
+	      fprintf (dump_file,
+		       ";; Matching loop pragma %s:%d with loop %s:%d\n",
+		       file_pragma, insn_line (pragma),
+		       file_loop, insn_line (nearest_loop_insn));
+	    }
+
+	  /* Sanity checks  */
+
+	  /* The pragma should be in the same file, and at a lower loop
+	     depth.  */
+	  if (strcmp (file_loop, file_pragma) != 0
+	      || (BLOCK_FOR_INSN (nearest_loop_insn)->loop_depth
+		  <= BLOCK_FOR_INSN (pragma)->loop_depth))
+	    {
+	      warn_unmatched_loop_pragma (pragma, warned_locations);
+	      li = start_li;
+	    }
+	  else
+	    {
+	      struct loop *loop =
+		BLOCK_FOR_INSN (nearest_loop_insn)->loop_father;
+	      struct niter_desc *desc = get_simple_loop_desc (loop);
+
+	      update_desc (desc, pragma);
+
+	      /* Handle cases where we have multiple copies of the pragma/loop
+	         due to cloning or inlining.  These pragmas/loops will have the
+	         same line numbers, and we need to rewind li to so that we're
+	         matching one such loop at a time.  */
+	      for (; li - 1 > start_li; li--)
+		{
+		  const rtx loop_insn1 = VEC_index (rtx, loop_insns, li - 2);
+		  const rtx loop_insn2 = VEC_index (rtx, loop_insns, li - 1);
+		  int cmp = insn_location_compare (&loop_insn1, &loop_insn2);
+		  if (cmp != 0)
+		    break;
+		}
+	    }
+	}
+      else
+	warn_unmatched_loop_pragma (pragma, warned_locations);
+    }
+
+  VEC_free (int, heap, warned_locations);
+}
+
+
+static void
+delete_insns (VEC(rtx, gc) *insns)
+{
+  size_t i;
+  for (i = 0; i < VEC_length (rtx, insns); i++)
+    delete_insn (VEC_index (rtx, insns, i));
+}
+
+
+static void
+parse_loop_pragmas (void)
+{
+  VEC(rtx, gc) *unroll_pragmas;
+  VEC(rtx, gc) *must_iterate_pragmas;
+  VEC(rtx, gc) *loop_insns;
+
+  emitted_pragma_warning_header = false;
+
+  unroll_pragmas = VEC_alloc (rtx, gc, number_of_loops ());
+  unroll_pragmas =
+    get_loop_pragmas (unroll_pragmas, CODE_FOR_tilepro_pragma_unroll);
+
+  must_iterate_pragmas = VEC_alloc (rtx, gc, number_of_loops ());
+  must_iterate_pragmas =
+    get_loop_pragmas (must_iterate_pragmas,
+		      CODE_FOR_tilepro_pragma_must_iterate);
+
+  if (VEC_length (rtx, unroll_pragmas) == 0
+      && VEC_length (rtx, must_iterate_pragmas) == 0)
+    return;
+
+  loop_insns = VEC_alloc (rtx, gc, number_of_loops ());
+  loop_insns = get_inner_loop_insns (loop_insns);
+
+  if (VEC_length (rtx, unroll_pragmas))
+    {
+      match_pragmas_with_loops (loop_insns, unroll_pragmas,
+				update_desc_for_unroll_pragma);
+
+      delete_insns (unroll_pragmas);
+    }
+
+  if (VEC_length (rtx, must_iterate_pragmas))
+    {
+      match_pragmas_with_loops (loop_insns, must_iterate_pragmas,
+				update_desc_for_must_iterate_pragma);
+
+      delete_insns (must_iterate_pragmas);
+    }
+}
+
+
+static void
+tilepro_pre_unrolling_and_peeling_hook (void)
+{
+  parse_loop_pragmas ();
+}
+
+
+
+/* Fix up issue with asm("" : "+rm" (x)) constructs used in the linux kernel
+   where x is of size DI.  An example rtl is:
+
+   (set (mem:DI (reg:SI 87))
+        (asm_operands:DI ("") ("=rm") 0
+        [ (reg:DI 83) ]
+        [ (asm_input:DI ("0") 0) ]))
+
+   The asm requires the input and output operands to be either both memory or
+   both register, but gcc may not enforce that until after register
+   allocation, at which point it might try to do a 64 bit memory operation and
+   we don't have the scratch register we need to generate the plus 4 address
+   for the store.  This code checks for the failing case and patches it.
+*/
+static void
+tilepro_asm_fixup (rtx insn)
+{
+  rtx pattern;
+  rtx src, dest;
+  rtx temp, copy;
+
+  pattern = PATTERN (insn);
+
+  if (!(GET_CODE (pattern) == SET
+	&& GET_CODE (SET_SRC (pattern)) == ASM_OPERANDS))
+    return;
+
+  src = SET_SRC (pattern);
+  dest = SET_DEST (pattern);
+
+  if (!(GET_MODE (src) == DImode
+	&& !strcmp (ASM_OPERANDS_OUTPUT_CONSTRAINT (src), "=rm")
+	&& MEM_P (dest)
+	&& !strcmp (ASM_OPERANDS_INPUT_CONSTRAINT (src, 0), "0")
+	&& REG_P (ASM_OPERANDS_INPUT (src, 0))))
+    return;
+
+  temp = gen_reg_rtx (DImode);
+
+  SET_DEST (pattern) = temp;
+
+  start_sequence ();
+  emit_move_insn (dest, temp);
+  copy = get_insns ();
+  end_sequence ();
+
+  emit_insn_after (copy, insn);
+}
+
+
+
+/* Parsing of post-incrementing load/store intrinsics.  */
+
+
+typedef struct asm_descriptor
+{
+  const char *string;
+  const insn_gen_fn fn;
+  const enum machine_mode mode;
+} asm_descriptor;
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns whether
+   their template strings match STR.  */
+static bool
+match_asm_string (rtx pattern1, rtx pattern2, const char *str)
+{
+  return strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern1)), str) == 0
+    && strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern2)), str) == 0;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns an
+   asm_dsecriptor in DESC with a matching template string, or NULL if no match
+   is found.  */
+static const asm_descriptor *
+match_asm_descriptor (rtx pattern1, rtx pattern2, const asm_descriptor *desc)
+{
+  int i;
+
+  for (i = 0; desc[i].string != NULL; i++)
+    {
+      if (match_asm_string (pattern1, pattern2, desc[i].string))
+	return &desc[i];
+    }
+
+  return NULL;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns a
+   store-add asm_descriptor that matches that of the two patterns, or NULL if
+   no match is found.  */
+static const asm_descriptor *
+match_storeadd (rtx pattern1, rtx pattern2)
+{
+#define ARGS " %0, %2, %3"
+  static const asm_descriptor descriptor[] = {
+    {"sbadd" ARGS, (insn_gen_fn) gen_insn_sbadd, QImode},
+    {"shadd" ARGS, (insn_gen_fn) gen_insn_shadd, HImode},
+    {"swadd" ARGS, (insn_gen_fn) gen_insn_swadd, SImode},
+    {NULL, NULL, VOIDmode},
+  };
+#undef ARGS
+
+  return match_asm_descriptor (pattern1, pattern2, descriptor);
+}
+
+
+/* PATTERN is a SET statement of ASM_OPERANDS.  Returns whether the PATTERN
+   satisfies the following:
+
+   dest idx is DEST_IDX;
+   dest constraint is DEST_CONSTRAINT;
+   dest mode is DEST_MODE;
+   has NUM_SRCS number of source operands;
+   its source operands satisfy CONSTRANTS and MODES.  */
+static bool
+asm_sanity_check (rtx pattern, int dest_idx,
+		  const char *dest_constraint,
+		  const enum machine_mode dest_mode,
+		  int num_srcs, const char *src_constraints[],
+		  const enum machine_mode src_modes[])
+{
+  int i;
+
+  if (strcmp (ASM_OPERANDS_OUTPUT_CONSTRAINT (SET_SRC (pattern)),
+	      dest_constraint) != 0)
+    return false;
+
+  if (GET_MODE (SET_SRC (pattern)) != dest_mode)
+    return false;
+
+  if (ASM_OPERANDS_OUTPUT_IDX (SET_SRC (pattern)) != dest_idx)
+    return false;
+
+  if (ASM_OPERANDS_INPUT_LENGTH (SET_SRC (pattern)) != num_srcs)
+    return false;
+
+  for (i = 0; i < num_srcs; i++)
+    {
+      rtx constraint_exp =
+	ASM_OPERANDS_INPUT_CONSTRAINT_EXP (SET_SRC (pattern), i);
+
+      if (GET_CODE (constraint_exp) != ASM_INPUT)
+	return false;
+
+      if (GET_MODE (constraint_exp) != src_modes[i])
+	return false;
+
+      if (strcmp (ASM_OPERANDS_INPUT_CONSTRAINT (SET_SRC (pattern), i),
+		  src_constraints[i]) != 0)
+	return false;
+    }
+
+  return true;
+}
+
+
+/* Check whether the store add patterns conform to what we expect.  */
+static bool
+sanity_check_storeadd_operands (rtx pattern1, rtx pattern2,
+				enum machine_mode mem_mode)
+{
+  static const char *src_constraints[] = { "r", "i", "0" };
+  enum machine_mode src_modes[] =
+  { word_mode, SImode, SImode };
+
+  return asm_sanity_check (pattern1, 0, "=r", SImode,
+			   3, src_constraints, src_modes)
+    && asm_sanity_check (pattern2, 1, "=m", mem_mode,
+			 3, src_constraints, src_modes);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("swadd %0, %2, %3") ("=r") 0
+               [ SRC0 SRC1 SRC2 ]
+               [ (asm_input:MODE ("r") 0)
+                 (asm_input:SI ("i") 0)
+                 (asm_input:SI ("0") 0) ]))
+
+  FN is the cprresponding store-add generating function.  Create and return the
+  corresponding store-add rtl.
+*/
+static rtx
+gen_storeadd (rtx pattern, insn_gen_fn fn,
+	      enum machine_mode mode ATTRIBUTE_UNUSED)
+{
+  rtx dest = SET_DEST (pattern);
+  rtx src0 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 0);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 1);
+  rtx src2 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 2);
+  rtx res = fn (dest, src0, src1, src2);
+
+  /* return the pattern, not the insn containing it.  */
+  if (INSN_P (res))
+    return PATTERN (res);
+  else
+    return res;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns a
+   load-add whose template string matches that of the two patterns, or NULL if
+   no match is found.  */
+static const asm_descriptor *
+match_loadadd (rtx pattern1, rtx pattern2)
+{
+#define ARGS " %0, %1, %3"
+  static const asm_descriptor descriptor[] = {
+    {"lbadd" ARGS, (insn_gen_fn) gen_insn_lbadd, QImode},
+    {"lbadd_u" ARGS, (insn_gen_fn) gen_insn_lbadd_u, QImode},
+    {"lhadd" ARGS, (insn_gen_fn) gen_insn_lhadd, HImode},
+    {"lhadd_u" ARGS, (insn_gen_fn) gen_insn_lhadd_u, HImode},
+    {"lwadd" ARGS, (insn_gen_fn) gen_insn_lwadd, SImode},
+    {"lwadd_na" ARGS, (insn_gen_fn) gen_insn_lwadd_na, SImode},
+
+    {"lbadd_L2" ARGS, (insn_gen_fn) gen_insn_lbadd_L2, QImode},
+    {"lbadd_u_L2" ARGS, (insn_gen_fn) gen_insn_lbadd_u_L2, QImode},
+    {"lhadd_L2" ARGS, (insn_gen_fn) gen_insn_lhadd_L2, HImode},
+    {"lhadd_u_L2" ARGS, (insn_gen_fn) gen_insn_lhadd_u_L2, HImode},
+    {"lwadd_L2" ARGS, (insn_gen_fn) gen_insn_lwadd_L2, SImode},
+    {"lwadd_na_L2" ARGS, (insn_gen_fn) gen_insn_lwadd_na_L2, SImode},
+
+    {"lbadd_miss" ARGS, (insn_gen_fn) gen_insn_lbadd_miss, QImode},
+    {"lbadd_u_miss" ARGS, (insn_gen_fn) gen_insn_lbadd_u_miss, QImode},
+    {"lhadd_miss" ARGS, (insn_gen_fn) gen_insn_lhadd_miss, HImode},
+    {"lhadd_u_miss" ARGS, (insn_gen_fn) gen_insn_lhadd_u_miss, HImode},
+    {"lwadd_miss" ARGS, (insn_gen_fn) gen_insn_lwadd_miss, SImode},
+    {"lwadd_na_miss" ARGS, (insn_gen_fn) gen_insn_lwadd_na_miss, SImode},
+
+    {NULL, NULL, VOIDmode},
+  };
+#undef ARGS
+
+  return match_asm_descriptor (pattern1, pattern2, descriptor);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("lwadd %0, %1, %3") ("=r") 0
+               [ SRC0 SRC1 SRC2 ]
+               [ (asm_input:MODE ("m") 0)
+                 (asm_input:SI ("i") 0)
+                 (asm_input:SI ("1") 0) ]))
+
+  FN is the cprresponding store-add generating function.  Create and return the
+  corresponding load-add rtl.
+*/
+static rtx
+gen_loadadd (rtx pattern1, rtx pattern2, insn_gen_fn fn,
+	     enum machine_mode mode ATTRIBUTE_UNUSED)
+{
+  rtx dest0 = SET_DEST (pattern1);
+  rtx dest1 = SET_DEST (pattern2);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern1), 1);
+  rtx src2 = ASM_OPERANDS_INPUT (SET_SRC (pattern1), 2);
+
+  return fn (dest0, dest1, src1, src2);
+}
+
+
+/* Check whether the store add patterns conform to what we expect.  */
+static bool
+sanity_check_loadadd_operands (rtx pattern1, rtx pattern2,
+			       enum machine_mode mem_mode)
+{
+  static const char *src_constraints[] = { "m", "i", "1" };
+  enum machine_mode src_modes[] =
+  { mem_mode, SImode, SImode };
+
+  return asm_sanity_check (pattern1, 0, "=r", SImode,
+			   3, src_constraints, src_modes)
+    && asm_sanity_check (pattern2, 1, "=r", SImode,
+			 3, src_constraints, src_modes);
+}
+
+
+/* Do post processing after rtl expansion.  */
+static void
+tilepro_post_expand_to_rtl_hook (void)
+{
+  rtx insn, last;
+  basic_block bb;
+
+  if (!TARGET_EXPAND_ASM)
+    return;
+
+  FOR_EACH_BB (bb)
+    {
+      for (insn = BB_HEAD (bb), last = NEXT_INSN (BB_END (bb));
+	   insn != last; insn = NEXT_INSN (insn))
+	{
+	  rtx pattern;
+	  rtx pattern1;
+	  rtx pattern2;
+	  const asm_descriptor *desc;
+
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  tilepro_asm_fixup (insn);
+
+	  /* Look for specific inline assembly patterns and replace them with
+	     rtl that the compiler can understand, optimize, schedule, and
+	     bundle.  We use this to implement post-inc load/store
+	     intrinsics.  */
+	  pattern = PATTERN (insn);
+
+	  if (!(GET_CODE (pattern) == PARALLEL && XVECLEN (pattern, 0) == 2))
+	    continue;
+
+	  pattern1 = XVECEXP (pattern, 0, 0);
+	  pattern2 = XVECEXP (pattern, 0, 1);
+
+	  if (!(GET_CODE (pattern1) == SET
+		&& GET_CODE (pattern2) == SET
+		&& GET_CODE (SET_SRC (pattern1)) == ASM_OPERANDS
+		&& GET_CODE (SET_SRC (pattern2)) == ASM_OPERANDS))
+	    continue;
+
+	  if ((desc = match_storeadd (pattern1, pattern2)))
+	    {
+	      if (sanity_check_storeadd_operands (pattern1, pattern2,
+						  desc->mode))
+		{
+		  PATTERN (insn) =
+		    gen_storeadd (pattern1, desc->fn, desc->mode);
+		}
+	      else
+		{
+		  location_t loc =
+		    ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern1));
+		  warning_at (loc, 0, "Unrecognized store-add asm pattern");
+		}
+
+	    }
+	  else if ((desc = match_loadadd (pattern1, pattern2)))
+	    {
+	      if (sanity_check_loadadd_operands (pattern1, pattern2,
+						 desc->mode))
+		{
+		  PATTERN (insn) =
+		    gen_loadadd (pattern1, pattern2, desc->fn, desc->mode);
+		}
+	      else
+		{
+		  location_t loc =
+		    ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern1));
+		  warning_at (loc, 0, "Unrecognized load-add asm pattern");
+		}
+	    }
+	}
+    }
+}
+
+
+
+/* Unnecessary zero/sign extension optimization.  */
+
+
+enum reg_extend_state
+{
+  REG_EXTEND_INVALID,
+  REG_EXTEND_TRUNCATE,
+  REG_EXTEND_ZERO_EXTENDED,
+  REG_EXTEND_SIGN_EXTENDED,
+  REG_EXTEND_ASHIFTHI,
+  REG_EXTEND_ASHIFTQI,
+  REG_EXTEND_ASHIFTRTHI,
+  REG_EXTEND_ASHIFTRTQI
+};
+
+
+/* A reg_extend_info describes two operands that are related through some
+   extension related operations.  REG_RTX is the result rtx; REG_NUM is the
+   corresponding register number; and SRC_REG_RTX is the source rtx.  TO_MODE
+   is the mode of REG_RTX.  FROM_MODE is the mode of the source of the
+   truncation or sign extension.
+
+   If STATE is either REG_EXTEND_ZERO_EXTENDED or REG_EXTEND_SIGN_EXTENDED,
+   then REG_RTX and SRC_REG_RTX should have the same modes, and REG_RTX is
+   extended version of SRC_REG_RTX.  If STATE is REG_EXTEND_ASHIFT**, then
+   REG_RTX and SRC_REG_RTX should have the same modes, and REG_RTX is the
+   corresponding shoft operation performed on SRC_REG_RTX.  If STATE is
+   REG_EXTEND_TRUNCATE, then SRC_REG_RTX should have FROM_MODE, and REG_RTX is
+   the truncation of SRC_REG_RTX.
+
+   Example instructions from which reg_extend_info can be extracted:
+
+   (set (reg:SI 97) (truncate:SI (reg:DI 82)))
+   (set (reg:DI 98) (sign/zero_extend:DI (reg:SI 97)))
+
+   (set (reg:DI 94) (sign/zero_extend:DI (subreg/s:SI (reg:DI 84) 0)))
+*/
+typedef struct reg_extend_info
+{
+  int reg_num;
+  rtx reg_rtx;
+  rtx src_reg_rtx;
+  enum reg_extend_state state;
+  enum machine_mode from_mode;
+  enum machine_mode to_mode;
+} reg_extend_info;
+
+
+/* Returns the hash value of a pointer to a reg_extend_info.  */
+static hashval_t
+htab_rei_hash (const void *p)
+{
+  const reg_extend_info *const rei = (const reg_extend_info *) p;
+
+  return (hashval_t) rei->reg_num;
+}
+
+
+/* Equality function for reg_extend_info *.  */
+static int
+htab_rei_eq (const void *p1, const void *p2)
+{
+  const reg_extend_info *const rei1 = (const reg_extend_info *) p1;
+  const reg_extend_info *const rei2 = (const reg_extend_info *) p2;
+
+  return rei1->reg_num == rei2->reg_num;
+}
+
+
+/* Hash entry delete function for reg_extend_info *.  */
+static void
+htab_rei_del (void *p)
+{
+  reg_extend_info *const rei = (reg_extend_info *) p;
+  free (rei);
+}
+
+
+/* INSN is the outer most insn containing SET_INSN.  Returns the mode
+   corresponding to the number of low order bits in the register result of the
+   INSN that are actually used.  */
+static enum machine_mode
+get_result_used_mode (rtx insn, rtx set_insn)
+{
+  enum machine_mode max_used_mode;
+  enum machine_mode result_mode;
+  struct df_insn_info *insn_info;
+  df_ref *def_rec;
+
+  max_used_mode = VOIDmode;
+  result_mode = GET_MODE (SET_DEST (set_insn));
+
+  insn_info = DF_INSN_INFO_GET (insn);
+  def_rec = DF_INSN_INFO_DEFS (insn_info);
+
+  while (*def_rec)
+    {
+      df_ref def_ref = *def_rec;
+      rtx reg;
+      struct df_link *link;
+      enum machine_mode used_mode;
+
+      reg = DF_REF_REAL_REG (def_ref);
+
+      if (reg != SET_DEST (set_insn))
+	{
+	  def_rec++;
+	  continue;
+	}
+
+      for (link = DF_REF_CHAIN (def_ref); link; link = link->next)
+	{
+	  /* If we see an artifical definitions, assume the full result is
+	     used.  This may be conservative.  */
+	  if (DF_REF_IS_ARTIFICIAL (link->ref))
+	    {
+	      return result_mode;
+	    }
+
+	  /* The reg being used.  This may be a SUBREG of the REG produced by
+	     insn.  */
+	  reg = DF_REF_REG (link->ref);
+
+	  /* The mode corresponding to how much of the result gets used by
+	     this spcific use.  By default, we assume the entire result is
+	     used.  */
+	  used_mode = result_mode;
+
+	  /* If USE is a subreg, set USED_MODE to the mode of the subreg.  */
+	  if (GET_CODE (reg) == SUBREG && XINT (reg, 1) == 0)
+	    {
+	      used_mode = GET_MODE (reg);
+	    }
+	  /* If USE is a truncate, set USED_MODE to the mode of the
+	     truncate.  */
+	  else
+	    {
+	      rtx use = DF_REF_INSN (link->ref);
+	      rtx use_pattern = PATTERN (use);
+
+	      if (GET_CODE (use_pattern) == SET)
+		{
+		  rtx use_set_src = SET_SRC (use_pattern);
+		  if (GET_CODE (use_set_src) == TRUNCATE)
+		    {
+		      used_mode = GET_MODE (use_set_src);
+		    }
+		}
+	    }
+
+	  if (GET_MODE_SIZE (used_mode) > GET_MODE_SIZE (max_used_mode))
+	    max_used_mode = used_mode;
+
+	}
+
+      def_rec++;
+    }
+
+  return max_used_mode;
+}
+
+
+/* gets the reg_extend_info * corresponding to register rtx OPND.  Returns
+   NULL if none is found.  */
+static reg_extend_info *
+get_extend_info (rtx opnd, htab_t extend_infos)
+{
+  reg_extend_info key;
+
+  if (!REG_P (opnd))
+    return NULL;
+
+  key.reg_num = REGNO (opnd);
+  return (reg_extend_info *) htab_find (extend_infos, &key);
+}
+
+
+/* Get a set insn in the pattern of INSN.  If INSN is a PARALLEL, only
+   consider the first expression inside the PARALLEL.  */
+static rtx
+get_set_insn (rtx insn)
+{
+  rtx pattern = PATTERN (insn);
+
+  switch (GET_CODE (pattern))
+    {
+    case SET:
+      return pattern;
+    case PARALLEL:
+      if (GET_CODE (XVECEXP (pattern, 0, 0)) == SET)
+	return XVECEXP (pattern, 0, 0);
+      else
+	return NULL_RTX;
+    default:
+      return NULL_RTX;
+    }
+}
+
+
+/* Asserts that SET_INSN only uses the lower MODE bits of the opnd'th source
+   operand, so look for opportunity to short circuit any unnecessary zero or
+   sign extension.  Returns whether INSN was changed.  */
+static bool
+optimize_extends_src (rtx set_insn, int opnd, enum machine_mode mode,
+		      htab_t extend_infos)
+{
+  rtx expr;
+  rtx src;
+  reg_extend_info *rei;
+
+  expr = SET_SRC (set_insn);
+
+  src = XEXP (expr, opnd);
+
+  rei = get_extend_info (src, extend_infos);
+  if (rei != NULL
+      && (GET_MODE_SIZE (rei->to_mode) >= GET_MODE_SIZE (mode))
+      && (GET_MODE_SIZE (rei->from_mode) == GET_MODE_SIZE (mode))
+      && (rei->state == REG_EXTEND_ZERO_EXTENDED
+	  || rei->state == REG_EXTEND_SIGN_EXTENDED))
+    {
+      XEXP (expr, opnd) = rei->src_reg_rtx;
+      return true;
+    }
+
+  return false;
+}
+
+
+/* Checks to see if the primary result of INSN is only used in its low order
+   bits.  If so, optimize the first and second source operands assuming that
+   they only use those bits.  Returns whether INSN was changed.  */
+static bool
+optimize_extends_propagate_res_use_bits (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_set_insn (insn);
+  enum machine_mode result_mode = GET_MODE (SET_DEST (set_insn));
+  enum machine_mode used_mode = get_result_used_mode (insn, set_insn);
+
+  /* If used_mode is VOIDmode, it means we didn't find any non-artificial use.
+     We do nothing in that case.  */
+  if (used_mode == VOIDmode)
+    return false;
+
+  if (GET_MODE_SIZE (used_mode) < GET_MODE_SIZE (result_mode))
+    {
+      changed |= optimize_extends_src (set_insn, 0, used_mode, extend_infos);
+      changed |= optimize_extends_src (set_insn, 1, used_mode, extend_infos);
+    }
+
+  return changed;
+}
+
+
+/* Do extension optimizations for INSN.  */
+static void
+optimize_extends_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed;
+  rtx pattern;
+  rtx set_src;
+
+  /* Look for simple SET patterns that are amenable to optimization.  */
+
+  pattern = PATTERN (insn);
+
+  if (GET_CODE (pattern) != SET)
+    return;
+
+  set_src = SET_SRC (pattern);
+
+  changed = false;
+  switch (GET_CODE (set_src))
+    {
+    case PLUS:
+    case MINUS:
+    case MULT:
+    case AND:
+    case IOR:
+    case XOR:
+      changed = optimize_extends_propagate_res_use_bits (insn, extend_infos);
+      break;
+    default:
+      break;
+    }
+
+  if (changed)
+    df_insn_rescan (insn);
+}
+
+
+/* Returns the reg_extend_info corresponding to REG_NUM.  */
+static reg_extend_info *
+get_reg_extend_info (unsigned reg_num, htab_t extend_infos)
+{
+  reg_extend_info **hash_slot;
+  reg_extend_info *rei;
+  reg_extend_info key;
+
+  key.reg_num = reg_num;
+
+  hash_slot =
+    (reg_extend_info **) htab_find_slot (extend_infos, &key, INSERT);
+  rei = *hash_slot;
+  if (rei == NULL)
+    {
+      rei = *hash_slot = XCNEW (reg_extend_info);
+      rei->reg_num = reg_num;
+    }
+
+  return rei;
+}
+
+
+/* Invalidate the reg_extend_info corresponding to REG_NUM.  */
+static void
+optimize_extends_invalidate_reg (unsigned reg_num, htab_t extend_infos)
+{
+  reg_extend_info key;
+  reg_extend_info *rei;
+
+  key.reg_num = reg_num;
+  rei = (reg_extend_info *) htab_find (extend_infos, &key);
+  if (rei != NULL)
+    rei->state = REG_EXTEND_INVALID;
+}
+
+
+/* Invalidate all reg_extend_info corresponding to registers that have been
+   chagned by PATTERN.  */
+static void
+optimize_extends_invalidate_results (rtx pattern, htab_t extend_infos)
+{
+  int i;
+
+  switch (GET_CODE (pattern))
+    {
+    case PARALLEL:
+      {
+	for (i = 0; i < XVECLEN (pattern, 0); i++)
+	  optimize_extends_invalidate_results (XVECEXP (pattern, 0, i),
+					       extend_infos);
+	break;
+      }
+    case SET:
+      {
+	rtx dest;
+	dest = SET_DEST (pattern);
+	if (REG_P (dest))
+	  optimize_extends_invalidate_reg (REGNO (dest), extend_infos);
+
+	break;
+      }
+    case CLOBBER:
+      {
+	rtx clobbered = XEXP (pattern, 0);
+	if (REG_P (clobbered))
+	  optimize_extends_invalidate_reg (REGNO (clobbered), extend_infos);
+
+	break;
+      }
+    default:
+      break;
+    }
+}
+
+
+/* Update EXTEND_INFOS to reflect the extension pattern found in PATTERN.
+   OUTPUT_STATE reflects the extension type.  */
+static void
+optimize_extends_update_extend (enum reg_extend_state output_state,
+				enum machine_mode from_mode,
+				enum machine_mode to_mode,
+				rtx pattern, htab_t extend_infos)
+{
+  reg_extend_info *rei_src;
+  reg_extend_info key;
+  rtx dest;
+  rtx src;
+  rtx extending_src;
+
+  gcc_assert (GET_CODE (pattern) == SET);
+
+  dest = SET_DEST (pattern);
+
+  if (REG_P (dest))
+    {
+      /* get the source of the extend insn.  */
+      src = XEXP (SET_SRC (pattern), 0);
+
+      /* Look for the a corresponding source in SI mode whose lower bits are
+         being extended  */
+      extending_src = NULL;
+      if (REG_P (src))
+	{
+	  /* (set (reg:SI 98) (sign/zero_extend:SI (reg:HI 97))) */
+	  key.reg_num = REGNO (src);
+	  rei_src = (reg_extend_info *) htab_find (extend_infos, &key);
+	  if (rei_src != NULL && rei_src->state == REG_EXTEND_TRUNCATE)
+	    extending_src = rei_src->src_reg_rtx;
+	}
+      else if (GET_CODE (src) == SUBREG && XINT (src, 1) == 0)
+	{
+	  /* (set (reg:SI 94)
+	     (sign/zero_extend:SI (subreg/s:HI (reg/v:SI 84) 0)))  */
+	  extending_src = XEXP (src, 0);
+	}
+
+      /* We only take advantage the case when EXTENDING_SRC has the same mode
+         as DEST, but it may be possible to handle the case where the
+         EXTENDING_SRC has a wider mode, by setting src_reg_rtx to (subreg:M
+         EXTENDING_SRC) where M is the mode of DEST.  */
+      if (extending_src != NULL
+	  && GET_MODE (extending_src) == GET_MODE (dest))
+	{
+	  reg_extend_info *rei_dest;
+
+	  rei_dest = get_reg_extend_info (REGNO (dest), extend_infos);
+	  rei_dest->reg_rtx = dest;
+	  rei_dest->src_reg_rtx = extending_src;
+	  rei_dest->state = output_state;
+	  rei_dest->from_mode = from_mode;
+	  rei_dest->to_mode = to_mode;
+	}
+      else
+	optimize_extends_invalidate_results (pattern, extend_infos);
+    }
+}
+
+
+/* Update EXTEND_INFOS to reflect the shift pattern found in PATTERN.
+   OUTPUT_STATE reflects the extension type.  */
+static void
+optimize_extends_update_shift (enum reg_extend_state output_state,
+			       enum machine_mode from_mode,
+			       enum machine_mode to_mode,
+			       rtx pattern, htab_t extend_infos)
+{
+  reg_extend_info *rei_src;
+  reg_extend_info key;
+  rtx dest;
+  rtx src;
+  rtx extending_src;
+
+  gcc_assert (GET_CODE (pattern) == SET);
+
+  dest = SET_DEST (pattern);
+
+  if (REG_P (dest))
+    {
+      /* get the source of the extend insn.  */
+      src = XEXP (SET_SRC (pattern), 0);
+
+      /* Look for the a corresponding source in SI mode whose lower bits are
+         being extended  */
+      extending_src = NULL;
+      if (REG_P (src))
+	{
+	  /* (set (reg:SI 98) (sign/zero_extend:SI (reg:HI 97))) */
+	  key.reg_num = REGNO (src);
+	  rei_src = (reg_extend_info *) htab_find (extend_infos, &key);
+	  if (output_state == REG_EXTEND_ASHIFTRTQI
+	      && rei_src != NULL && rei_src->state == REG_EXTEND_ASHIFTQI)
+	    {
+	      extending_src = rei_src->src_reg_rtx;
+	      from_mode = QImode;
+	    }
+	  else if (output_state == REG_EXTEND_ASHIFTRTHI
+		   && rei_src != NULL
+		   && rei_src->state == REG_EXTEND_ASHIFTHI)
+	    {
+	      extending_src = rei_src->src_reg_rtx;
+	      from_mode = HImode;
+	    }
+	}
+      else if (GET_CODE (src) == SUBREG && XINT (src, 1) == 0)
+	{
+	  /* (set (reg:SI 94)
+	     (sign/zero_extend:SI (subreg/s:HI (reg/v:SI 84) 0)))  */
+	  extending_src = XEXP (src, 0);
+	}
+
+      if (extending_src != NULL
+	  && GET_MODE (extending_src) == GET_MODE (dest))
+	{
+	  reg_extend_info *rei_dest;
+
+	  rei_dest = get_reg_extend_info (REGNO (dest), extend_infos);
+	  rei_dest->reg_rtx = dest;
+	  rei_dest->src_reg_rtx = extending_src;
+	  rei_dest->state = output_state;
+	  rei_dest->from_mode = from_mode;
+	  rei_dest->to_mode = to_mode;
+	}
+      else
+	optimize_extends_invalidate_results (pattern, extend_infos);
+    }
+}
+
+
+/* Update EXTEND_INFOS to reflect the insn pattern found in PATTERN.  
+   OUTPUT_STATE is the corresponding relation.  */
+static bool
+optimize_extends_update_insn (enum reg_extend_state output_state,
+			      enum machine_mode from_mode,
+			      enum machine_mode to_mode,
+			      rtx pattern, htab_t extend_infos)
+{
+  rtx dest;
+  rtx src;
+
+  gcc_assert (GET_CODE (pattern) == SET);
+
+  dest = SET_DEST (pattern);
+
+  if (REG_P (dest))
+    {
+      /* get the first source of the pattern */
+      src = XEXP (SET_SRC (pattern), 0);
+
+      if (REG_P (src))
+	{
+	  reg_extend_info *rei_dest;
+
+	  rei_dest = get_reg_extend_info (REGNO (dest), extend_infos);
+	  rei_dest->reg_rtx = dest;
+	  rei_dest->src_reg_rtx = src;
+	  rei_dest->state = output_state;
+	  rei_dest->from_mode = from_mode;
+	  rei_dest->to_mode = to_mode;
+
+	  return true;
+	}
+    }
+  else
+    optimize_extends_invalidate_results (pattern, extend_infos);
+
+  return false;
+}
+
+
+/* Process INSN and update EXTEND_INFOS.  Look for extension patterns.  If
+   found, add an entry to extend_infos.  */
+static void
+optimize_extends_update_info (rtx insn, htab_t extend_infos)
+{
+  rtx pattern = PATTERN (insn);
+
+  if (GET_CODE (pattern) == SET)
+    {
+      enum rtx_code code = GET_CODE (SET_SRC (pattern));
+      enum reg_extend_state state;
+      enum machine_mode from_mode;
+      enum machine_mode to_mode;
+
+      state = REG_EXTEND_INVALID;
+      switch (code)
+	{
+	case ZERO_EXTEND:
+	  state = REG_EXTEND_ZERO_EXTENDED;
+	  break;
+	case SIGN_EXTEND:
+	  state = REG_EXTEND_SIGN_EXTENDED;
+	  break;
+	case TRUNCATE:
+	  state = REG_EXTEND_TRUNCATE;
+	  break;
+	case ASHIFT:
+	  {
+	    /* tile uses two shifts to implement sign extension.  So look for
+	       and remember the first shift.  */
+	    rtx src1 = XEXP (SET_SRC (pattern), 1);
+	    if (GET_MODE (SET_SRC (pattern)) == SImode && CONST_INT_P (src1))
+	      {
+		int shift_amt = INTVAL (src1);
+		if (shift_amt == BITS_PER_WORD - GET_MODE_BITSIZE (QImode))
+		  state = REG_EXTEND_ASHIFTQI;
+		else if (shift_amt ==
+			 BITS_PER_WORD - GET_MODE_BITSIZE (HImode))
+		  state = REG_EXTEND_ASHIFTHI;
+	      }
+	    break;
+	  }
+	case ASHIFTRT:
+	  {
+	    rtx src1 = XEXP (SET_SRC (pattern), 1);
+	    if (GET_MODE (SET_SRC (pattern)) == SImode && CONST_INT_P (src1))
+	      {
+		int shift_amt = INTVAL (src1);
+		if (shift_amt == BITS_PER_WORD - GET_MODE_BITSIZE (QImode))
+		  state = REG_EXTEND_ASHIFTRTQI;
+		else if (shift_amt ==
+			 BITS_PER_WORD - GET_MODE_BITSIZE (HImode))
+		  state = REG_EXTEND_ASHIFTRTHI;
+	      }
+	  }
+	default:
+	  break;
+	}
+
+      if (state != REG_EXTEND_INVALID)
+	{
+	  from_mode = GET_MODE (XEXP (SET_SRC (pattern), 0));
+	  to_mode = GET_MODE (SET_DEST (pattern));
+	}
+
+      switch (state)
+	{
+	case REG_EXTEND_ZERO_EXTENDED:
+	case REG_EXTEND_SIGN_EXTENDED:
+	  optimize_extends_update_extend (state, from_mode, to_mode,
+					  pattern, extend_infos);
+	  return;
+	case REG_EXTEND_ASHIFTRTQI:
+	case REG_EXTEND_ASHIFTRTHI:
+	  optimize_extends_update_shift (state, from_mode, to_mode,
+					 pattern, extend_infos);
+	  return;
+	case REG_EXTEND_TRUNCATE:
+	case REG_EXTEND_ASHIFTQI:
+	case REG_EXTEND_ASHIFTHI:
+	  optimize_extends_update_insn (state, from_mode, to_mode,
+					pattern, extend_infos);
+	  return;
+	default:
+	  break;
+	}
+    }
+
+  optimize_extends_invalidate_results (pattern, extend_infos);
+}
+
+
+/* Entry point to an optimization pass that optimizes away unnecessary
+   sign/zero extensions for source operands of intrinsics instructions.  If an
+   extension is not necessary, we short circuit the operations to use the
+   value before extension.  We leave to other passes (dce) to eliminate any
+   resulting dead code.  Requries availability of du-chains.  */
+static void
+optimize_extends (void)
+{
+  basic_block bb;
+  rtx insn, last;
+  htab_t extend_infos;
+
+  FOR_EACH_BB (bb)
+    {
+      extend_infos = htab_create (10, htab_rei_hash, htab_rei_eq, htab_rei_del);
+
+      for (insn = BB_HEAD (bb), last = NEXT_INSN (BB_END (bb));
+	   insn != last; insn = NEXT_INSN (insn))
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  optimize_extends_insn (insn, extend_infos);
+
+	  optimize_extends_update_info (insn, extend_infos);
+	}
+
+      htab_delete (extend_infos);
+    }
+}
+
+
+static bool
+tilepro_gate_handle_target_peephole (void)
+{
+  return optimize > 0;
+}
+
+
+static unsigned int
+tilepro_rest_of_handle_target_peephole (void)
+{
+  df_chain_add_problem (DF_DU_CHAIN);
+  df_analyze ();
+  df_set_flags (DF_DEFER_INSN_RESCAN);
+
+  optimize_extends ();
+
+  df_remove_problem (df_chain);
+  df_process_deferred_rescans ();
+
+  return 0;
+}
+
+
+
+#undef  TARGET_SCHED_INIT_GLOBAL
+#define TARGET_SCHED_INIT_GLOBAL tilepro_sched_init_global
+
+#undef  TARGET_SCHED_FINISH_GLOBAL
+#define TARGET_SCHED_FINISH_GLOBAL tilepro_sched_finish_global
+
+#undef  TARGET_PRE_UNROLLING_AND_PEELING_HOOK
+#define TARGET_PRE_UNROLLING_AND_PEELING_HOOK \
+  tilepro_pre_unrolling_and_peeling_hook
+
+#undef  TARGET_POST_EXPAND_TO_RTL_HOOK
+#define TARGET_POST_EXPAND_TO_RTL_HOOK tilepro_post_expand_to_rtl_hook
+
+#undef  TARGET_GATE_HANDLE_TARGET_PEEPHOLE
+#define TARGET_GATE_HANDLE_TARGET_PEEPHOLE \
+  tilepro_gate_handle_target_peephole
+
+#undef  TARGET_REST_OF_HANDLE_TARGET_PEEPHOLE
+#define TARGET_REST_OF_HANDLE_TARGET_PEEPHOLE \
+  tilepro_rest_of_handle_target_peephole
diff -r -u -p -N /home/packages/gcc-4.8.2/gcc/config.gcc ./gcc/config.gcc
--- /home/packages/gcc-4.8.2/gcc/config.gcc	2013-10-02 20:47:24.000000000 -0400
+++ ./gcc/config.gcc	2015-10-26 22:26:34.911022000 -0400
@@ -475,7 +475,7 @@ tilegx*-*-*)
 	cpu_type=tilegx
 	need_64bit_hwint=yes
 	;;
-tilepro-*-*)
+tilepro*-*-*)
 	cpu_type=tilepro
 	need_64bit_hwint=yes
 	;;
@@ -2555,15 +2555,20 @@ tic6x-*-uclinux)
 	tmake_file="${tmake_file} c6x/t-c6x c6x/t-c6x-elf c6x/t-c6x-uclinux"
 	use_collect2=no
 	;;
-tilegx-*-linux*)
+tilegx*-*-linux*)
 	tm_file="elfos.h gnu-user.h linux.h glibc-stdint.h tilegx/linux.h ${tm_file}"
         tmake_file="${tmake_file} tilegx/t-tilegx"
 	extra_objs="mul-tables.o"
 	c_target_objs="${c_target_objs} tilegx-c.o"
 	cxx_target_objs="${cxx_target_objs} tilegx-c.o"
-	extra_headers="feedback.h"
+	extra_headers="feedback.h postinc.h"
+	case $target in
+	tilegxbe-*)
+		tm_defines="${tm_defines} TARGET_BIG_ENDIAN_DEFAULT=1"
+ 		;;
+	esac
 	;;
-tilepro-*-linux*)
+tilepro*-*-linux*)
 	tm_file="elfos.h gnu-user.h linux.h glibc-stdint.h tilepro/linux.h ${tm_file}"
         tmake_file="${tmake_file} tilepro/t-tilepro"
 	extra_objs="mul-tables.o"
