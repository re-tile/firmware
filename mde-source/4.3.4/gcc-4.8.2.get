+
+;;
+;; Pragmas
+;;
+
+(define_insn "tilegx_pragma_unroll"
+  [(unspec_volatile:SI [(match_operand:SI 0 "immediate_operand" "i")]
+		       UNSPEC_PRAGMA_UNROLL)]
+  ""
+  "")
+
