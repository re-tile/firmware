+/* Inline assembly macro for post incrementing loads/stores.  */
+#define TILEPRO_POST_INC_BUILTINS() \
+  builtin_define (" __post_inc_store(o, t, p, v, c)= "                 \
+                  " ({ "                                               \
+                     " __asm__ ( #o \" %0, %2, %3\" "                  \
+                               " : \"+r\" (p), \"=m\" (*(t *)p) "      \
+                               " : \"r\" ((int)v), \"i\" (c) ); }) "); \
+                                                                       \
+  builtin_define (" __insn_sbadd(p, v, i) = "                          \
+                  "   __post_inc_store(sbadd, char, p, v, i) ");       \
+  builtin_define (" __insn_shadd(p, v, i) = "                          \
+                  "   __post_inc_store(shadd, short, p, v, i) ");      \
