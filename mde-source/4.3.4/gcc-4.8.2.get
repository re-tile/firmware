+
+#define __insn_ld_add_miss(p, i)		\
+  __post_inc_load(ld_add_miss, long long, p, i)
+
+#define __insn_ldnt1s_add_miss(p, i)		\
+  __post_inc_load(ldnt1s_add_miss, char, p, i)
+
+#define __insn_ldnt1u_add_miss(p, i)		\
