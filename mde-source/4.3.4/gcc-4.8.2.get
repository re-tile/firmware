+++ ./gcc/config/tilepro/tilepro.c	2015-10-26 22:26:35.363007000 -0400
@@ -45,6 +45,7 @@
 #include "tilepro-builtins.h"
 #include "tilepro-multiply.h"
 #include "diagnostic.h"
+#include "opts.h"
 
 /* SYMBOL_REF for GOT */
 static GTY(()) rtx g_got_symbol = NULL;
@@ -71,6 +72,43 @@ tilepro_option_override (void)
      scheduler for bundling.  */
   if (flag_modulo_sched)
     flag_resched_modulo_sched = 1;
+  /* Temporarily turn off cfi asm because it generates pcrel
+     relocations in eh_frame sections.  */
+  flag_dwarf2_cfi_asm = 0;
