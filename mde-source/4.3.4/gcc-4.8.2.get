diff -r -u -p -N /home/packages/gcc-4.8.2/gcc/config/tilegx/tilegx2.c ./gcc/config/tilegx/tilegx2.c
--- /home/packages/gcc-4.8.2/gcc/config/tilegx/tilegx2.c	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilegx/tilegx2.c	2015-10-26 22:26:34.405001000 -0400
@@ -0,0 +1,3529 @@
+/* Subroutines used for code generation on the Tilera TILE-Gx.
+   Copyright (C) 2011
+   Free Software Foundation, Inc.
+   Contributed by Walter Lee (walt@tilera.com)
+
+   This file is part of GCC.
+
+   GCC is free software; you can redistribute it and/or modify it
+   under the terms of the GNU General Public License as published
+   by the Free Software Foundation; either version 3, or (at your
+   option) any later version.
+
+   GCC is distributed in the hope that it will be useful, but WITHOUT
+   ANY WARRANTY; without even the implied warranty of MERCHANTABILITY
+   or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU General Public
+   License for more details.
+
+   You should have received a copy of the GNU General Public License
+   along with GCC; see the file COPYING3.  If not see
+   <http://www.gnu.org/licenses/>.  */
+
+#include "dumpfile.h"
+
+static FILE * tilegx_lock_data_file (const char *fn);
+static void tilegx_unlock_data_file (FILE *file);
+
+/* Functions to support scheduling of network register operations.  */
+
+
+/* Return the ordering register corresponding to the port.  */
+static int
+get_ordering_reg (int unspec_num, rtx netreg)
+{
+  int netreg_num;
+  gcc_assert (CONST_INT_P (netreg));
+  netreg_num = INTVAL (netreg);
+
+  if (unspec_num == UNSPEC_NETWORK_RECEIVE)
+    {
+      switch (netreg_num)
+	{
+	case TILEGX_NETREG_IDN0:
+	  return TILEGX_NETORDER_IDN0_RECEIVE_REGNUM;
+	case TILEGX_NETREG_IDN1:
+	  return TILEGX_NETORDER_IDN1_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN0:
+	  return TILEGX_NETORDER_UDN0_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN1:
+	  return TILEGX_NETORDER_UDN1_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN2:
+	  return TILEGX_NETORDER_UDN2_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN3:
+	  return TILEGX_NETORDER_UDN3_RECEIVE_REGNUM;
+	}
+    }
+  else				/* UNSPEC_NETWORK_SEND */
+    {
+      switch (netreg_num)
+	{
+	case TILEGX_NETREG_IDN0:
+	  return TILEGX_NETORDER_IDN0_SEND_REGNUM;
+	case TILEGX_NETREG_UDN0:
+	  return TILEGX_NETORDER_UDN0_SEND_REGNUM;
+	}
+    }
+
+  return 0;
+}
+
+
+/* Specialize or generalize the ordering operand, depending on the
+   input pattern.  If the input pattern contains
+   TILEGX_NETORDER_REGNUM, then specialize it.  If it contains a port
+   specific ordering reg, then generalize it to
+   TILEGX_NETORDER_REGNUM.  Changes are made in two places: in the
+   ordering operand inside the unspec, and in the corresponding
+   clobber expression.  */
+static void
+replace_ordering_operands (rtx pattern, rtx last_parallel)
+{
+  int opnd;
+  int i;
+  int ordering_reg;
+  int from_reg;
+  int to_reg;
+  enum machine_mode mode;
+  rtx temp;
+
+  if (XINT (pattern, 1) == UNSPEC_NETWORK_RECEIVE)
+    opnd = 1;
+  else				/* UNSPEC_NETWORK_SEND */
+    opnd = 2;
+
+  ordering_reg =
+    get_ordering_reg (XINT (pattern, 1), XVECEXP (pattern, 0, 0));
+
+  from_reg = REGNO (XVECEXP (pattern, 0, opnd));
+
+  if (from_reg == TILEGX_NETORDER_REGNUM)
+    {
+      to_reg = ordering_reg;
+    }
+  else
+    {
+      gcc_assert (from_reg == ordering_reg);
+      to_reg = TILEGX_NETORDER_REGNUM;
+    }
+
+  mode = GET_MODE (XVECEXP (pattern, 0, opnd));
+  temp = gen_rtx_REG (mode, to_reg);
+
+  XVECEXP (pattern, 0, opnd) = temp;
+
+  for (i = 0; i < XVECLEN (last_parallel, 0); i++)
+    {
+      rtx expr = XVECEXP (last_parallel, 0, i);
+
+      if (GET_CODE (expr) == CLOBBER &&
+	  REG_P (XEXP (expr, 0)) &&
+	  REGNO (XEXP (expr, 0)) == (unsigned) from_reg)
+	{
+	  /* gcc defines a single clobber expression for each register
+	     and reuses them, and it can be accessed via
+	     gen_hard_reg_clobber ().  */
+	  XVECEXP (last_parallel, 0, i) = gen_hard_reg_clobber (mode, to_reg);
+	  break;
+	}
+    }
+
+  /* check that we've found a corresponding clobber expression.  */
+  gcc_assert (i < XVECLEN (last_parallel, 0));
+}
+
+
+/* This routine is used to modify the network instructions before
+   scheduling so that they can be bundled, and also to reverse the
+   transformation after scheduling.  Two changes are made:
+
+   1. Replace the rtx_code FROM with TO.  Before scheduling, we're
+      replacing UNSPEC_VOLATILE with UNSPEC.  After scheduling, we're
+      replacing UNSPEC with UNSPEC_VOLATILE.
+
+   2. Specialize the ordering operands before scheduling, from the
+      generic TILEGX_NETORDER_REGNUM to a per-port ordering register.
+      Also reverse this transformation after scheduling.
+
+   For debug_insn, we only do item 1.  */
+static void
+replace_network_unspec (rtx pattern, rtx last_parallel, RTX_CODE from,
+			RTX_CODE to, bool is_debug_insn)
+{
+  const char *fmt;
+  int i, j;
+
+  /* As we recurse, keep track of the last parallel construct as
+     that's where we expect to find the clobber expressions
+     corresponding to the nework operation.  */
+  if (GET_CODE (pattern) == PARALLEL)
+    last_parallel = pattern;
+
+  if (GET_CODE (pattern) == from)
+    {
+      /* We've found a network operation.  Do the transformation.  */
+      if (XINT (pattern, 1) == UNSPEC_NETWORK_RECEIVE
+	  || XINT (pattern, 1) == UNSPEC_NETWORK_SEND)
+	{
+	  PUT_CODE (pattern, to);
+	  if (!is_debug_insn)
+	    replace_ordering_operands (pattern, last_parallel);
+	}
+    }
+
+  fmt = GET_RTX_FORMAT (GET_CODE (pattern));
+  for (i = 0; i < GET_RTX_LENGTH (GET_CODE (pattern)); i++)
+    {
+      if (fmt[i] == 'e')
+	{
+	  replace_network_unspec (XEXP (pattern, i), last_parallel, from, to,
+				  is_debug_insn);
+	}
+      else if (fmt[i] == 'E')
+	{
+	  for (j = 0; j < XVECLEN (pattern, i); j++)
+	    {
+	      replace_network_unspec (XVECEXP (pattern, i, j), last_parallel,
+				      from, to, is_debug_insn);
+	    }
+	}
+    }
+}
+
+
+/* Assign unused registers to zero, so that they don't consume a
+   useful register.
+
+   At the beginning of the post-register-allocation scheduling phase,
+   we assign unused registers to zero.  Ideally, we want to do this at
+   the end of the pre-register-allocation scheduling phase.  This
+   allows the scheduler to schedule without any artificial output
+   dependences, and prevents the register allocator from allocating
+   unused registers.  However, we need to sanity check the operand
+   constraints, which is only available after register allocation, so
+   we currently run this pass after register allocation, at the
+   beginning of the last scheduling pass.
+
+   It is not always legal to assign unused registers to zero.  We do
+   not do this for the following instructions:
+   - calls.
+   - inline asms.
+   - loads from memory, because loads into zero turn into prefetches.
+   - instructions that cannot be bundled, in particular those that
+     take multiple cycles may have hidden uses that we don't know
+     about, i.e. the stack protect patterns.
+
+   We also check validate that the operand constraints are satisfied,
+   to catch illegal replacement of same-res instructions, for
+   example.  */
+static void
+tilegx_assign_unused_regs (rtx insn)
+{
+  rtx link;
+  rtx next_link;
+  rtx new_reg = NULL;
+  enum attr_type type;
+
+  /* Skip instructions that we don't recognize.  */
+  if (recog_memoized (insn) < 0)
+    return;
+
+  /* Skip instructions that cannot be bundled.  In particular those
+     that take multiple cycles may have hidden uses that we don't know
+     about, i.e. the stack protect patterns.  */
+  type = get_attr_type (insn);
+  if (type == TYPE_CANNOT_BUNDLE
+      || type == TYPE_CANNOT_BUNDLE_3CYCLE
+      || type == TYPE_CANNOT_BUNDLE_4CYCLE)
+    return;
+
+  for (link = REG_NOTES (insn); link; link = next_link)
+    {
+      const_rtx datum;
+
+      next_link = XEXP (link, 1);
+      datum = XEXP (link, 0);
+
+      if (REG_NOTE_KIND (link) == REG_UNUSED
+	  && REG_P (datum)
+	  && GET_MODE_SIZE (GET_MODE (datum)) <= UNITS_PER_WORD
+	  && REGNO (datum) != 63)
+	{
+	  rtx set = (rtx_def *)set_of (datum, insn);
+	  RTX_CODE set_code;
+
+	  if (!set || GET_CODE (set) != SET)
+	    continue;
+
+	  set_code = GET_CODE (SET_SRC (set));
+
+	  if (SET_DEST (set) == datum
+	      && set_code != CALL
+	      && set_code != ASM_OPERANDS
+	      && set_code != MEM
+	      && !((set_code == SIGN_EXTEND || set_code == ZERO_EXTEND)
+		   && GET_CODE (XEXP (SET_SRC (set), 0)) == MEM))
+	    {
+	      rtx old_reg = SET_DEST (set);
+	      new_reg = gen_rtx_REG (GET_MODE (SET_DEST (set)), 63);
+
+	      SET_DEST (set) = new_reg;
+
+	      /* Check if the new instruction is valid, and restore
+		 old register if not.  */
+	      extract_insn (insn);
+	      if (!constrain_operands_cached (1))
+		{
+		  SET_DEST (set) = old_reg;
+		  new_reg = NULL;
+		}
+	      else
+		remove_note (insn, link);
+	    }
+	} 
+    }
+
+  if (new_reg)
+    {
+      add_reg_note (insn, REG_UNUSED, new_reg);
+      df_insn_rescan (insn);
+    }
+}
+
+
+/* Implement TARGET_SCHED_INIT_GLOBAL.  */
+static void
+tilegx_sched_init_global (FILE *dump ATTRIBUTE_UNUSED,
+			  int sched_verbose ATTRIBUTE_UNUSED,
+			  int max_ready ATTRIBUTE_UNUSED)
+{
+  basic_block bb;
+
+  /* Set up df to support tilegx_assign_unused_regs.  */
+  df_set_flags (DF_DEFER_INSN_RESCAN);
+
+  FOR_EACH_BB (bb)
+  {
+    rtx insn, next;
+
+    FOR_BB_INSNS_SAFE (bb, insn, next)
+    {
+      if (!NONDEBUG_INSN_P (insn))
+	continue;
+
+      /* We need to delete any loop pragmas before we schedule, because
+         any bundle markers on them will be lost.  */
+      if (recog_memoized (insn) == CODE_FOR_tilegx_pragma_unroll ||
+	  recog_memoized (insn) == CODE_FOR_tilegx_pragma_must_iterate)
+	{
+	  delete_insn (insn);
+	}
+      else
+	{
+	  /* Modify the instructions that touch the network so they can be
+	     bundled.  */
+	  replace_network_unspec (PATTERN (insn), NULL, UNSPEC_VOLATILE,
+				  UNSPEC, DEBUG_INSN_P (insn));
+
+	  if (reload_completed)
+	    tilegx_assign_unused_regs (insn);
+	}
+    }
+  }
+
+  /* Process the deferred rescans from tilegx_assign_unused_regs.  */
+  df_process_deferred_rescans ();
+}
+
+
+/* Returns true of insn has jump prediction state that may be lost if
+   it is stalled.  */
+static bool has_jump_prediction_state (rtx insn)
+{
+  switch (get_attr_type (insn))
+    {
+    case TYPE_X1_JUMP:
+      return tilegx_hazard_opt;
+    case TYPE_X1_CALL:
+    case TYPE_Y1_RETURN:
+      return tilegx_hazard_opt >= 2;
+    case TYPE_X1_BRANCH:
+      /* Note that insn addresses have not been computed yet, so we
+	 cannot tell if the branch distance will fit, so this only
+	 handles the common case.  */
+      return tilegx_hazard_opt && cbranch_predicted_p (insn);
+    default:
+      return false;
+    }
+}
+
+
+/* Skip over irrelevant NOTEs and such and look for the next insn we
+   would consider bundling, going backwards  */
+static rtx
+prev_insn_to_bundle (rtx r, rtx end)
+{
+  for (; r != end; r = PREV_INSN (r))
+    {
+      if (NONDEBUG_INSN_P (r)
+	  && GET_CODE (PATTERN (r)) != USE
+	  && GET_CODE (PATTERN (r)) != CLOBBER)
+	return r;
+    }
+
+  return NULL_RTX;
+}
+
+
+/* Implement TARGET_SCHED_FINISH_GLOBAL.  */
+static void
+tilegx_sched_finish_global (FILE *dump ATTRIBUTE_UNUSED,
+			    int sched_verbose ATTRIBUTE_UNUSED)
+{
+  basic_block bb;
+  FOR_EACH_BB (bb)
+  {
+    rtx insn;
+
+    FOR_BB_INSNS (bb, insn)
+    {
+      if (!NONDEBUG_INSN_P (insn))
+	continue;
+
+      /* Change accesses to the network back to the form before
+         scheduling.  */
+      replace_network_unspec (PATTERN (insn), NULL, UNSPEC,
+			      UNSPEC_VOLATILE, DEBUG_INSN_P (insn));
+    }
+  }
+
+  /* If there is a pipeline bubble before a branch or jump, the
+     pipeline will stall.  The target is not saved and instead the
+     pipe needs to restart and incur a 2-cycle "branch mispredication"
+     penalty.  Here we try to eliminate the bubble by inserting a
+     nop.
+
+     The bubble can easily be identified in the schedule as an idle
+     slot.  To minimize code bloat, we only insert a nop for the case
+     when there is only one bubble.  Since we only have 1 and 2-cycle
+     operations, the only time we'd have more bubbles is for a cache
+     miss anyways.  */
+  if (!reload_completed || tilegx_hazard_opt == 0)
+    return;
+
+  FOR_EACH_BB (bb)
+  {
+    rtx last, insn;
+    int last_cycle, cycle;
+    rtx end = PREV_INSN (BB_HEAD (bb));
+
+    last = prev_insn_to_bundle (BB_END (bb), end);
+
+    if (last == NULL || !has_jump_prediction_state (last))
+      continue;
+
+    last_cycle = HID (last)->tick;
+
+    for (insn = prev_insn_to_bundle (PREV_INSN (last), end); insn;
+	 insn = prev_insn_to_bundle (PREV_INSN (insn), end))
+      {
+	cycle = HID (insn)->tick;
+	if (cycle < last_cycle)
+	  {
+	    if (cycle == last_cycle - 2)
+	      {
+		rtx new_insns;
+
+		/* Add a nop.  */
+		start_sequence ();
+		emit_insn (gen_nop ());
+		new_insns = get_insns ();
+
+		/* Put the nop in its own bundle.  */
+		PUT_MODE (new_insns, TImode);
+		end_sequence ();
+
+		/* Insert the nop after the current insn.  */
+		emit_insn_after (new_insns, insn);
+	      }
+	    break;
+	  }
+      }
+  }
+}
+
+
+
+/* Loop pragmas support.  */
+
+
+/* Keep track of whether a function has emitted a header for pragma
+   warnings.  */
+static bool emitted_pragma_warning_header;
+
+
+static void
+emit_pragma_warning_header (const char *file)
+{
+  if (!emitted_pragma_warning_header)
+    {
+      fprintf (stderr, "%s: In function '%s':\n", file,
+	       current_function_name ());
+
+      emitted_pragma_warning_header = true;
+    }
+}
+
+
+/* Emit warning for loop pragmas that do not have corresponding loops.  */
+static void
+warn_unmatched_loop_pragma (rtx insn, vec<int> *warned_locations)
+{
+  size_t i;
+  int loc;
+  const char *file;
+  int line;
+
+  if (!TARGET_WARN_UNMATCHED_LOOP_PRAGMAS)
+    return;
+
+  loc = INSN_LOCATION (insn);
+
+  file = LOCATION_FILE (loc);
+  line = LOCATION_LINE (loc);
+
+  /* Check to see if we've warned about this pragma already.  This is N^2, but
+     we don't expect many pragmas.  */
+  for (i = 0; i < warned_locations->length (); i++)
+    {
+      int warned_loc = (*warned_locations)[i];
+      if (strcmp (file, LOCATION_FILE (warned_loc)) == 0 &&
+	  line == LOCATION_LINE (warned_loc))
+	return;
+    }
+
+  emit_pragma_warning_header (file);
+
+  fprintf (stderr, "%s:%d: warning: loop pragma without matching loop\n",
+	   file, line);
+
+  warned_locations->quick_push (loc);
+}
+
+
+/* Requires that unroll_pragma is an unroll pragma; returns the unroll
+   factor. */
+static unsigned
+get_unroll_factor (rtx unroll_pragma)
+{
+  rtx pattern;
+  rtx constant;
+
+  pattern = PATTERN (unroll_pragma);
+  constant = XVECEXP (pattern, 0, 0);
+  return (unsigned) XINT (constant, 0);
+}
+
+
+/* For each inner loop, pick an instruction in it and insert it into the INSNS.
+   Returns the vector of instructions.  */
+static
+vec<rtx, va_gc> *
+get_inner_loop_insns (vec<rtx, va_gc> *insns)
+{
+  struct loop *loop;
+  loop_iterator li;
+  FOR_EACH_LOOP (li, loop, LI_ONLY_INNERMOST)
+    {
+      basic_block header = loop->header;
+      bool found = false;
+      rtx insn;
+
+      FOR_BB_INSNS (header, insn)
+	{
+	  if (NONDEBUG_INSN_P (insn))
+	    {
+	      found = true;
+	      break;
+	    }
+	}
+
+      /* If header has no instruction, ignore loop for now.  FIXME: should look
+	 in other blocks in loop.  */
+      if (found)
+	vec_safe_push (insns, insn);
+    }
+
+  return insns;
+}
+
+
+/* Find all the unroll pragmas in the function and insert them into the INSNS.
+   Returns the vector of pragmas.  */
+static
+vec<rtx, va_gc> *
+get_loop_pragmas (vec<rtx, va_gc> *insns, enum insn_code code)
+{
+  basic_block bb;
+
+  FOR_EACH_BB (bb)
+    {
+      rtx insn;
+
+      FOR_BB_INSNS (bb, insn)
+	{
+	  if (NONDEBUG_INSN_P (insn) && recog_memoized (insn) == (int) code)
+	    vec_safe_push (insns, insn);
+	}
+    }
+
+  return insns;
+}
+
+
+/* Sort function that orders higher line numbers first. */
+static int
+insn_location_compare (const void *b, const void *a)
+{
+  const rtx insn_a = *((const rtx *) a);
+  const rtx insn_b = *((const rtx *) b);
+
+  int loc_a = INSN_LOCATION (insn_a);
+  int loc_b = INSN_LOCATION (insn_b);
+
+  const char *file_a = LOCATION_FILE (loc_a);
+  const char *file_b = LOCATION_FILE (loc_b);
+
+  int line_a = insn_line (insn_a);
+  int line_b = insn_line (insn_b);
+
+  int file_compare;
+
+  int loop_depth_a;
+  int loop_depth_b;
+
+  if (loc_a == 0)
+    if (loc_b == 0)
+      return 0;
+    else
+      return -1;
+  else if (loc_b == 0)
+    return 1;
+
+  file_compare = strcmp (file_a, file_b);
+
+  if (file_compare != 0)
+    return file_compare;
+
+  if (line_a < line_b)
+    return -1;
+  else if (line_a > line_b)
+    return 1;
+
+  loop_depth_a = bb_loop_depth (BLOCK_FOR_INSN (insn_a));
+  loop_depth_b = bb_loop_depth (BLOCK_FOR_INSN (insn_b));
+
+  if (loop_depth_a < loop_depth_b)
+    return -1;
+  else if (loop_depth_a > loop_depth_b)
+    return 1;
+
+  return 0;
+}
+
+
+static void
+update_desc_for_unroll_pragma (struct loop *loop ATTRIBUTE_UNUSED,
+			       struct niter_desc *desc,
+			       rtx pragma)
+{
+  unsigned unroll_factor = get_unroll_factor (pragma);
+
+  /* If unroll factor is 0, it really means "don't unroll" which is
+     the same as setting unroll factor to 1.  */
+  if (unroll_factor == 0)
+    unroll_factor = 1;
+
+  desc->pragma_unroll_factor = unroll_factor;
+}
+
+
+static void
+update_desc_for_must_iterate_pragma (struct loop *loop, struct niter_desc *desc,
+				     rtx pragma)
+{
+  rtx pattern = PATTERN (pragma);
+  unsigned HOST_WIDE_INT pragma_niter_min = XINT (XVECEXP (pattern, 0, 0), 0);
+  unsigned HOST_WIDE_INT pragma_niter_max = XINT (XVECEXP (pattern, 0, 1), 0);
+  unsigned HOST_WIDE_INT pragma_niter_multiple =
+    XINT (XVECEXP (pattern, 0, 2), 0);
+  double_int bound;
+
+  desc->has_must_iterate_pragma = true;
+  desc->pragma_niter_min = pragma_niter_min;
+  desc->pragma_niter_max = pragma_niter_max;
+  desc->pragma_niter_multiple = pragma_niter_multiple;
+
+  /* FIXME: don't really understand desc->noloop_assumptions and how to
+     initialize it.  */
+
+  if (pragma_niter_max != (unsigned HOST_WIDE_INT) -1)
+    {
+      bound = double_int::from_uhwi (pragma_niter_max - 1);
+      record_niter_bound (loop, bound, false, true);
+      desc->infinite = NULL_RTX;
+    }
+
+  if (pragma_niter_min == pragma_niter_max)
+    {
+      if (desc->const_iter && (desc->niter != pragma_niter_min - 1))
+	{
+	  const char *file = insn_file (pragma);
+	  int line = insn_line (pragma);
+	  emit_pragma_warning_header (file);
+
+	  fprintf (stderr,
+		   "%s:%d: warning: must_iterate iteration count (%lld) "
+		   "is inconsistent with actual iteration count (%lld).\n",
+		   file, line, pragma_niter_min, desc->niter + 1);
+	}
+
+      desc->pragma_niter_multiple = pragma_niter_min;
+
+      /* We can set the constant iteration info based on pragmas, but don't
+         bother since I don't see any tangible benefit at the moment.  */
+    }
+}
+
+
+static void
+match_pragmas_with_loops (vec<rtx, va_gc> *loop_insns,
+			  vec<rtx, va_gc> *pragmas,
+			  void (*update_desc) (struct loop *,
+					       struct niter_desc *, rtx))
+{
+  vec<int> warned_locations;
+  size_t li;
+  size_t ui;
+
+  warned_locations.create (pragmas->length ());
+
+  qsort (loop_insns->address (), loop_insns->length (),
+	 sizeof (rtx), insn_location_compare);
+
+  qsort (pragmas->address (), pragmas->length (),
+	 sizeof (rtx), insn_location_compare);
+
+  li = 0;
+  ui = 0;
+
+  while (ui < pragmas-> length())
+    {
+      rtx pragma = (*pragmas)[ui++];
+      size_t start_li = li;
+
+      /* Find the nearest loop_insn following the pragma.  */
+      rtx nearest_loop_insn = NULL;
+      for (; li < loop_insns->length (); li++)
+	{
+	  rtx loop_insn = (*loop_insns)[li];
+
+	  int cmp = insn_location_compare (&pragma, &loop_insn);
+
+	  /* pragma precedes loop_insn ==> possible match.  */
+	  if (cmp == 1)
+	    nearest_loop_insn = loop_insn;
+	  else
+	    break;
+	}
+
+      if (nearest_loop_insn != NULL)
+	{
+	  const char *file_loop = insn_file (nearest_loop_insn);
+	  const char *file_pragma = insn_file (pragma);
+
+	  if (dump_file)
+	    {
+	      fprintf (dump_file,
+		       ";; Matching loop pragma %s:%d with loop %s:%d\n",
+		       file_pragma, insn_line (pragma),
+		       file_loop, insn_line (nearest_loop_insn));
+	    }
+
+	  /* Sanity checks  */
+
+	  /* The pragma should be in the same file, and at a lower loop
+	     depth.  */
+	  if (strcmp (file_loop, file_pragma) != 0 ||
+	      (bb_loop_depth (BLOCK_FOR_INSN (nearest_loop_insn)) <=
+	       bb_loop_depth (BLOCK_FOR_INSN (pragma))))
+	    {
+	      warn_unmatched_loop_pragma (pragma, &warned_locations);
+	      li = start_li;
+	    }
+	  else
+	    {
+	      struct loop *loop =
+		BLOCK_FOR_INSN (nearest_loop_insn)->loop_father;
+	      struct niter_desc *desc = get_simple_loop_desc (loop);
+
+	      update_desc (loop, desc, pragma);
+
+	      /* Handle cases where we have multiple copies of the pragma/loop
+	         due to cloning or inlining.  These pragmas/loops will have the
+	         same line numbers, and we need to rewind li to so that we're
+	         matching one such loop at a time.  */
+	      for (; li - 1 > start_li; li--)
+		{
+		  const rtx loop_insn1 = (*loop_insns)[li - 2];
+		  const rtx loop_insn2 = (*loop_insns)[li - 1];
+		  int cmp = insn_location_compare (&loop_insn1, &loop_insn2);
+		  if (cmp != 0)
+		    break;
+		}
+	    }
+	}
+      else
+	warn_unmatched_loop_pragma (pragma, &warned_locations);
+    }
+
+  warned_locations.release ();
+}
+
+
+static void
+delete_insns (vec<rtx, va_gc> *insns)
+{
+  size_t i;
+  for (i = 0; i < insns->length (); i++)
+    delete_insn ((*insns)[i]);
+}
+
+
+static void
+parse_loop_pragmas (void)
+{
+  vec<rtx, va_gc> *unroll_pragmas;
+  vec<rtx, va_gc> *must_iterate_pragmas;
+  vec<rtx, va_gc> *loop_insns;
+
+  emitted_pragma_warning_header = false;
+
+  vec_alloc (unroll_pragmas, number_of_loops ());
+  unroll_pragmas =
+    get_loop_pragmas (unroll_pragmas, CODE_FOR_tilegx_pragma_unroll);
+
+  vec_alloc (must_iterate_pragmas, number_of_loops ());
+  must_iterate_pragmas =
+    get_loop_pragmas (must_iterate_pragmas,
+		      CODE_FOR_tilegx_pragma_must_iterate);
+
+  if (unroll_pragmas->length () == 0 &&
+      must_iterate_pragmas->length () == 0)
+    return;
+
+  vec_alloc (loop_insns, number_of_loops ());
+  loop_insns = get_inner_loop_insns (loop_insns);
+
+  if (unroll_pragmas->length ())
+    {
+      match_pragmas_with_loops (loop_insns, unroll_pragmas,
+				update_desc_for_unroll_pragma);
+
+      delete_insns (unroll_pragmas);
+    }
+
+  if (must_iterate_pragmas->length ())
+    {
+      match_pragmas_with_loops (loop_insns, must_iterate_pragmas,
+				update_desc_for_must_iterate_pragma);
+
+      delete_insns (must_iterate_pragmas);
+    }
+}
+
+
+static void
+tilegx_pre_unrolling_and_peeling_hook (void)
+{
+  parse_loop_pragmas ();
+}
+
+
+
+/* Parsing of post-incrementing intrinsics.  */
+
+
+struct asm_descriptor
+{
+  const char *string;
+  insn_gen_fn::f0 fn;
+  insn_gen_fn::f0 fn_32bit;
+  const enum machine_mode mode;
+};
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns whether
+   their template strings match STR.  */
+static bool
+match_asm_string (rtx pattern1, rtx pattern2, const char *str)
+{
+  return
+    strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern1)), str) == 0 &&
+    strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern2)), str) == 0;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns an
+   asm_dsecriptor in DESC with a matching template string, or NULL if no match
+   is found.  */
+static const asm_descriptor *
+match_asm_descriptor (rtx pattern1, rtx pattern2, const asm_descriptor *desc)
+{
+  int i;
+
+  for (i = 0; desc[i].string != NULL; i++)
+    {
+      if (match_asm_string (pattern1, pattern2, desc[i].string))
+	return &desc[i];
+    }
+
+  return NULL;
+}
+
+
+/* PATTERN is a SET statement of ASM_OPERANDS.  Returns whether the PATTERN
+   satisfies the following:
+
+   dest idx is DEST_IDX;
+   dest constraint is DEST_CONSTRAINT;
+   dest mode is DEST_MODE;
+   has NUM_SRCS number of source operands;
+   its source operands satisfy CONSTRANTS and MODES.  */
+static bool
+asm_sanity_check (rtx pattern, int dest_idx,
+		  const char *dest_constraint,
+		  const enum machine_mode dest_mode,
+		  int num_srcs, const char *src_constraints[],
+		  const enum machine_mode src_modes[])
+{
+  int i;
+
+  if (strcmp (ASM_OPERANDS_OUTPUT_CONSTRAINT (SET_SRC (pattern)),
+	      dest_constraint) != 0)
+    return false;
+
+  if (GET_MODE (SET_SRC (pattern)) != dest_mode)
+    return false;
+
+  if (ASM_OPERANDS_OUTPUT_IDX (SET_SRC (pattern)) != dest_idx)
+    return false;
+
+  if (ASM_OPERANDS_INPUT_LENGTH (SET_SRC (pattern)) != num_srcs)
+    return false;
+
+  for (i = 0; i < num_srcs; i++)
+    {
+      rtx constraint_exp =
+	ASM_OPERANDS_INPUT_CONSTRAINT_EXP (SET_SRC (pattern), i);
+
+      if (GET_CODE (constraint_exp) != ASM_INPUT)
+	return false;
+
+      if (GET_MODE (constraint_exp) != src_modes[i])
+	return false;
+
+      if (strcmp (ASM_OPERANDS_INPUT_CONSTRAINT (SET_SRC (pattern), i),
+		  src_constraints[i]) != 0)
+	return false;
+    }
+
+  return true;
+}
+
+/* PATTERN is a SET statement of ASM_OPERANDS.  Returns a prefetch-add
+   asm_descriptor that matches the pattern.  */
+static const asm_descriptor *
+match_prefetchadd (rtx pattern)
+{
+#define ARGS " %0, %1"
+#define ASM_DESC_ENTRY(op) \
+    { #op ARGS, (insn_gen_fn::f0)gen_insn_ ## op, \
+                (insn_gen_fn::f0)gen_insn_ ## op ## _32bit, VOIDmode }
+  static const asm_descriptor descriptor[] = {
+    ASM_DESC_ENTRY(prefetch_add_l1),
+    ASM_DESC_ENTRY(prefetch_add_l1_fault),
+    ASM_DESC_ENTRY(prefetch_add_l2),
+    ASM_DESC_ENTRY(prefetch_add_l2_fault),
+    ASM_DESC_ENTRY(prefetch_add_l3),
+    ASM_DESC_ENTRY(prefetch_add_l3_fault),
+    { NULL, NULL, NULL, VOIDmode },
+  };
+#undef ARGS
+#undef ASM_DESC_ENTRY
+  int i;
+
+  for (i = 0; descriptor[i].string != NULL; i++)
+    {
+      if (strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern)),
+		  descriptor[i].string) == 0)
+	return &descriptor[i];
+    }
+
+  return NULL;
+}
+
+
+/* Check whether the prefetch add patterns conform to what we expect.  */
+static bool
+sanity_check_prefetchadd_operands (rtx pattern)
+{
+  static const char *src_constraints[] = { "i", "0" };
+  enum machine_mode src_modes[] = { SImode, Pmode };
+
+  return asm_sanity_check (pattern, 0, "=r", Pmode, 2, src_constraints,
+			   src_modes);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("prefetch_l1_add %0, %2, %3") ("=r") 0
+               [ SRC0 SRC1 ]
+               [ (asm_input:SI ("i") 0)
+                 (asm_input:DI ("0") 0) ]))
+
+  FN is the cprresponding prefetch-add generating function.  Create
+  and return the corresponding prefetch-add rtl.
+*/
+static rtx
+gen_prefetchadd (rtx pattern, insn_gen_fn::f3 fn)
+{
+  rtx dest = SET_DEST (pattern);
+  rtx src0 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 0);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 1);
+  rtx res = fn (dest, src0, src1);
+
+  /* return the pattern, not the insn containing it.  */
+  if (INSN_P (res))
+    return PATTERN (res);
+  else
+    return res;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns a
+   store-add asm_descriptor that matches that of the two patterns, or NULL if
+   no match is found.  */
+static const asm_descriptor *
+match_storeadd (rtx pattern1, rtx pattern2)
+{
+#define ARGS " %0, %2, %3"
+#define ASM_DESC_ENTRY(op, mode) \
+    { #op ARGS, (insn_gen_fn::f0)gen_insn_ ## op, \
+                (insn_gen_fn::f0)gen_insn_ ## op ## _32bit, mode }
+  static const asm_descriptor descriptor[] = {
+    ASM_DESC_ENTRY (st1_add, QImode),
+    ASM_DESC_ENTRY (st2_add, HImode),
+    ASM_DESC_ENTRY (st4_add, SImode),
+    ASM_DESC_ENTRY (st_add, DImode),
+    ASM_DESC_ENTRY (stnt1_add, QImode),
+    ASM_DESC_ENTRY (stnt2_add, HImode),
+    ASM_DESC_ENTRY (stnt4_add, SImode),
+    ASM_DESC_ENTRY (stnt_add, DImode),
+    {NULL, NULL, NULL, VOIDmode},
+  };
+#undef ARGS
+#undef ASM_DESCRIPTOR
+
+  return match_asm_descriptor (pattern1, pattern2, descriptor);
+}
+
+
+/* Check whether the store add patterns conform to what we expect.  */
+static bool
+sanity_check_storeadd_operands (rtx pattern1, rtx pattern2,
+				enum machine_mode mem_mode)
+{
+  static const char *src_constraints[] = { "r", "i", "0" };
+  enum machine_mode src_modes[] =
+  { word_mode, SImode, Pmode };
+
+  return
+    asm_sanity_check (pattern1, 0, "=r", Pmode,
+		      3, src_constraints, src_modes) &&
+    asm_sanity_check (pattern2, 1, "=m", mem_mode,
+		      3, src_constraints, src_modes);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("st_add %0, %2, %3") ("=r") 0
+               [ SRC0 SRC1 SRC2 ]
+               [ (asm_input:MODE ("r") 0)
+                 (asm_input:SI ("i") 0)
+                 (asm_input:DI ("0") 0) ]))
+
+  FN is the cprresponding store-add generating function.  Create and return the
+  corresponding store-add rtl.
+*/
+static rtx
+gen_storeadd (rtx pattern, insn_gen_fn::f4 fn,
+	      enum machine_mode mode ATTRIBUTE_UNUSED)
+{
+  rtx dest = SET_DEST (pattern);
+  rtx src0 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 0);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 1);
+  rtx src2 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 2);
+  rtx res = fn (dest, src0, src1, src2);
+
+  /* return the pattern, not the insn containing it.  */
+  if (INSN_P (res))
+    return PATTERN (res);
+  else
+    return res;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns a
+   load-add whose template string matches that of the two patterns, or NULL if
+   no match is found.  */
+static const asm_descriptor *
+match_loadadd (rtx pattern1, rtx pattern2)
+{
+#define ARGS " %0, %1, %3"
+#define ASM_DESC_ENTRY(op, mode) \
+    { #op ARGS, (insn_gen_fn::f0)gen_insn_ ## op, \
+                (insn_gen_fn::f0)gen_insn_ ## op ## _32bit, mode }
+  static const asm_descriptor descriptor[] = {
+    ASM_DESC_ENTRY (ld1s_add, QImode),
+    ASM_DESC_ENTRY (ld1u_add, QImode),
+    ASM_DESC_ENTRY (ld2s_add, HImode),
+    ASM_DESC_ENTRY (ld2u_add, HImode),
+    ASM_DESC_ENTRY (ld4s_add, SImode),
+    ASM_DESC_ENTRY (ld4u_add, SImode),
+    ASM_DESC_ENTRY (ld_add, DImode),
+    ASM_DESC_ENTRY (ldnt1s_add, QImode),
+    ASM_DESC_ENTRY (ldnt1u_add, QImode),
+    ASM_DESC_ENTRY (ldnt2s_add, HImode),
+    ASM_DESC_ENTRY (ldnt2u_add, HImode),
+    ASM_DESC_ENTRY (ldnt4s_add, SImode),
+    ASM_DESC_ENTRY (ldnt4u_add, SImode),
+    ASM_DESC_ENTRY (ldnt_add, DImode),
+    ASM_DESC_ENTRY (ldna_add, DImode),
+
+    ASM_DESC_ENTRY (ld1s_add_L2, QImode),
+    ASM_DESC_ENTRY (ld1u_add_L2, QImode),
+    ASM_DESC_ENTRY (ld2s_add_L2, HImode),
+    ASM_DESC_ENTRY (ld2u_add_L2, HImode),
+    ASM_DESC_ENTRY (ld4s_add_L2, SImode),
+    ASM_DESC_ENTRY (ld4u_add_L2, SImode),
+    ASM_DESC_ENTRY (ld_add_L2, DImode),
+    ASM_DESC_ENTRY (ldnt1s_add_L2, QImode),
+    ASM_DESC_ENTRY (ldnt1u_add_L2, QImode),
+    ASM_DESC_ENTRY (ldnt2s_add_L2, HImode),
+    ASM_DESC_ENTRY (ldnt2u_add_L2, HImode),
+    ASM_DESC_ENTRY (ldnt4s_add_L2, SImode),
+    ASM_DESC_ENTRY (ldnt4u_add_L2, SImode),
+    ASM_DESC_ENTRY (ldnt_add_L2, DImode),
+    ASM_DESC_ENTRY (ldna_add_L2, DImode),
+
+    ASM_DESC_ENTRY (ld1s_add_miss, QImode),
+    ASM_DESC_ENTRY (ld1u_add_miss, QImode),
+    ASM_DESC_ENTRY (ld2s_add_miss, HImode),
+    ASM_DESC_ENTRY (ld2u_add_miss, HImode),
+    ASM_DESC_ENTRY (ld4s_add_miss, SImode),
+    ASM_DESC_ENTRY (ld4u_add_miss, SImode),
+    ASM_DESC_ENTRY (ld_add_miss, DImode),
+    ASM_DESC_ENTRY (ldnt1s_add_miss, QImode),
+    ASM_DESC_ENTRY (ldnt1u_add_miss, QImode),
+    ASM_DESC_ENTRY (ldnt2s_add_miss, HImode),
+    ASM_DESC_ENTRY (ldnt2u_add_miss, HImode),
+    ASM_DESC_ENTRY (ldnt4s_add_miss, SImode),
+    ASM_DESC_ENTRY (ldnt4u_add_miss, SImode),
+    ASM_DESC_ENTRY (ldnt_add_miss, DImode),
+    ASM_DESC_ENTRY (ldna_add_miss, DImode),
+
+    {NULL, NULL, NULL, VOIDmode},
+  };
+#undef ARGS
+#undef ASM_DESC_ENTRY
+
+  return match_asm_descriptor (pattern1, pattern2, descriptor);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("ld_add %0, %1, %3") ("=r") 0
+               [ SRC0 SRC1 SRC2 ]
+               [ (asm_input:MODE ("m") 0)
+                 (asm_input:SI ("i") 0)
+                 (asm_input:DI ("1") 0) ]))
+
+  FN is the cprresponding store-add generating function.  Create and return the
+  corresponding load-add rtl.
+*/
+static rtx
+gen_loadadd (rtx pattern1, rtx pattern2, insn_gen_fn::f4 fn,
+	     enum machine_mode mode ATTRIBUTE_UNUSED)
+{
+  rtx dest0 = SET_DEST (pattern1);
+  rtx dest1 = SET_DEST (pattern2);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern1), 1);
+  rtx src2 = ASM_OPERANDS_INPUT (SET_SRC (pattern1), 2);
+
+  return fn (dest0, dest1, src1, src2);
+}
+
+
+/* Check whether the store add patterns conform to what we expect.  */
+static bool
+sanity_check_loadadd_operands (rtx pattern1, rtx pattern2,
+			       enum machine_mode mem_mode)
+{
+  static const char *src_constraints[] = { "m", "i", "1" };
+  enum machine_mode src_modes[] =
+  { mem_mode, SImode, Pmode };
+
+  return
+    asm_sanity_check (pattern1, 0, "=r", DImode,
+		      3, src_constraints, src_modes) &&
+    asm_sanity_check (pattern2, 1, "=r", Pmode,
+		      3, src_constraints, src_modes);
+}
+
+
+/* Do post processing after rtl expansion.  */
+static void
+tilegx_post_expand_to_rtl_hook (void)
+{
+  rtx insn, last;
+  basic_block bb;
+
+  if (!TARGET_EXPAND_ASM)
+    return;
+
+  /* Look for specific inline assembly patterns and replace them with
+     rtl that the compiler can understand, optimize, schedule, and
+     bundle.  We use this to implement post-inc load/store
+     intrinsics.  */
+  FOR_EACH_BB (bb)
+    {
+      for (insn = BB_HEAD (bb), last = NEXT_INSN (BB_END (bb));
+	   insn != last; insn = NEXT_INSN (insn))
+	{
+	  rtx pattern;
+	  rtx pattern1;
+	  rtx pattern2;
+	  const asm_descriptor *desc;
+
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  pattern = PATTERN (insn);
+
+	  /* post-inc prefetches.  */
+	  if (GET_CODE (pattern) == SET
+	      && GET_CODE (SET_SRC (pattern)) == ASM_OPERANDS)
+	    {
+	      if ((desc = match_prefetchadd (pattern)))
+		{
+		  if (sanity_check_prefetchadd_operands (pattern))
+		    {
+		      insn_gen_fn::f3 fn
+			= (insn_gen_fn::f3)((TARGET_32BIT)
+					    ? desc->fn_32bit : desc->fn);
+		      PATTERN (insn) =
+			gen_prefetchadd (pattern, fn);
+		    }
+		  else
+		    {
+		      location_t loc =
+			ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern));
+		      warning_at (loc, 0,
+				  "Unrecognized prefetch-add asm pattern");
+		    }
+		}
+	      continue;
+	    }
+
+	  /* post-inc loads and stores.  */
+	  if (!(GET_CODE (pattern) == PARALLEL
+		&& XVECLEN (pattern, 0) == 2))
+	    continue;
+
+	  pattern1 = XVECEXP (pattern, 0, 0);
+	  pattern2 = XVECEXP (pattern, 0, 1);
+
+	  if (!(GET_CODE (pattern1) == SET
+		&& GET_CODE (pattern2) == SET
+		&& GET_CODE (SET_SRC (pattern1)) == ASM_OPERANDS
+		&& GET_CODE (SET_SRC (pattern2)) == ASM_OPERANDS))
+	    continue;
+
+	  if ((desc = match_storeadd (pattern1, pattern2)))
+	    {
+	      if (sanity_check_storeadd_operands (pattern1, pattern2,
+						  desc->mode))
+		{
+		  insn_gen_fn::f4 fn
+		    = (insn_gen_fn::f4)((TARGET_32BIT)
+					? desc->fn_32bit : desc->fn);
+		  PATTERN (insn) = gen_storeadd (pattern1, fn, desc->mode);
+		}
+	      else
+		{
+		  location_t loc =
+		    ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern1));
+		  warning_at (loc, 0, "Unrecognized store-add asm pattern");
+		}
+
+	    }
+	  else if ((desc = match_loadadd (pattern1, pattern2)))
+	    {
+	      if (sanity_check_loadadd_operands (pattern1, pattern2,
+						 desc->mode))
+		{
+		  insn_gen_fn::f4 fn
+		    = (insn_gen_fn::f4)((TARGET_32BIT)
+					? desc->fn_32bit : desc->fn);
+		  PATTERN (insn) =
+		    gen_loadadd (pattern1, pattern2, fn, desc->mode);
+		}
+	      else
+		{
+		  location_t loc =
+		    ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern1));
+		  warning_at (loc, 0, "Unrecognized load-add asm pattern");
+		}
+	    }
+	}
+    }
+}
+
+/* Functions to support gathering information on compiler
+   optimizations.  */
+
+static FILE *
+tilegx_lock_data_file (const char *fn)
+{
+  struct flock fl;
+  int fd;
+  FILE *file;
+
+  fl.l_type   = F_WRLCK;
+  fl.l_whence = SEEK_SET;
+  fl.l_start  = 0;
+  fl.l_len    = 0;
+  fl.l_pid    = getpid();
+
+  fd = open (fn, O_CREAT|O_WRONLY, 0644);
+  if (fd == -1)
+    abort ();
+
+  if (fcntl (fd, F_SETLKW, &fl) == -1)
+    abort ();
+
+  file = fdopen (fd, "a");
+  if (file == NULL)
+    {
+      fl.l_type   = F_UNLCK;
+      fcntl (fd, F_SETLK, &fl);
+      abort ();
+    }
+
+  return file;
+}
+
+
+static void
+tilegx_unlock_data_file (FILE *file)
+{
+  struct flock fl;
+
+  fl.l_type   = F_UNLCK;
+  fl.l_whence = SEEK_SET;
+  fl.l_start  = 0;
+  fl.l_len    = 0;
+  fl.l_pid    = getpid();
+
+  if (fcntl (fileno (file), F_SETLK, &fl) == -1)
+    abort ();
+
+  fclose (file);
+}
+
+
+
+/* Extension propagation optimization.  */
+
+
+/* Print X to OUTF, and add a newline.  */
+static void
+print_rtx (FILE *outf, const_rtx x)
+{
+  print_inline_rtx (outf, x, 0);
+  fprintf (outf, "\n");
+}
+
+
+/* A classification of various extension types.  */
+enum extend_type
+{
+  no_extend,
+  si_to_udi,
+  di_to_udi,
+  si_to_sdi,
+  di_to_sdi,
+  di_to_si
+};
+
+
+/* Extension information of an instruction.  */
+struct insn_extend_info
+{
+  rtx insn;
+  enum extend_type extend_type;
+  rtx extend_insn;
+  int num_uses;
+  bool is_propagate_candidate;
+};
+
+
+/* Returns the hash value of a pointer to a insn_extend_info.  */
+static hashval_t
+htab_iei_hash (const void *p)
+{
+  const struct insn_extend_info *const iei
+    = (const struct insn_extend_info *) p;
+
+  return (hashval_t)INSN_UID (iei->insn);
+}
+
+
+/* Equality function for insn_extend_info *.  */
+static int
+htab_iei_eq (const void *p1, const void *p2)
+{
+  const struct insn_extend_info *const iei1
+    = (const struct insn_extend_info *) p1;
+  const struct insn_extend_info *const iei2
+    = (const struct insn_extend_info *) p2;
+
+  return INSN_UID (iei1->insn) == INSN_UID (iei2->insn);
+}
+
+
+/* Hash entry delete function for insn_extend_info *.  */
+static void
+htab_iei_del (void *p)
+{
+  struct insn_extend_info *const iei = (struct insn_extend_info *) p;
+  free (iei);
+}
+
+
+/* Create an insn_extend_info for INSN, and add it to the hash
+   table.  */
+static struct insn_extend_info *
+create_insn_extend_info (rtx insn, htab_t insn_extend_infos)
+{
+  struct insn_extend_info *info;
+  struct insn_extend_info **slot;
+
+  info = XCNEW (struct insn_extend_info);
+  
+  info->insn = insn;
+  slot = (struct insn_extend_info **) htab_find_slot (insn_extend_infos, info,
+						      INSERT);
+  *slot = info;
+
+  return info;
+}
+
+
+/* Return the insn_extend_info corresponding to INSN in the hash
+   table.  */
+static struct insn_extend_info *
+get_insn_extend_info (rtx insn, htab_t insn_extend_infos)
+{
+  struct insn_extend_info key;
+  key.insn = insn;
+  return (struct insn_extend_info *)htab_find (insn_extend_infos, &key);
+}
+
+
+/* Get the Nth operand of a set insn.  Requires that INSN is a set
+   instruction.  */
+static rtx
+get_set_src_xexp (rtx insn, int n)
+{
+  rtx pattern = PATTERN (insn);
+  rtx set_src;
+
+  if (GET_CODE (pattern) != SET)
+    return NULL_RTX;
+
+  set_src = SET_SRC (pattern);
+
+  return XEXP (set_src, n);
+}
+
+
+/* Return the extend type of INSN.  */
+static enum extend_type
+classify_extend (rtx insn)
+{
+  int code;
+  rtx src;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_zero_extendsidi2:
+    case CODE_FOR_extendsidi2:
+      src = get_set_src_xexp (insn, 0);
+
+      if (src == NULL_RTX)
+	return no_extend;
+      else if (REG_P (src))
+	return (code == CODE_FOR_zero_extendsidi2) ? si_to_udi : si_to_sdi;
+      else if (GET_CODE (src) == SUBREG
+	       && GET_MODE (SUBREG_REG (src)) == DImode)
+	return (code == CODE_FOR_zero_extendsidi2) ? di_to_udi : di_to_sdi;
+
+      break;
+    case CODE_FOR_truncdisi2:
+      src = get_set_src_xexp (insn, 0);
+
+      if (src == NULL_RTX)
+	return no_extend;
+      else if (REG_P (src))
+	return di_to_si;
+    default:
+      ;
+     }
+
+  return no_extend;
+}
+
+
+/* Initialize extension information for INSN.  We keep track of one
+   extension per INSN.  This is used for two purposes: to find
+   candidates for propagation, and to evalulate the cost of adding and
+   extend to an operation.  Return whether one is found.  */
+static bool
+init_insn_extend_info (rtx insn, htab_t insn_extend_infos)
+{
+  rtx pattern;
+  struct insn_extend_info *info;
+  df_ref def, use;
+  struct df_link *link;
+  rtx extend_insn;
+  enum extend_type extend_type;
+  int num_uses;
+
+  pattern = PATTERN (insn);
+
+  /* Only handle SETs.  */
+  if (GET_CODE (pattern) != SET)
+    return false;
+
+  if (!REG_P (SET_DEST (pattern)))
+    return false;
+
+  def = df_find_def (insn, SET_DEST (pattern));
+
+  /* FIXME: I wouldn't expect DEF to be NULL, but this seems to happen
+     if we're writing to a floating argument register used by call,
+     cos the register inside DEF is of mode DI.  For now we just
+     conservatively give up.  */
+  if (!def)
+    return false;
+
+  link = DF_REF_CHAIN (def);
+
+  num_uses = 0;
+  extend_type = no_extend;
+  for (; link; link = link->next, num_uses++)
+    {
+      rtx use_insn;
+      enum extend_type type;
+
+      if (DF_REF_IS_ARTIFICIAL (link->ref))
+	continue;
+      
+      use_insn = DF_REF_INSN (link->ref);
+      type = classify_extend (use_insn);
+
+      if (type != no_extend
+	  && extend_type == no_extend)
+	{
+	  extend_insn = use_insn;
+	  extend_type = type;
+	}
+    }
+
+  if (extend_type == no_extend)
+    return false;
+
+  /* The extension must only have one parent (i.e. INSN).  */
+  use = df_find_use (extend_insn, SET_DEST (pattern));
+  link = DF_REF_CHAIN (use);
+  if (!(link && !link->next))
+    return false;
+
+  info = create_insn_extend_info (insn, insn_extend_infos);
+  info->extend_insn = extend_insn;
+  info->extend_type = extend_type;
+  info->num_uses = num_uses;
+
+  /* Determine whether this extension is a candidate for
+     propagation.  For an extend to be a valid candidate, we
+     require the following:
+     - it has only one parent (i.e. INSN).
+     - it is in the same basic block as INSN.
+     - it follows INSN in the basic block.
+     - it is not a si_to_sdi (which is a no-op anyways).
+     - it is not a di_to_si (FIXME: temporarily disable until we can
+       resolve phase ordering issue with combine.)  */
+  if (num_uses == 1
+      && BLOCK_NUM (insn) == BLOCK_NUM (extend_insn)
+      && extend_type != si_to_sdi
+      && extend_type != di_to_si)
+    info->is_propagate_candidate = true;
+
+  if (dump_file)
+    fprintf (dump_file,
+	     "Create insn_extend_info %p insn %d extend_insn %d "
+	     "extend_type %d num_uses %d is_candidate %d\n",
+	     (void *)info, INSN_UID (info->insn), INSN_UID (info->extend_insn),
+	     (int)info->extend_type, info->num_uses,
+	     info->is_propagate_candidate);
+
+  return true;
+}
+
+
+/* Check that REF has exactly one link and that the link is not
+   artifical, and return the link's reference.  Return NULL_RTX if the
+   conditions are not met.  */
+static rtx
+get_single_link_insn (df_ref ref)
+{
+  struct df_link *link;
+
+  link = DF_REF_CHAIN (ref);
+
+  if (!(link && !link->next))
+    return NULL_RTX;
+
+  if (DF_REF_IS_ARTIFICIAL (link->ref))
+    return NULL_RTX;
+
+  return DF_REF_INSN (link->ref);
+}
+
+
+/* Check that INSN has a single successor, and if so return it.
+   Return NULL_RTX otherwise.  */
+static rtx
+get_single_succ (rtx insn)
+{
+  df_ref *defs;
+
+  defs = DF_INSN_DEFS (insn);
+  if (!(defs[0] && !defs[1]))
+    return NULL_RTX;
+
+  return get_single_link_insn (defs[0]);
+}
+
+
+/* Returns whether INSN preserves sign extension.  We currently only
+   handle a subset of all such operations: ands, ors, and xors with
+   register operands.  We also currently require register operands,
+   but it should also support constant operands.  */
+static bool
+insn_propagates_extend (rtx insn)
+{
+  int code;
+  rtx src0, src1;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_xorsi3:
+    case CODE_FOR_xordi3:
+    case CODE_FOR_iorsi3:
+    case CODE_FOR_iordi3:
+    case CODE_FOR_andsi3:
+    case CODE_FOR_anddi3:
+      src0 = get_set_src_xexp (insn, 0);
+      src1 = get_set_src_xexp (insn, 1);
+
+      if (!src0 || !src1)
+	return false;
+
+      if (!REG_P (src0) && GET_CODE (src0) != SUBREG)
+	return false;
+
+      if (!REG_P (src1) && GET_CODE (src1) != SUBREG)
+	return false;
+
+      return true;
+      break;
+    default:
+      return false;
+    }
+}
+
+
+/* Returns whether an extension of TYPE1 is compatible with an
+   extension of TYPE0.  */
+static bool extend_type_compatible (enum extend_type type0,
+				    enum extend_type type1)
+{
+  switch (type0)
+    {
+    case si_to_udi:
+    case di_to_udi:
+      return type1 == si_to_udi || type1 == di_to_udi;
+    case si_to_sdi:
+    case di_to_sdi:
+      return type1 == si_to_sdi || type1 == di_to_sdi;
+    case di_to_si:
+      return type1 == di_to_si;
+    default:
+      return false;
+    }
+}
+
+
+/* Returns whether there is a variant of INSN with TYPE extension.
+   Currently we only handle a subset of such patterns.  */
+static bool
+has_extend_pattern (rtx insn, enum extend_type type ATTRIBUTE_UNUSED)
+{
+  int code;
+  rtx pattern;
+  rtx set_src;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_zero_extendsidi2:
+    case CODE_FOR_extendsidi2:
+      return true;
+      break;
+    default:
+      pattern = PATTERN (insn);
+
+      if (GET_CODE (pattern) != SET)
+	return false;
+
+      set_src = SET_SRC (pattern);
+      if (GET_MODE (set_src) == SImode
+	  && GET_CODE (set_src) == MEM)
+	return true;
+
+      return false;
+    }
+
+  gcc_unreachable ();
+}
+
+
+static bool
+can_combine_for_free (rtx insn, enum extend_type type)
+{
+  /* Check that INSN only has a single use, which presumably is the
+     one that requires the extension.  */
+  rtx succ = get_single_succ (insn);
+
+  if (!succ)
+    return false;
+
+  return has_extend_pattern (insn, type);
+}
+
+
+/* Returns the cost of adding the extension of type TYPE to INSN.  The
+   cost is either 0 or 1.  It's 0 if:
+   - the extension is a noop (FIXME: not yet implemented).
+   - the extension already exists.
+   - the extension can be combined with INSN into a single
+     instruction, INSN only has one use.  */
+static int
+extension_cost (rtx insn, enum extend_type type, htab_t insn_extend_info)
+{
+  struct insn_extend_info *info;
+
+  info = get_insn_extend_info (insn, insn_extend_info);
+
+  if (info && extend_type_compatible (type, info->extend_type))
+    return 0;
+
+  if (can_combine_for_free (insn, type))
+    return 0;
+
+  return 1;
+}
+
+
+/* The maximum number of levels of dependencies we will traverse.  */
+#define MAX_PROPAGATE_LEVELS 3
+
+/* The maximum number of source operands supported for each propagated
+   instruction.  */
+#define MAX_PROPAGATE_SOURCES 2
+
+/* The maximum number of target instructions supported.  */
+#define MAX_PROPAGATE_TARGETS 8
+
+/* The maximum number of through instructions supported.  */
+#define MAX_PROPAGATE_THROUGH 7
+
+/* Information on an extension propagation opportunity.  */
+struct propagate_extend_info
+{
+  /* Information on the extension instruction to be propagated.  */
+  struct insn_extend_info *extend_info;
+
+  /* Cost of the propagation, i.e. number of extensions required.  */
+  int cost;
+
+  /* Number of targets, and through instructions.  */
+  int ntargets, nthrough;
+
+  /* The targets of the propagation.   */
+  rtx target[MAX_PROPAGATE_TARGETS];
+
+  /* The instructions through which the propagation is done.   */
+  rtx through[MAX_PROPAGATE_THROUGH];
+
+  /* The next propagate_extend_info in the list.  */
+  struct propagate_extend_info *next;
+};
+
+
+/* Add a target to PINFO.  */
+static bool
+pei_add_target (struct propagate_extend_info *pinfo, rtx target)
+{
+  if (pinfo->ntargets >= MAX_PROPAGATE_TARGETS)
+    return false;
+
+  pinfo->target[pinfo->ntargets++] = target;
+  return true;
+}
+
+
+/* Add a through instruction to PINFO.  */
+static bool
+pei_add_through (struct propagate_extend_info *pinfo, rtx through)
+{
+  if (pinfo->nthrough >= MAX_PROPAGATE_THROUGH)
+    return false;
+
+  pinfo->through[pinfo->nthrough++] = through;
+  return true;
+}
+
+
+/* Dump out the contents of PINFO.  */
+static void
+debug_pei (FILE *f, struct propagate_extend_info *pinfo, bool verbose)
+{
+  fprintf (f, "Pinfo ");
+  if (pinfo->extend_info)
+    fprintf (f, "Insn %d Type %d ", 
+	     INSN_UID (pinfo->extend_info->insn),
+	     (int)pinfo->extend_info->extend_type);
+  fprintf (f, "Cost %d Ntargets %d Nthrough %d\n",
+	   pinfo->cost, pinfo->ntargets, pinfo->nthrough);
+
+  if (verbose)
+    {
+      int i;
+      fprintf (f, "Targets\n");
+      for (i = 0; i < pinfo->ntargets; i++)
+	print_rtx (f, pinfo->target[i]);
+
+      fprintf (f, "Through\n");
+      for (i = 0; i < pinfo->nthrough; i++)
+	print_rtx (f, pinfo->through[i]);
+
+      fprintf (f, "Base\n");
+      print_rtx (f, pinfo->extend_info->insn);
+
+      fprintf (f, "Extend\n");
+      print_rtx (f, pinfo->extend_info->extend_insn);
+    }
+}
+
+
+/* Returns whether INSN0 strictly dominates INSN1 in the same basic
+   block.  */
+static bool
+strictly_dominates (rtx insn0, rtx insn1)
+{
+  basic_block bb;
+  rtx insn;
+
+  if (BLOCK_NUM (insn0) != BLOCK_NUM (insn1))
+    return false;
+
+  if (insn0 == insn1)
+    return false;
+
+  bb = BASIC_BLOCK (BLOCK_NUM (insn0));
+  for (insn = insn0; insn != NEXT_INSN (BB_END (bb)); insn = NEXT_INSN (insn))
+    {
+      if (insn == insn1)
+	return true;
+    }
+
+  return false;
+}
+
+
+/* Attempt to propagate an extension of type TYPE upward from INSN,
+   and return the result in PINFO.  If no propagation is done, return
+   PINFO containing INSN as its only target.  */
+static void
+try_propagate_extend (rtx insn, enum extend_type type,
+		      struct propagate_extend_info *pinfo, int level,
+		      htab_t insn_extend_info)
+{
+  df_ref *uses, *defs;
+  int num_uses;
+  struct df_link *link;
+  int i, j;
+  int total_src_cost;
+  struct propagate_extend_info src_pinfos[MAX_PROPAGATE_SOURCES];
+
+  /* Check the conditions required for propagation.  Initialize pinfo
+     with default information, if we don't do any propagation.  */
+  pinfo->cost = (level == 0) ? 1 : extension_cost (insn, type, insn_extend_info);
+  gcc_assert (pei_add_target (pinfo, insn));
+
+  /* Limit the depth of the search.  */
+  if (level == MAX_PROPAGATE_LEVELS)
+    return;
+
+  /* Only proceed if INSN propagates extension information.  */
+  if (!insn_propagates_extend (insn))
+    return;
+
+  uses = DF_INSN_USES (insn);
+
+  num_uses = 0;
+  while (uses[num_uses])
+    {
+      rtx src_insn = get_single_link_insn (uses[num_uses]);
+
+      /* Require that there is only one predecessor for each of its
+	 source operands.  */
+      if (src_insn == NULL_RTX)
+	return;
+
+      /* Require that the propagation be local to a basic block, to avoid
+	 degradation due to live range issues.  */
+      if (!strictly_dominates (src_insn, insn))
+	return;
+
+      num_uses++;
+    }
+
+  /* Require that we don't exeed the maximum number of source
+     operands supported.  */
+  if (num_uses > MAX_PROPAGATE_SOURCES)
+    return;
+
+  /* Require that the result is only used once.  This can be relaxed,
+     if our analysis extends to being able to analyze multiple
+     bases.  */
+  defs = DF_INSN_DEFS (insn);
+  if (!(defs[0] && !defs[1]))
+    return;
+
+  link = DF_REF_CHAIN (defs[0]);
+  if (!(link && !link->next))
+    return;
+
+  /* All the conditions for propagation have been met.  Recursively
+     propagate through the sources, and merge the results.  */
+  memset (&src_pinfos, 0, (sizeof (struct propagate_extend_info)
+			   * MAX_PROPAGATE_SOURCES));
+
+  total_src_cost = 0;
+  for (i = 0; i < num_uses; i++)
+    {
+      rtx src_insn = get_single_link_insn (uses[i]);
+
+      /* The transformation code only handles SET insns (when it tries
+	 to find the result if the insn), so require it here.  This can
+	 be relaxed in the future.  */
+      if (GET_CODE (PATTERN (src_insn)) != SET)
+	return;
+
+      try_propagate_extend (src_insn, type, &src_pinfos[i], level + 1,
+			    insn_extend_info);
+      total_src_cost += src_pinfos[i].cost;
+
+      if (dump_file)
+	{
+	  fprintf (dump_file, "try_propagate_extend level %d\n", level + 1);
+	  print_rtx (dump_file, src_insn);
+	  debug_pei (dump_file, &src_pinfos[i], false);
+	}
+    }
+
+  if (total_src_cost <= pinfo->cost)
+    {
+      if (dump_file)
+	fprintf (dump_file, "Found better cost %d <= %d\n", total_src_cost,
+		 pinfo->cost);
+
+      pinfo->ntargets = 0;
+      pinfo->target[0] = NULL_RTX;
+
+      pinfo->cost = total_src_cost;
+
+      for (i = 0; i < num_uses; i++)
+	{
+	  for (j = 0; j < src_pinfos[i].ntargets; j++)
+	    gcc_assert (pei_add_target (pinfo, src_pinfos[i].target[j]));
+
+	  for (j = 0; j < src_pinfos[i].nthrough; j++)
+	    gcc_assert (pei_add_through (pinfo, src_pinfos[i].through[j]));
+	}
+
+      gcc_assert (pei_add_through (pinfo, insn));
+    }
+}
+
+
+/* Look for profitable propgation of an extension from INSN, and
+   return its info if one is found.  */
+static struct propagate_extend_info *
+analyze_extend_propagation (rtx insn, htab_t insn_extend_infos)
+{
+  struct insn_extend_info *info;
+  struct propagate_extend_info pinfo;
+  struct propagate_extend_info *ret_pinfo;
+
+  info = get_insn_extend_info (insn, insn_extend_infos);
+
+  /* Check to see if INSN has an extend that is a candidate for
+     propagation.  */
+  if (!info || !info->is_propagate_candidate)
+    return NULL;
+
+  /* Require that the propagation be local to a basic block, to avoid
+     degradation due to live range issues.  */
+  if (!strictly_dominates (insn, info->extend_insn))
+    return NULL;
+
+  /* Check for profitable extension.  */
+  memset (&pinfo, 0, sizeof(struct propagate_extend_info));
+  try_propagate_extend (insn, info->extend_type, &pinfo, 0, insn_extend_infos);
+  pinfo.extend_info = info;
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "try_propagate_extend level 0\n");
+      print_rtx (dump_file, insn);
+      debug_pei (dump_file, &pinfo, false);
+    }
+
+  if (pinfo.ntargets == 1 && pinfo.nthrough == 0)
+    return NULL;
+
+  ret_pinfo = XCNEW (struct propagate_extend_info);
+  *ret_pinfo = pinfo;
+
+  return ret_pinfo;
+}
+
+
+/* If X is a subreg, returns its reg; otherwise return X.  */
+static rtx
+strip_subreg (rtx x)
+{
+  if (GET_CODE (x) == SUBREG)
+    return SUBREG_REG (x);
+  return x;
+}
+
+
+/* A small table mapping rtx to rtx.  */
+struct rtx_table_entry
+{
+  rtx from, to;
+};
+
+
+#define RTX_TABLE_MAX_ENTRIES 20
+struct rtx_table
+{
+  int num_entries;
+  struct rtx_table_entry entries[RTX_TABLE_MAX_ENTRIES];
+};
+
+
+/* Return the rtx corresponding to FROM in RMAP, or NULL_RTX.  */
+static rtx
+rtx_table_lookup (rtx from, struct rtx_table *rmap)
+{
+  struct rtx_table_entry *entries;
+  int i;
+
+  from = strip_subreg (from);
+
+  if (!REG_P (from))
+    return from;
+
+  entries = rmap->entries;
+  for (i = 0; (i < rmap->num_entries) && (entries[i].from != NULL_RTX); i++)
+    {
+      if (entries[i].from == from)
+	return entries[i].to;
+    }
+
+  return NULL_RTX;
+}
+
+
+/* Add an entry from to RMAP.  */
+static int
+rtx_table_add (rtx from, rtx to, struct rtx_table *rmap)
+{
+  int n = rmap->num_entries++;
+
+  gcc_assert (n < RTX_TABLE_MAX_ENTRIES);
+
+  from = strip_subreg (from);
+
+  rmap->entries[n].from = from;
+  rmap->entries[n].to = to;
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "rtx_table_add ");
+      print_inline_rtx (dump_file, from, 0);
+      fprintf (dump_file, " ");
+      print_inline_rtx (dump_file, to, 0);
+      fprintf (dump_file, "\n");
+    }
+
+  return n;
+}
+
+
+/* Return the rtx corresponding to FROM, or create a new MODE reg
+   return it.  */
+static rtx
+rtx_table_lookup_or_create (rtx from, enum machine_mode mode,
+			    struct rtx_table *rmap)
+{
+  rtx to;
+
+  to = rtx_table_lookup (from, rmap);
+
+  if (to)
+    {
+      gcc_assert (GET_MODE (to) == mode || GET_MODE (to) == VOIDmode);
+      return to;
+    }
+
+  to = gen_reg_rtx (mode);
+  rtx_table_add (from, to, rmap);
+  return to;
+}
+
+
+/* Fixup the target of an extend propagation.  */
+static void
+propagate_extend_fixup_target (rtx insn, enum extend_type type,
+			       struct rtx_table *rmap)
+{
+  rtx pattern;
+  rtx set_dest;
+  rtx dest, src, x;
+  rtx new_insns = NULL_RTX;
+
+  pattern = PATTERN (insn);
+
+  gcc_assert (GET_CODE (pattern) == SET);
+
+  set_dest = SET_DEST (pattern);
+
+  switch (type)
+    {
+    case si_to_udi:
+    case si_to_sdi:
+    case di_to_udi:
+    case di_to_sdi:
+      src = simplify_gen_subreg (SImode, set_dest, GET_MODE (set_dest), 0);
+      dest = rtx_table_lookup_or_create (set_dest, DImode, rmap);
+
+      start_sequence ();
+      if (type == si_to_udi || type == di_to_udi)
+	emit_insn (gen_zero_extendsidi2 (dest, src));
+      else
+	emit_insn (gen_extendsidi2 (dest, src));
+      new_insns = get_insns ();
+      end_sequence ();
+      break;
+    case di_to_si:
+      src = simplify_gen_subreg (DImode, set_dest, GET_MODE (set_dest), 0);
+      dest = rtx_table_lookup_or_create (set_dest, SImode, rmap);
+
+      start_sequence ();
+      emit_insn (gen_truncdisi2 (dest, src));
+      new_insns = get_insns ();
+      end_sequence ();
+      break;
+    default:
+      gcc_unreachable ();
+    }
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\npropagate_extend_fixup_target\n");
+      print_rtx (dump_file, insn);
+      fprintf (dump_file, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (dump_file, x);
+	  x = NEXT_INSN (x);
+	}
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\npropagate_extend_fixup_target\n");
+      print_rtx (f, insn);
+      fprintf (f, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (f, x);
+	  x = NEXT_INSN (x);
+	}
+      tilegx_unlock_data_file (f);
+    }
+
+  emit_insn_after (new_insns, insn);
+}
+
+
+/* Fixup the through instruction of an extend propagation.  */
+static void
+propagate_extend_fixup_through (rtx insn, enum extend_type type,
+				struct rtx_table *rmap)
+{
+  rtx new_insns;
+  rtx dest, src0, src1;
+  rtx new_dest, new_src0, new_src1;
+  enum machine_mode mode;
+  int code, new_code;
+  rtx x;
+
+  gcc_assert (GET_CODE (PATTERN (insn)) == SET);
+  dest = SET_DEST (PATTERN (insn));
+
+  /* these cases do not require mode change.  */
+  if (type == di_to_udi || type == di_to_sdi)
+    {
+      if (!rtx_table_lookup (dest, rmap))
+	rtx_table_add (dest, dest, rmap);
+      return;
+    }
+
+  mode = (type == di_to_si) ? SImode : DImode;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_xorsi3:
+    case CODE_FOR_xordi3:
+      new_code = (type == di_to_si) ? CODE_FOR_xorsi3 : CODE_FOR_xordi3;
+      break;
+    case CODE_FOR_iorsi3:
+    case CODE_FOR_iordi3:
+      new_code = (type == di_to_si) ? CODE_FOR_iorsi3 : CODE_FOR_iordi3;
+      break;
+    case CODE_FOR_andsi3:
+    case CODE_FOR_anddi3:
+      new_code = (type == di_to_si) ? CODE_FOR_andsi3 : CODE_FOR_anddi3;
+      break;
+    default:
+      gcc_unreachable ();
+    }
+
+  src0 = get_set_src_xexp (insn, 0);
+  src1 = get_set_src_xexp (insn, 1);
+
+  gcc_assert (src0 && src1);
+
+  new_src0 = rtx_table_lookup (src0, rmap);
+  if (GET_MODE (new_src0) != VOIDmode)
+    new_src0 = simplify_gen_subreg (mode, new_src0, GET_MODE (new_src0), 0);
+
+  new_src1 = rtx_table_lookup (src1, rmap);
+  if (GET_MODE (new_src1) != VOIDmode)
+    new_src1 = simplify_gen_subreg (mode, new_src1, GET_MODE (new_src1), 0);
+
+  new_dest = rtx_table_lookup_or_create (dest, mode, rmap);
+      
+  start_sequence ();
+  emit_insn (GEN_FCN (new_code) (new_dest, new_src0, new_src1));
+  new_insns = get_insns ();
+  end_sequence ();
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\npropagate_extend_fixup_through\n");
+      print_rtx (dump_file, insn);
+      fprintf (dump_file, " ==> Replaced by\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (dump_file, x);
+	  x = NEXT_INSN (x);
+	}
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\npropagate_extend_fixup_through\n");
+      print_rtx (f, insn);
+      fprintf (f, " ==> Replaced by\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (f, x);
+	  x = NEXT_INSN (x);
+	}
+      tilegx_unlock_data_file (f);
+    }
+
+  emit_insn_after (new_insns, insn);
+  delete_insn (insn);
+}
+
+
+/* Fixup the base instruction of an extend propagation.  */
+static void
+propagate_extend_fixup_base (struct insn_extend_info *info,
+			     enum extend_type type ATTRIBUTE_UNUSED,
+			     struct rtx_table *rmap)
+{
+  rtx extend_insn;
+  rtx new_insns;
+  rtx dest, src;
+  rtx new_src;
+  rtx x;
+
+  extend_insn = info->extend_insn;
+
+  gcc_assert (GET_CODE (PATTERN (extend_insn)) == SET);
+
+  src = get_set_src_xexp (extend_insn, 0);
+  dest = SET_DEST (PATTERN (extend_insn));
+
+  new_src = rtx_table_lookup (src, rmap);
+
+  start_sequence ();
+  emit_move_insn (dest, new_src);
+  new_insns = get_insns ();
+  end_sequence ();
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\npropagate_extend_fixup_base\n");
+      fprintf (dump_file, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (dump_file, x);
+	  x = NEXT_INSN (x);
+	}
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\npropagate_extend_fixup_base\n");
+      fprintf (f, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (f, x);
+	  x = NEXT_INSN (x);
+	}
+      tilegx_unlock_data_file (f);
+    }
+
+  emit_insn_after (new_insns, extend_insn);
+  delete_insn (extend_insn);
+}
+
+
+/* Returns whether M contains any insns in PINFO.  */
+static bool
+has_insn_in_bitmap (struct propagate_extend_info *pinfo, bitmap m)
+{
+  int i;
+  for (i = 0; i < pinfo->ntargets; i++)
+    if (bitmap_bit_p (m, INSN_UID (pinfo->target[i])))
+      return true;
+
+  for (i = 0; i < pinfo->nthrough; i++)
+    if (bitmap_bit_p (m, INSN_UID (pinfo->through[i])))
+      return true;
+
+  if (bitmap_bit_p (m, INSN_UID (pinfo->extend_info->insn)))
+    return true;
+
+  if (bitmap_bit_p (m, INSN_UID (pinfo->extend_info->extend_insn)))
+    return true;
+
+  return false;
+}
+
+
+/* Put the insns in PINFO into M.  */
+static void
+put_insns_in_bitmap (struct propagate_extend_info *pinfo, bitmap m)
+{
+  int i;
+  for (i = 0; i < pinfo->ntargets; i++)
+    bitmap_set_bit (m, INSN_UID (pinfo->target[i]));
+
+  for (i = 0; i < pinfo->nthrough; i++)
+    bitmap_set_bit (m, INSN_UID (pinfo->through[i]));
+
+  bitmap_set_bit (m, INSN_UID (pinfo->extend_info->insn));
+  bitmap_set_bit (m, INSN_UID (pinfo->extend_info->extend_insn));
+}
+
+
+/* Propagate the extension described in PINFO.  */
+static void
+do_propagate_extend (struct propagate_extend_info *pinfo)
+{
+  struct insn_extend_info *info = pinfo->extend_info;
+  enum extend_type type = info->extend_type;
+  int i;
+  struct rtx_table rmap;
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\nDo propagate extend\n");
+      debug_pei (dump_file, pinfo, true);
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\nDo propagate extend %s %s\n", main_input_filename,
+	       current_function_name());
+      debug_pei (f, pinfo, true);
+      tilegx_unlock_data_file (f);
+    }
+
+  memset (&rmap, 0, sizeof (struct rtx_table));
+
+  for (i = 0; i < pinfo->ntargets; i++)
+    propagate_extend_fixup_target (pinfo->target[i], type, &rmap);
+
+  for (i = 0; i < pinfo->nthrough; i++)
+    propagate_extend_fixup_through (pinfo->through[i], type, &rmap);
+
+  propagate_extend_fixup_base (pinfo->extend_info, type, &rmap);
+}
+
+
+/* Perform extension propagation for the linked list headed by
+   HEAD.  */
+static void
+do_propagate_extends (struct propagate_extend_info *head)
+{
+  bitmap processed_insns = BITMAP_ALLOC (NULL);
+
+  while (head)
+    {
+      if (!has_insn_in_bitmap (head, processed_insns))
+	{
+	  put_insns_in_bitmap (head, processed_insns);
+	  do_propagate_extend (head);
+	}
+      head = head->next;
+    }
+
+  BITMAP_FREE (processed_insns);
+}
+
+
+/* Optimize the placement of extension insns.  */
+static void
+propagate_extends (void)
+{
+  htab_t insn_extend_infos;
+  basic_block bb;
+  rtx insn;
+  struct propagate_extend_info *pinfo;
+  struct propagate_extend_info *phead;
+
+  insn_extend_infos = htab_create (10, htab_iei_hash, htab_iei_eq,
+				   htab_iei_del);
+
+  if (dump_file)
+    fprintf (dump_file, "@@@ Init insn extend info @@@\n");
+
+  /* Initialize the insn_extend_infos.  */
+  FOR_EACH_BB (bb)
+    {
+      for (insn = BB_HEAD (bb); insn != NEXT_INSN (BB_END (bb));
+	   insn = NEXT_INSN (insn))
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  init_insn_extend_info (insn, insn_extend_infos);
+	}
+    }
+
+  if (dump_file)
+    fprintf (dump_file, "@@@ Analyze extend propagation @@@\n");
+
+  /* Look for profitable extend propagation.  Note the order in which
+     we insert the pinfo.  When we do the actual propagation, we visit
+     the pinfo corresponding to the bottem of the basic block
+     first.  */
+  phead = NULL;
+  FOR_EACH_BB (bb)
+    {
+      for (insn = BB_HEAD (bb); insn != NEXT_INSN (BB_END (bb));
+	   insn = NEXT_INSN (insn))
+	{
+	  pinfo = analyze_extend_propagation (insn, insn_extend_infos);
+	  if (pinfo)
+	    {
+	      if (phead)
+		pinfo->next = phead;
+	      phead = pinfo;
+	    }
+	}
+    }
+
+  if (dump_file)
+    fprintf (dump_file, "@@@ Do propagate extends @@@\n");
+
+  /* Do the transformation.  */
+  if (phead)
+    do_propagate_extends (phead);
+
+  /* Clean up */
+  while (phead)
+    {
+      struct propagate_extend_info *next = phead->next;
+      XDELETE (phead);
+      phead = next;
+    }
+
+  htab_delete (insn_extend_infos);
+}
+
+
+
+/* Unnecessary zero/sign extension optimization.  */
+
+
+enum reg_extend_state
+{
+  REG_EXTEND_INVALID,
+  REG_EXTEND_TRUNCATE,
+  REG_EXTEND_ZERO_EXTENDED,
+  REG_EXTEND_SIGN_EXTENDED
+};
+
+
+typedef struct reg_extend_info
+{
+  int reg_num;
+  rtx reg_rtx;
+  rtx src_reg_rtx;
+  enum reg_extend_state state;
+} reg_extend_info;
+
+
+/* Returns the hash value of a pointer to a reg_extend_info.  */
+static hashval_t
+htab_rei_hash (const void *p)
+{
+  const reg_extend_info *const rei = (const reg_extend_info *) p;
+
+  return (hashval_t) rei->reg_num;
+}
+
+
+/* Equality function for reg_extend_info *.  */
+static int
+htab_rei_eq (const void *p1, const void *p2)
+{
+  const reg_extend_info *const rei1 = (const reg_extend_info *) p1;
+  const reg_extend_info *const rei2 = (const reg_extend_info *) p2;
+
+  return rei1->reg_num == rei2->reg_num;
+}
+
+
+/* Hash entry delete function for reg_extend_info *.  */
+static void
+htab_rei_del (void *p)
+{
+  reg_extend_info *const rei = (reg_extend_info *) p;
+  free (rei);
+}
+
+
+/* INSN is the outer most insn containing SET_INSN.  Returns true if
+   the register result of SET_INSN is only used in its lower 32
+   bits.  */
+static bool
+is_result_32bit_reg (rtx insn, rtx set_insn)
+{
+  bool truncated;
+  struct df_insn_info *insn_info;
+  df_ref *def_rec;
+
+  truncated = true;
+
+  insn_info = DF_INSN_INFO_GET (insn);
+  def_rec = DF_INSN_INFO_DEFS (insn_info);
+
+  while (*def_rec)
+    {
+      df_ref def_ref = *def_rec;
+
+      if (DF_REF_REG (def_ref) == SET_DEST (set_insn))
+	{
+	  struct df_link *link = DF_REF_CHAIN (def_ref);
+	  if (link)
+	    {
+	      if (!DF_REF_IS_ARTIFICIAL (link->ref))
+		{
+		  rtx use = DF_REF_INSN (link->ref);
+		  if (recog_memoized (use) != CODE_FOR_truncdisi2)
+		    {
+		      truncated = false;
+		      break;
+		    }
+		}
+	      else
+		truncated = false;
+	    }
+	}
+      def_rec++;
+    }
+
+  return truncated;
+}
+
+
+/* gets the reg_extend_info * corresponding to register rtx OPND.
+   Returns NULL if none is found.  */
+static reg_extend_info *
+get_extend_info (rtx opnd, htab_t extend_infos)
+{
+  reg_extend_info key;
+
+  if (!REG_P (opnd))
+    return NULL;
+
+  key.reg_num = REGNO (opnd);
+  return (reg_extend_info *) htab_find (extend_infos, &key);
+}
+
+
+/* Get the set insn that performs the intrinsic operation.  If insn is
+   a PARALLEL, assumes the first insn is the intrinsic.  */
+static rtx
+get_intrinsic_set_insn (rtx insn)
+{
+  rtx pattern = PATTERN (insn);
+
+  switch (GET_CODE (pattern))
+    {
+    case SET:
+      return pattern;
+    case PARALLEL:
+      return XVECEXP (pattern, 0, 0);
+    default:
+      return NULL_RTX;
+    }
+}
+
+
+/* Asserts that SET_INSN only uses the lower 32 bits of the opnd'th
+   source operand, so look for opportunity to short circuit any
+   unnecessary zero or sign extension.  Returns whether INSN was
+   changed.  */
+static bool
+optimize_extends_src32 (rtx set_insn, int opnd, htab_t extend_infos)
+{
+  rtx unspec;
+  rtx src;
+  reg_extend_info *rei;
+
+  unspec = SET_SRC (set_insn);
+
+  gcc_assert (GET_CODE (unspec) == UNSPEC);
+  gcc_assert (opnd < XVECLEN (unspec, 0));
+
+  src = XVECEXP (unspec, 0, opnd);
+
+  rei = get_extend_info (src, extend_infos);
+  if (rei != NULL &&
+      (rei->state == REG_EXTEND_ZERO_EXTENDED ||
+       rei->state == REG_EXTEND_SIGN_EXTENDED))
+    {
+      XVECEXP (unspec, 0, opnd) = rei->src_reg_rtx;
+      return true;
+    }
+
+  return false;
+}
+
+
+/* Checks to see if the primary result of INSN is only used in its
+   lower 32 bits.  If so, optimize the first and second source
+   operands assuming that they only use the lower 32 bits.  Returns
+   whether INSN was changed.  */
+static bool
+optimize_extends_res32_implies_src32_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  if (is_result_32bit_reg (insn, set_insn))
+    {
+      changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+      changed |= optimize_extends_src32 (set_insn, 1, extend_infos);
+    }
+
+  return changed;
+}
+
+
+/* Checks to see if the primary result of INSN is only used in its
+   lower 32 bits.  If so, optimize the first source operand assuming
+   that it only uses the lower 32 bits.  Returns whether INSN was
+   changed.  */
+static bool
+optimize_extends_res32_implies_src32_imm_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  if (is_result_32bit_reg (insn, set_insn))
+    changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+
+  return changed;
+}
+
+
+/* Optimize the first and second source operands assuming that they
+   only use the lower 32 bits.  Returns whether INSN was changed.  */
+static bool
+optimize_extends_src32_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+  changed |= optimize_extends_src32 (set_insn, 1, extend_infos);
+
+  return changed;
+}
+
+
+/* Optimize a sada instruction.  If the result is 32 bit, then only
+   use 32 bits of the sum input operand.  */
+static bool
+optimize_extends_sada_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  if (is_result_32bit_reg (insn, set_insn))
+    changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+
+  return changed;
+}
+
+
+/* Do extension optimizations for INSN.  */
+static void
+optimize_extends_insn (rtx insn, htab_t extend_infos)
+{
+  int code;
+  bool changed;
+
+  code = recog_memoized (insn);
+
+  changed = false;
+  switch (code)
+    {
+    case CODE_FOR_insn_v4add:
+    case CODE_FOR_insn_v4addsc:
+    case CODE_FOR_insn_v2add:
+    case CODE_FOR_insn_v2addsc:
+    case CODE_FOR_insn_v1add:
+    case CODE_FOR_insn_v1adduc:
+    case CODE_FOR_insn_v4sub:
+    case CODE_FOR_insn_v4subsc:
+    case CODE_FOR_insn_v2sub:
+    case CODE_FOR_insn_v2subsc:
+    case CODE_FOR_insn_v1sub:
+    case CODE_FOR_insn_v1subuc:
+    case CODE_FOR_insn_v4shrs:
+    case CODE_FOR_insn_v2shrs:
+    case CODE_FOR_insn_v1shrs:
+    case CODE_FOR_insn_v4shru:
+    case CODE_FOR_insn_v2shru:
+    case CODE_FOR_insn_v1shru:
+    case CODE_FOR_insn_v4shl:
+    case CODE_FOR_insn_v2shl:
+    case CODE_FOR_insn_v1shl:
+    case CODE_FOR_insn_v4shlsc:
+    case CODE_FOR_insn_v2shlsc:
+    case CODE_FOR_insn_v2adiffs:
+    case CODE_FOR_insn_v1adiffu:
+    case CODE_FOR_insn_v2avgs:
+    case CODE_FOR_insn_v1avgu:
+    case CODE_FOR_insn_v2maxs:
+    case CODE_FOR_insn_v1maxu:
+    case CODE_FOR_insn_v2mins:
+    case CODE_FOR_insn_v1minu:
+    case CODE_FOR_insn_v2mz:
+    case CODE_FOR_insn_v1mz:
+    case CODE_FOR_insn_v2mnz:
+    case CODE_FOR_insn_v1mnz:
+    case CODE_FOR_insn_v2cmplts:
+    case CODE_FOR_insn_v1cmplts:
+    case CODE_FOR_insn_v2cmples:
+    case CODE_FOR_insn_v1cmples:
+    case CODE_FOR_insn_v2cmpltu:
+    case CODE_FOR_insn_v1cmpltu:
+    case CODE_FOR_insn_v2cmpleu:
+    case CODE_FOR_insn_v1cmpleu:
+    case CODE_FOR_insn_v2cmpeq:
+    case CODE_FOR_insn_v1cmpeq:
+    case CODE_FOR_insn_v2cmpne:
+    case CODE_FOR_insn_v1cmpne:
+    case CODE_FOR_insn_v2mults:
+    case CODE_FOR_insn_v1multu:
+    case CODE_FOR_insn_v1ddotpus:
+
+      /* If result is 32 bit, then only use 32 bits of sources. */
+      changed =
+	optimize_extends_res32_implies_src32_insn (insn, extend_infos);
+      break;
+
+    case CODE_FOR_insn_v2addi:
+    case CODE_FOR_insn_v1addi:
+    case CODE_FOR_insn_v2maxsi:
+    case CODE_FOR_insn_v1maxui:
+    case CODE_FOR_insn_v2minsi:
+    case CODE_FOR_insn_v1minui:
+    case CODE_FOR_insn_v2cmpltsi:
+    case CODE_FOR_insn_v1cmpltsi:
+    case CODE_FOR_insn_v2cmpltui:
+    case CODE_FOR_insn_v1cmpltui:
+    case CODE_FOR_insn_v2cmpeqi:
+    case CODE_FOR_insn_v1cmpeqi:
+      /* If result is 32 bit, then only use 32 bits of sources;
+         immediate version. */
+      changed =
+	optimize_extends_res32_implies_src32_imm_insn (insn, extend_infos);
+      break;
+
+    case CODE_FOR_insn_crc32_8:
+    case CODE_FOR_insn_crc32_32:
+    case CODE_FOR_insn_v4int_l:
+    case CODE_FOR_insn_v2int_l:
+    case CODE_FOR_insn_v1int_l:
+    case CODE_FOR_insn_v2muls:
+    case CODE_FOR_insn_v2mulfsc:
+    case CODE_FOR_insn_v1mulu:
+    case CODE_FOR_insn_v1mulus:
+      /* Only use the lower 32 bits on the inputs.  */
+      changed = optimize_extends_src32_insn (insn, extend_infos);
+      break;
+
+    case CODE_FOR_insn_v2sadas:
+    case CODE_FOR_insn_v2sadau:
+    case CODE_FOR_insn_v1sadau:
+      /* If the result is 32 bit, then only use 32 bits of the sum
+         input operand.  */
+      changed = optimize_extends_sada_insn (insn, extend_infos);
+      break;
+
+    default:
+      break;
+    }
+
+  if (changed)
+    df_insn_rescan (insn);
+}
+
+
+/* Returns the reg_extend_info corresponding to REG_NUM.  */
+static reg_extend_info *
+get_reg_extend_info (unsigned reg_num, htab_t extend_infos)
+{
+  reg_extend_info **hash_slot;
+  reg_extend_info *rei;
+  reg_extend_info key;
+
+  key.reg_num = reg_num;
+
+  hash_slot =
+    (reg_extend_info **) htab_find_slot (extend_infos, &key, INSERT);
+  rei = *hash_slot;
+  if (rei == NULL)
+    {
+      rei = *hash_slot = XCNEW (reg_extend_info);
+      rei->reg_num = reg_num;
+    }
+
+  return rei;
+}
+
+
+/* Invalidate the reg_extend_info corresponding to REG_NUM.  */
+static void
+optimize_extends_invalidate_reg (unsigned reg_num, htab_t extend_infos)
+{
+  reg_extend_info key;
+  reg_extend_info *rei;
+
+  key.reg_num = reg_num;
+  rei = (reg_extend_info *) htab_find (extend_infos, &key);
+  if (rei != NULL)
+    rei->state = REG_EXTEND_INVALID;
+}
+
+
+/* Invalidate all reg_extend_info corresponding to registers that have
+   been chagned by PATTERN.  */
+static void
+optimize_extends_invalidate_results (rtx pattern, htab_t extend_infos)
+{
+  int i;
+
+  switch (GET_CODE (pattern))
+    {
+    case PARALLEL:
+      {
+	for (i = 0; i < XVECLEN (pattern, 0); i++)
+	  optimize_extends_invalidate_results (XVECEXP (pattern, 0, i),
+					       extend_infos);
+	break;
+      }
+    case SET:
+      {
+	rtx dest;
+	dest = SET_DEST (pattern);
+	if (REG_P (dest))
+	  optimize_extends_invalidate_reg (REGNO (dest), extend_infos);
+
+	break;
+      }
+    case CLOBBER:
+      {
+	rtx clobbered = XEXP (pattern, 0);
+	if (REG_P (clobbered))
+	  optimize_extends_invalidate_reg (REGNO (clobbered), extend_infos);
+
+	break;
+      }
+    default:
+      break;
+    }
+}
+
+
+/* Update EXTEND_INFOS to refect the extension pattern found in
+   PATTERN.  OUTPUT_STATE reflects the extension type.  */
+static void
+optimize_extends_update_extend (enum reg_extend_state output_state,
+				rtx pattern, htab_t extend_infos)
+{
+  reg_extend_info *rei_src;
+  reg_extend_info key;
+  rtx dest;
+  rtx src;
+  rtx extending_src;
+
+  gcc_assert (GET_CODE (pattern) == SET);
+
+  dest = SET_DEST (pattern);
+
+  if (REG_P (dest))
+    {
+      /* get the source of the extend insn.  */
+      src = XEXP (SET_SRC (pattern), 0);
+
+      /* Look for the a corresponding source DI whose lower bits are
+         being extended  */
+      extending_src = NULL;
+      if (REG_P (src))
+	{
+	  /* (set (reg:DI 98) (sign/zero_extend:DI (reg:SI 97))) */
+	  key.reg_num = REGNO (src);
+	  rei_src = (reg_extend_info *) htab_find (extend_infos, &key);
+	  if (rei_src != NULL && rei_src->state == REG_EXTEND_TRUNCATE)
+	    extending_src = rei_src->src_reg_rtx;
+	}
+      else if ((GET_CODE (src) == SUBREG))
+	{
+	  /* FIXME: handle this case for big endian.  */
+	  if (TARGET_BIG_ENDIAN)
+	    return;
+
+	  /* (set (reg:DI 94)
+	     (sign/zero_extend:DI (subreg/s:SI (reg/v:DI 84) 0)))  */
+	  gcc_assert (XINT (src, 1) == 0);
+	  extending_src = XEXP (src, 0);
+	}
+
+      if (extending_src != NULL)
+	{
+	  reg_extend_info *rei_dest;
+
+	  rei_dest = get_reg_extend_info (REGNO (dest), extend_infos);
+	  rei_dest->reg_rtx = dest;
+	  rei_dest->src_reg_rtx = extending_src;
+	  rei_dest->state = output_state;
+	}
+    }
+}
+
+
+/* Process INSN and update EXTEND_INFOS.  */
+static void
+optimize_extends_update_info (rtx insn, htab_t extend_infos)
+{
+  int code;
+  rtx pattern;
+  bool done = false;
+
+  code = recog_memoized (insn);
+  pattern = PATTERN (insn);
+
+  switch (code)
+    {
+    case CODE_FOR_zero_extendsidi2:
+      {
+	optimize_extends_update_extend (REG_EXTEND_ZERO_EXTENDED,
+					pattern, extend_infos);
+	done = true;
+	break;
+      }
+    case CODE_FOR_extendsidi2:
+      {
+	optimize_extends_update_extend (REG_EXTEND_SIGN_EXTENDED,
+					pattern, extend_infos);
+	done = true;
+	break;
+      }
+    case CODE_FOR_truncdisi2:
+      {
+	/* example: (set (reg:SI 97) (truncate:SI (reg:DI 82 [ D.1532 ]))) */
+	rtx dest;
+	rtx src;
+
+	gcc_assert (GET_CODE (pattern) == SET);
+
+	dest = SET_DEST (pattern);
+
+	if (REG_P (dest))
+	  {
+	    /* get the source of the truncate */
+	    src = XEXP (SET_SRC (pattern), 0);
+
+	    if (REG_P (src))
+	      {
+		reg_extend_info *rei_dest;
+
+		rei_dest = get_reg_extend_info (REGNO (dest), extend_infos);
+		rei_dest->reg_rtx = dest;
+		rei_dest->src_reg_rtx = src;
+		rei_dest->state = REG_EXTEND_TRUNCATE;
+		done = true;
+	      }
+	  }
+	break;
+      }
+    default:
+      break;
+    }
+
+  if (!done)
+    optimize_extends_invalidate_results (pattern, extend_infos);
+}
+
+
+/* Entry point to an optimization pass that optimizes away unnecessary
+   sign/zero extensions for source operands of intrinsics
+   instructions.  If an extension is not necessary, we short circuit
+   the operations to use the value before extension.  We leave to
+   other passes (dce) to eliminate any resulting dead code.  Requries
+   availability of du-chains.  */
+static void
+optimize_extends (void)
+{
+  basic_block bb;
+  rtx insn, last;
+  htab_t extend_infos;
+
+  FOR_EACH_BB (bb)
+  {
+    extend_infos = htab_create (10, htab_rei_hash, htab_rei_eq, htab_rei_del);
+
+    for (insn = BB_HEAD (bb), last = NEXT_INSN (BB_END (bb));
+	 insn != last; insn = NEXT_INSN (insn))
+      {
+	if (!NONDEBUG_INSN_P (insn))
+	  continue;
+
+	optimize_extends_insn (insn, extend_infos);
+
+	optimize_extends_update_info (insn, extend_infos);
+      }
+
+    htab_delete (extend_infos);
+  }
+}
+
+
+static bool
+tilegx_gate_handle_target_peephole (void)
+{
+  return optimize > 0;
+}
+
+
+static int
+tilegx_rest_of_handle_target_peephole (void)
+{
+  df_chain_add_problem (DF_DU_CHAIN);
+  df_analyze ();
+  df_set_flags (DF_DEFER_INSN_RESCAN);
+
+  optimize_extends ();
+
+  df_remove_problem (df_chain);
+  df_process_deferred_rescans ();
+
+  return 0;
+}
+
+
+static bool
+tilegx_gate_handle_extend_propagation (void)
+{
+  return (optimize > 0) && TARGET_EXTEND_OPT && !TARGET_BIG_ENDIAN;
+}
+
+
+static int
+tilegx_rest_of_handle_extension_propagation (void)
+{
+  df_chain_add_problem (DF_DU_CHAIN + DF_UD_CHAIN);
+  df_analyze ();
+  df_set_flags (DF_DEFER_INSN_RESCAN);
+
+  propagate_extends ();
+
+  df_remove_problem (df_chain);
+  df_process_deferred_rescans ();
+  return 0;
+}
+
+
+
+/* tilegx specific code to move by pieces.  We handle four cases:
+
+   1. If TO and FROM have the same alignment, generate load-store
+   pairs, but interleave them so we get better scheduling.
+
+   2. If FROM is not 8-byte aligned, TO is 8-byte aligned, and we're
+   copying 8 or more bytes, emit unaligned loads + dblalign, then do
+   aligned stores.
+
+   3. If TO has bigger alignment than FROM, do multiple loads at
+   FROM's alignment, accumulate the value, and then a single store.
+
+   4. If TO has lesser alignment than FROM, do a single load, then
+   multiple shift-and-stores.  */
+rtx
+tilegx_move_by_pieces (rtx to, rtx from, unsigned HOST_WIDE_INT len,
+		       unsigned int align ATTRIBUTE_UNUSED, int endp)
+{
+  unsigned HOST_WIDE_INT i;
+  unsigned int word_bitsize = GET_MODE_BITSIZE (word_mode);
+  unsigned int wordsize = GET_MODE_SIZE (word_mode);
+  unsigned int max_size = MOVE_MAX_PIECES + 1;
+  unsigned HOST_WIDE_INT orig_len = len;
+  rtx from_addr, to_addr;
+
+  if (TARGET_BIG_ENDIAN)
+    return NULL;
+
+  /* We only handle ENDP = 0 */
+  if (endp != 0)
+    return NULL;
+
+  /* if alignment is sufficient do copy LEN bytes in one load/store
+     pair, go to default codegen.  */
+  if (MEM_ALIGN (to) >= len * BITS_PER_UNIT
+      && MEM_ALIGN (from) >= len * BITS_PER_UNIT
+      && len <= word_bitsize)
+    return NULL;
+
+  if (MEM_ALIGN (from) == MEM_ALIGN (to))
+    {
+      /* If TO and FROM have the same alignment, generate load-store
+	 pairs, but interleave them so we get better scheduling.  */
+      unsigned int size;
+      enum machine_mode mode = VOIDmode, tmode;
+      enum insn_code icode;
+
+      size = MIN (MIN (MEM_ALIGN (from) / BITS_PER_UNIT, len), max_size);
+
+      /* Find the mode of the largest move...  */
+      for (tmode = GET_CLASS_NARROWEST_MODE (MODE_INT);
+	   tmode != VOIDmode; tmode = GET_MODE_WIDER_MODE (tmode))
+	{
+	  if (GET_MODE_SIZE (tmode) <= size)
+	    mode = tmode;
+	}
+
+      size = GET_MODE_SIZE (mode);
+
+      icode = optab_handler (mov_optab, mode);
+
+      gcc_assert (icode != CODE_FOR_nothing);
+
+      from_addr = adjust_address (from, mode, 0);
+      to_addr = adjust_address (to, mode, 0);
+
+      while (len >= 2 * size)
+	{
+	  rtx tmp = gen_reg_rtx (mode);
+	  rtx tmp2 = gen_reg_rtx (mode);
+
+	  emit_insn (GEN_FCN (icode) (tmp, from_addr));
+	  from_addr = adjust_address (from_addr, mode, size);
+	  
+	  emit_insn (GEN_FCN (icode) (tmp2, from_addr));
+	  from_addr = adjust_address (from_addr, mode, size);
+
+	  emit_insn (GEN_FCN (icode) (to_addr, tmp));
+	  to_addr = adjust_address (to_addr, mode, size);
+
+	  emit_insn (GEN_FCN (icode) (to_addr, tmp2));
+	  to_addr = adjust_address (to_addr, mode, size);
+
+	  len -= 2 * size;
+	}
+
+      if (len >= size)
+	{
+	  rtx tmp = gen_reg_rtx (mode);
+
+	  emit_insn (GEN_FCN (icode) (tmp, from_addr));
+	  from_addr = adjust_address (from_addr, mode, size);
+	  
+	  emit_insn (GEN_FCN (icode) (to_addr, tmp));
+	  to_addr = adjust_address (to_addr, mode, size);
+
+	  len -= size;
+	}
+    }
+  else if (MEM_ALIGN (from) < word_bitsize
+	   && MEM_ALIGN (to) == word_bitsize
+	   && (len >= wordsize))
+    {
+      /* If FROM is not 8-byte aligned, TO is 8-byte aligned, and
+	 we're copying 8 or more bytes, emit unaligned loads +
+	 dblalign, then do aligned stores. then do aligned stores.
+
+	 16-byte example:
+
+	 ldna tmp, src
+	 addi src2, src, 8
+	 ldna tmp2, src2
+	 dblalign tmp, tmp2, src
+	 st dst, tmp
+	 addi dst, dst, 8
+	 addi src3, src2, 7
+	 ldna tmp3, src3
+	 dblalign tmp2, tmp3, src
+	 st dst, tmp2  */
+      unsigned n = len / wordsize;
+      rtx tmp = gen_reg_rtx (word_mode);
+      rtx insn;
+      rtx mem;
+
+      from_addr = adjust_address (from, word_mode, 0);
+      to_addr = adjust_address (to, word_mode, 0);
+
+      insn = emit_insn (gen_insn_ldna (tmp, XEXP (from_addr, 0)));
+      mem = SET_SRC (PATTERN (insn));
+      MEM_COPY_ATTRIBUTES (mem, from_addr);
+      set_mem_size (mem, wordsize);
+      set_mem_align (mem, BITS_PER_WORD);
+
+      for (i = 0; i < n; i++, len -= wordsize)
+	{
+	  rtx tmp2 = gen_reg_rtx (word_mode);
+
+	  /* Load the high word at an address that will not fault if
+	     the low address is aligned and at the very end of a page.
+	     When adjusting address, give special care to make sure we
+	     preserve the alignment information in from_addr.  */
+	  from_addr = adjust_address (from_addr, word_mode, wordsize);
+
+	  if (i < n - 1 || len > wordsize)
+	    insn = emit_insn (gen_insn_ldna (tmp2, XEXP (from_addr, 0)));
+	  else
+	    insn =
+	      emit_insn (gen_insn_ldna (tmp2,
+					XEXP (adjust_address (from_addr,
+							      word_mode, -1),
+					      0)));
+	  mem = SET_SRC (PATTERN (insn));
+	  MEM_COPY_ATTRIBUTES (mem, from_addr);
+	  set_mem_size (mem, wordsize);
+	  set_mem_align (mem, BITS_PER_WORD);
+
+	  emit_insn (gen_insn_dblalign (tmp, tmp, tmp2, XEXP (from, 0)));
+	  emit_move_insn (to_addr, tmp);
+
+	  to_addr = adjust_address (to_addr, word_mode, wordsize);
+	  tmp = tmp2;
+	}
+    }
+  else if (MEM_ALIGN (to) > MEM_ALIGN (from))
+    {
+      /* If TO has bigger alignment than FROM, do multiple loads at
+	 FROM's alignment, accumulate the value, and then a single
+	 store.
+
+	 ld2 tmp, src
+	 addi src, src, 2
+	 ld2 tmp2, src
+	 [addi src, src, 2]
+	 bfins tmp, tmp, tmp2, 16, 31
+	 st4 dst, tmp
+	 [addi dst, dst, 4]  */
+      unsigned int from_size;
+      unsigned int to_size;
+      int loads_per_store;
+      enum machine_mode from_mode = VOIDmode, to_mode = VOIDmode, tmode;
+      enum insn_code from_icode, to_icode;
+      int i;
+
+      from_size = MIN (MIN (MEM_ALIGN (from) / BITS_PER_UNIT, len), max_size);
+      to_size = MIN (MIN (MEM_ALIGN (to) / BITS_PER_UNIT, len), max_size);
+
+      /* Find the mode of the largest move...  */
+      for (tmode = GET_CLASS_NARROWEST_MODE (MODE_INT);
+	   tmode != VOIDmode; tmode = GET_MODE_WIDER_MODE (tmode))
+	{
+	  if (GET_MODE_SIZE (tmode) <= from_size)
+	    from_mode = tmode;
+	  if (GET_MODE_SIZE (tmode) <= to_size)
+	    to_mode = tmode;
+	}
+
+      from_size = GET_MODE_SIZE (from_mode);
+      to_size = GET_MODE_SIZE (to_mode);
+      loads_per_store = to_size / from_size;
+
+      from_icode = optab_handler (mov_optab, from_mode);
+      to_icode = optab_handler (mov_optab, to_mode);
+
+      gcc_assert (from_icode != CODE_FOR_nothing);
+      gcc_assert (to_icode != CODE_FOR_nothing);
+
+      from_addr = adjust_address (from, from_mode, 0);
+      to_addr = adjust_address (to, to_mode, 0);
+
+      while (len >= to_size)
+	{
+	  rtx tmp = NULL_RTX;
+
+	  for (i = 0; i < loads_per_store; i++)
+	    {
+	      rtx tmp2 = gen_reg_rtx (from_mode);
+
+	      emit_insn (GEN_FCN (from_icode) (tmp2, from_addr));
+
+	      from_addr = adjust_address (from_addr, from_mode, from_size);
+
+	      if (i == 0)
+		tmp = convert_to_mode (DImode, tmp2, 0);
+	      else
+		emit_insn (gen_insn_bfins (tmp, tmp,
+					   convert_to_mode (DImode, tmp2, 0),
+					   GEN_INT (i * from_size *
+						    BITS_PER_UNIT),
+					   GEN_INT ((i + 1) * from_size *
+						    BITS_PER_UNIT - 1)));
+	    }
+
+	  emit_insn (GEN_FCN (to_icode) (to_addr,
+					 convert_to_mode (to_mode, tmp, 0)));
+
+	  to_addr = adjust_address (to_addr, to_mode, to_size);
+
+	  len -= to_size;
+	}
+    }
+  else if (MEM_ALIGN (to) < MEM_ALIGN (from))
+    {
+      /* If TO has lesser alignment than FROM, do a ingle load, then
+	 multiple shift-and-stores.
+
+	 ld4 tmp, src
+	 [addi src, src, 4]
+	 st2 dst, tmp
+	 addi dst, dst, 2
+	 shru tmp2, tmp, 16
+	 st2 dst, tmp2
+	 [addi dst dst, 2]  */
+      unsigned int from_size;
+      unsigned int to_size;
+      int stores_per_load;
+      enum machine_mode from_mode = VOIDmode, to_mode = VOIDmode, tmode;
+      enum machine_mode lshr_mode;
+      enum insn_code from_icode, to_icode, lshr_icode;
+      int i;
+
+      from_size = MIN (MIN (MEM_ALIGN (from) / BITS_PER_UNIT, len), max_size);
+      to_size = MIN (MIN (MEM_ALIGN (to) / BITS_PER_UNIT, len), max_size);
+
+      /* Find the mode of the largest move...  */
+      for (tmode = GET_CLASS_NARROWEST_MODE (MODE_INT);
+	   tmode != VOIDmode; tmode = GET_MODE_WIDER_MODE (tmode))
+	{
+	  if (GET_MODE_SIZE (tmode) <= from_size)
+	    from_mode = tmode;
+	  if (GET_MODE_SIZE (tmode) <= to_size)
+	    to_mode = tmode;
+	}
+
+      from_size = GET_MODE_SIZE (from_mode);
+      to_size = GET_MODE_SIZE (to_mode);
+      stores_per_load = from_size / to_size;
+
+      lshr_mode = (from_mode == DImode) ? DImode : SImode;
+
+      from_icode = optab_handler (mov_optab, from_mode);
+      to_icode = optab_handler (mov_optab, to_mode);
+      lshr_icode = optab_handler (lshr_optab, lshr_mode);
+
+      gcc_assert (from_icode != CODE_FOR_nothing);
+      gcc_assert (to_icode != CODE_FOR_nothing);
+      gcc_assert (lshr_icode != CODE_FOR_nothing);
+
+      from_addr = adjust_address (from, from_mode, 0);
+      to_addr = adjust_address (to, to_mode, 0);
+
+      while (len >= from_size)
+	{
+	  rtx tmp = gen_reg_rtx (from_mode);
+
+	  emit_insn (GEN_FCN (from_icode) (tmp, from_addr));
+
+	  from_addr = adjust_address (from_addr, from_mode, from_size);
+
+	  for (i = 0; i < stores_per_load; i++)
+	    {
+	      rtx tmp2 = gen_reg_rtx (lshr_mode);
+
+	      if (i != 0)
+		{
+		  emit_insn (GEN_FCN (lshr_icode) (tmp2,
+						   convert_to_mode (lshr_mode,
+								    tmp, 0),
+						   GEN_INT (to_size *
+							    BITS_PER_UNIT)));
+		  tmp = tmp2;
+		}
+
+	      emit_insn (GEN_FCN (to_icode) (to_addr,
+					     convert_to_mode (to_mode, tmp, 0)));
+
+	      to_addr = adjust_address (to_addr, to_mode, to_size);
+	    }
+
+	  len -= from_size;
+	}
+    }
+
+  /* Assert that we've made progress.  */
+  gcc_assert (len < orig_len);
+
+  if (len != 0)
+    move_by_pieces (to_addr, from_addr, len,
+		    MIN (MEM_ALIGN (to_addr), MEM_ALIGN (from_addr)), 0);
+  return to;
+}
+
+
+#undef  TARGET_SCHED_INIT_GLOBAL
+#define TARGET_SCHED_INIT_GLOBAL tilegx_sched_init_global
+
+#undef  TARGET_SCHED_FINISH_GLOBAL
+#define TARGET_SCHED_FINISH_GLOBAL tilegx_sched_finish_global
+
+#undef  TARGET_PRE_UNROLLING_AND_PEELING_HOOK
+#define TARGET_PRE_UNROLLING_AND_PEELING_HOOK \
+  tilegx_pre_unrolling_and_peeling_hook
+
+#undef  TARGET_POST_EXPAND_TO_RTL_HOOK
+#define TARGET_POST_EXPAND_TO_RTL_HOOK tilegx_post_expand_to_rtl_hook
+
+#undef  TARGET_GATE_HANDLE_EXTEND_PROPAGATION
+#define TARGET_GATE_HANDLE_EXTEND_PROPAGATION \
+  tilegx_gate_handle_extend_propagation
+
+#undef  TARGET_REST_OF_HANDLE_EXTEND_PROPAGATION
+#define TARGET_REST_OF_HANDLE_EXTEND_PROPAGATION \
+  tilegx_rest_of_handle_extension_propagation
+
+#undef  TARGET_GATE_HANDLE_TARGET_PEEPHOLE
+#define TARGET_GATE_HANDLE_TARGET_PEEPHOLE \
+  tilegx_gate_handle_target_peephole
+
+#undef  TARGET_REST_OF_HANDLE_TARGET_PEEPHOLE
+#define TARGET_REST_OF_HANDLE_TARGET_PEEPHOLE \
+  tilegx_rest_of_handle_target_peephole
+
+#undef  TARGET_MOVE_BY_PIECES
+#define TARGET_MOVE_BY_PIECES tilegx_move_by_pieces
