+  [(unspec_volatile:SI [(match_operand:SI 0 "immediate_operand" "i")
+			(match_operand:SI 1 "immediate_operand" "i")
+			(match_operand:SI 2 "immediate_operand" "i")]
+		       UNSPEC_PRAGMA_MUST_ITERATE)]
