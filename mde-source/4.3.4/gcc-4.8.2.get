diff -r -u -p -N /home/packages/gcc-4.8.2/gcc/config/tilegx/tilegx-c.c ./gcc/config/tilegx/tilegx-c.c
--- /home/packages/gcc-4.8.2/gcc/config/tilegx/tilegx-c.c	2013-01-10 15:38:27.000000000 -0500
+++ ./gcc/config/tilegx/tilegx-c.c	2015-10-26 22:26:34.976999000 -0400
@@ -27,6 +27,8 @@
 #include "cpplib.h"
 #include "tree.h"
 #include "c-family/c-common.h"
+#include "c-family/c-pragma.h"
+#include "tilegx-builtins.h"
 
 /* copy defines in c-cppbuiltin.c */
 # define builtin_define(TXT) cpp_define (pfile, TXT)
@@ -47,8 +49,95 @@ tilegx_cpu_cpp_builtins (struct cpp_read
   if (TARGET_32BIT)
     builtin_define ("__tilegx32__");
 
+  builtin_define ("__GCC_HAVE_SYNC_COMPARE_AND_SWAP_1");
+  builtin_define ("__GCC_HAVE_SYNC_COMPARE_AND_SWAP_2");
+
   TILEGX_CPU_CPP_ENDIAN_BUILTINS ();
   GNU_USER_TARGET_OS_CPP_BUILTINS ();
 }
 
 
+void
+tilegx_support_pragma_unroll (struct cpp_reader *pfile ATTRIBUTE_UNUSED)
+{
+  tree x;
+  enum cpp_ttype token;
+  tree type, t, operand;
+  int unroll_factor = 0;
+
+  token = pragma_lex (&x);
+  if (token == CPP_EQ)
+    token = pragma_lex (&x);
+  if (token != CPP_NUMBER)
+    {
+      warning (OPT_Wpragmas, "invalid unroll pragama syntax\n");
+      return;
+    }
+  unroll_factor = TREE_INT_CST_LOW (x);
+
+  type = build_function_type_list (void_type_node, integer_type_node,
+				   NULL_TREE);
+  t = build_fn_decl ("__tilegx_pragma_unroll", type);
+  DECL_BUILT_IN_CLASS (t) = BUILT_IN_MD;
+  TREE_PUBLIC (t) = 1;
+  DECL_EXTERNAL (t) = 1;
+  DECL_FUNCTION_CODE (t) = (built_in_function)TILEGX_PRAGMA_UNROLL;
+
+  operand = build_int_cst (NULL_TREE, unroll_factor);
+  t = build_call_expr (t, 1, operand);
+
+  add_stmt (t);
+}
+
+/* #pragma must_iterate [min] [, [max] [, [multiple]]] */
+void
+tilegx_support_pragma_must_iterate (struct cpp_reader *pfile ATTRIBUTE_UNUSED)
+{
+  tree x;
+  enum cpp_ttype token;
+  tree type, t;
+  int min = 0, max = -1, multiple = 1;
+  tree min_tree, max_tree, multiple_tree;
+
+  token = pragma_lex (&x);
+
+  if (token == CPP_NUMBER)
+    {
+      min = TREE_INT_CST_LOW (x);
+      token = pragma_lex (&x);
+    }
+
+  if (token == CPP_COMMA)
+    token = pragma_lex (&x);
+
+  if (token == CPP_NUMBER)
+    {
+      max = TREE_INT_CST_LOW (x);
+      token = pragma_lex (&x);
+    }
+
+  if (token == CPP_COMMA)
+    token = pragma_lex (&x);
+
+  if (token == CPP_NUMBER)
+    {
+      multiple = TREE_INT_CST_LOW (x);
+      token = pragma_lex (&x);
+    }
+
+  type = build_function_type_list (void_type_node, integer_type_node,
+				   integer_type_node, integer_type_node,
+				   NULL_TREE);
+  t = build_fn_decl ("__tilegx_pragma_must_iterate", type);
+  DECL_BUILT_IN_CLASS (t) = BUILT_IN_MD;
+  TREE_PUBLIC (t) = 1;
+  DECL_EXTERNAL (t) = 1;
+  DECL_FUNCTION_CODE (t) = (built_in_function)TILEGX_PRAGMA_MUST_ITERATE;
+
+  min_tree = build_int_cst (NULL_TREE, min);
+  max_tree = build_int_cst (NULL_TREE, max);
+  multiple_tree = build_int_cst (NULL_TREE, multiple);
+  t = build_call_expr (t, 3, min_tree, max_tree, multiple_tree);
+
+  add_stmt (t);
+}
