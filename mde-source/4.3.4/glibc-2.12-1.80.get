diff -r -u -N /ORIG/sysdeps/unix/sysv/linux/generic/not-cancel.h ./sysdeps/unix/sysv/linux/generic/not-cancel.h
--- /ORIG/sysdeps/unix/sysv/linux/generic/not-cancel.h	1969-12-31 19:00:00.000000000 -0500
