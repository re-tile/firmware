diff -r -u -N /ORIG/sysdeps/unix/sysv/linux/generic/futimesat.c ./sysdeps/unix/sysv/linux/generic/futimesat.c
--- /ORIG/sysdeps/unix/sysv/linux/generic/futimesat.c	1969-12-31 19:00:00.000000000 -0500
+++ ./sysdeps/unix/sysv/linux/generic/futimesat.c	2015-10-26 22:26:00.022763000 -0400
@@ -0,0 +1,53 @@
+/* Copyright (C) 2005, 2006, 2009 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+   Contributed by Chris Metcalf <cmetcalf@tilera.com>, 2011.
+
+   The GNU C Library is free software; you can redistribute it and/or
+   modify it under the terms of the GNU Lesser General Public
+   License as published by the Free Software Foundation; either
