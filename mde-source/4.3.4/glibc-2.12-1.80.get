patch -d .. -p1 -s < glibc-rh788959.patch
patch -d .. -p1 -s < glibc-rh789189.patch
patch -d .. -p1 -s < glibc-rh789238.patch
patch -d .. -p1 -s < glibc-rh794817.patch
patch -d .. -p1 -s < glibc-rh797094-1.patch
patch -d .. -p1 -s < glibc-rh797094-2.patch
patch -d .. -p1 -s < glibc-rh789238-2.patch
patch -d .. -p1 -s < glibc-rh795498.patch
patch -d .. -p1 -s < glibc-rh794817-2.patch
patch -d .. -p1 -s < glibc-rh804689.patch
patch -d .. -p1 -s < glibc-rh809602.patch
patch -d .. -p1 -s < glibc-rh808337.patch
patch -d .. -p1 -s < glibc-rh804630.patch
patch -d .. -p1 -s < glibc-rh788959-2.patch
patch -d .. -p1 -s < glibc-rh808545.patch
cd ..
find . -type f -size 0 -o -name "*.orig" -exec rm -f {} \;
cat > find_provides.sh <<EOF
#!/bin/sh
/usr/lib/rpm/find-provides | grep -v GLIBC_PRIVATE
exit 0
EOF
chmod +x find_provides.sh
touch `find . -name configure`
touch locale/programs/*-kw.h

cd ..
rm -rf $DIR/SRPM

cat $0 | patch -d $DIR -p1 -s

exit 0

# The actual Tilera patch starts here.

diff -r -u -N /ORIG/configure ./configure
--- /ORIG/configure	2012-08-01 17:32:21.753427000 -0400
+++ ./configure	2015-10-26 22:27:51.506607000 -0400
@@ -4305,6 +4305,16 @@
 		base_machine=sparc machine=sparc/sparc64/sparcv9v ;;
 sparc64v2)
 		base_machine=sparc machine=sparc/sparc64/sparcv9v2 ;;
+tile | tilepro)
+		base_machine=tile machine=tile/tilepro ;;
+tilegx)
+		base_machine=tile
+		if $CC $CFLAGS $CPPFLAGS -E -dM -xc /dev/null | \
+		  grep -q __LP64__; then
+		    machine=tile/tilegx/tilegx64
+		else
+		    machine=tile/tilegx/tilegx32
+		fi ;;
 *)		base_machine=$machine ;;
 esac
 
diff -r -u -N /ORIG/configure.in ./configure.in
--- /ORIG/configure.in	2012-08-01 17:32:21.012391000 -0400
+++ ./configure.in	2015-10-26 22:25:59.620741000 -0400
@@ -617,6 +617,16 @@
 		base_machine=sparc machine=sparc/sparc64/sparcv9v ;;
 sparc64v2)
 		base_machine=sparc machine=sparc/sparc64/sparcv9v2 ;;
+tile | tilepro | tile64)
+		base_machine=tile machine=tile/tilepro ;;
+tilegx)
+		base_machine=tile
+		if $CC $CFLAGS $CPPFLAGS -E -dM -xc /dev/null | \
+		  grep -q __LP64__; then
+		    machine=tile/tilegx/tilegx64
+		else
+		    machine=tile/tilegx/tilegx32
+		fi ;;
 *)		base_machine=$machine ;;
 esac
 changequote([,])dnl
diff -r -u -N /ORIG/elf/dl-load.c ./elf/dl-load.c
--- /ORIG/elf/dl-load.c	2012-08-01 17:32:21.301393000 -0400
+++ ./elf/dl-load.c	2015-10-26 22:25:59.648736000 -0400
@@ -1508,6 +1508,10 @@
     add_name_to_object (l, ((const char *) D_PTR (l, l_info[DT_STRTAB])
 			    + l->l_info[DT_SONAME]->d_un.d_val));
 
+#ifdef DL_AFTER_LOAD
+  DL_AFTER_LOAD (l);
+#endif
+
   /* Now that the object is fully initialized add it to the object list.  */
   _dl_add_to_namespace_list (l, nsid);
 
