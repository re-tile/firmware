#!/bin/bash -ex

# Run this script to create the corresponding source subdir in the CWD.

me=$(basename $0)
DIR=$(basename $0 .get)
if [ -d $DIR ]; then
    echo "$me: Cannot replace existing directory '$DIR'." >&2
    exit 1
fi

MD5SUM=65ea0a9f66d1364b5e70435996600804
FROM=http://vault.centos.org/6.3/os/Source/SPackages
ORIG=glibc-2.12-1.80.el6.src.rpm
ODIR=$(pwd)
if [ ! -f $ORIG ]; then
    if [ -n "$DOWNLOAD_CACHE" -a -f "$DOWNLOAD_CACHE/$ORIG" ]; then
        ODIR=$DOWNLOAD_CACHE
    else
        curl -L $FROM/$ORIG > $ORIG.tmp
        mv $ORIG.tmp $ORIG
    fi
fi

if [ $MD5SUM != `md5sum $ODIR/$ORIG | cut -f1 -d' '` ]; then
    echo "$me: Wrong md5sum for '$ORIG'." >&2
    exit 1
fi

mkdir -p $DIR/SRPM
cd $DIR/SRPM
rpm2cpio $ODIR/$ORIG | cpio -idv
tar -C .. --strip-components 1 -xjf glibc-2.12-2-gc4ccff1.tar.bz2
tar -C .. --strip-components 1 -xjf glibc-2.12-2-gc4ccff1-fedora.tar.bz2

patch -d .. -E -p1 -s < glibc-fedora.patch
patch -d .. -p1 -s < glibc-rh587360.patch
patch -d .. -p1 -s < glibc-rh582738.patch
patch -d .. -p1 -s < glibc-getlogin-r.patch
patch -d .. -p1 -s < glibc-localedata.patch
patch -d .. -p1 -s < glibc-rh593396.patch
patch -d .. -p1 -s < glibc-recvmmsg.patch
patch -d .. -p1 -s < glibc-aliasing.patch
patch -d .. -p1 -s < glibc-rh593686.patch
