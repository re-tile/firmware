+(define_expand "insn_ld16"
+  [(set (match_operand:TI 0 "register_operand" "")
+	(mem:TI (match_operand 1 "pointer_operand" "")))]
+  ""
+{
+  if (!TARGET_ISE1)
+    {
+      rtx dest_lo, dest_hi;
+      rtx addr_lo;
+      rtx mem_lo, mem_hi;
+
+      dest_lo = simplify_gen_subreg (DImode, operands[0], TImode, 0);
+      dest_hi = simplify_gen_subreg (DImode, operands[0], TImode, 8);
+
+      addr_lo = force_reg (Pmode, operands[1]);
+      mem_lo = gen_rtx_MEM (DImode, addr_lo);
+      mem_hi = change_address (mem_lo, DImode,
+			       gen_rtx_PLUS (Pmode, addr_lo, GEN_INT (8)));
+
+      emit_move_insn (dest_lo, mem_lo);
+      emit_move_insn (dest_hi, mem_hi);
+
+      DONE;
+    }
+})
