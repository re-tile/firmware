diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/tree-sra.c ./gcc/tree-sra.c
--- /home/packages/gcc-4.4.7-3-java/gcc/tree-sra.c	2013-10-15 20:07:54.551617000 -0400
+++ ./gcc/tree-sra.c	2015-10-26 22:26:56.592200000 -0400
@@ -2924,14 +2924,62 @@
     }
   else if (TREE_CODE (fld->element) == INTEGER_CST)
     {
-      tree domain_type = TYPE_DOMAIN (TREE_TYPE (fld->parent->element));
-      flen = fold_convert (bitsizetype, TYPE_SIZE (fld->type));
-      fpos = fold_convert (bitsizetype, fld->element);
-      if (domain_type && TYPE_MIN_VALUE (domain_type))
-	fpos = size_binop (MINUS_EXPR, fpos,
-			   fold_convert (bitsizetype,
-			   		 TYPE_MIN_VALUE (domain_type)));
-      fpos = size_binop (MULT_EXPR, flen, fpos);
+      if (TREE_CODE (fld->parent->element) != INTEGER_CST)
+	{
+	  tree domain_type = TYPE_DOMAIN (TREE_TYPE (fld->parent->element));
+	  flen = fold_convert (bitsizetype, TYPE_SIZE (fld->type));
+	  fpos = fold_convert (bitsizetype, fld->element);
+	  if (domain_type && TYPE_MIN_VALUE (domain_type))
+	    fpos = size_binop (MINUS_EXPR, fpos,
+			       fold_convert (bitsizetype,
+					     TYPE_MIN_VALUE (domain_type)));
+	  fpos = size_binop (MULT_EXPR, flen, fpos);
+	}
+      else
+	{
+	  tree domain_type = NULL;
+	  struct sra_elt *fld_parent = fld->parent;
+	  int n = 0;
+
+	  flen = fold_convert (bitsizetype, TYPE_SIZE (fld->type));
+	  fpos = fold_convert (bitsizetype, fld->element);
+
+	  while (fld_parent
+		 && fld_parent->element
+		 && TREE_CODE (fld_parent->element) == INTEGER_CST)
+	    {
+	      fld_parent = fld_parent->parent;
+	      n++;
+	    }
+
+	  if (fld_parent
+	      && fld_parent->element
+	      && TREE_CODE (fld_parent->element) == FIELD_DECL)
+	    {
+	      tree subtype = TREE_TYPE (fld_parent->element);
+	      if (TREE_CODE (subtype) == ARRAY_TYPE)
+		{
+		  while (n-- > 0)
+		    {
+		      if (TREE_CODE (subtype) != ARRAY_TYPE)
+			{
+			  subtype = NULL;
+			  break;
+			}
+		      subtype = TREE_TYPE (subtype);
+		    }
+		}
+
