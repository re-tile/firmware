+(define_insn "mulqihi3"
+  [(set (match_operand:HI 0 "register_operand" "=r")
+	(mult:HI (sign_extend:HI
+		  (match_operand:QI 1 "reg_or_0_operand" "rO"))
+		 (sign_extend:HI
+		  (match_operand:QI 2 "reg_or_0_operand" "rO"))))]
