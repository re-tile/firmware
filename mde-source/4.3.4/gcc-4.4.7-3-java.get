+(define_expand "umulsi3_highpart"
+  [(set (match_operand:SI 0 "register_operand" "")
+	(truncate:SI
+	 (lshiftrt:DI
+	  (mult:DI (zero_extend:DI (match_operand:SI 1 "reg_or_0_operand" ""))
+		   (zero_extend:DI (match_operand:SI 2 "reg_or_0_operand" "")))
