+
+static void
+decide_unroll_constant_mod_iterations (struct loop *loop,
+				       int flags ATTRIBUTE_UNUSED)
+{
+  struct niter_desc *desc;
+  unsigned pragma_unroll_factor;
+  int pragma_niter_min, pragma_niter_multiple;
+
+  desc = get_simple_loop_desc (loop);
+
+  pragma_unroll_factor = desc->pragma_unroll_factor;
+
+  /* Only catches the common case here: those loops that have both a pragma
+     unroll factor and a must_iterate pragma, and whose remainder iterations
+     can be eliminated by using information in the must_iterate pragma.  */
+
+  if (!desc->simple_p)
+    return;
+
+  if (!(pragma_unroll_factor > 1 && desc->has_must_iterate_pragma))
+    return;
+
+  /* To avoid misinterpreting the iteraction count, only accept loops with exit
+     conditions at the end.  */
+  if (!loop_exit_at_end_p (loop))
+    return;
+
+  pragma_niter_min = desc->pragma_niter_min;
+  pragma_niter_multiple = desc->pragma_niter_multiple;
+
+  if (pragma_niter_min % pragma_unroll_factor == 0 &&
+      pragma_niter_multiple % pragma_unroll_factor == 0)
+    {
+      loop->lpt_decision.decision = LPT_UNROLL_CONSTANT;
+      loop->lpt_decision.times = pragma_unroll_factor - 1;
+
+      if (dump_file)
+	fprintf (dump_file,
+		 ";; Decide to unroll loop with constant mod, %d times.\n",
+		 loop->lpt_decision.times);
+    }
+}
+
