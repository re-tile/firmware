+#endif
+
+#ifdef L_float32_lt
+int8
+__float32_lt ( float32 a, float32 b )
+{
+  if (    ( ( extractFloat32Exp( a ) == 0xFF ) && extractFloat32Frac( a ) )
+       || ( ( extractFloat32Exp( b ) == 0xFF ) && extractFloat32Frac( b ) )
+     ) {
+      return 1;
