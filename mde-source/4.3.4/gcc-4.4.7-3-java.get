+  [(unspec_volatile:SI
+    [(reg:SI TILE_NETORDER_IDN0_RECEIVE_REGNUM)
+     (reg:SI TILE_NETORDER_IDN1_RECEIVE_REGNUM)
+     (reg:SI TILE_NETORDER_UDN0_RECEIVE_REGNUM)
+     (reg:SI TILE_NETORDER_UDN1_RECEIVE_REGNUM)
+     (reg:SI TILE_NETORDER_UDN2_RECEIVE_REGNUM)
