+     (reg:SI TILE_NETORDER_IDN0_SEND_REGNUM)
+     (reg:SI TILE_NETORDER_UDN0_SEND_REGNUM)
+     (reg:SI TILE_NETORDER_SN_SEND_REGNUM)]
+    UNSPEC_NETWORK_BARRIER)
+   (clobber (reg:SI TILE_NETORDER_IDN0_RECEIVE_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_IDN1_RECEIVE_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_UDN0_RECEIVE_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_UDN1_RECEIVE_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_UDN2_RECEIVE_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_UDN3_RECEIVE_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_SN_RECEIVE_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_IDN0_SEND_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_UDN0_SEND_REGNUM))
+   (clobber (reg:SI TILE_NETORDER_SN_SEND_REGNUM))]
+  ""
+  "pseudo"
+  [(set_attr "type" "nothing")
