+		      (match_operand:I48MODE 2 "s8bit_cint_operand" "i")))
+   (set (match_operand:DI 0 "register_operand" "=r")
+        (any_extend:DI (unspec:I124MODE [(mem:I124MODE (match_dup 3))]
+					UNSPEC_LATENCY_MISS)))]
+  ""
+  "ld<I124MODE:n><s>_add\t%0, %1, %2"
+  [(set_attr "type" "X1_miss")])
