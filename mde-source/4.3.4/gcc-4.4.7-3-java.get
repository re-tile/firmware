+static void
+create_profile_path_object(const char *asm_filename, const char *pathname)
+{
+  int i;
+  FILE *asm_file = fopen(asm_filename, "w");
+  fprintf(asm_file,
+	  "\t.section .rodata, \"a\"\n"
+	  "\t.global\t__feedback_dir\n"
+	  "\t.hidden\t__feedback_dir\n"
+	  "\t.type __feedback_dir, @object\n"
+	  "__feedback_dir:\n"
+	  "\t.byte\t");
+
+  /* Write out the filename as a sequence of bytes rather than
+     .asciz in case it contains any wacky characters like a
+     backslash.  */
+  for (i = 0; pathname[i] != '\0'; i++)
+    fprintf(asm_file, "0x%02x, ", (unsigned char)pathname[i]);
+
+  fprintf(asm_file,
+	  "0x00\n"
+	  "\t.size __feedback_dir, . - __feedback_dir\n");
+  fclose (asm_file);
+}
+
+
+/* Linker feedback file, either from -ffeedback-use= or
+   -ffeedback-use-linker=.  */
+const char *feedback_use_linker_file = 0;
+
+bool linker_command_override = false;
+
+#define MAX_INSERT_ARGS 8
+
+static void
+targ_specific_driver (int *in_argc, const char *const **in_argv,
+		      int *in_added_libraries)
+{
+  int i;
+
+  /* Argument to -ffeedback-emit.  */
+  const char *feedback_emit_pathname = 0;
+
+  /* The new argument list will be contained in this.  */
+  const char **arglist;
+
+  /* Flags to keep track of state of various feedback options.  */
+  bool feedback_generate_compiler = false;
+  bool feedback_generate_linker = false;
+  bool feedback_generate_linker_explicit = false;
+  bool feedback_use_compiler = false;
+
+  /* True if we found the flag -ffeedback-emit.  */
+  bool feedback_emit = false;
+
+  /* The total number of arguments with the new stuff.  */
+  int argc;
+
+  /* The argument list.  */
+  const char *const *argv;
+
+  /* Number of arguments to insert */
+  int ninsert_args;
+
+  /* List of argumenst to insert */
+  const char *insert_args[MAX_INSERT_ARGS];
+
+  const char *generate_str = "-ffeedback-generate";
+  const char *generate_compiler_str = "-ffeedback-generate-compiler";
+  const char *generate_linker_str = "-ffeedback-generate-linker";
+  const char *no_generate_str = "-fno-feedback-generate";
+  const char *no_generate_compiler_str = "-fno-feedback-generate-compiler";
+  const char *no_generate_linker_str = "-fno-feedback-generate-linker";
+
+  const char *emit_str = "-ffeedback-emit=";
+  int emit_len = strlen (emit_str);
+
+  const char *use_str  = "-ffeedback-use=";
+  const char *use_compiler_str  = "-ffeedback-use-compiler=";
+  const char *use_linker_str  = "-ffeedback-use-linker=";
+  int use_len  = strlen (use_str);
+  int use_compiler_len  = strlen (use_compiler_str);
+  int use_linker_len  = strlen (use_linker_str);
+
+  const char *profile_generate_str = "-fprofile-generate";
+  const char *profile_use_str = "-fprofile-use";
+
+  /* True if the options -c or -S are passed.  We need to parse and initialize
+     this here because the corresponding global value has not been
+     initialized.  */
+  int targ_have_c = 0;
+
+  /* True if temporaries should be saved.  */
+  int save_temps = 0;
+
+  /* Parse the feedback related flags, noting:
+
+     1. whether generate-linker is implied but not explicit.  If so, we insert
+        the flag explicitly so that multilib works correctly.
+
+     2. whether generate-compiler is on.  If so, we insert -fprofile-generate
+        explicitly.
+
+     3. whether feedback-use is on.  If so, we insert -fprofile-use.
+  */
+
+  argc = *in_argc;
+  argv = *in_argv;
+
+  for (i = 1; i < argc; i++)
+    {
+      if (argv[i][0] == '-')
+	{
+	  if (!strcmp (argv[i], generate_str))
+	    {
+	      feedback_generate_compiler = true;
+	      feedback_generate_linker = true;
+	    }
+	  else if (!strcmp (argv[i], generate_compiler_str))
+	    {
+	      feedback_generate_compiler = true;
+	    }
+	  else if (!strcmp (argv[i], generate_linker_str))
+	    {
+	      feedback_generate_linker = true;
+	      feedback_generate_linker_explicit = true;
+	    }
+	  else if (!strcmp (argv[i], no_generate_str))
+	    {
+	      feedback_generate_compiler = false;
+	      feedback_generate_linker = false;
+	      feedback_generate_linker_explicit = false;
+	    }
+	  else if (!strcmp (argv[i], no_generate_compiler_str))
+	    {
+	      feedback_generate_compiler = false;
+	    }
+	  else if (!strcmp (argv[i], no_generate_linker_str))
+	    {
+	      feedback_generate_linker = false;
+	      feedback_generate_linker_explicit = false;
+	    }
+	  else if (!strncmp (argv[i], emit_str, emit_len))
+	    {
+	      feedback_emit = true;
+	      feedback_emit_pathname = &argv[i][emit_len];
+	    }
+	  else if (!strncmp (argv[i], use_str, use_len))
+	    {
+	      feedback_use_compiler = true;
+	      feedback_use_linker_file = &argv[i][use_len];
+	      linker_command_override = true;
+	    }
+	  else if (!strncmp (argv[i], use_compiler_str, use_compiler_len))
+	    {
+	      feedback_use_compiler = true;
+	    }
+	  else if (!strncmp (argv[i], use_linker_str, use_linker_len))
+	    {
+	      feedback_use_linker_file = &argv[i][use_linker_len];
+	      linker_command_override = true;
+	    }
+	  else if (!strcmp (argv[i], "-S") ||
+		   !strcmp (argv[i], "-c"))
+	    {
+	      targ_have_c = 1;
+	    }
+	  /* ugh.  need to know whether to save temps */
+          else if (!strcmp (argv[i], "-save-temps"))
+	    {
+	      save_temps = 1;
+	    }
+	}
+    }
+
+  ninsert_args = 0;
+
+  if (feedback_generate_compiler)
+    {
+      gcc_assert (ninsert_args < MAX_INSERT_ARGS);
+      insert_args[ninsert_args++] = profile_generate_str;
+    }
+
+  if (feedback_use_compiler)
+    {
+      gcc_assert (ninsert_args < MAX_INSERT_ARGS);
+      insert_args[ninsert_args++] = profile_use_str;
+    }
+
+  if (feedback_generate_linker && !feedback_generate_linker_explicit)
+    {
+      gcc_assert (ninsert_args < MAX_INSERT_ARGS);
+      insert_args[ninsert_args++] = generate_linker_str;
+    }
+
+  if (feedback_emit && !targ_have_c)
+    {
+      const char *asm_filename = make_temp_file (".s");
+
+      create_profile_path_object (asm_filename,
+				  feedback_emit_pathname);
+
+      record_temp_file (asm_filename, !save_temps, !save_temps);
+
+      gcc_assert (ninsert_args < MAX_INSERT_ARGS);
+      insert_args[ninsert_args++] = asm_filename;
+
+      (*in_added_libraries) ++;
+    }
+
+  if (ninsert_args > 0)
+    {
+      /* Make sure to have room for the trailing NULL argument.  */
+      arglist = XNEWVEC (const char *,
+			 argc + ninsert_args + 1);
+
+      i = 0;
+      do
+	{
+	  arglist[i] = argv[i];
+	  i++;
+	}
+      while (i < argc);
+
+      do
+	{
+	  arglist[i] = insert_args[i - argc];
+	  i++;
+	}
+      while (i < argc + ninsert_args);
+
+      arglist[i] = NULL;
+
+      *in_argc = i;
+      *in_argv = arglist;
+    }
+}
+
+static bool
+empty_linker_command (const char *link_spec)
+{
+  int value;
+
+  value = do_spec_2 (link_spec);
+
+  /* Check for non-empty command.  Check for trailing pipe and remove it.  */
+  if (value == 0)
+    {
+      if (argbuf_index > 0 && !strcmp (argbuf[argbuf_index - 1], "|"))
+	argbuf_index--;
+
+      return argbuf_index == 0;
+    }
+
+  return false;
+}
+
+static int
+generate_linker_map (const char *link_spec)
+{
+  int len;
+  char *cmd;
+
+  /* <link_spec> -Map %u.map [--script=%U.scr] */
+  len = strlen (link_spec) + 2 * (temp_filename_length + 4) + 20 + 1;
+
+  cmd = XNEWVEC (char, len);
+
+  /* FIXME: tile-gcc: need to check if command line is already passing in the
+     name of a linker map.  Assume not.  */
+  strcpy (cmd, link_spec);
+
+  strcat (cmd, " -Map %u.map");
+
+  return do_spec (cmd);
+}
+
+static int
+run_cpack (void)
+{
+  int len;
+  char *cmd;
+
+  /* gen-ld-cpack [--verbose] --map %%U.map -o %%u.scr
+     <feedback_use_linker_file> + 10 spaces to be safe */
+  len = 2 * (temp_filename_length + 4) + strlen (feedback_use_linker_file)
+    + 37 + 1 + 10;
+
+  cmd = XNEWVEC (char, len);
+
+  if (feedback_use_linker_file == NULL)
+    fatal ("gen-ld-cpack: no feedback data file provided");
+
+  sprintf (cmd, "gen-ld-cpack %s --map %%U.map -o %%u.scr %s",
+           verbose_flag ? "--verbose" : "", feedback_use_linker_file);
+
+  return do_spec (cmd);
+}
+
+static int
+use_linker_script (const char *link_spec, bool no_obj)
+{
+  int len;
+  char *cmd;
+  const char *p;
+  char *q;
+
+  /* <link_spec> --script=%U.scr */
+  len = strlen(link_spec) + (temp_filename_length + 4) + 10 + 1;
+
+  cmd = XNEWVEC (char, len);
+
+  if (no_obj)
+    {
+      /* HACK: go through the original link spec and removes the list object
+	 files.  This means we get rid of %o, %S, and %E.  */
+      for (p = link_spec, q = cmd; *p != '\0'; p++)
+	{
+	  if (*p == '%')
+	    {
+	      if (*(p + 1) == 'S' ||
+		  *(p + 1) == 'E' ||
+		  *(p + 1) == 'o')
+		{
+		  p++;
+		  continue;
+		}
+	    }
+
+	  *q++ = *p;
+	}
+      *q = '\0';
+    }
+  else
+    {
+      strcpy (cmd, link_spec);
+    }
+
+  /* Add the linker script argument */
+  strcat (cmd, " --script=%U.scr");
+
+  return do_spec (cmd);
+}
+
+static int
+do_linker_spec_override (const char *link_spec)
+{
+  int value;
+
+  if (empty_linker_command (link_spec))
+      return 0;
+
+  if (feedback_use_linker_file != NULL)
+    {
+      value = generate_linker_map (link_spec);
+
+      if (value != 0)
+	return value;
+
+      value = run_cpack ();
+
+      if (value != 0)
+	return value;
+
+    }
+
+  return use_linker_script (link_spec, feedback_use_linker_file != NULL);
+}
+
