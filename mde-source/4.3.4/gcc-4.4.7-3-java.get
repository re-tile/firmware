+#endif
+
+#ifdef L_float32_le
+int8
+__float32_le ( float32 a, float32 b )
+{
+  if (    ( ( extractFloat32Exp( a ) == 0xFF ) && extractFloat32Frac( a ) )
+       || ( ( extractFloat32Exp( b ) == 0xFF ) && extractFloat32Frac( b ) )
+     ) {
+      return 1;
+  }
+
+  return __float32_cmp (a, b) ;
+}
+
+#ifdef CREATE_GCC_ALIASES 
+flag __lesf2( float32 a, float32 b )
+     __attribute__((weak, alias("__float32_le")));
+#endif
+
+#endif
+
