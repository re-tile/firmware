+/*----------------------------------------------------------------------------
+| Turn this on to create an optimized version with a fixed rounding mode
+| and no exception flags recorded.
+*----------------------------------------------------------------------------*/
+#define SIMPLE_SOFTFLOAT
+
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE floating-point types.
+*----------------------------------------------------------------------------*/
+typedef uint32 float32;
+typedef uint64 float64;
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE floating-point underflow tininess-detection mode.
+*----------------------------------------------------------------------------*/
+#ifdef SIMPLE_SOFTFLOAT
+#define __float_detect_tininess float_tininess_after_rounding
+#else
+extern unsigned char __float_detect_tininess;
+#endif
+enum {
+    float_tininess_after_rounding  = 0,
+    float_tininess_before_rounding = 1
+};
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE floating-point rounding mode.
+*----------------------------------------------------------------------------*/
+#ifdef SIMPLE_SOFTFLOAT
+#define __float_rounding_mode float_round_nearest_even
+#else
+extern unsigned char __float_rounding_mode;
+#endif
+enum {
+    float_round_nearest_even = 0,
+    float_round_to_zero      = 1,
+    float_round_down         = 2,
+    float_round_up           = 3
+};
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE floating-point exception flags.
+*----------------------------------------------------------------------------*/
+#ifndef SIMPLE_SOFTFLOAT
+extern unsigned char __float_exception_flags;
+#endif
+enum {
+    float_flag_inexact   =  1,
+    float_flag_underflow =  2,
+    float_flag_overflow  =  4,
+    float_flag_divbyzero =  8,
+    float_flag_invalid   = 16
+};
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE integer-to-floating-point conversion routines.
+*----------------------------------------------------------------------------*/
+extern float32 __int32_to_float32( int32 );
+extern float64 __int32_to_float64( int32 );
+extern float32 __uint32_to_float32( uint32 );
+extern float64 __uint32_to_float64( uint32 );
+extern float32 __int64_to_float32( int64 );
+extern float64 __int64_to_float64( int64 );
+extern float32 __uint64_to_float32( uint64 );
+extern float64 __uint64_to_float64( uint64 );
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE single-precision conversion routines.
+*----------------------------------------------------------------------------*/
+extern int     __float32_to_int32( float32 );
+extern int     __float32_to_int32_round_to_zero( float32 );
+extern uint32  __float32_to_uint32_round_to_zero( float32 );
+extern int64 __float32_to_int64( float32 a );
+extern int64   __float32_to_int64_round_to_zero( float32 );
+extern uint64  __float32_to_uint64_round_to_zero( float32 );
+extern float64 __float32_to_float64( float32 );
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE single-precision operations.
+*----------------------------------------------------------------------------*/
+extern float32 __float32_round_to_int( float32 );
+extern float32 __float32_add( float32, float32 );
+extern float32 __float32_sub( float32, float32 );
+extern float32 __float32_mul( float32, float32 );
+extern float32 __float32_div( float32, float32 );
+extern float32 __float32_rem( float32, float32 );
+extern float32 __float32_min( float32, float32 );
+extern float32 __float32_max( float32, float32 );
+extern float32 __float32_sqrt( float32 );
+extern float32 __float32_neg( float32 );
+extern flag __float32_eq( float32, float32 );
+extern flag __float32_ne( float32, float32 );
+extern flag __float32_le( float32, float32 );
+extern flag __float32_lt( float32, float32 );
+extern flag __float32_gt( float32, float32 );
+extern flag __float32_ge( float32, float32 );
+extern flag __float32_eq_signaling( float32, float32 );
+extern flag __float32_le_quiet( float32, float32 );
+extern flag __float32_lt_quiet( float32, float32 );
+INLINE flag __float32_is_signaling_nan( float32 );
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE double-precision conversion routines.
+*----------------------------------------------------------------------------*/
+extern int32 __float64_to_int32( float64 );
+extern int32 __float64_to_int32_round_to_zero( float64 );
+extern uint32 __float64_to_uint32_round_to_zero( float64 );
+extern int64 __float64_to_int64( float64 a );
+extern int64   __float64_to_int64_round_to_zero( float64 );
+extern uint64  __float64_to_uint64_round_to_zero( float64 );
+extern float32 __float64_to_float32( float64 );
+
+/*----------------------------------------------------------------------------
+| Software IEC/IEEE double-precision operations.
+*----------------------------------------------------------------------------*/
+extern float64 __float64_round_to_int( float64 );
+extern float64 __float64_add( float64, float64 );
+extern float64 __float64_sub( float64, float64 );
+extern float64 __float64_mul( float64, float64 );
+extern float64 __float64_div( float64, float64 );
+extern float64 __float64_rem( float64, float64 );
+extern float64 __float64_min( float64, float64 );
+extern float64 __float64_max( float64, float64 );
+extern float64 __float64_sqrt( float64 );
+extern float64 __float64_neg( float64 );
+extern flag __float64_eq( float64, float64 );
+extern flag __float64_ne( float64, float64 );
+extern flag __float64_le( float64, float64 );
+extern flag __float64_lt( float64, float64 );
+extern flag __float64_gt( float64, float64 );
+extern flag __float64_ge( float64, float64 );
+extern flag __float64_eq_signaling( float64, float64 );
+extern flag __float64_le_quiet( float64, float64 );
+extern flag __float64_lt_quiet( float64, float64 );
+INLINE flag __float64_is_signaling_nan( float64 );
+
+/*----------------------------------------------------------------------------
+| Software gcc compare operations.
+*----------------------------------------------------------------------------*/
+
+extern int8 __float64_cmp( float64 a, float64 b );
+extern int8 __float64_eq ( float64 a, float64 b );
+extern int8 __float64_ne ( float64 a, float64 b );
