+(define_insn "jump"
+  [(set (pc) (label_ref (match_operand 0 "" "")))]
+  ""
+  "j\t%l0"
+  [(set_attr "type" "X1")])
+
+(define_insn "indirect_jump"
+  [(set (pc) (match_operand:SI 0 "register_operand" "rO"))]
+  ""
+  "jr\t%r0"
+  [(set_attr "type" "X1")])
+
+(define_expand "return"
+  [(parallel
+    [(return)
+     (use (reg:SI 55))])]
+  "tile_can_use_return_insn_p ()"
+  "")
+
+(define_insn "_return"
+  [(return)
+   (use (reg:SI 55))]
+  "reload_completed"
