diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/bb-reorder.c ./gcc/bb-reorder.c
--- /home/packages/gcc-4.4.7-3-java/gcc/bb-reorder.c	2011-04-13 10:10:38.000000000 -0400
+++ ./gcc/bb-reorder.c	2015-10-26 22:26:50.830147000 -0400
@@ -2226,19 +2226,30 @@
 {
   basic_block bb;
 
+  /* Don't reorder/partition functions with section name
+     attribute.  */
+  if (lookup_attribute ("section", DECL_ATTRIBUTES (cfun->decl)))
+    return 0;
+
   /* Last attempt to optimize CFG, as scheduling, peepholing and insn
      splitting possibly introduced more crossjumping opportunities.  */
   cfg_layout_initialize (CLEANUP_EXPENSIVE);
 
-  if ((flag_reorder_blocks || flag_reorder_blocks_and_partition)
-      /* Don't reorder blocks when optimizing for size because extra jump insns may
-	 be created; also barrier may create extra padding.
-
-	 More correctly we should have a block reordering mode that tried to
-	 minimize the combined size of all the jumps.  This would more or less
-	 automatically remove extra jumps, but would also try to use more short
-	 jumps instead of long jumps.  */
-      && optimize_function_for_speed_p (cfun))
+      /* gcc turned off this optimization when optimizing for space, but:
+
+	 1. it relies on basic block reordering to give us a single switch
+	 between hot and cold sections, so reordering must be done when
+	 flag_reorder_blocks_and_partition is on even if we're optimizing for
+	 space.
+
+	 2. without this optimization, it generates poor code for c++
+         exception handlers, where you have handler interleaved with
+         non-handler code, with lots of unnecessary jumps in between.
+
+	 3. in context where size matters, what people usually care about is
+         icache utilization, and reordering the blocks according to traces
+         is usually better for that than strictly looking at size.  */
+  if (flag_reorder_blocks_and_partition || flag_reorder_blocks)
     {
       reorder_basic_blocks ();
       cleanup_cfg (CLEANUP_EXPENSIVE);
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/builtin-types.def ./gcc/builtin-types.def
