+			      UNSPEC_NETWORK_RECEIVE))
+     (clobber (reg:DI TILEGX_NETORDER_REG))])]
+  "")
+
+(define_expand "tile_udn2_receive"
+  [(parallel
+    [(set (match_operand:DI 0 "register_operand" "")
+	  (unspec_volatile:DI [(const_int TILEGX_NETREG_UDN2)
+			       (reg:DI TILEGX_NETORDER_REG)]
+			      UNSPEC_NETWORK_RECEIVE))
+     (clobber (reg:DI TILEGX_NETORDER_REG))])]
+  "")
+
+(define_expand "tile_udn3_receive"
+  [(parallel
+    [(set (match_operand:DI 0 "register_operand" "")
+	  (unspec_volatile:DI [(const_int TILEGX_NETREG_UDN3)
+			       (reg:DI TILEGX_NETORDER_REG)]
+			      UNSPEC_NETWORK_RECEIVE))
+     (clobber (reg:DI TILEGX_NETORDER_REG))])]
+  "")
+
+(define_expand "tile_udn_send"
+  [(parallel
+    [(unspec_volatile:DI [(const_int TILEGX_NETREG_UDN0)
+			  (match_operand:DI 0 "reg_or_cint_operand" "")
+			  (reg:DI TILEGX_NETORDER_REG)]
+			 UNSPEC_NETWORK_SEND)
+    (clobber (reg:DI TILEGX_NETORDER_REG))])]
+  "")
+
+(define_insn "*netreg_adddi_to_network"
+  [(unspec_volatile:DI
+    [(match_operand:DI 0 "netreg_operand" "i,i,i")
+     (plus:DI (match_operand:DI 1 "reg_or_0_operand" "%rO,rO,rO")
+              (match_operand:DI 2 "add_operand" "r,I,JT"))
+     (reg:DI TILEGX_NETORDER_REG)]
+    UNSPEC_NETWORK_SEND)
+   (clobber (reg:DI TILEGX_NETORDER_REG))]
+  ""
+  "@
+   add\t%N0, %r1, %2
+   addi\t%N0, %r1, %2
+   addli\t%N0, %r1, %H2"
+  [(set_attr "type" "*,*,X01")])
+
+(define_insn "*netreg_adddi_from_network"
+  [(set (match_operand:DI 0 "register_operand" "=r,r,r")
+	(plus:DI (unspec_volatile:DI
+                  [(match_operand:DI 1 "netreg_operand" "%i,i,i")
+		   (reg:DI TILEGX_NETORDER_REG)]
+                  UNSPEC_NETWORK_RECEIVE)
+		 (match_operand:DI 2 "add_operand" "rO,I,JT")))
+   (clobber (reg:DI TILEGX_NETORDER_REG))]
+  ""
+  "@
+   add\t%0, %N1, %r2
+   addi\t%0, %N1, %2
+   addli\t%0, %N1, %H2"
+  [(set_attr "type" "*,*,X01")])
+
+
+;;
+;; Stack protector instructions.
+;;
+
+(define_expand "stack_protect_set"
+  [(set (match_operand 0 "nonautoincmem_operand" "")
+	(match_operand 1 "nonautoincmem_operand" ""))]
+  ""
+{
+#ifdef TARGET_THREAD_SSP_OFFSET
+  rtx tp = gen_rtx_REG (Pmode, THREAD_POINTER_REGNUM);
+  rtx ssp_addr = gen_rtx_PLUS (Pmode, tp, GEN_INT (TARGET_THREAD_SSP_OFFSET));
+  rtx ssp = gen_reg_rtx (Pmode);
+  
+  emit_insn (gen_rtx_SET (VOIDmode, ssp, ssp_addr));
+
+  operands[1] = gen_rtx_MEM (Pmode, ssp);
+#endif
+
+  if (TARGET_32BIT)
+    emit_insn (gen_stack_protect_setsi (operands[0], operands[1]));
+  else
+    emit_insn (gen_stack_protect_setdi (operands[0], operands[1]));
+
+  DONE;
+})
+
+(define_insn "stack_protect_setsi"
+  [(set (match_operand:SI 0 "nonautoincmem_operand" "=U")
+        (unspec:SI [(match_operand:SI 1 "nonautoincmem_operand" "U")]
+		   UNSPEC_SP_SET))
+   (set (match_scratch:SI 2 "=&r") (const_int 0))]
+  ""
+  "ld4s\t%2, %1; { st4\t%0, %2; move\t%2, zero }"
+  [(set_attr "length" "16")
+   (set_attr "type" "cannot_bundle_3cycle")])
+
+(define_insn "stack_protect_setdi"
+  [(set (match_operand:DI 0 "nonautoincmem_operand" "=U")
+        (unspec:DI [(match_operand:DI 1 "nonautoincmem_operand" "U")]
+		   UNSPEC_SP_SET))
+   (set (match_scratch:DI 2 "=&r") (const_int 0))]
+  ""
+  "ld\t%2, %1; { st\t%0, %2; move\t%2, zero }"
+  [(set_attr "length" "16")
+   (set_attr "type" "cannot_bundle_3cycle")])
+
+(define_expand "stack_protect_test"
+  [(match_operand 0 "nonautoincmem_operand" "")
+   (match_operand 1 "nonautoincmem_operand" "")
+   (match_operand 2 "" "")]
+  ""
+{
+  rtx compare_result;
+  rtx bcomp, loc_ref;
+
+#ifdef TARGET_THREAD_SSP_OFFSET
+  rtx tp = gen_rtx_REG (Pmode, THREAD_POINTER_REGNUM);
+  rtx ssp_addr = gen_rtx_PLUS (Pmode, tp, GEN_INT (TARGET_THREAD_SSP_OFFSET));
+  rtx ssp = gen_reg_rtx (Pmode);
+  
+  emit_insn (gen_rtx_SET (VOIDmode, ssp, ssp_addr));
+
+  operands[1] = gen_rtx_MEM (Pmode, ssp);
+#endif
+
+  compare_result = gen_reg_rtx (Pmode);
+
+  if (TARGET_32BIT)
+    emit_insn (gen_stack_protect_testsi (compare_result, operands[0],
+					 operands[1]));
+  else
+    emit_insn (gen_stack_protect_testdi (compare_result, operands[0],
+					 operands[1]));
+
+  bcomp = gen_rtx_NE (SImode, compare_result, const0_rtx);
+
+  loc_ref = gen_rtx_LABEL_REF (VOIDmode, operands[2]);
+
+  emit_jump_insn (gen_rtx_SET (VOIDmode, pc_rtx,
+			       gen_rtx_IF_THEN_ELSE (VOIDmode, bcomp,
+						     loc_ref, pc_rtx)));
+
+  DONE;
+})
+
+(define_insn "stack_protect_testsi"
+  [(set (match_operand:SI 0 "register_operand" "=&r")
+        (unspec:SI [(match_operand:SI 1 "nonautoincmem_operand" "U")
+                    (match_operand:SI 2 "nonautoincmem_operand" "U")]
+                   UNSPEC_SP_TEST))
+   (set (match_scratch:SI 3 "=&r") (const_int 0))]
+  ""
+  "ld4s\t%0, %1; ld4s\t%3, %2; { cmpeq\t%0, %0, %3; move\t%3, zero }"
+  [(set_attr "length" "24")
+   (set_attr "type" "cannot_bundle_4cycle")])
+
+(define_insn "stack_protect_testdi"
+  [(set (match_operand:DI 0 "register_operand" "=&r")
+        (unspec:DI [(match_operand:DI 1 "nonautoincmem_operand" "U")
+                    (match_operand:DI 2 "nonautoincmem_operand" "U")]
+                   UNSPEC_SP_TEST))
+   (set (match_scratch:DI 3 "=&r") (const_int 0))]
+  ""
+  "ld\t%0, %1; ld\t%3, %2; { cmpeq\t%0, %0, %3; move\t%3, zero }"
+  [(set_attr "length" "24")
+   (set_attr "type" "cannot_bundle_4cycle")])
+
+
+;;
+;; Pragmas
+;;
+
+(define_insn "tile_pragma_unroll"
+  [(unspec_volatile:SI [(match_operand:SI 0 "immediate_operand" "i")]
+		       UNSPEC_PRAGMA_UNROLL)]
+  ""
+  "")
+
+(define_insn "tile_pragma_must_iterate"
+  [(unspec_volatile:SI [(match_operand:SI 0 "immediate_operand" "i")
+			(match_operand:SI 1 "immediate_operand" "i")
+			(match_operand:SI 2 "immediate_operand" "i")]
+		       UNSPEC_PRAGMA_MUST_ITERATE)]
+  ""
+  "")
+
+(include "sync.md")
+
+;; Local variables:
+;; mode:emacs-lisp
+;; indent-tabs-mode: nil
+;; End:
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/tilegx.opt ./gcc/config/tilegx/tilegx.opt
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/tilegx.opt	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilegx/tilegx.opt	2015-10-26 22:26:57.676200000 -0400
@@ -0,0 +1,135 @@
+; Options for the TILE-Gx port of the compiler.
+; Copyright (C) 2011
+; Free Software Foundation, Inc.
+; Contributed by Walter Lee (walt@tilera.com)
+;
+; This file is part of GCC.
+;
+; GCC is free software; you can redistribute it and/or modify it under
+; the terms of the GNU General Public License as published by the Free
+; Software Foundation; either version 3, or (at your option) any later
+; version.
+;
+; GCC is distributed in the hope that it will be useful, but WITHOUT ANY
+; WARRANTY; without even the implied warranty of MERCHANTABILITY or
+; FITNESS FOR A PARTICULAR PURPOSE.  See the GNU General Public License
+; for more details.
+;
+; You should have received a copy of the GNU General Public License
+; along with GCC; see the file COPYING3.  If not see
+; <http://www.gnu.org/licenses/>.
+
+
+ffeedback-generate
+Target Report Var(tilegx_feedback_generate) VarExists
+Generate instrumentation to collect data for for both compiler and
+linker-based feedback optimizations.  
+
+ffeedback-generate-compiler
+Target Report Var(tilegx_feedback_generate_compiler) VarExists
+Generate instrumentation to collect data for for compiler-based feedback
+optimizations.  Similar as fprofile-generate except it uses a single file
+format that is easier to use, especially with linker feedback.
+
+ffeedback-generate-linker
+Target Report Var(tilegx_feedback_generate_linker) VarExists
+Generate instrumentation to collect data for for linker-based feedback
+optimizations.
+
+ffeedback-emit=
+Target Report RejectNegative Joined Var(tilegx_feedback_emit_dir) VarExists
+Generate binary to collect linker feedback in formation, using the argument as
+the directory where profiling information is stored.  Requires that the input
+object files has been compiled with -ffeedback-generate[-xxxx].
+
+ffeedback-use-compiler=
+Target Report RejectNegative Joined Var(tilegx_feedback_use_compiler_file) VarExists
+Use the input data file to perform linker-based feedback optimizations.
+
+ffeedback-use-linker=
+Target Report RejectNegative Joined Var(tilegx_feedback_use_linker_file) VarExists
+Use the input data file to perform linker-based feedback optimizations.
+
+ffeedback-use=
+Target Report RejectNegative Joined Var(tilegx_feedback_use_file) VarExists
+Use the input data file to perform linker-based feedback optimizations.
+
+mbme
+Target Report RejectNegative
+Compile using the BME headers and libraries
+
+mcmodel=
+Target RejectNegative Joined Var(tilegx_cmodel_string)
+Use given TILE-Gx code model
+
+mcollect-data
+Target Report Mask(COLLECT_DATA)
+Collect data about compiler optimizations into a global file.
+
+mdata-file=
+Target RejectNegative Joined Var(tilegx_data_file) VarExists
+uData file to use to collect data.
+
+mexpand-asm
+Target Report Mask(EXPAND_ASM)
+Expand certain inline assembly into rtl patterns that the compiler can
+better optimize.
+
+mextend-opt
+Target Report Mask(EXTEND_OPT)
+Optimizations on zero/sign-extension operations.
+
+mnewlib
+Target Report RejectNegative
+Compile using the newlib headers and libraries
+
+march=
+Target Report RejectNegative Joined Var(tilegx_arch_string)
+Use features of given architecture
+
+mhazard-opt=
+Target RejectNegative UInteger Joined Var(tilegx_hazard_opt) VarExists
+Optimzie the schedule of instructions around micro-architecture
+hazards by selectively inserting nops.  0 = off, 1 = branches and
+jumps only, and 2 = on.
+
+mise0
+Target Report Mask(ISE0)
+
+mise1
+Target Report Mask(ISE1)
+
+m32
+Target Report RejectNegative Negative(m64) Mask(32BIT)
+Compile with 32 bit longs and pointers.
+
+m64
+Target Report RejectNegative Negative(m32) InverseMask(32BIT, 64BIT)
+Compile with 64 bit longs and pointers.
+
+mbig-endian
+Target Report RejectNegative Mask(BIG_ENDIAN)
+Use big-endian byte order.
+
+mlittle-endian
+Target Report RejectNegative InverseMask(BIG_ENDIAN)
+Use little-endian byte order.
+
+Wunmatched-loop-pragmas
+Target Report Mask(WARN_UNMATCHED_LOOP_PRAGMAS)
+Warn about loop pragmas that do not have matching loops.
+
+;; The following are x86 options that are here for x86 compatibility.
+;; We simply ignore them.
+
+momit-leaf-frame-pointer
+Target Report
+Ignored (x86 compatibility flag)
+
+mcpu=
+Target RejectNegative Joined Var(tilegx_cpu_string)
+Ignored (x86 compatibility flag)
+
+mtune=
+Target RejectNegative Joined Var(tilegx_tune_string)
+Ignored (x86 compatibility flag)
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/tilegx2.c ./gcc/config/tilegx/tilegx2.c
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/tilegx2.c	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilegx/tilegx2.c	2015-10-26 22:26:57.722193000 -0400
@@ -0,0 +1,3518 @@
+/* Subroutines used for code generation on the Tilera TILE.
+   Copyright (C) 2011 Free Software Foundation, Inc.
+
+This file is part of GCC.
+
+GCC is free software; you can redistribute it and/or modify
+it under the terms of the GNU General Public License as published by
+the Free Software Foundation; either version 3, or (at your option)
+any later version.
+
+GCC is distributed in the hope that it will be useful,
+but WITHOUT ANY WARRANTY; without even the implied warranty of
+MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+GNU General Public License for more details.
+
+You should have received a copy of the GNU General Public License
+along with GCC; see the file COPYING3.  If not see
+<http://www.gnu.org/licenses/>.  */
+
+static FILE * tilegx_lock_data_file (const char *fn);
+static void tilegx_unlock_data_file (FILE *file);
+const char *tilegx_data_file = "/tmp/gcc_data_file";
+
+/* Functions to support scheduling of network register operations.  */
+
+
+/* Return the ordering register corresponding to the port.  */
+static int
+get_ordering_reg (int unspec_num, rtx netreg)
+{
+  int netreg_num;
+  gcc_assert (CONST_INT_P (netreg));
+  netreg_num = INTVAL (netreg);
+
+  if (unspec_num == UNSPEC_NETWORK_RECEIVE)
+    {
+      switch (netreg_num)
+	{
+	case TILEGX_NETREG_IDN0:
+	  return TILEGX_NETORDER_IDN0_RECEIVE_REGNUM;
+	case TILEGX_NETREG_IDN1:
+	  return TILEGX_NETORDER_IDN1_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN0:
+	  return TILEGX_NETORDER_UDN0_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN1:
+	  return TILEGX_NETORDER_UDN1_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN2:
+	  return TILEGX_NETORDER_UDN2_RECEIVE_REGNUM;
+	case TILEGX_NETREG_UDN3:
+	  return TILEGX_NETORDER_UDN3_RECEIVE_REGNUM;
+	}
+    }
+  else /* UNSPEC_NETWORK_SEND */
+    {
+      switch (netreg_num)
+	{
+	case TILEGX_NETREG_IDN0:
+	  return TILEGX_NETORDER_IDN0_SEND_REGNUM;
+	case TILEGX_NETREG_UDN0:
+	  return TILEGX_NETORDER_UDN0_SEND_REGNUM;
+	}
+    }
+
+  return 0;
+}
+
+
+/*  Specialize or generalize the ordering operand, depending on the input
+    pattern.  If the input pattern contains TILEGX_NETORDER_REGNUM,
+    then specialize it.  If it contains a port specific ordering reg, then
+    generalize it to TILEGX_NETORDER_REGNUM.  Changes are made in two
+    places: in the ordering operand inside the unspec, and in the corresponding
+    clobber expression.  */
+static void
+replace_ordering_operands (rtx pattern, rtx last_parallel)
+{
+  int opnd;
+  int i;
+  int ordering_reg;
+  int from_reg;
+  int to_reg;
+  enum machine_mode mode;
+  rtx temp;
+
+  if (XINT (pattern, 1) == UNSPEC_NETWORK_RECEIVE)
+    opnd = 1;
+  else /* UNSPEC_NETWORK_SEND */
+    opnd = 2;
+
+  ordering_reg = get_ordering_reg (XINT (pattern, 1), XVECEXP (pattern, 0, 0));
+
+  from_reg = REGNO (XVECEXP (pattern, 0, opnd));
+
+  if (from_reg == TILEGX_NETORDER_REGNUM)
+    {
+      to_reg = ordering_reg;
+    }
+  else
+    {
+      gcc_assert (from_reg == ordering_reg);
+      to_reg = TILEGX_NETORDER_REGNUM;
+    }
+
+  mode = GET_MODE (XVECEXP (pattern, 0, opnd));
+  temp = gen_rtx_REG (mode, to_reg);
+
+  XVECEXP (pattern, 0, opnd) = temp;
+
+  for (i = 0; i < XVECLEN (last_parallel, 0); i++)
+    {
+      rtx expr = XVECEXP (last_parallel, 0, i);
+
+      if (GET_CODE (expr) == CLOBBER &&
+	  REG_P (XEXP (expr, 0)) &&
+	  REGNO (XEXP (expr, 0)) == (unsigned)from_reg)
+	{
+	  /* gcc defines a single clobber expression for each register and
+	     reuses them, and it can be accessed via gen_hard_reg_clobber ().  */
+	  XVECEXP (last_parallel, 0, i) = gen_hard_reg_clobber (mode, to_reg);
+	  break;
+	}
+    }
+
+  /* check that we've found a corresponding clobber expression.  */
+  gcc_assert (i < XVECLEN (last_parallel, 0));
+}
+
+
+/* This routine is used to modify the network instructions before
+   scheduling so that they can be bundled, and also to reverse the
+   transformation after scheduling.  Two changes are made:
+
+   1. Replace the rtx_code FROM with TO.  Before scheduling, we're
+      replacing UNSPEC_VOLATILE with UNSPEC.  After scheduling, we're
+      replacing UNSPEC with UNSPEC_VOLATILE.
+
+   2. Specialize the ordering operands before scheduling, from the
+      generic TILEGX_NETORDER_REGNUM to a per-port ordering register.
+      Also reverse this transformation after scheduling.
+
+   For debug_insn, we only do item 1.  */
+static void
+replace_network_unspec (rtx pattern, rtx last_parallel, RTX_CODE from,
+			RTX_CODE to, bool is_debug_insn)
+{
+  const char *fmt;
+  int i, j;
+
+  /* As we recurse, keep track of the last parallel construct as that's where
+     we expect to find the clobber expressions corresponding to the nework
+     operation.  */
+  if (GET_CODE (pattern) == PARALLEL)
+    last_parallel = pattern;
+
+  if (GET_CODE (pattern) == from)
+    {
+      /* We've found a network operation.  Do the transformation.  */
+      if (XINT (pattern, 1) == UNSPEC_NETWORK_RECEIVE
+	  || XINT (pattern, 1) == UNSPEC_NETWORK_SEND)
+	{
+	  PUT_CODE (pattern, to);
+	  if (!is_debug_insn)
+	    replace_ordering_operands (pattern, last_parallel);
+	}
+    }
+
+  fmt = GET_RTX_FORMAT (GET_CODE (pattern));
+  for (i = 0; i < GET_RTX_LENGTH (GET_CODE (pattern)); i++)
+    {
+      if (fmt[i] == 'e')
+	{
+	  replace_network_unspec (XEXP (pattern, i), last_parallel, from, to,
+				  is_debug_insn);
+	}
+      else if (fmt[i] == 'E')
+	{
+	  for (j = 0; j < XVECLEN (pattern, i); j++)
+	    {
+	      replace_network_unspec (XVECEXP (pattern, i, j), last_parallel,
+				      from, to, is_debug_insn);
+	    }
+	}
+    }
+}
+
+
+/* Assign unused registers to zero, so that they don't consume a
+   useful register.
+
+   At the beginning of the post-register-allocation scheduling phase,
+   we assign unused registers to zero.  Ideally, we want to do this at
+   the end of the pre-register-allocation scheduling phase.  This
+   allows the scheduler to schedule without any artificial output
+   dependences, and prevents the register allocator from allocating
+   unused registers.  However, we need to sanity check the operand
+   constraints, which is only available after register allocation, so
+   we currently run this pass after register allocation, at the
+   beginning of the last scheduling pass.
+
+   It is not always legal to assign unused registers to zero.  We do
+   not do this for the following instructions:
+   - calls.
+   - inline asms.
+   - loads from memory, because loads into zero turn into prefetches.
+   - instructions that cannot be bundled, in particular those that
+     take multiple cycles may have hidden uses that we don't know
+     about, i.e. the stack protect patterns.
+
+   We also check validate that the operand constraints are satisfied,
+   to catch illegal replacement of same-res instructions, for
+   example.  */
+static void
+tilegx_assign_unused_regs (rtx insn)
+{
+  rtx link;
+  rtx next_link;
+  rtx new_reg = NULL;
+  enum attr_type type;
+
+  /* Skip instructions that we don't recognize.  */
+  if (recog_memoized (insn) < 0)
+    return;
+
+  /* Skip instructions that cannot be bundled.  In particular those
+     that take multiple cycles may have hidden uses that we don't know
+     about, i.e. the stack protect patterns.  */
+  type = get_attr_type (insn);
+  if (type == TYPE_CANNOT_BUNDLE
+      || type == TYPE_CANNOT_BUNDLE_3CYCLE
+      || type == TYPE_CANNOT_BUNDLE_4CYCLE)
+    return;
+
+  for (link = REG_NOTES (insn); link; link = next_link)
+    {
+      const_rtx datum;
+
+      next_link = XEXP (link, 1);
+      datum = XEXP (link, 0);
+
+      if (REG_NOTE_KIND (link) == REG_UNUSED
+	  && REG_P (datum)
+	  && GET_MODE_SIZE (GET_MODE (datum)) <= UNITS_PER_WORD
+	  && REGNO (datum) != 63)
+	{
+	  rtx set = set_of (datum, insn);
+	  RTX_CODE set_code;
+
+	  if (!set || GET_CODE (set) != SET)
+	    continue;
+
+	  set_code = GET_CODE (SET_SRC (set));
+
+	  if (SET_DEST (set) == datum
+	      && set_code != CALL
+	      && set_code != ASM_OPERANDS
+	      && set_code != MEM
+	      && !((set_code == SIGN_EXTEND || set_code == ZERO_EXTEND)
+		   && GET_CODE (XEXP (SET_SRC (set), 0)) == MEM))
+	    {
+	      rtx old_reg = SET_DEST (set);
+	      new_reg = gen_rtx_REG (GET_MODE (SET_DEST (set)), 63);
+
+	      SET_DEST (set) = new_reg;
+
+	      /* Check if the new instruction is valid, and restore
+		 old register if not.  */
+	      extract_insn (insn);
+	      if (!constrain_operands_cached (1))
+		{
+		  SET_DEST (set) = old_reg;
+		  new_reg = NULL;
+		}
+	      else
+		remove_note (insn, link);
+	    }
+	} 
+    }
+
+  if (new_reg)
+    {
+      add_reg_note (insn, REG_UNUSED, new_reg);
+      df_insn_rescan (insn);
+    }
+}
+
+
+/* Implement TARGET_SCHED_INIT_GLOBAL.  */
+static void
+tilegx_sched_init_global (FILE *dump ATTRIBUTE_UNUSED,
+			  int sched_verbose ATTRIBUTE_UNUSED,
+			  int max_ready ATTRIBUTE_UNUSED)
+{
+  basic_block bb;
+
+  /* Set up df to support tilegx_assign_unused_regs.  */
+  df_set_flags (DF_DEFER_INSN_RESCAN);
+
+  FOR_EACH_BB (bb)
+    {
+      rtx insn, next;
+
+      FOR_BB_INSNS_SAFE (bb, insn, next)
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  /* We need to delete any loop pragmas before we schedule, because
+	     any bundle markers on them will be lost.  */ 
+	  if (recog_memoized (insn) == CODE_FOR_tile_pragma_unroll ||
+	      recog_memoized (insn) == CODE_FOR_tile_pragma_must_iterate)
+	    {
+	      delete_insn (insn);
+	    }
+	  else
+	    {
+	      /* Modify the instructions that touch the network so they can be
+		 bundled.  */
+	      replace_network_unspec (PATTERN (insn), NULL, UNSPEC_VOLATILE,
+				      UNSPEC, DEBUG_INSN_P (insn));
+
+	      if (reload_completed)
+		tilegx_assign_unused_regs (insn);
+	    }
+	}
+    }
+
+  /* Process the deferred rescans from tilegx_assign_unused_regs.  */
+  df_process_deferred_rescans ();
+}
+
+
+/* Returns true of insn has jump prediction state that may be lost if
+   it is stalled.  */
+static bool has_jump_prediction_state (rtx insn)
+{
+  switch (get_attr_type (insn))
+    {
+    case TYPE_X1_JUMP:
+      return tilegx_hazard_opt;
+    case TYPE_X1_CALL:
+    case TYPE_Y1_RETURN:
+      return tilegx_hazard_opt >= 2;
+    case TYPE_X1_BRANCH:
+      /* Note that insn addresses have not been computed yet, so we
+	 cannot tell if the branch distance will fit, so this only
+	 handles the common case.  */
+      return tilegx_hazard_opt && cbranch_predicted_p (insn);
+    default:
+      return false;
+    }
+}
+
+
+/* Skip over irrelevant NOTEs and such and look for the next insn we
+   would consider bundling, going backwards  */
+static rtx
+prev_insn_to_bundle (rtx r, rtx end)
+{
+  for (; r != end; r = PREV_INSN (r))
+    {
+      if (NONDEBUG_INSN_P (r)
+	  && GET_CODE (PATTERN (r)) != USE
+	  && GET_CODE (PATTERN (r)) != CLOBBER)
+	return r;
+    }
+
+  return NULL_RTX;
+}
+
+
+/* Implement TARGET_SCHED_FINISH_GLOBAL.  */
+static void
+tilegx_sched_finish_global (FILE *dump ATTRIBUTE_UNUSED,
+			    int sched_verbose ATTRIBUTE_UNUSED)
+{
+  basic_block bb;
+  FOR_EACH_BB (bb)
+    {
+      rtx insn;
+
+      FOR_BB_INSNS (bb, insn)
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  /* Change accesses to the network back to the form before
+	     scheduling.  */
+	  replace_network_unspec (PATTERN (insn), NULL, UNSPEC,
+				  UNSPEC_VOLATILE, DEBUG_INSN_P (insn));
+	}
+    }
+
+  /* If there is a pipeline bubble before a branch or jump, the
+     pipeline will stall.  The target is not saved and instead the
+     pipe needs to restart and incur a 2-cycle "branch mispredication"
+     penalty.  Here we try to eliminate the bubble by inserting a
+     nop.
+
+     The bubble can easily be identified in the schedule as an idle
+     slot.  To minimize code bloat, we only insert a nop for the case
+     when there is only one bubble.  Since we only have 1 and 2-cycle
+     operations, the only time we'd have more bubbles is for a cache
+     miss anyways.  */
+  if (!reload_completed || tilegx_hazard_opt == 0)
+    return;
+
+  FOR_EACH_BB (bb)
+  {
+    rtx last, insn;
+    int last_cycle, cycle;
+    rtx end = PREV_INSN (BB_HEAD (bb));
+
+    last = prev_insn_to_bundle (BB_END (bb), end);
+
+    if (last == NULL || !has_jump_prediction_state (last))
+      continue;
+
+    last_cycle = HID (last)->tick;
+
+    for (insn = prev_insn_to_bundle (PREV_INSN (last), end); insn;
+	 insn = prev_insn_to_bundle (PREV_INSN (insn), end))
+      {
+	cycle = HID (insn)->tick;
+	if (cycle < last_cycle)
+	  {
+	    if (cycle == last_cycle - 2)
+	      {
+		rtx new_insns;
+
+		/* Add a nop.  */
+		start_sequence ();
+		emit_insn (gen_nop ());
+		new_insns = get_insns ();
+
+		/* Put the nop in its own bundle.  */
+		PUT_MODE (new_insns, TImode);
+		end_sequence ();
+
+		/* Insert the nop after the current insn.  */
+		emit_insn_after (new_insns, insn);
+	      }
+	    break;
+	  }
+      }
+  }
+}
+
+
+
+/* Loop pragmas support.  */
+
+
+/* Keep track of whether a function has emitted a header for pragma
+   warnings.  */
+static bool emitted_pragma_warning_header;
+
+
+static void
+emit_pragma_warning_header (const char *file)
+{
+  if (!emitted_pragma_warning_header)
+    {
+      fprintf (stderr, "%s: In function '%s':\n", file,
+	       current_function_name());
+
+      emitted_pragma_warning_header = true;
+    }
+}
+
+
+/* Emit warning for loop pragmas that do not have corresponding loops.  */
+static void
+warn_unmatched_loop_pragma (rtx insn, VEC(int,heap) *warned_locations)
+{
+  size_t i;
+  int loc;
+  const char *file;
+  int line;
+
+  if (!TARGET_WARN_UNMATCHED_LOOP_PRAGMAS)
+    return;
+
+  loc = INSN_LOCATOR (insn);
+
+  file = locator_file (loc);
+  line = locator_line (loc);
+
+  /* Check to see if we've warned about this pragma already.  This is N^2, but
+     we don't expect many pragmas.  */
+  for (i = 0; i < VEC_length (int, warned_locations); i++)
+    {
+      int warned_loc = VEC_index (int, warned_locations, i);
+      if (strcmp (file, locator_file (warned_loc)) == 0 &&
+	  line == locator_line (warned_loc))
+	return;
+    }
+
+  emit_pragma_warning_header (file);
+
+  fprintf (stderr, "%s:%d: warning: loop pragma without matching loop\n",
+	   file, line);
+
+  VEC_quick_push (int, warned_locations, loc);
+}
+
+
+/* Requires that unroll_pragma is an unroll pragma; returns the unroll
+   factor. */
+static unsigned
+get_unroll_factor (rtx unroll_pragma)
+{
+  rtx pattern;
+  rtx constant;
+
+  pattern = PATTERN (unroll_pragma);
+  constant = XVECEXP (pattern, 0, 0);
+  return (unsigned)XINT (constant, 0);
+}
+
+
+/* For each inner loop, pick an instruction in it and insert it into the INSNS.
+   Returns the vector of instructions.  */
+static VEC(rtx,gc) *
+get_inner_loop_insns (VEC(rtx,gc) *insns)
+{
+  struct loop *loop;
+  loop_iterator li;
+  FOR_EACH_LOOP (li, loop, LI_ONLY_INNERMOST)
+    {
+      basic_block header = loop->header;
+      bool found = false;
+      rtx insn;
+
+      FOR_BB_INSNS (header, insn)
+      {
+        if (NONDEBUG_INSN_P (insn))
+        {
+          found = true;
+          break;
+        }
+      }
+
+      /* If header has no instruction, ignore loop for now.  FIXME: should look
+	 in other blocks in loop.  */
+      if (found)
+	VEC_safe_push (rtx, gc, insns, insn);
+    }
+
+  return insns;
+}
+
+
+/* Find all the unroll pragmas in the function and insert them into the INSNS.
+   Returns the vector of pragmas.  */
+static VEC(rtx,gc) *
+get_loop_pragmas (VEC(rtx,gc) *insns, enum insn_code code)
+{
+  basic_block bb;
+
+  FOR_EACH_BB (bb)
+    {
+      rtx insn;
+
+      FOR_BB_INSNS (bb, insn)
+	{
+	  if (NONDEBUG_INSN_P (insn) && recog_memoized (insn) == (int)code)
+	    VEC_safe_push (rtx, gc, insns, insn);
+	}
+    }
+
+  return insns;
+}
+
+
+/* Sort function that orders higher line numbers first. */
+static int
+insn_location_compare (const void *b, const void *a)
+{
+  const rtx insn_a = *((const rtx *)a);
+  const rtx insn_b = *((const rtx *)b);
+
+  int loc_a = INSN_LOCATOR (insn_a);
+  int loc_b = INSN_LOCATOR (insn_b);
+
+  const char *file_a = locator_file (loc_a);
+  const char *file_b = locator_file (loc_b);
+
+  int line_a = insn_line (insn_a);
+  int line_b = insn_line (insn_b);
+
+  int file_compare;
+
+  int loop_depth_a;
+  int loop_depth_b;
+
+  if (loc_a == 0)
+    if (loc_b == 0)
+      return 0;
+    else
+      return -1;
+  else if (loc_b == 0)
+    return 1;
+
+  file_compare = strcmp (file_a, file_b);
+
+  if (file_compare != 0)
+    return file_compare;
+
+  if (line_a < line_b)
+    return -1;
+  else if (line_a > line_b)
+    return 1;
+
+  loop_depth_a = BLOCK_FOR_INSN (insn_a)->loop_depth;
+  loop_depth_b = BLOCK_FOR_INSN (insn_b)->loop_depth;
+
+  if (loop_depth_a < loop_depth_b)
+    return -1;
+  else if (loop_depth_a > loop_depth_b)
+    return 1;
+
+  return 0;
+}
+
+
+static void
+update_desc_for_unroll_pragma (struct niter_desc *desc, rtx pragma)
+{
+  unsigned unroll_factor = get_unroll_factor (pragma);
+
+  /* If unroll factor is 0, it really means "don't unroll" which is
+     the same as setting unroll factor to 1.  */
+  if (unroll_factor == 0)
+    unroll_factor = 1;
+
+  desc->pragma_unroll_factor = unroll_factor;
+}
+
+
+static void
+update_desc_for_must_iterate_pragma (struct niter_desc *desc, rtx pragma)
+{
+  rtx pattern = PATTERN (pragma);
+  unsigned HOST_WIDE_INT pragma_niter_min =
+    XINT (XVECEXP (pattern, 0, 0), 0);
+  unsigned HOST_WIDE_INT pragma_niter_max =
+    XINT (XVECEXP (pattern, 0, 1), 0);
+  unsigned HOST_WIDE_INT pragma_niter_multiple =
+    XINT (XVECEXP (pattern, 0, 2), 0);
+
+  desc->has_must_iterate_pragma = true;
+  desc->pragma_niter_min = pragma_niter_min;
+  desc->pragma_niter_max = pragma_niter_max;
+  desc->pragma_niter_multiple = pragma_niter_multiple;
+
+  /* FIXME: don't really understand desc->noloop_assumptions and how to
+     initialize it.  */
+
+  if (pragma_niter_max != (unsigned HOST_WIDE_INT)-1)
+    {
+      desc->niter_max = pragma_niter_max - 1;
+      desc->infinite = NULL_RTX;
+    }
+
+  if (pragma_niter_min == pragma_niter_max)
+    {
+      if (desc->const_iter && (desc->niter != pragma_niter_min - 1))
+	{
+	  const char *file = insn_file (pragma);
+	  int line = insn_line (pragma);
+	  emit_pragma_warning_header (file);
+
+	  fprintf (stderr,
+		   "%s:%d: warning: must_iterate iteration count (%lld) "
+		   "is inconsistent with actual iteration count (%lld).\n",
+		   file, line, pragma_niter_min, desc->niter + 1);
+	}
+
+      desc->pragma_niter_multiple = pragma_niter_min;
+
+      /* We can set the constant iteration info based on pragmas, but don't
+	 bother since I don't see any tangible benefit at the moment.  */
+    }
+}
+
+
+static void
+match_pragmas_with_loops (VEC(rtx,gc) *loop_insns, VEC(rtx,gc) *pragmas,
+			  void (*update_desc) (struct niter_desc *, rtx))
+{
+  VEC(int,heap) *warned_locations;
+  size_t li;
+  size_t ui;
+
+  warned_locations = VEC_alloc (int, heap, VEC_length (rtx, pragmas));
+
+  qsort (VEC_address(rtx, loop_insns), VEC_length(rtx, loop_insns),
+	 sizeof (rtx), insn_location_compare);
+
+  qsort (VEC_address(rtx, pragmas), VEC_length(rtx, pragmas),
+	 sizeof (rtx), insn_location_compare);
+
+  li = 0;
+  ui = 0;
+
+  while (ui < VEC_length (rtx, pragmas))
+    {
+      rtx pragma = VEC_index (rtx, pragmas, ui++);
+      size_t start_li = li;
+
+      /* Find the nearest loop_insn following the pragma.  */
+      rtx nearest_loop_insn = NULL;
+      for (; li < VEC_length (rtx, loop_insns); li++)
+	{
+	  rtx loop_insn = VEC_index (rtx, loop_insns, li);
+
+	  int cmp = insn_location_compare (&pragma, &loop_insn);
+
+	  /* pragma precedes loop_insn ==> possible match.  */
+	  if (cmp == 1)
+	    nearest_loop_insn = loop_insn;
+	  else
+	    break;
+	}
+
+      if (nearest_loop_insn != NULL)
+	{
+	  const char *file_loop = insn_file (nearest_loop_insn);
+	  const char *file_pragma = insn_file (pragma);
+
+	  if (dump_file)
+	    {
+	      fprintf (dump_file,
+		       ";; Matching loop pragma %s:%d with loop %s:%d\n",
+		       file_pragma, insn_line (pragma),
+		       file_loop, insn_line (nearest_loop_insn));
+	    }
+
+	  /* Sanity checks  */
+
+	  /* The pragma should be in the same file, and at a lower loop
+	     depth.  */
+	  if (strcmp (file_loop, file_pragma) != 0 ||
+	      (BLOCK_FOR_INSN (nearest_loop_insn)->loop_depth <=
+	       BLOCK_FOR_INSN (pragma)->loop_depth))
+	    {
+	      warn_unmatched_loop_pragma (pragma, warned_locations);
+	      li = start_li;
+	    }
+	  else
+	    {
+	      struct loop *loop =
+		BLOCK_FOR_INSN (nearest_loop_insn)->loop_father;
+	      struct niter_desc *desc = get_simple_loop_desc (loop);
+
+	      update_desc (desc, pragma);
+
+	      /* Handle cases where we have multiple copies of the pragma/loop
+		 due to cloning or inlining.  These pragmas/loops will have the
+		 same line numbers, and we need to rewind li to so that we're
+		 matching one such loop at a time.  */
+	      for (; li - 1 > start_li; li--)
+		{
+		  const rtx loop_insn1 = VEC_index (rtx, loop_insns, li - 2);
+		  const rtx loop_insn2 = VEC_index (rtx, loop_insns, li - 1);
+		  int cmp = insn_location_compare (&loop_insn1, &loop_insn2);
+		  if (cmp != 0)
+		    break;
+		}
+	    }
+	}
+      else
+	warn_unmatched_loop_pragma (pragma, warned_locations);
+    }
+
+  VEC_free (int, heap, warned_locations);
+}
+
+
+static void
+delete_insns (VEC(rtx,gc) *insns)
+{
+  size_t i;
+  for (i = 0; i < VEC_length (rtx, insns); i++)
+    delete_insn (VEC_index (rtx, insns, i));
+}
+
+
+static void
+parse_loop_pragmas (void)
+{
+  VEC(rtx,gc) *unroll_pragmas;
+  VEC(rtx,gc) *must_iterate_pragmas;
+  VEC(rtx,gc) *loop_insns;
+
+  emitted_pragma_warning_header = false;
+
+  unroll_pragmas = VEC_alloc (rtx, gc, number_of_loops ());
+  unroll_pragmas =
+    get_loop_pragmas (unroll_pragmas, CODE_FOR_tile_pragma_unroll);
+
+  must_iterate_pragmas = VEC_alloc (rtx, gc, number_of_loops ());
+  must_iterate_pragmas =
+    get_loop_pragmas (must_iterate_pragmas, CODE_FOR_tile_pragma_must_iterate);
+
+  if (VEC_length (rtx, unroll_pragmas) == 0 &&
+      VEC_length (rtx, must_iterate_pragmas) == 0)
+    return;
+
+  loop_insns = VEC_alloc (rtx, gc, number_of_loops ());
+  loop_insns = get_inner_loop_insns (loop_insns);
+
+  if (VEC_length (rtx, unroll_pragmas))
+    {
+      match_pragmas_with_loops (loop_insns, unroll_pragmas,
+				update_desc_for_unroll_pragma);
+
+      delete_insns (unroll_pragmas);
+    }
+
+  if (VEC_length (rtx, must_iterate_pragmas))
+    {
+      match_pragmas_with_loops (loop_insns, must_iterate_pragmas,
+				update_desc_for_must_iterate_pragma);
+
+      delete_insns (must_iterate_pragmas);
+    }
+}
+
+
+static void tilegx_pre_unrolling_and_peeling_hook (void)
+{
+  parse_loop_pragmas ();
+}
+
+
+
+/* Parsing of post-incrementing load/store intrinsics.  */
+
+
+typedef struct asm_descriptor
+{
+  const char *string;
+  const insn_gen_fn fn;
+  const insn_gen_fn fn_32bit;
+  const enum machine_mode mode;
+} asm_descriptor;
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns whether
+   their template strings match STR.  */
+static bool
+match_asm_string (rtx pattern1, rtx pattern2, const char *str)
+{
+  return
+    strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern1)), str) == 0 &&
+    strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern2)), str) == 0;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns an
+   asm_dsecriptor in DESC with a matching template string, or NULL if no match
+   is found.  */
+static const asm_descriptor *
+match_asm_descriptor (rtx pattern1, rtx pattern2, const asm_descriptor *desc)
+{
+  int i;
+
+  for (i = 0; desc[i].string != NULL; i++)
+    {
+      if (match_asm_string (pattern1, pattern2, desc[i].string))
+	return &desc[i];
+    }
+
+  return NULL;
+}
+
+
+/* PATTERN is a SET statement of ASM_OPERANDS.  Returns whether the PATTERN
+   satisfies the following:
+
+   dest idx is DEST_IDX;
+   dest constraint is DEST_CONSTRAINT;
+   dest mode is DEST_MODE;
+   has NUM_SRCS number of source operands;
+   its source operands satisfy CONSTRANTS and MODES.  */
+static bool
+asm_sanity_check (rtx pattern, int dest_idx,
+		  const char *dest_constraint,
+		  const enum machine_mode dest_mode,
+		  int num_srcs, const char *src_constraints[],
+		  const enum machine_mode src_modes[])
+{
+  int i;
+
+  if (strcmp (ASM_OPERANDS_OUTPUT_CONSTRAINT (SET_SRC (pattern)),
+	      dest_constraint) != 0)
+    return false;
+
+  if (GET_MODE (SET_SRC (pattern)) != dest_mode)
+    return false;
+
+  if (ASM_OPERANDS_OUTPUT_IDX (SET_SRC (pattern)) != dest_idx)
+    return false;
+
+  if (ASM_OPERANDS_INPUT_LENGTH (SET_SRC (pattern)) != num_srcs)
+    return false;
+
+  for (i = 0; i < num_srcs; i ++)
+    {
+      rtx constraint_exp =
+	ASM_OPERANDS_INPUT_CONSTRAINT_EXP (SET_SRC (pattern), i);
+
+      if (GET_CODE (constraint_exp) != ASM_INPUT)
+	return false;
+
+      if (GET_MODE (constraint_exp) != src_modes[i])
+	return false;
+
+      if (strcmp (ASM_OPERANDS_INPUT_CONSTRAINT (SET_SRC (pattern), i),
+		  src_constraints[i]) != 0)
+	return false;
+    }
+
+  return true;
+}
+
+
+/* PATTERN is a SET statement of ASM_OPERANDS.  Returns a prefetch-add
+   asm_descriptor that matches the pattern.  */
+static const asm_descriptor *
+match_prefetchadd (rtx pattern)
+{
+#define ARGS " %0, %1"
+#define ASM_DESC_ENTRY(op) \
+    { #op ARGS, (insn_gen_fn) gen_insn_ ## op, \
+                (insn_gen_fn) gen_insn_ ## op ## _32bit, VOIDmode }
+  static const asm_descriptor descriptor[] = {
+    ASM_DESC_ENTRY(prefetch_add_l1),
+    ASM_DESC_ENTRY(prefetch_add_l1_fault),
+    ASM_DESC_ENTRY(prefetch_add_l2),
+    ASM_DESC_ENTRY(prefetch_add_l2_fault),
+    ASM_DESC_ENTRY(prefetch_add_l3),
+    ASM_DESC_ENTRY(prefetch_add_l3_fault),
+    ASM_DESC_ENTRY(prefetchnt_add_l1),
+    ASM_DESC_ENTRY(prefetchnt_add_l1_fault),
+    ASM_DESC_ENTRY(prefetchnt_add_l2),
+    ASM_DESC_ENTRY(prefetchnt_add_l2_fault),
+    ASM_DESC_ENTRY(prefetchnt_add_l3),
+    ASM_DESC_ENTRY(prefetchnt_add_l3_fault),
+    { NULL, NULL, NULL, VOIDmode },
+  };
+#undef ARGS
+#undef ASM_DESC_ENTRY
+  int i;
+
+  for (i = 0; descriptor[i].string != NULL; i++)
+    {
+      if (strcmp (ASM_OPERANDS_TEMPLATE (SET_SRC (pattern)),
+		  descriptor[i].string) == 0)
+	return &descriptor[i];
+    }
+
+  return NULL;
+}
+
+
+/* Check whether the prefetch add patterns conform to what we expect.  */
+static bool
+sanity_check_prefetchadd_operands (rtx pattern)
+{
+  static const char *src_constraints[] = { "i", "0" };
+  enum machine_mode src_modes[] = { SImode, Pmode };
+
+  return asm_sanity_check (pattern, 0, "=r", Pmode, 2, src_constraints,
+			   src_modes);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("prefetch_l1_add %0, %2, %3") ("=r") 0
+               [ SRC0 SRC1 ]
+               [ (asm_input:SI ("i") 0)
+                 (asm_input:DI ("0") 0) ]))
+
+  FN is the cprresponding prefetch-add generating function.  Create
+  and return the corresponding prefetch-add rtl.
+*/
+static rtx
+gen_prefetchadd (rtx pattern, insn_gen_fn fn)
+{
+  rtx dest = SET_DEST (pattern);
+  rtx src0 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 0);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 1);
+  rtx res = fn (dest, src0, src1);
+
+  /* return the pattern, not the insn containing it.  */
+  if (INSN_P (res))
+    return PATTERN (res);
+  else
+    return res;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns a
+   store-add asm_descriptor that matches that of the two patterns, or NULL if
+   no match is found.  */
+static const asm_descriptor *
+match_storeadd (rtx pattern1, rtx pattern2)
+{
+#define ARGS " %0, %2, %3"
+#define ASM_DESC_ENTRY(op, mode) \
+    { #op ARGS, (insn_gen_fn) gen_insn_ ## op, \
+                (insn_gen_fn) gen_insn_ ## op ## _32bit, mode }
+  static const asm_descriptor descriptor[] = {
+    ASM_DESC_ENTRY(st1_add, QImode),
+    ASM_DESC_ENTRY(st2_add, HImode),
+    ASM_DESC_ENTRY(st4_add, SImode),
+    ASM_DESC_ENTRY(st_add, DImode),
+    ASM_DESC_ENTRY(stnt1_add, QImode),
+    ASM_DESC_ENTRY(stnt2_add, HImode),
+    ASM_DESC_ENTRY(stnt4_add, SImode),
+    ASM_DESC_ENTRY(stnt_add, DImode),
+    { NULL, NULL, NULL, VOIDmode },
+  };
+#undef ARGS
+#undef ASM_DESCRIPTOR
+
+  return match_asm_descriptor (pattern1, pattern2, descriptor);
+}
+
+
+/* Check whether the store add patterns conform to what we expect.  */
+static bool
+sanity_check_storeadd_operands (rtx pattern1, rtx pattern2,
+				enum machine_mode mem_mode)
+{
+  static const char *src_constraints[] = { "r", "i", "0" };
+  enum machine_mode src_modes[] = { word_mode, SImode, Pmode };
+
+  return
+    asm_sanity_check (pattern1, 0, "=r", Pmode,
+		      3, src_constraints, src_modes) &&
+    asm_sanity_check (pattern2, 1, "=m", mem_mode,
+		      3, src_constraints, src_modes);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("st_add %0, %2, %3") ("=r") 0
+               [ SRC0 SRC1 SRC2 ]
+               [ (asm_input:MODE ("r") 0)
+                 (asm_input:SI ("i") 0)
+                 (asm_input:DI ("0") 0) ]))
+
+  FN is the cprresponding store-add generating function.  Create and return the
+  corresponding store-add rtl.
+*/
+static rtx
+gen_storeadd (rtx pattern, insn_gen_fn fn,
+	      enum machine_mode mode ATTRIBUTE_UNUSED)
+{
+  rtx dest = SET_DEST (pattern);
+  rtx src0 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 0);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 1);
+  rtx src2 = ASM_OPERANDS_INPUT (SET_SRC (pattern), 2);
+  rtx res = fn (dest, src0, src1, src2);
+
+  /* return the pattern, not the insn containing it.  */
+  if (INSN_P (res))
+    return PATTERN (res);
+  else
+    return res;
+}
+
+
+/* PATTERN1, and PATTERN2 are SET statements of ASM_OPERANDS.  Returns a
+   load-add whose template string matches that of the two patterns, or NULL if
+   no match is found.  */
+static const asm_descriptor *
+match_loadadd (rtx pattern1, rtx pattern2)
+{
+#define ARGS " %0, %1, %3"
+#define ASM_DESC_ENTRY(op, mode) \
+    { #op ARGS, (insn_gen_fn) gen_insn_ ## op, \
+                (insn_gen_fn) gen_insn_ ## op ## _32bit, mode }
+  static const asm_descriptor descriptor[] = {
+    ASM_DESC_ENTRY(ld1s_add, QImode),
+    ASM_DESC_ENTRY(ld1u_add, QImode),
+    ASM_DESC_ENTRY(ld2s_add, HImode),
+    ASM_DESC_ENTRY(ld2u_add, HImode),
+    ASM_DESC_ENTRY(ld4s_add, SImode),
+    ASM_DESC_ENTRY(ld4u_add, SImode),
+    ASM_DESC_ENTRY(ld_add, DImode),
+    ASM_DESC_ENTRY(ld16_add, TImode),
+    ASM_DESC_ENTRY(ldnt1s_add, QImode),
+    ASM_DESC_ENTRY(ldnt1u_add, QImode),
+    ASM_DESC_ENTRY(ldnt2s_add, HImode),
+    ASM_DESC_ENTRY(ldnt2u_add, HImode),
+    ASM_DESC_ENTRY(ldnt4s_add, SImode),
+    ASM_DESC_ENTRY(ldnt4u_add, SImode),
+    ASM_DESC_ENTRY(ldnt_add, DImode),
+    ASM_DESC_ENTRY(ldnt16_add, TImode),
+    ASM_DESC_ENTRY(ldna_add, DImode),
+    ASM_DESC_ENTRY(ldna16_add, TImode),
+
+    ASM_DESC_ENTRY(ld1s_add_L2, QImode),
+    ASM_DESC_ENTRY(ld1u_add_L2, QImode),
+    ASM_DESC_ENTRY(ld2s_add_L2, HImode),
+    ASM_DESC_ENTRY(ld2u_add_L2, HImode),
+    ASM_DESC_ENTRY(ld4s_add_L2, SImode),
+    ASM_DESC_ENTRY(ld4u_add_L2, SImode),
+    ASM_DESC_ENTRY(ld_add_L2, DImode),
+    ASM_DESC_ENTRY(ld16_add_L2, TImode),
+    ASM_DESC_ENTRY(ldnt1s_add_L2, QImode),
+    ASM_DESC_ENTRY(ldnt1u_add_L2, QImode),
+    ASM_DESC_ENTRY(ldnt2s_add_L2, HImode),
+    ASM_DESC_ENTRY(ldnt2u_add_L2, HImode),
+    ASM_DESC_ENTRY(ldnt4s_add_L2, SImode),
+    ASM_DESC_ENTRY(ldnt4u_add_L2, SImode),
+    ASM_DESC_ENTRY(ldnt_add_L2, DImode),
+    ASM_DESC_ENTRY(ldnt16_add_L2, TImode),
+    ASM_DESC_ENTRY(ldna_add_L2, DImode),
+    ASM_DESC_ENTRY(ldna16_add_L2, TImode),
+
+    ASM_DESC_ENTRY(ld1s_add_miss, QImode),
+    ASM_DESC_ENTRY(ld1u_add_miss, QImode),
+    ASM_DESC_ENTRY(ld2s_add_miss, HImode),
+    ASM_DESC_ENTRY(ld2u_add_miss, HImode),
+    ASM_DESC_ENTRY(ld4s_add_miss, SImode),
+    ASM_DESC_ENTRY(ld4u_add_miss, SImode),
+    ASM_DESC_ENTRY(ld_add_miss, DImode),
+    ASM_DESC_ENTRY(ld16_add_miss, TImode),
+    ASM_DESC_ENTRY(ldnt1s_add_miss, QImode),
+    ASM_DESC_ENTRY(ldnt1u_add_miss, QImode),
+    ASM_DESC_ENTRY(ldnt2s_add_miss, HImode),
+    ASM_DESC_ENTRY(ldnt2u_add_miss, HImode),
+    ASM_DESC_ENTRY(ldnt4s_add_miss, SImode),
+    ASM_DESC_ENTRY(ldnt4u_add_miss, SImode),
+    ASM_DESC_ENTRY(ldnt_add_miss, DImode),
+    ASM_DESC_ENTRY(ldnt16_add_miss, TImode),
+    ASM_DESC_ENTRY(ldna_add_miss, DImode),
+    ASM_DESC_ENTRY(ldna16_add_miss, TImode),
+
+    { NULL, NULL, NULL, VOIDmode },
+  };
+#undef ARGS
+#undef ASM_DESC_ENTRY
+
+  return match_asm_descriptor (pattern1, pattern2, descriptor);
+}
+
+
+/* PATTERN is of the form:
+
+   (set DEST (asm_operands:SI ("ld_add %0, %1, %3") ("=r") 0
+               [ SRC0 SRC1 SRC2 ]
+               [ (asm_input:MODE ("m") 0)
+                 (asm_input:SI ("i") 0)
+                 (asm_input:DI ("1") 0) ]))
+
+  FN is the cprresponding store-add generating function.  Create and return the
+  corresponding load-add rtl.
+*/
+static rtx
+gen_loadadd (rtx pattern1, rtx pattern2, insn_gen_fn fn,
+	     enum machine_mode mode ATTRIBUTE_UNUSED)
+{
+  rtx dest0 = SET_DEST (pattern1);
+  rtx dest1 = SET_DEST (pattern2);
+  rtx src1 = ASM_OPERANDS_INPUT (SET_SRC (pattern1), 1);
+  rtx src2 = ASM_OPERANDS_INPUT (SET_SRC (pattern1), 2);
+
+  return fn (dest0, dest1, src1, src2);
+}
+
+
+/* Check whether the store add patterns conform to what we expect.  */
+static bool
+sanity_check_loadadd_operands (rtx pattern1, rtx pattern2,
+			       enum machine_mode mem_mode)
+{
+  static const char *src_constraints[] = { "m", "i", "1" };
+  enum machine_mode src_modes[] = { mem_mode, SImode, Pmode };
+  enum machine_mode dest_mode;
+
+  dest_mode = (mem_mode == TImode) ? TImode : DImode;
+
+  return
+    asm_sanity_check (pattern1, 0, "=r", dest_mode,
+		      3, src_constraints, src_modes) &&
+    asm_sanity_check (pattern2, 1, "=r", Pmode,
+		      3, src_constraints, src_modes);
+}
+
+
+/* Do post processing after rtl expansion.  */
+static void
+tilegx_post_expand_to_rtl_hook (void)
+{
+  rtx insn, last;
+  basic_block bb;
+
+  if (!TARGET_EXPAND_ASM)
+    return;
+
+  /* Look for specific inline assembly patterns and replace them with rtl that
+     the compiler can understand, optimize, schedule, and bundle.  We use this
+     to implement post-inc load/store intrinsics.  */
+  FOR_EACH_BB (bb)
+    {
+      for (insn = BB_HEAD (bb), last = NEXT_INSN (BB_END (bb));
+	   insn != last;
+	   insn = NEXT_INSN (insn))
+	{
+	  rtx pattern;
+	  rtx pattern1;
+	  rtx pattern2;
+	  const asm_descriptor* desc;
+
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  pattern = PATTERN (insn);
+
+	  /* post-inc prefetches.  */
+	  if (GET_CODE (pattern) == SET
+	      && GET_CODE (SET_SRC (pattern)) == ASM_OPERANDS)
+	    {
+	      if ((desc = match_prefetchadd (pattern)))
+		{
+		  if (sanity_check_prefetchadd_operands (pattern))
+		    {
+		      insn_gen_fn fn = ((TARGET_32BIT)
+					? desc->fn_32bit : desc->fn);
+		      PATTERN (insn) =
+			gen_prefetchadd (pattern, fn);
+		    }
+		  else
+		    {
+		      location_t loc =
+			ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern));
+		      warning_at (loc, 0,
+				  "Unrecognized prefetch-add asm pattern");
+		    }
+		}
+	      continue;
+	    }
+
+	  /* post-inc loads and stores.  */
+	  if (! (GET_CODE (pattern) == PARALLEL
+		 && XVECLEN (pattern, 0) == 2))
+	    continue;
+
+	  pattern1 = XVECEXP (pattern, 0, 0);
+	  pattern2 = XVECEXP (pattern, 0, 1);
+
+	  if (! (GET_CODE (pattern1) == SET
+		 && GET_CODE (pattern2) == SET
+		 && GET_CODE (SET_SRC (pattern1)) == ASM_OPERANDS
+		 && GET_CODE (SET_SRC (pattern2)) == ASM_OPERANDS))
+	    continue;
+
+	  if ((desc = match_storeadd (pattern1, pattern2)))
+	    {
+	      if (sanity_check_storeadd_operands (pattern1, pattern2,
+						  desc->mode))
+		{
+		  insn_gen_fn fn = (TARGET_32BIT) ? desc->fn_32bit : desc->fn;
+		  PATTERN (insn) =
+		    gen_storeadd (pattern1, fn, desc->mode);
+		}
+	      else
+		{
+		  location_t loc =
+		    ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern1));
+		  warning_at (loc, 0, "Unrecognized store-add asm pattern");
+		}
+
+	    }
+	  else if ((desc = match_loadadd (pattern1, pattern2)))
+	    {
+	      if (sanity_check_loadadd_operands (pattern1, pattern2,
+						 desc->mode))
+		{
+		  insn_gen_fn fn = (TARGET_32BIT) ? desc->fn_32bit : desc->fn;
+		  PATTERN (insn) =
+		    gen_loadadd (pattern1, pattern2, fn, desc->mode);
+		}
+	      else
+		{
+		  location_t loc =
+		    ASM_OPERANDS_SOURCE_LOCATION (SET_SRC (pattern1));
+		  warning_at (loc, 0, "Unrecognized load-add asm pattern");
+		}
+	    }
+	}
+    }
+}
+
+
+
+/* Functions to support gathering information on compiler
+   optimizations.  */
+
+
+static FILE *
+tilegx_lock_data_file (const char *fn)
+{
+  struct flock fl;
+  int fd;
+  FILE *file;
+
+  fl.l_type   = F_WRLCK;
+  fl.l_whence = SEEK_SET;
+  fl.l_start  = 0;
+  fl.l_len    = 0;
+  fl.l_pid    = getpid();
+
+  fd = open (fn, O_CREAT|O_WRONLY, 0644);
+  if (fd == -1)
+    abort ();
+
+  if (fcntl (fd, F_SETLKW, &fl) == -1)
+    abort ();
+
+  file = fdopen (fd, "a");
+  if (file == NULL)
+    {
+      fl.l_type   = F_UNLCK;
+      fcntl (fd, F_SETLK, &fl);
+      abort ();
+    }
+
+  return file;
+}
+
+
+static void
+tilegx_unlock_data_file (FILE *file)
+{
+  struct flock fl;
+
+  fl.l_type   = F_UNLCK;
+  fl.l_whence = SEEK_SET;
+  fl.l_start  = 0;
+  fl.l_len    = 0;
+  fl.l_pid    = getpid();
+
+  if (fcntl (fileno (file), F_SETLK, &fl) == -1)
+    abort ();
+
+  fclose (file);
+}
+
+
+
+/* Extension propagation optimization.  */
+
+
+/* Print X to OUTF, and add a newline.  */
+static void
+print_rtx (FILE *outf, const_rtx x)
+{
+  print_inline_rtx (outf, x, 0);
+  fprintf (outf, "\n");
+}
+
+
+/* A classification of various extension types.  */
+enum extend_type
+{
+  no_extend,
+  si_to_udi,
+  di_to_udi,
+  si_to_sdi,
+  di_to_sdi,
+  di_to_si
+};
+
+
+/* Extension information of an instruction.  */
+struct insn_extend_info
+{
+  rtx insn;
+  enum extend_type extend_type;
+  rtx extend_insn;
+  int num_uses;
+  bool is_propagate_candidate;
+};
+
+
+/* Returns the hash value of a pointer to a insn_extend_info.  */
+static hashval_t
+htab_iei_hash (const void *p)
+{
+  const struct insn_extend_info *const iei
+    = (const struct insn_extend_info *) p;
+
+  return (hashval_t)INSN_UID (iei->insn);
+}
+
+
+/* Equality function for insn_extend_info *.  */
+static int
+htab_iei_eq (const void *p1, const void *p2)
+{
+  const struct insn_extend_info *const iei1
+    = (const struct insn_extend_info *) p1;
+  const struct insn_extend_info *const iei2
+    = (const struct insn_extend_info *) p2;
+
+  return INSN_UID (iei1->insn) == INSN_UID (iei2->insn);
+}
+
+
+/* Hash entry delete function for insn_extend_info *.  */
+static void
+htab_iei_del (void *p)
+{
+  struct insn_extend_info *const iei = (struct insn_extend_info *) p;
+  free (iei);
+}
+
+
+/* Create an insn_extend_info for INSN, and add it to the hash
+   table.  */
+static struct insn_extend_info *
+create_insn_extend_info (rtx insn, htab_t insn_extend_infos)
+{
+  struct insn_extend_info *info;
+  struct insn_extend_info **slot;
+
+  info = XCNEW (struct insn_extend_info);
+  
+  info->insn = insn;
+  slot = (struct insn_extend_info **) htab_find_slot (insn_extend_infos, info,
+						      INSERT);
+  *slot = info;
+
+  return info;
+}
+
+
+/* Return the insn_extend_info corresponding to INSN in the hash
+   table.  */
+static struct insn_extend_info *
+get_insn_extend_info (rtx insn, htab_t insn_extend_infos)
+{
+  struct insn_extend_info key;
+  key.insn = insn;
+  return (struct insn_extend_info *)htab_find (insn_extend_infos, &key);
+}
+
+
+/* Get the Nth operand of a set insn.  Requires that INSN is a set
+   instruction.  */
+static rtx
+get_set_src_xexp (rtx insn, int n)
+{
+  rtx pattern = PATTERN (insn);
+  rtx set_src;
+
+  if (GET_CODE (pattern) != SET)
+    return NULL_RTX;
+
+  set_src = SET_SRC (pattern);
+
+  return XEXP (set_src, n);
+}
+
+
+/* Return the extend type of INSN.  */
+static enum extend_type
+classify_extend (rtx insn)
+{
+  int code;
+  rtx src;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_zero_extendsidi2:
+    case CODE_FOR_extendsidi2:
+      src = get_set_src_xexp (insn, 0);
+
+      if (src == NULL_RTX)
+	return no_extend;
+      else if (REG_P (src))
+	return (code == CODE_FOR_zero_extendsidi2) ? si_to_udi : si_to_sdi;
+      else if (GET_CODE (src) == SUBREG
+	       && GET_MODE (SUBREG_REG (src)) == DImode)
+	return (code == CODE_FOR_zero_extendsidi2) ? di_to_udi : di_to_sdi;
+
+      break;
+    case CODE_FOR_truncdisi2:
+      src = get_set_src_xexp (insn, 0);
+
+      if (src == NULL_RTX)
+	return no_extend;
+      else if (REG_P (src))
+	return di_to_si;
+    default:
+      ;
+     }
+
+  return no_extend;
+}
+
+
+/* Initialize extension information for INSN.  We keep track of one
+   extension per INSN.  This is used for two purposes: to find
+   candidates for propagation, and to evalulate the cost of adding and
+   extend to an operation.  Return whether one is found.  */
+static bool
+init_insn_extend_info (rtx insn, htab_t insn_extend_infos)
+{
+  rtx pattern;
+  struct insn_extend_info *info;
+  df_ref def, use;
+  struct df_link *link;
+  rtx extend_insn;
+  enum extend_type extend_type;
+  int num_uses;
+
+  pattern = PATTERN (insn);
+
+  /* Only handle SETs.  */
+  if (GET_CODE (pattern) != SET)
+    return false;
+
+  if (!REG_P (SET_DEST (pattern)))
+    return false;
+
+  def = df_find_def (insn, SET_DEST (pattern));
+
+  /* FIXME: I wouldn't expect DEF to be NULL, but this seems to happen
+     if we're writing to a floating argument register used by call,
+     cos the register inside DEF is of mode DI.  For now we just
+     conservatively give up.  */
+  if (!def)
+    return false;
+
+  link = DF_REF_CHAIN (def);
+
+  num_uses = 0;
+  extend_type = no_extend;
+  for (; link; link = link->next, num_uses++)
+    {
+      rtx use_insn;
+      enum extend_type type;
+
+      if (DF_REF_IS_ARTIFICIAL (link->ref))
+	continue;
+      
+      use_insn = DF_REF_INSN (link->ref);
+      type = classify_extend (use_insn);
+
+      if (type != no_extend
+	  && extend_type == no_extend)
+	{
+	  extend_insn = use_insn;
+	  extend_type = type;
+	}
+    }
+
+  if (extend_type == no_extend)
+    return false;
+
+  /* The extension must only have one parent (i.e. INSN).  */
+  use = df_find_use (extend_insn, SET_DEST (pattern));
+  link = DF_REF_CHAIN (use);
+  if (!(link && !link->next))
+    return false;
+
+  info = create_insn_extend_info (insn, insn_extend_infos);
+  info->extend_insn = extend_insn;
+  info->extend_type = extend_type;
+  info->num_uses = num_uses;
+
+  /* Determine whether this extension is a candidate for
+     propagation.  For an extend to be a valid candidate, we
+     require the following:
+     - it has only one parent (i.e. INSN).
+     - it is in the same basic block as INSN.
+     - it follows INSN in the basic block.
+     - it is not a si_to_sdi (which is a no-op anyways).
+     - it is not a di_to_si (FIXME: temporarily disable until we can
+       resolve phase ordering issue with combine.)  */
+  if (num_uses == 1
+      && BLOCK_NUM (insn) == BLOCK_NUM (extend_insn)
+      && extend_type != si_to_sdi
+      && extend_type != di_to_si)
+    info->is_propagate_candidate = true;
+
+  if (dump_file)
+    fprintf (dump_file,
+	     "Create insn_extend_info %p insn %d extend_insn %d "
+	     "extend_type %d num_uses %d is_candidate %d\n",
+	     (void *)info, INSN_UID (info->insn), INSN_UID (info->extend_insn),
+	     (int)info->extend_type, info->num_uses,
+	     info->is_propagate_candidate);
+
+  return true;
+}
+
+
+/* Check that REF has exactly one link and that the link is not
+   artifical, and return the link's reference.  Return NULL_RTX if the
+   conditions are not met.  */
+static rtx
+get_single_link_insn (df_ref ref)
+{
+  struct df_link *link;
+
+  link = DF_REF_CHAIN (ref);
+
+  if (!(link && !link->next))
+    return NULL_RTX;
+
+  if (DF_REF_IS_ARTIFICIAL (link->ref))
+    return NULL_RTX;
+
+  return DF_REF_INSN (link->ref);
+}
+
+
+/* Check that INSN has a single successor, and if so return it.
+   Return NULL_RTX otherwise.  */
+static rtx
+get_single_succ (rtx insn)
+{
+  df_ref *defs;
+
+  defs = DF_INSN_DEFS (insn);
+  if (!(defs[0] && !defs[1]))
+    return NULL_RTX;
+
+  return get_single_link_insn (defs[0]);
+}
+
+
+/* Returns whether INSN preserves sign extension.  We currently only
+   handle a subset of all such operations: ands, ors, and xors with
+   register operands.  We also currently require register operands,
+   but it should also support constant operands.  */
+static bool
+insn_propagates_extend (rtx insn)
+{
+  int code;
+  rtx src0, src1;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_xorsi3:
+    case CODE_FOR_xordi3:
+    case CODE_FOR_iorsi3:
+    case CODE_FOR_iordi3:
+    case CODE_FOR_andsi3:
+    case CODE_FOR_anddi3:
+      src0 = get_set_src_xexp (insn, 0);
+      src1 = get_set_src_xexp (insn, 1);
+
+      if (!src0 || !src1)
+	return false;
+
+      if (!REG_P (src0) && GET_CODE (src0) != SUBREG)
+	return false;
+
+      if (!REG_P (src1) && GET_CODE (src1) != SUBREG)
+	return false;
+
+      return true;
+      break;
+    default:
+      return false;
+    }
+}
+
+
+/* Returns whether an extension of TYPE1 is compatible with an
+   extension of TYPE0.  */
+static bool extend_type_compatible (enum extend_type type0,
+				    enum extend_type type1)
+{
+  switch (type0)
+    {
+    case si_to_udi:
+    case di_to_udi:
+      return type1 == si_to_udi || type1 == di_to_udi;
+    case si_to_sdi:
+    case di_to_sdi:
+      return type1 == si_to_sdi || type1 == di_to_sdi;
+    case di_to_si:
+      return type1 == di_to_si;
+    default:
+      return false;
+    }
+}
+
+
+/* Returns whether there is a variant of INSN with TYPE extension.
+   Currently we only handle a subset of such patterns.  */
+static bool
+has_extend_pattern (rtx insn, enum extend_type type ATTRIBUTE_UNUSED)
+{
+  int code;
+  rtx pattern;
+  rtx set_src;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_zero_extendsidi2:
+    case CODE_FOR_extendsidi2:
+      return true;
+      break;
+    default:
+      pattern = PATTERN (insn);
+
+      if (GET_CODE (pattern) != SET)
+	return false;
+
+      set_src = SET_SRC (pattern);
+      if (GET_MODE (set_src) == SImode
+	  && GET_CODE (set_src) == MEM)
+	return true;
+
+      return false;
+    }
+
+  gcc_unreachable ();
+}
+
+
+static bool
+can_combine_for_free (rtx insn, enum extend_type type)
+{
+  /* Check that INSN only has a single use, which presumably is the
+     one that requires the extension.  */
+  rtx succ = get_single_succ (insn);
+
+  if (!succ)
+    return false;
+
+  return has_extend_pattern (insn, type);
+}
+
+
+/* Returns the cost of adding the extension of type TYPE to INSN.  The
+   cost is either 0 or 1.  It's 0 if:
+   - the extension is a noop (FIXME: not yet implemented).
+   - the extension already exists.
+   - the extension can be combined with INSN into a single
+     instruction, INSN only has one use.  */
+static int
+extension_cost (rtx insn, enum extend_type type, htab_t insn_extend_info)
+{
+  struct insn_extend_info *info;
+
+  info = get_insn_extend_info (insn, insn_extend_info);
+
+  if (info && extend_type_compatible (type, info->extend_type))
+    return 0;
+
+  if (can_combine_for_free (insn, type))
+    return 0;
+
+  return 1;
+}
+
+
+/* The maximum number of levels of dependencies we will traverse.  */
+#define MAX_PROPAGATE_LEVELS 3
+
+/* The maximum number of source operands supported for each propagated
+   instruction.  */
+#define MAX_PROPAGATE_SOURCES 2
+
+/* The maximum number of target instructions supported.  */
+#define MAX_PROPAGATE_TARGETS 8
+
+/* The maximum number of through instructions supported.  */
+#define MAX_PROPAGATE_THROUGH 7
+
+/* Information on an extension propagation opportunity.  */
+struct propagate_extend_info
+{
+  /* Information on the extension instruction to be propagated.  */
+  struct insn_extend_info *extend_info;
+
+  /* Cost of the propagation, i.e. number of extensions required.  */
+  int cost;
+
+  /* Number of targets, and through instructions.  */
+  int ntargets, nthrough;
+
+  /* The targets of the propagation.   */
+  rtx target[MAX_PROPAGATE_TARGETS];
+
+  /* The instructions through which the propagation is done.   */
+  rtx through[MAX_PROPAGATE_THROUGH];
+
+  /* The next propagate_extend_info in the list.  */
+  struct propagate_extend_info *next;
+};
+
+
+/* Add a target to PINFO.  */
+static bool
+pei_add_target (struct propagate_extend_info *pinfo, rtx target)
+{
+  if (pinfo->ntargets >= MAX_PROPAGATE_TARGETS)
+    return false;
+
+  pinfo->target[pinfo->ntargets++] = target;
+  return true;
+}
+
+
+/* Add a through instruction to PINFO.  */
+static bool
+pei_add_through (struct propagate_extend_info *pinfo, rtx through)
+{
+  if (pinfo->nthrough >= MAX_PROPAGATE_THROUGH)
+    return false;
+
+  pinfo->through[pinfo->nthrough++] = through;
+  return true;
+}
+
+
+/* Dump out the contents of PINFO.  */
+static void
+debug_pei (FILE *f, struct propagate_extend_info *pinfo, bool verbose)
+{
+  fprintf (f, "Pinfo ");
+  if (pinfo->extend_info)
+    fprintf (f, "Insn %d Type %d ", 
+	     INSN_UID (pinfo->extend_info->insn),
+	     (int)pinfo->extend_info->extend_type);
+  fprintf (f, "Cost %d Ntargets %d Nthrough %d\n",
+	   pinfo->cost, pinfo->ntargets, pinfo->nthrough);
+
+  if (verbose)
+    {
+      int i;
+      fprintf (f, "Targets\n");
+      for (i = 0; i < pinfo->ntargets; i++)
+	print_rtx (f, pinfo->target[i]);
+
+      fprintf (f, "Through\n");
+      for (i = 0; i < pinfo->nthrough; i++)
+	print_rtx (f, pinfo->through[i]);
+
+      fprintf (f, "Base\n");
+      print_rtx (f, pinfo->extend_info->insn);
+
+      fprintf (f, "Extend\n");
+      print_rtx (f, pinfo->extend_info->extend_insn);
+    }
+}
+
+
+/* Returns whether INSN0 strictly dominates INSN1 in the same basic
+   block.  */
+static bool
+strictly_dominates (rtx insn0, rtx insn1)
+{
+  basic_block bb;
+  rtx insn;
+
+  if (BLOCK_NUM (insn0) != BLOCK_NUM (insn1))
+    return false;
+
+  if (insn0 == insn1)
+    return false;
+
+  bb = BASIC_BLOCK (BLOCK_NUM (insn0));
+  for (insn = insn0; insn != NEXT_INSN (BB_END (bb)); insn = NEXT_INSN (insn))
+    {
+      if (insn == insn1)
+	return true;
+    }
+
+  return false;
+}
+
+
+/* Attempt to propagate an extension of type TYPE upward from INSN,
+   and return the result in PINFO.  If no propagation is done, return
+   PINFO containing INSN as its only target.  */
+static void
+try_propagate_extend (rtx insn, enum extend_type type,
+		      struct propagate_extend_info *pinfo, int level,
+		      htab_t insn_extend_info)
+{
+  df_ref *uses, *defs;
+  int num_uses;
+  struct df_link *link;
+  int i, j;
+  int total_src_cost;
+  struct propagate_extend_info src_pinfos[MAX_PROPAGATE_SOURCES];
+
+  /* Check the conditions required for propagation.  Initialize pinfo
+     with default information, if we don't do any propagation.  */
+  pinfo->cost = (level == 0) ? 1 : extension_cost (insn, type, insn_extend_info);
+  gcc_assert (pei_add_target (pinfo, insn));
+
+  /* Limit the depth of the search.  */
+  if (level == MAX_PROPAGATE_LEVELS)
+    return;
+
+  /* Only proceed if INSN propagates extension information.  */
+  if (!insn_propagates_extend (insn))
+    return;
+
+  uses = DF_INSN_USES (insn);
+
+  num_uses = 0;
+  while (uses[num_uses])
+    {
+      rtx src_insn = get_single_link_insn (uses[num_uses]);
+
+      /* Require that there is only one predecessor for each of its
+	 source operands.  */
+      if (src_insn == NULL_RTX)
+	return;
+
+      /* Require that the propagation be local to a basic block, to avoid
+	 degradation due to live range issues.  */
+      if (!strictly_dominates (src_insn, insn))
+	return;
+
+      num_uses++;
+    }
+
+  /* Require that we don't exeed the maximum number of source
+     operands supported.  */
+  if (num_uses > MAX_PROPAGATE_SOURCES)
+    return;
+
+  /* Require that the result is only used once.  This can be relaxed,
+     if our analysis extends to being able to analyze multiple
+     bases.  */
+  defs = DF_INSN_DEFS (insn);
+  if (!(defs[0] && !defs[1]))
+    return;
+
+  link = DF_REF_CHAIN (defs[0]);
+  if (!(link && !link->next))
+    return;
+
+  /* All the conditions for propagation have been met.  Recursively
+     propagate through the sources, and merge the results.  */
+  memset (&src_pinfos, 0, (sizeof (struct propagate_extend_info)
+			   * MAX_PROPAGATE_SOURCES));
+
+  total_src_cost = 0;
+  for (i = 0; i < num_uses; i++)
+    {
+      rtx src_insn = get_single_link_insn (uses[i]);
+
+      /* The transformation code only handles SET insns (when it tries
+	 to find the result if the insn), so require it here.  This can
+	 be relaxed in the future.  */
+      if (GET_CODE (PATTERN (src_insn)) != SET)
+	return;
+
+      try_propagate_extend (src_insn, type, &src_pinfos[i], level + 1,
+			    insn_extend_info);
+      total_src_cost += src_pinfos[i].cost;
+
+      if (dump_file)
+	{
+	  fprintf (dump_file, "try_propagate_extend level %d\n", level + 1);
+	  print_rtx (dump_file, src_insn);
+	  debug_pei (dump_file, &src_pinfos[i], false);
+	}
+    }
+
+  if (total_src_cost <= pinfo->cost)
+    {
+      if (dump_file)
+	fprintf (dump_file, "Found better cost %d <= %d\n", total_src_cost,
+		 pinfo->cost);
+
+      pinfo->ntargets = 0;
+      pinfo->target[0] = NULL_RTX;
+
+      pinfo->cost = total_src_cost;
+
+      for (i = 0; i < num_uses; i++)
+	{
+	  for (j = 0; j < src_pinfos[i].ntargets; j++)
+	    gcc_assert (pei_add_target (pinfo, src_pinfos[i].target[j]));
+
+	  for (j = 0; j < src_pinfos[i].nthrough; j++)
+	    gcc_assert (pei_add_through (pinfo, src_pinfos[i].through[j]));
+	}
+
+      gcc_assert (pei_add_through (pinfo, insn));
+    }
+}
+
+
+/* Look for profitable propgation of an extension from INSN, and
+   return its info if one is found.  */
+static struct propagate_extend_info *
+analyze_extend_propagation (rtx insn, htab_t insn_extend_infos)
+{
+  struct insn_extend_info *info;
+  struct propagate_extend_info pinfo;
+  struct propagate_extend_info *ret_pinfo;
+
+  info = get_insn_extend_info (insn, insn_extend_infos);
+
+  /* Check to see if INSN has an extend that is a candidate for
+     propagation.  */
+  if (!info || !info->is_propagate_candidate)
+    return NULL;
+
+  /* Require that the propagation be local to a basic block, to avoid
+     degradation due to live range issues.  */
+  if (!strictly_dominates (insn, info->extend_insn))
+    return NULL;
+
+  /* Check for profitable extension.  */
+  memset (&pinfo, 0, sizeof(struct propagate_extend_info));
+  try_propagate_extend (insn, info->extend_type, &pinfo, 0, insn_extend_infos);
+  pinfo.extend_info = info;
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "try_propagate_extend level 0\n");
+      print_rtx (dump_file, insn);
+      debug_pei (dump_file, &pinfo, false);
+    }
+
+  if (pinfo.ntargets == 1 && pinfo.nthrough == 0)
+    return NULL;
+
+  ret_pinfo = XCNEW (struct propagate_extend_info);
+  *ret_pinfo = pinfo;
+
+  return ret_pinfo;
+}
+
+
+/* If X is a subreg, returns its reg; otherwise return X.  */
+static rtx
+strip_subreg (rtx x)
+{
+  if (GET_CODE (x) == SUBREG)
+    return SUBREG_REG (x);
+  return x;
+}
+
+
+/* A small table mapping rtx to rtx.  */
+struct rtx_table_entry
+{
+  rtx from, to;
+};
+
+
+#define RTX_TABLE_MAX_ENTRIES 20
+struct rtx_table
+{
+  int num_entries;
+  struct rtx_table_entry entries[RTX_TABLE_MAX_ENTRIES];
+};
+
+
+/* Return the rtx corresponding to FROM in RMAP, or NULL_RTX.  */
+static rtx
+rtx_table_lookup (rtx from, struct rtx_table *rmap)
+{
+  struct rtx_table_entry *entries;
+  int i;
+
+  from = strip_subreg (from);
+
+  if (!REG_P (from))
+    return from;
+
+  entries = rmap->entries;
+  for (i = 0; (i < rmap->num_entries) && (entries[i].from != NULL_RTX); i++)
+    {
+      if (entries[i].from == from)
+	return entries[i].to;
+    }
+
+  return NULL_RTX;
+}
+
+
+/* Add an entry from to RMAP.  */
+static int
+rtx_table_add (rtx from, rtx to, struct rtx_table *rmap)
+{
+  int n = rmap->num_entries++;
+
+  gcc_assert (n < RTX_TABLE_MAX_ENTRIES);
+
+  from = strip_subreg (from);
+
+  rmap->entries[n].from = from;
+  rmap->entries[n].to = to;
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "rtx_table_add ");
+      print_inline_rtx (dump_file, from, 0);
+      fprintf (dump_file, " ");
+      print_inline_rtx (dump_file, to, 0);
+      fprintf (dump_file, "\n");
+    }
+
+  return n;
+}
+
+
+/* Return the rtx corresponding to FROM, or create a new MODE reg
+   return it.  */
+static rtx
+rtx_table_lookup_or_create (rtx from, enum machine_mode mode,
+			    struct rtx_table *rmap)
+{
+  rtx to;
+
+  to = rtx_table_lookup (from, rmap);
+
+  if (to)
+    {
+      gcc_assert (GET_MODE (to) == mode || GET_MODE (to) == VOIDmode);
+      return to;
+    }
+
+  to = gen_reg_rtx (mode);
+  rtx_table_add (from, to, rmap);
+  return to;
+}
+
+
+/* Fixup the target of an extend propagation.  */
+static void
+propagate_extend_fixup_target (rtx insn, enum extend_type type,
+			       struct rtx_table *rmap)
+{
+  rtx pattern;
+  rtx set_dest;
+  rtx dest, src, x;
+  rtx new_insns = NULL_RTX;
+
+  pattern = PATTERN (insn);
+
+  gcc_assert (GET_CODE (pattern) == SET);
+
+  set_dest = SET_DEST (pattern);
+
+  switch (type)
+    {
+    case si_to_udi:
+    case si_to_sdi:
+    case di_to_udi:
+    case di_to_sdi:
+      src = simplify_gen_subreg (SImode, set_dest, GET_MODE (set_dest), 0);
+      dest = rtx_table_lookup_or_create (set_dest, DImode, rmap);
+
+      start_sequence ();
+      if (type == si_to_udi || type == di_to_udi)
+	emit_insn (gen_zero_extendsidi2 (dest, src));
+      else
+	emit_insn (gen_extendsidi2 (dest, src));
+      new_insns = get_insns ();
+      end_sequence ();
+      break;
+    case di_to_si:
+      src = simplify_gen_subreg (DImode, set_dest, GET_MODE (set_dest), 0);
+      dest = rtx_table_lookup_or_create (set_dest, SImode, rmap);
+
+      start_sequence ();
+      emit_insn (gen_truncdisi2 (dest, src));
+      new_insns = get_insns ();
+      end_sequence ();
+      break;
+    default:
+      gcc_unreachable ();
+    }
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\npropagate_extend_fixup_target\n");
+      print_rtx (dump_file, insn);
+      fprintf (dump_file, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (dump_file, x);
+	  x = NEXT_INSN (x);
+	}
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\npropagate_extend_fixup_target\n");
+      print_rtx (f, insn);
+      fprintf (f, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (f, x);
+	  x = NEXT_INSN (x);
+	}
+      tilegx_unlock_data_file (f);
+    }
+
+  emit_insn_after (new_insns, insn);
+}
+
+
+/* Fixup the through instruction of an extend propagation.  */
+static void
+propagate_extend_fixup_through (rtx insn, enum extend_type type,
+				struct rtx_table *rmap)
+{
+  rtx new_insns;
+  rtx dest, src0, src1;
+  rtx new_dest, new_src0, new_src1;
+  enum machine_mode mode;
+  int code, new_code;
+  rtx x;
+
+  gcc_assert (GET_CODE (PATTERN (insn)) == SET);
+  dest = SET_DEST (PATTERN (insn));
+
+  /* these cases do not require mode change.  */
+  if (type == di_to_udi || type == di_to_sdi)
+    {
+      if (!rtx_table_lookup (dest, rmap))
+	rtx_table_add (dest, dest, rmap);
+      return;
+    }
+
+  mode = (type == di_to_si) ? SImode : DImode;
+
+  code = recog_memoized (insn);
+  switch (code)
+    {
+    case CODE_FOR_xorsi3:
+    case CODE_FOR_xordi3:
+      new_code = (type == di_to_si) ? CODE_FOR_xorsi3 : CODE_FOR_xordi3;
+      break;
+    case CODE_FOR_iorsi3:
+    case CODE_FOR_iordi3:
+      new_code = (type == di_to_si) ? CODE_FOR_iorsi3 : CODE_FOR_iordi3;
+      break;
+    case CODE_FOR_andsi3:
+    case CODE_FOR_anddi3:
+      new_code = (type == di_to_si) ? CODE_FOR_andsi3 : CODE_FOR_anddi3;
+      break;
+    default:
+      gcc_unreachable ();
+    }
+
+  src0 = get_set_src_xexp (insn, 0);
+  src1 = get_set_src_xexp (insn, 1);
+
+  gcc_assert (src0 && src1);
+
+  new_src0 = rtx_table_lookup (src0, rmap);
+  if (GET_MODE (new_src0) != VOIDmode)
+    new_src0 = simplify_gen_subreg (mode, new_src0, GET_MODE (new_src0), 0);
+
+  new_src1 = rtx_table_lookup (src1, rmap);
+  if (GET_MODE (new_src1) != VOIDmode)
+    new_src1 = simplify_gen_subreg (mode, new_src1, GET_MODE (new_src1), 0);
+
+  new_dest = rtx_table_lookup_or_create (dest, mode, rmap);
+      
+  start_sequence ();
+  emit_insn (GEN_FCN (new_code) (new_dest, new_src0, new_src1));
+  new_insns = get_insns ();
+  end_sequence ();
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\npropagate_extend_fixup_through\n");
+      print_rtx (dump_file, insn);
+      fprintf (dump_file, " ==> Replaced by\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (dump_file, x);
+	  x = NEXT_INSN (x);
+	}
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\npropagate_extend_fixup_through\n");
+      print_rtx (f, insn);
+      fprintf (f, " ==> Replaced by\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (f, x);
+	  x = NEXT_INSN (x);
+	}
+      tilegx_unlock_data_file (f);
+    }
+
+  emit_insn_after (new_insns, insn);
+  delete_insn (insn);
+}
+
+
+/* Fixup the base instruction of an extend propagation.  */
+static void
+propagate_extend_fixup_base (struct insn_extend_info *info,
+			     enum extend_type type ATTRIBUTE_UNUSED,
+			     struct rtx_table *rmap)
+{
+  rtx extend_insn;
+  rtx new_insns;
+  rtx dest, src;
+  rtx new_src;
+  rtx x;
+
+  extend_insn = info->extend_insn;
+
+  gcc_assert (GET_CODE (PATTERN (extend_insn)) == SET);
+
+  src = get_set_src_xexp (extend_insn, 0);
+  dest = SET_DEST (PATTERN (extend_insn));
+
+  new_src = rtx_table_lookup (src, rmap);
+
+  start_sequence ();
+  emit_move_insn (dest, new_src);
+  new_insns = get_insns ();
+  end_sequence ();
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\npropagate_extend_fixup_base\n");
+      fprintf (dump_file, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (dump_file, x);
+	  x = NEXT_INSN (x);
+	}
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\npropagate_extend_fixup_base\n");
+      fprintf (f, " ==> Added\n");
+      x = new_insns;
+      while (x)
+	{
+	  print_rtx (f, x);
+	  x = NEXT_INSN (x);
+	}
+      tilegx_unlock_data_file (f);
+    }
+
+  emit_insn_after (new_insns, extend_insn);
+  delete_insn (extend_insn);
+}
+
+
+/* Returns whether M contains any insns in PINFO.  */
+static bool
+has_insn_in_bitmap (struct propagate_extend_info *pinfo, bitmap m)
+{
+  int i;
+  for (i = 0; i < pinfo->ntargets; i++)
+    if (bitmap_bit_p (m, INSN_UID (pinfo->target[i])))
+      return true;
+
+  for (i = 0; i < pinfo->nthrough; i++)
+    if (bitmap_bit_p (m, INSN_UID (pinfo->through[i])))
+      return true;
+
+  if (bitmap_bit_p (m, INSN_UID (pinfo->extend_info->insn)))
+    return true;
+
+  if (bitmap_bit_p (m, INSN_UID (pinfo->extend_info->extend_insn)))
+    return true;
+
+  return false;
+}
+
+
+/* Put the insns in PINFO into M.  */
+static void
+put_insns_in_bitmap (struct propagate_extend_info *pinfo, bitmap m)
+{
+  int i;
+  for (i = 0; i < pinfo->ntargets; i++)
+    bitmap_set_bit (m, INSN_UID (pinfo->target[i]));
+
+  for (i = 0; i < pinfo->nthrough; i++)
+    bitmap_set_bit (m, INSN_UID (pinfo->through[i]));
+
+  bitmap_set_bit (m, INSN_UID (pinfo->extend_info->insn));
+  bitmap_set_bit (m, INSN_UID (pinfo->extend_info->extend_insn));
+}
+
+
+/* Propagate the extension described in PINFO.  */
+static void
+do_propagate_extend (struct propagate_extend_info *pinfo)
+{
+  struct insn_extend_info *info = pinfo->extend_info;
+  enum extend_type type = info->extend_type;
+  int i;
+  struct rtx_table rmap;
+
+  if (dump_file)
+    {
+      fprintf (dump_file, "\nDo propagate extend\n");
+      debug_pei (dump_file, pinfo, true);
+    }
+
+  if (TARGET_COLLECT_DATA)
+    {
+      FILE *f = tilegx_lock_data_file (tilegx_data_file);
+      fprintf (f, "\nDo propagate extend %s %s\n", main_input_filename,
+	       current_function_name());
+      debug_pei (f, pinfo, true);
+      tilegx_unlock_data_file (f);
+    }
+
+  memset (&rmap, 0, sizeof (struct rtx_table));
+
+  for (i = 0; i < pinfo->ntargets; i++)
+    propagate_extend_fixup_target (pinfo->target[i], type, &rmap);
+
+  for (i = 0; i < pinfo->nthrough; i++)
+    propagate_extend_fixup_through (pinfo->through[i], type, &rmap);
+
+  propagate_extend_fixup_base (pinfo->extend_info, type, &rmap);
+}
+
+
+/* Perform extension propagation for the linked list headed by
+   HEAD.  */
+static void
+do_propagate_extends (struct propagate_extend_info *head)
+{
+  bitmap processed_insns = BITMAP_ALLOC (NULL);
+
+  while (head)
+    {
+      if (!has_insn_in_bitmap (head, processed_insns))
+	{
+	  put_insns_in_bitmap (head, processed_insns);
+	  do_propagate_extend (head);
+	}
+      head = head->next;
+    }
+
+  BITMAP_FREE (processed_insns);
+}
+
+
+/* Optimize the placement of extension insns.  */
+static void
+propagate_extends (void)
+{
+  htab_t insn_extend_infos;
+  basic_block bb;
+  rtx insn;
+  struct propagate_extend_info *pinfo;
+  struct propagate_extend_info *phead;
+
+  insn_extend_infos = htab_create (10, htab_iei_hash, htab_iei_eq,
+				   htab_iei_del);
+
+  if (dump_file)
+    fprintf (dump_file, "@@@ Init insn extend info @@@\n");
+
+  /* Initialize the insn_extend_infos.  */
+  FOR_EACH_BB (bb)
+    {
+      for (insn = BB_HEAD (bb); insn != NEXT_INSN (BB_END (bb));
+	   insn = NEXT_INSN (insn))
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  init_insn_extend_info (insn, insn_extend_infos);
+	}
+    }
+
+  if (dump_file)
+    fprintf (dump_file, "@@@ Analyze extend propagation @@@\n");
+
+  /* Look for profitable extend propagation.  Note the order in which
+     we insert the pinfo.  When we do the actual propagation, we visit
+     the pinfo corresponding to the bottem of the basic block
+     first.  */
+  phead = NULL;
+  FOR_EACH_BB (bb)
+    {
+      for (insn = BB_HEAD (bb); insn != NEXT_INSN (BB_END (bb));
+	   insn = NEXT_INSN (insn))
+	{
+	  pinfo = analyze_extend_propagation (insn, insn_extend_infos);
+	  if (pinfo)
+	    {
+	      if (phead)
+		pinfo->next = phead;
+	      phead = pinfo;
+	    }
+	}
+    }
+
+  if (dump_file)
+    fprintf (dump_file, "@@@ Do propagate extends @@@\n");
+
+  /* Do the transformation.  */
+  if (phead)
+    do_propagate_extends (phead);
+
+  /* Clean up */
+  while (phead)
+    {
+      struct propagate_extend_info *next = phead->next;
+      XDELETE (phead);
+      phead = next;
+    }
+
+  htab_delete (insn_extend_infos);
+}
+
+
+
+/* Unnecessary zero/sign extension optimization.  */
+
+
+enum reg_extend_state {
+  REG_EXTEND_INVALID,
+  REG_EXTEND_TRUNCATE,
+  REG_EXTEND_ZERO_EXTENDED,
+  REG_EXTEND_SIGN_EXTENDED
+};
+
+
+typedef struct reg_extend_info
+{
+  int reg_num;
+  rtx reg_rtx;
+  rtx src_reg_rtx;
+  enum reg_extend_state state;
+} reg_extend_info;
+
+
+/* Returns the hash value of a pointer to a reg_extend_info.  */
+static hashval_t
+htab_rei_hash (const void *p)
+{
+  const reg_extend_info *const rei = (const reg_extend_info *) p;
+
+  return (hashval_t)rei->reg_num;
+}
+
+
+/* Equality function for reg_extend_info *.  */
+static int
+htab_rei_eq (const void *p1, const void *p2)
+{
+  const reg_extend_info *const rei1 = (const reg_extend_info *) p1;
+  const reg_extend_info *const rei2 = (const reg_extend_info *) p2;
+
+  return rei1->reg_num == rei2->reg_num;
+}
+
+
+/* Hash entry delete function for reg_extend_info *.  */
+static void
+htab_rei_del (void *p)
+{
+  reg_extend_info *const rei = (reg_extend_info *) p;
+  free (rei);
+}
+
+
+/* INSN is the outer most insn containing SET_INSN.  Returns true if the
+   register result of SET_INSN is only used in its lower 32 bits.  */
+static bool
+is_result_32bit_reg (rtx insn, rtx set_insn)
+{
+  bool truncated;
+  struct df_insn_info *insn_info;
+  df_ref *def_rec;
+
+  truncated = true;
+
+  insn_info = DF_INSN_INFO_GET (insn);
+  def_rec = DF_INSN_INFO_DEFS (insn_info);
+
+  while (*def_rec)
+    {
+      df_ref def_ref = *def_rec;
+
+      if (DF_REF_REG (def_ref) == SET_DEST (set_insn))
+	{
+	  struct df_link *link = DF_REF_CHAIN (def_ref);
+	  if (link)
+	    {
+	      if (!DF_REF_IS_ARTIFICIAL (link->ref))
+		{
+		  rtx use = DF_REF_INSN (link->ref);
+		  if (recog_memoized (use) != CODE_FOR_truncdisi2)
+		    {
+		      truncated = false;
+		      break;
+		    }
+		}
+	      else
+		truncated = false;
+	    }
+	}
+      def_rec++;
+    }
+
+  return truncated;
+}
+
+
+/* gets the reg_extend_info * corresponding to register rtx OPND.  Returns
+   NULL if none is found.  */
+static reg_extend_info *
+get_extend_info (rtx opnd, htab_t extend_infos)
+{
+  reg_extend_info key;
+
+  if (!REG_P (opnd))
+    return NULL;
+
+  key.reg_num = REGNO (opnd);
+  return (reg_extend_info *)htab_find (extend_infos, &key);
+}
+
+
+/* Get the set insn that performs the intrinsic operation.  If insn is a
+   PARALLEL, assumes the first insn is the intrinsic.  */
+static rtx
+get_intrinsic_set_insn (rtx insn)
+{
+  rtx pattern = PATTERN (insn);
+
+  switch (GET_CODE (pattern))
+    {
+    case SET:
+      return pattern;
+    case PARALLEL:
+      return XVECEXP (pattern, 0, 0);
+    default:
+      return NULL_RTX;
+    }
+}
+
+
+/* Asserts that SET_INSN only uses the lower 32 bits of the opnd'th source
+   operand, so look for opportunity to short circuit any unnecessary zero or
+   sign extension.  Returns whether INSN was changed.  */
+static bool
+optimize_extends_src32 (rtx set_insn, int opnd, htab_t extend_infos)
+{
+  rtx unspec;
+  rtx src;
+  reg_extend_info *rei;
+
+  unspec = SET_SRC (set_insn);
+
+  gcc_assert (GET_CODE (unspec) == UNSPEC);
+  gcc_assert (opnd < XVECLEN (unspec, 0));
+
+  src = XVECEXP (unspec, 0, opnd);
+
+  rei = get_extend_info (src, extend_infos);
+  if (rei != NULL &&
+      (rei->state == REG_EXTEND_ZERO_EXTENDED ||
+       rei->state == REG_EXTEND_SIGN_EXTENDED))
+    {
+      XVECEXP (unspec, 0, opnd) = rei->src_reg_rtx;
+      return true;
+    }
+
+  return false;
+}
+
+
+/* Checks to see if the primary result of INSN is only used in its lower 32
+   bits.  If so, optimize the first and second source operands assuming that
+   they only use the lower 32 bits.  Returns whether INSN was changed.  */
+static bool
+optimize_extends_res32_implies_src32_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  if (is_result_32bit_reg (insn, set_insn))
+    {
+      changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+      changed |= optimize_extends_src32 (set_insn, 1, extend_infos);
+    }
+
+  return changed;
+}
+
+
+/* Checks to see if the primary result of INSN is only used in its lower 32
+   bits.  If so, optimize the first source operand assuming that it only uses
+   the lower 32 bits.  Returns whether INSN was changed.  */
+static bool
+optimize_extends_res32_implies_src32_imm_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  if (is_result_32bit_reg (insn, set_insn))
+    changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+
+  return changed;
+}
+
+
+/* Optimize the first and second source operands assuming that they only use
+   the lower 32 bits.  Returns whether INSN was changed.  */
+static bool
+optimize_extends_src32_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+  changed |= optimize_extends_src32 (set_insn, 1, extend_infos);
+
+  return changed;
+}
+
+
+/* Optimize a sada instruction.  If the result is 32 bit, then only use 32
+   bits of the sum input operand.  */
+static bool
+optimize_extends_sada_insn (rtx insn, htab_t extend_infos)
+{
+  bool changed = false;
+  rtx set_insn = get_intrinsic_set_insn (insn);
+
+  if (is_result_32bit_reg (insn, set_insn))
+    changed |= optimize_extends_src32 (set_insn, 0, extend_infos);
+
+  return changed;
+}
+
+
+/* Do extension optimizations for INSN.  */
+static void
+optimize_extends_insn (rtx insn, htab_t extend_infos)
+{
+  enum insn_code code;
+  bool changed;
+
+  code = recog_memoized (insn);
+
+  changed = false;
+  switch (code)
+    {
+    case CODE_FOR_insn_v4add:
+    case CODE_FOR_insn_v4addsc:
+    case CODE_FOR_insn_v2add:
+    case CODE_FOR_insn_v2addsc:
+    case CODE_FOR_insn_v1add:
+    case CODE_FOR_insn_v1adduc:
+    case CODE_FOR_insn_v4sub:
+    case CODE_FOR_insn_v4subsc:
+    case CODE_FOR_insn_v2sub:
+    case CODE_FOR_insn_v2subsc:
+    case CODE_FOR_insn_v1sub:
+    case CODE_FOR_insn_v1subuc:
+    case CODE_FOR_insn_v4shrs:
+    case CODE_FOR_insn_v2shrs:
+    case CODE_FOR_insn_v1shrs:
+    case CODE_FOR_insn_v4shru:
+    case CODE_FOR_insn_v2shru:
+    case CODE_FOR_insn_v1shru:
+    case CODE_FOR_insn_v4shl:
+    case CODE_FOR_insn_v2shl:
+    case CODE_FOR_insn_v1shl:
+    case CODE_FOR_insn_v4shlsc:
+    case CODE_FOR_insn_v2shlsc:
+    case CODE_FOR_insn_v2adiffs:
+    case CODE_FOR_insn_v1adiffu:
+    case CODE_FOR_insn_v2avgs:
+    case CODE_FOR_insn_v1avgu:
+    case CODE_FOR_insn_v2maxs:
+    case CODE_FOR_insn_v1maxu:
+    case CODE_FOR_insn_v2mins:
+    case CODE_FOR_insn_v1minu:
+    case CODE_FOR_insn_v2mz:
+    case CODE_FOR_insn_v1mz:
+    case CODE_FOR_insn_v2mnz:
+    case CODE_FOR_insn_v1mnz:
+    case CODE_FOR_insn_v2cmplts:
+    case CODE_FOR_insn_v1cmplts:
+    case CODE_FOR_insn_v2cmples:
+    case CODE_FOR_insn_v1cmples:
+    case CODE_FOR_insn_v2cmpltu:
+    case CODE_FOR_insn_v1cmpltu:
+    case CODE_FOR_insn_v2cmpleu:
+    case CODE_FOR_insn_v1cmpleu:
+    case CODE_FOR_insn_v2cmpeq:
+    case CODE_FOR_insn_v1cmpeq:
+    case CODE_FOR_insn_v2cmpne:
+    case CODE_FOR_insn_v1cmpne:
+    case CODE_FOR_insn_v2mults:
+    case CODE_FOR_insn_v1multu:
+    case CODE_FOR_insn_v1ddotpus:
+
+      /* If result is 32 bit, then only use 32 bits of sources. */
+      changed = optimize_extends_res32_implies_src32_insn (insn, extend_infos);
+      break;
+
+    case CODE_FOR_insn_v2addi:
+    case CODE_FOR_insn_v1addi:
+    case CODE_FOR_insn_v2maxsi:
+    case CODE_FOR_insn_v1maxui:
+    case CODE_FOR_insn_v2minsi:
+    case CODE_FOR_insn_v1minui:
+    case CODE_FOR_insn_v2cmpltsi:
+    case CODE_FOR_insn_v1cmpltsi:
+    case CODE_FOR_insn_v2cmpltui:
+    case CODE_FOR_insn_v1cmpltui:
+    case CODE_FOR_insn_v2cmpeqi:
+    case CODE_FOR_insn_v1cmpeqi:
+      /* If result is 32 bit, then only use 32 bits of sources; immediate
+	 version. */
+      changed = optimize_extends_res32_implies_src32_imm_insn (insn, extend_infos);
+      break;
+
+    case CODE_FOR_insn_crc32_8:
+    case CODE_FOR_insn_crc32_32:
+    case CODE_FOR_insn_v4int_l:
+    case CODE_FOR_insn_v2int_l:
+    case CODE_FOR_insn_v1int_l:
+    case CODE_FOR_insn_v2muls:
+    case CODE_FOR_insn_v2mulfsc:
+    case CODE_FOR_insn_v1mulu:
+    case CODE_FOR_insn_v1mulus:
+      /* Only use the lower 32 bits on the inputs.  */
+      changed = optimize_extends_src32_insn (insn, extend_infos);
+      break;
+
+    case CODE_FOR_insn_v2sadas:
+    case CODE_FOR_insn_v2sadau:
+    case CODE_FOR_insn_v1sadau:
+      /* If the result is 32 bit, then only use 32 bits of the sum input
+	 operand.  */
+      changed = optimize_extends_sada_insn (insn, extend_infos);
+      break;
+
+    default:
+      break;
+    }
+
+  if (changed)
+    df_insn_rescan (insn);
+}
+
+
+/* Returns the reg_extend_info corresponding to REG_NUM.  */
+static reg_extend_info *
+get_reg_extend_info (unsigned reg_num, htab_t extend_infos)
+{
+  reg_extend_info **hash_slot;
+  reg_extend_info *rei;
+  reg_extend_info key;
+
+  key.reg_num = reg_num;
+
+  hash_slot = (reg_extend_info **) htab_find_slot (extend_infos, &key, INSERT);
+  rei = *hash_slot;
+  if (rei == NULL)
+    {
+      rei = *hash_slot = XCNEW (reg_extend_info);
+      rei->reg_num = reg_num;
+    }
+
+  return rei;
+}
+
+
+/* Invalidate the reg_extend_info corresponding to REG_NUM.  */
+static void
+optimize_extends_invalidate_reg (unsigned reg_num, htab_t extend_infos)
+{
+  reg_extend_info key;
+  reg_extend_info *rei;
+
+  key.reg_num = reg_num;
+  rei = (reg_extend_info *)htab_find (extend_infos, &key);
+  if (rei != NULL)
+    rei->state = REG_EXTEND_INVALID;
+}
+
+
+/* Invalidate all reg_extend_info corresponding to registers that have been
+   chagned by PATTERN.  */
+static void
+optimize_extends_invalidate_results (rtx pattern, htab_t extend_infos)
+{
+  int i;
+
+  switch (GET_CODE (pattern)) 
+    {    
+    case PARALLEL: {
+      for (i = 0; i < XVECLEN (pattern, 0); i++)
+	optimize_extends_invalidate_results (XVECEXP (pattern, 0, i),
+					     extend_infos);
+      break;
+    }
+    case SET: {
+      rtx dest;
+      dest = SET_DEST (pattern);
+      if (REG_P (dest))
+	optimize_extends_invalidate_reg (REGNO (dest), extend_infos);
+
+      break;
+    }
+    case CLOBBER: {
+      rtx clobbered = XEXP (pattern, 0);
+      if (REG_P (clobbered))
+	optimize_extends_invalidate_reg (REGNO (clobbered), extend_infos);
+
+      break;
+    }
+    default:
+      break;
+    }
+}
+
+
+/* Update EXTEND_INFOS to refect the extension pattern found in PATTERN.
+   OUTPUT_STATE reflects the extension type.  */
+static void
+optimize_extends_update_extend (enum reg_extend_state output_state,
+				rtx pattern, htab_t extend_infos)
+{
+  reg_extend_info *rei_src;
+  reg_extend_info key;
+  rtx dest;
+  rtx src;
+  rtx extending_src;
+
+  gcc_assert (GET_CODE (pattern) == SET);
+
+  dest = SET_DEST (pattern);
+
+  if (REG_P (dest))
+    {
+      /* get the source of the extend insn.  */
+      src = XEXP (SET_SRC (pattern), 0);
+
+      /* Look for the a corresponding source DI whose lower bits are being
+	 extended  */
+      extending_src = NULL;
+      if (REG_P (src))
+	{
+	  /* (set (reg:DI 98) (sign/zero_extend:DI (reg:SI 97))) */
+	  key.reg_num = REGNO (src);
+	  rei_src = (reg_extend_info *)htab_find (extend_infos, &key);
+	  if (rei_src != NULL && rei_src->state == REG_EXTEND_TRUNCATE)
+	    extending_src = rei_src->src_reg_rtx;
+	}
+      else if ((GET_CODE (src) == SUBREG))
+	{
+	  /* FIXME: handle this case for big endian.  */
+	  if (TARGET_BIG_ENDIAN)
+	    return;
+
+	  /* (set (reg:DI 94)
+	          (sign/zero_extend:DI (subreg/s:SI (reg/v:DI 84) 0)))  */
+	  gcc_assert (XINT (src, 1) == 0);
+	  extending_src = XEXP (src, 0);
+	}
+
+      if (extending_src != NULL)
+	{
+	  reg_extend_info *rei_dest;
+	      
+	  rei_dest = get_reg_extend_info (REGNO (dest), extend_infos);
+	  rei_dest->reg_rtx = dest;
+	  rei_dest->src_reg_rtx = extending_src;
+	  rei_dest->state = output_state;
+	}
+    }
+}
+
+
+/* Process INSN and update EXTEND_INFOS.  */
+static void
+optimize_extends_update_info (rtx insn, htab_t extend_infos)
+{
+  enum insn_code code;
+  rtx pattern;
+  bool done = false;
+
+  code = recog_memoized (insn);
+  pattern = PATTERN (insn);
+
+  switch (code)
+    {
+    case CODE_FOR_zero_extendsidi2: {
+      optimize_extends_update_extend (REG_EXTEND_ZERO_EXTENDED,
+				      pattern, extend_infos);
+      done = true;
+      break;
+    }
+    case CODE_FOR_extendsidi2: {
+      optimize_extends_update_extend (REG_EXTEND_SIGN_EXTENDED,
+				      pattern, extend_infos);
+      done = true;
+      break;
+    }
+    case CODE_FOR_truncdisi2: {
+      /* example: (set (reg:SI 97) (truncate:SI (reg:DI 82 [ D.1532 ]))) */
+      rtx dest;
+      rtx src;
+
+      gcc_assert (GET_CODE (pattern) == SET);
+
+      dest = SET_DEST (pattern);
+
+      if (REG_P (dest))
+	{
+	  /* get the source of the truncate */
+	  src = XEXP (SET_SRC (pattern), 0);
+
+	  if (REG_P (src))
+	    {
+	      reg_extend_info *rei_dest;
+
+	      rei_dest = get_reg_extend_info (REGNO (dest), extend_infos);
+	      rei_dest->reg_rtx = dest;
+	      rei_dest->src_reg_rtx = src;
+	      rei_dest->state = REG_EXTEND_TRUNCATE;
+	      done = true;
+	    }
+	}
+      break;
+    }
+    default:
+      break;
+    }
+
+  if (!done)
+    optimize_extends_invalidate_results (pattern, extend_infos);
+}
+
+
+/* Entry point to an optimization pass that optimizes away unnecessary
+   sign/zero extensions for source operands of intrinsics instructions.  If an
+   extension is not necessary, we short circuit the operations to use the
+   value before extension.  We leave to other passes (dce) to eliminate any
+   resulting dead code.  Requries availability of du-chains.  */
+static void
+optimize_extends (void)
+{
+  basic_block bb;
+  rtx insn, last;
+  htab_t extend_infos;
+
+  FOR_EACH_BB (bb)
+    {
+      extend_infos = htab_create (10, htab_rei_hash, htab_rei_eq,
+				  htab_rei_del);
+
+      for (insn = BB_HEAD (bb), last = NEXT_INSN (BB_END (bb));
+	   insn != last;
+	   insn = NEXT_INSN (insn))
+	{
+	  if (!NONDEBUG_INSN_P (insn))
+	    continue;
+
+	  optimize_extends_insn (insn, extend_infos);
+
+	  optimize_extends_update_info (insn, extend_infos);
+	}
+
+      htab_delete (extend_infos);
+    }
+}
+
+
+static bool
+tilegx_gate_handle_target_peephole (void)
+{
+  return optimize > 0;
+}
+
+
+static int
+tilegx_rest_of_handle_target_peephole (void)
+{
+  df_chain_add_problem (DF_DU_CHAIN);
+  df_analyze ();
+  df_set_flags (DF_DEFER_INSN_RESCAN);
+
+  optimize_extends ();
+
+  df_remove_problem (df_chain);
+  df_process_deferred_rescans ();
+
+  return 0;
+}
+
+
+static bool
+tilegx_gate_handle_extend_propagation (void)
+{
+  return (optimize > 0) && TARGET_EXTEND_OPT && !TARGET_BIG_ENDIAN;
+}
+
+
+static int
+tilegx_rest_of_handle_extension_propagation (void)
+{
+  df_chain_add_problem (DF_DU_CHAIN + DF_UD_CHAIN);
+  df_analyze ();
+  df_set_flags (DF_DEFER_INSN_RESCAN);
+
+  propagate_extends ();
+
+  df_remove_problem (df_chain);
+  df_process_deferred_rescans ();
+  return 0;
+}
+
+
+
+/* tilegx specific code to move by pieces.  We handle four cases:
+
+   1. If TO and FROM have the same alignment, generate load-store
+   pairs, but interleave them so we get better scheduling.
+
+   2. If FROM is not 8-byte aligned, TO is 8-byte aligned, and we're
+   copying 8 or more bytes, emit unaligned loads + dblalign, then do
+   aligned stores.
+
+   3. If TO has bigger alignment than FROM, do multiple loads at
+   FROM's alignment, accumulate the value, and then a single store.
+
+   4. If TO has lesser alignment than FROM, do a single load, then
+   multiple shift-and-stores.  */
+rtx
+tilegx_move_by_pieces (rtx to, rtx from, unsigned HOST_WIDE_INT len,
+		       unsigned int align ATTRIBUTE_UNUSED, int endp)
+{
+  unsigned HOST_WIDE_INT i;
+  unsigned int word_bitsize = GET_MODE_BITSIZE (word_mode);
+  unsigned int wordsize = GET_MODE_SIZE (word_mode);
+  unsigned int max_size = MOVE_MAX_PIECES + 1;
+  unsigned HOST_WIDE_INT orig_len = len;
+  rtx from_addr, to_addr;
+
+  if (TARGET_BIG_ENDIAN)
+    return NULL;
+
+  /* We only handle ENDP = 0 */
+  if (endp != 0)
+    return NULL;
+
+  /* if alignment is sufficient do copy LEN bytes in one load/store
+     pair, go to default codegen.  */
+  if (MEM_ALIGN (to) >= len * BITS_PER_UNIT
+      && MEM_ALIGN (from) >= len * BITS_PER_UNIT
+      && len <= word_bitsize)
+    return NULL;
+
+  if (MEM_ALIGN (from) == MEM_ALIGN (to))
+    {
+      /* If TO and FROM have the same alignment, generate load-store
+	 pairs, but interleave them so we get better scheduling.  */
+      unsigned int size;
+      enum machine_mode mode = VOIDmode, tmode;
+      enum insn_code icode;
+
+      size = MIN (MIN (MEM_ALIGN (from) / BITS_PER_UNIT, len), max_size);
+
+      /* Find the mode of the largest move...  */
+      for (tmode = GET_CLASS_NARROWEST_MODE (MODE_INT);
+	   tmode != VOIDmode; tmode = GET_MODE_WIDER_MODE (tmode))
+	{
+	  if (GET_MODE_SIZE (tmode) <= size)
+	    mode = tmode;
+	}
+
+      size = GET_MODE_SIZE (mode);
+
+      icode = optab_handler (mov_optab, mode)->insn_code;
+
+      gcc_assert (icode != CODE_FOR_nothing);
+
+      from_addr = adjust_address (from, mode, 0);
+      to_addr = adjust_address (to, mode, 0);
+
+      while (len >= 2 * size)
+	{
+	  rtx tmp = gen_reg_rtx (mode);
+	  rtx tmp2 = gen_reg_rtx (mode);
+
+	  emit_insn (GEN_FCN (icode) (tmp, from_addr));
+	  from_addr = adjust_address (from_addr, mode, size);
+	  
+	  emit_insn (GEN_FCN (icode) (tmp2, from_addr));
+	  from_addr = adjust_address (from_addr, mode, size);
+
+	  emit_insn (GEN_FCN (icode) (to_addr, tmp));
+	  to_addr = adjust_address (to_addr, mode, size);
+
+	  emit_insn (GEN_FCN (icode) (to_addr, tmp2));
+	  to_addr = adjust_address (to_addr, mode, size);
+
+	  len -= 2 * size;
+	}
+
+      if (len >= size)
+	{
+	  rtx tmp = gen_reg_rtx (mode);
+
+	  emit_insn (GEN_FCN (icode) (tmp, from_addr));
+	  from_addr = adjust_address (from_addr, mode, size);
+	  
+	  emit_insn (GEN_FCN (icode) (to_addr, tmp));
+	  to_addr = adjust_address (to_addr, mode, size);
+
+	  len -= size;
+	}
+    }
+  else if (MEM_ALIGN (from) < word_bitsize
+	   && MEM_ALIGN (to) == word_bitsize
+	   && (len >= wordsize))
+    {
+      /* If FROM is not 8-byte aligned, TO is 8-byte aligned, and
+	 we're copying 8 or more bytes, emit unaligned loads +
+	 dblalign, then do aligned stores. then do aligned stores.
+
+	 16-byte example:
+
+	 ldna tmp, src
+	 addi src2, src, 8
+	 ldna tmp2, src2
+	 dblalign tmp, tmp2, src
+	 st dst, tmp
+	 addi dst, dst, 8
+	 addi src3, src2, 7
+	 ldna tmp3, src3
+	 dblalign tmp2, tmp3, src
+	 st dst, tmp2  */
+      unsigned n = len / wordsize;
+      rtx tmp = gen_reg_rtx (word_mode);
+      rtx insn;
+      rtx mem;
+
+      from_addr = adjust_address (from, word_mode, 0);
+      to_addr = adjust_address (to, word_mode, 0);
+
+      insn = emit_insn (gen_insn_ldna (tmp, XEXP (from_addr, 0)));
+      mem = SET_SRC (PATTERN (insn));
+      MEM_COPY_ATTRIBUTES (mem, from_addr);
+      set_mem_size (mem, GEN_INT (wordsize));
+      set_mem_align (mem, BITS_PER_WORD);
+
+      for (i = 0; i < n; i++, len -= wordsize)
+	{
+	  rtx tmp2 = gen_reg_rtx (word_mode);
+
+	  /* Load the high word at an address that will not fault if
+	     the low address is aligned and at the very end of a page.
+	     When adjusting address, give special care to make sure we
+	     preserve the alignment information in from_addr.  */
+	  from_addr = adjust_address (from_addr, word_mode, wordsize);
+
+	  if (i < n - 1 || len > wordsize)
+	    insn = emit_insn (gen_insn_ldna (tmp2, XEXP (from_addr, 0)));
+	  else
+	    insn =
+	      emit_insn (gen_insn_ldna (tmp2,
+					XEXP (adjust_address (from_addr,
+							      word_mode, -1),
+					      0)));
+	  mem = SET_SRC (PATTERN (insn));
+	  MEM_COPY_ATTRIBUTES (mem, from_addr);
+	  set_mem_size (mem, GEN_INT (wordsize));
+	  set_mem_align (mem, BITS_PER_WORD);
+
+	  emit_insn (gen_insn_dblalign (tmp, tmp, tmp2, XEXP (from, 0)));
+	  emit_move_insn (to_addr, tmp);
+
+	  to_addr = adjust_address (to_addr, word_mode, wordsize);
+	  tmp = tmp2;
+	}
+    }
+  else if (MEM_ALIGN (to) > MEM_ALIGN (from))
+    {
+      /* If TO has bigger alignment than FROM, do multiple loads at
+	 FROM's alignment, accumulate the value, and then a single
+	 store.
+
+	 ld2 tmp, src
+	 addi src, src, 2
+	 ld2 tmp2, src
+	 [addi src, src, 2]
+	 bfins tmp, tmp, tmp2, 16, 31
+	 st4 dst, tmp
+	 [addi dst, dst, 4]  */
+      unsigned int from_size;
+      unsigned int to_size;
+      int loads_per_store;
+      enum machine_mode from_mode = VOIDmode, to_mode = VOIDmode, tmode;
+      enum insn_code from_icode, to_icode;
+      int i;
+
+      from_size = MIN (MIN (MEM_ALIGN (from) / BITS_PER_UNIT, len), max_size);
+      to_size = MIN (MIN (MEM_ALIGN (to) / BITS_PER_UNIT, len), max_size);
+
+      /* Find the mode of the largest move...  */
+      for (tmode = GET_CLASS_NARROWEST_MODE (MODE_INT);
+	   tmode != VOIDmode; tmode = GET_MODE_WIDER_MODE (tmode))
+	{
+	  if (GET_MODE_SIZE (tmode) <= from_size)
+	    from_mode = tmode;
+	  if (GET_MODE_SIZE (tmode) <= to_size)
+	    to_mode = tmode;
+	}
+
+      from_size = GET_MODE_SIZE (from_mode);
+      to_size = GET_MODE_SIZE (to_mode);
+      loads_per_store = to_size / from_size;
+
+      from_icode = optab_handler (mov_optab, from_mode)->insn_code;
+      to_icode = optab_handler (mov_optab, to_mode)->insn_code;
+
+      gcc_assert (from_icode != CODE_FOR_nothing);
+      gcc_assert (to_icode != CODE_FOR_nothing);
+
+      from_addr = adjust_address (from, from_mode, 0);
+      to_addr = adjust_address (to, to_mode, 0);
+
+      while (len >= to_size)
+	{
+	  rtx tmp = NULL_RTX;
+
+	  for (i = 0; i < loads_per_store; i++)
+	    {
+	      rtx tmp2 = gen_reg_rtx (from_mode);
+
+	      emit_insn (GEN_FCN (from_icode) (tmp2, from_addr));
+
+	      from_addr = adjust_address (from_addr, from_mode, from_size);
+
+	      if (i == 0)
+		tmp = convert_to_mode (DImode, tmp2, 0);
+	      else
+		emit_insn (gen_insn_bfins (tmp, tmp,
+					   convert_to_mode (DImode, tmp2, 0),
+					   GEN_INT (i * from_size *
+						    BITS_PER_UNIT),
+					   GEN_INT ((i + 1) * from_size *
+						    BITS_PER_UNIT - 1)));
+	    }
+
+	  emit_insn (GEN_FCN (to_icode) (to_addr,
+					 convert_to_mode (to_mode, tmp, 0)));
+
+	  to_addr = adjust_address (to_addr, to_mode, to_size);
+
+	  len -= to_size;
+	}
+    }
+  else if (MEM_ALIGN (to) < MEM_ALIGN (from))
+    {
+      /* If TO has lesser alignment than FROM, do a ingle load, then
+	 multiple shift-and-stores.
+
+	 ld4 tmp, src
+	 [addi src, src, 4]
+	 st2 dst, tmp
+	 addi dst, dst, 2
+	 shru tmp2, tmp, 16
+	 st2 dst, tmp2
+	 [addi dst dst, 2]  */
+      unsigned int from_size;
+      unsigned int to_size;
+      int stores_per_load;
+      enum machine_mode from_mode = VOIDmode, to_mode = VOIDmode, tmode;
+      enum machine_mode lshr_mode;
+      enum insn_code from_icode, to_icode, lshr_icode;
+      int i;
+
+      from_size = MIN (MIN (MEM_ALIGN (from) / BITS_PER_UNIT, len), max_size);
+      to_size = MIN (MIN (MEM_ALIGN (to) / BITS_PER_UNIT, len), max_size);
+
+      /* Find the mode of the largest move...  */
+      for (tmode = GET_CLASS_NARROWEST_MODE (MODE_INT);
+	   tmode != VOIDmode; tmode = GET_MODE_WIDER_MODE (tmode))
+	{
+	  if (GET_MODE_SIZE (tmode) <= from_size)
+	    from_mode = tmode;
+	  if (GET_MODE_SIZE (tmode) <= to_size)
+	    to_mode = tmode;
+	}
+
+      from_size = GET_MODE_SIZE (from_mode);
+      to_size = GET_MODE_SIZE (to_mode);
+      stores_per_load = from_size / to_size;
+
+      lshr_mode = (from_mode == DImode) ? DImode : SImode;
+
+      from_icode = optab_handler (mov_optab, from_mode)->insn_code;
+      to_icode = optab_handler (mov_optab, to_mode)->insn_code;
+      lshr_icode = optab_handler (lshr_optab, lshr_mode)->insn_code;
+
+      gcc_assert (from_icode != CODE_FOR_nothing);
+      gcc_assert (to_icode != CODE_FOR_nothing);
+      gcc_assert (lshr_icode != CODE_FOR_nothing);
+
+      from_addr = adjust_address (from, from_mode, 0);
+      to_addr = adjust_address (to, to_mode, 0);
+
+      while (len >= from_size)
+	{
+	  rtx tmp = gen_reg_rtx (from_mode);
+
+	  emit_insn (GEN_FCN (from_icode) (tmp, from_addr));
+
+	  from_addr = adjust_address (from_addr, from_mode, from_size);
+
+	  for (i = 0; i < stores_per_load; i++)
+	    {
+	      rtx tmp2 = gen_reg_rtx (lshr_mode);
+
+	      if (i != 0)
+		{
+		  emit_insn (GEN_FCN (lshr_icode) (tmp2,
+						   convert_to_mode (lshr_mode,
+								    tmp, 0),
+						   GEN_INT (to_size *
+							    BITS_PER_UNIT)));
+		  tmp = tmp2;
+		}
+
+	      emit_insn (GEN_FCN (to_icode) (to_addr,
+					     convert_to_mode (to_mode, tmp, 0)));
+
+	      to_addr = adjust_address (to_addr, to_mode, to_size);
+	    }
+
+	  len -= from_size;
+	}
+    }
+
+  /* Assert that we've made progress.  */
+  gcc_assert (len < orig_len);
+
+  if (len != 0)
+    move_by_pieces (to_addr, from_addr, len,
+		    MIN (MEM_ALIGN (to_addr), MEM_ALIGN (from_addr)), 0);
+  return to;
+}
+
+
+
+#undef TARGET_SCHED_INIT_GLOBAL
+#define TARGET_SCHED_INIT_GLOBAL tilegx_sched_init_global
+
+#undef TARGET_SCHED_FINISH_GLOBAL
+#define TARGET_SCHED_FINISH_GLOBAL tilegx_sched_finish_global
+
+#undef TARGET_PRE_UNROLLING_AND_PEELING_HOOK
+#define TARGET_PRE_UNROLLING_AND_PEELING_HOOK \
+  tilegx_pre_unrolling_and_peeling_hook
+
+#undef TARGET_POST_EXPAND_TO_RTL_HOOK
+#define TARGET_POST_EXPAND_TO_RTL_HOOK tilegx_post_expand_to_rtl_hook
+
+#undef TARGET_GATE_HANDLE_TARGET_PEEPHOLE
+#define TARGET_GATE_HANDLE_TARGET_PEEPHOLE \
+  tilegx_gate_handle_target_peephole
+
+#undef TARGET_REST_OF_HANDLE_TARGET_PEEPHOLE
+#define TARGET_REST_OF_HANDLE_TARGET_PEEPHOLE \
+  tilegx_rest_of_handle_target_peephole
+
+#undef TARGET_GATE_HANDLE_EXTEND_PROPAGATION
+#define TARGET_GATE_HANDLE_EXTEND_PROPAGATION \
+  tilegx_gate_handle_extend_propagation
+
+#undef TARGET_REST_OF_HANDLE_EXTEND_PROPAGATION
+#define TARGET_REST_OF_HANDLE_EXTEND_PROPAGATION \
+  tilegx_rest_of_handle_extension_propagation
+
+#undef TARGET_MOVE_BY_PIECES
+#define TARGET_MOVE_BY_PIECES tilegx_move_by_pieces
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/constraints.md ./gcc/config/tilepro/constraints.md
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/constraints.md	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/constraints.md	2015-10-26 22:26:56.915184000 -0400
@@ -0,0 +1,100 @@
+;; Constraint definitions for Tilera TILE.
+;; Copyright (C) 2009 Free Software Foundation, Inc.
+;;
+;; This file is part of GCC.
+;;
+;; GCC is free software; you can redistribute it and/or modify
+;; it under the terms of the GNU General Public License as published by
+;; the Free Software Foundation; either version 3, or (at your option)
+;; any later version.
+;;
+;; GCC is distributed in the hope that it will be useful,
+;; but WITHOUT ANY WARRANTY; without even the implied warranty of
+;; MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+;; GNU General Public License for more details.
+;;
+;; You should have received a copy of the GNU General Public License
+;; along with GCC; see the file COPYING3.  If not see
+;; <http://www.gnu.org/licenses/>.
+
+(define_register_constraint "R00" "R0_REGS"  "r0")
+(define_register_constraint "R01" "R1_REGS"  "r1")
+(define_register_constraint "R02" "R2_REGS"  "r2")
+(define_register_constraint "R03" "R3_REGS"  "r3")
+(define_register_constraint "R04" "R4_REGS"  "r4")
+(define_register_constraint "R05" "R5_REGS"  "r5")
+(define_register_constraint "R06" "R6_REGS"  "r6")
+(define_register_constraint "R07" "R7_REGS"  "r7")
+(define_register_constraint "R08" "R8_REGS"  "r8")
+(define_register_constraint "R09" "R9_REGS"  "r9")
+(define_register_constraint "R10" "R10_REGS" "r10")
+
+(define_constraint "I"
+  "A signed 8 bit constant"
+  (and (match_code "const_int")
+       (match_test "ival >= -128 && ival <= 127")))
+
+(define_constraint "J"
+  "Signed 16-bit integer constant"
+  (and (match_code "const_int")
+       (match_test "ival >= -32768 && ival <= 32767")))
+
+(define_constraint "K"
+  "Nonzero integer constant with low 16 bits zero"
+  (and (match_code "const_int")
+       (match_test "ival && (ival & 0xFFFF) == 0")))
+
+(define_constraint "L"
+  "Integer constant that fits in one signed byte when incremented"
+  (and (match_code "const_int")
+       (match_test "ival >= -129 && ival <= 126")))
+
+(define_constraint "M"
+  "A bit mask suitable for 'mm'"
+  (and (match_code "const_int")
+       (match_test "tile_bitfield_operand_p (ival, NULL, NULL)")))
+
+(define_constraint "N"
+  "Integer constant that is a byte tiled out four times"
+  (and (match_code "const_int")
+       (match_test "(ival & 0xFFFFFFFF) == (ival & 0xFF) * 0x01010101")))
+
+(define_constraint "O"
+ "The integer zero constant"
+ (and (match_code "const_int")
+      (match_test "ival == 0")))
+
+(define_constraint "P"
+  "Integer constant that is a sign-extended byte tiled out as two shorts"
+  (and (match_code "const_int")
+       (match_test "((ival & 0xFFFFFFFF)
+                     == ((trunc_int_for_mode (ival, QImode) & 0xFFFF)
+                         * 0x00010001))")))
+
+(define_constraint "Q"
+  "Integer constant that fits in one signed byte when incremented, but not -1"
+  (and (match_code "const_int")
+       (match_test "ival >= -129 && ival <= 126 && ival != -1")))
+
+(define_constraint "T"
+  "A const symbolc operand"
+  (match_operand 0 "const_symbolic_operand"))
+
+(define_memory_constraint "U"
+  "Non-auto-incrementing memory"
+  (and (match_code "mem")
+       (match_test "GET_RTX_CLASS (GET_CODE (XEXP (op, 0))) != RTX_AUTOINC")))
+
+(define_constraint "W"
+  "A 4-element vector constant with identical elements"
+  (and (match_code "const_vector")
+       (match_test "CONST_VECTOR_NUNITS (op) == 4")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 1)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 2)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 3)")))
+
+(define_constraint "Y"
+  "A 2-element vector constant with identical elements"
+  (and (match_code "const_vector")
+       (match_test "CONST_VECTOR_NUNITS (op) == 2")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 1)")))
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/feedback-flags.h ./gcc/config/tilepro/feedback-flags.h
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/feedback-flags.h	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/feedback-flags.h	2015-10-26 22:26:57.006180000 -0400
@@ -0,0 +1,47 @@
+#ifndef _FEEDBACK_H
+#define _FEEDBACK_H
+
+extern int tile_feedback_generate;
+
+extern int tile_feedback_generate_compiler;
+
+extern int tile_feedback_generate_linker;
+
+extern const char* tile_feedback_use_compiler_file;
+extern const char* tile_feedback_use_linker_file;
+extern const char* tile_feedback_use_file;
+
+extern const char* tile_feedback_emit_dir;
+extern const char* tile_strip_file_prefix;
+
+static inline bool
+enable_feedback_generate (void)
+{
+  return tile_feedback_generate_compiler || tile_feedback_generate_linker;
+}
+
+static inline bool
+enable_feedback_generate_compiler (void)
+{
+  return tile_feedback_generate_compiler;
+}
+
+static inline bool
+enable_feedback_generate_linker (void)
+{
+  return tile_feedback_generate_linker;
+}
+
+static inline bool
+enable_feedback_emit (void)
+{
+  return tile_feedback_emit_dir != NULL;
+}
+
+static inline bool
+enable_feedback_use_linker (void)
+{
+  return tile_feedback_use_linker_file != NULL;
+}
+
+#endif
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/feedback.c ./gcc/config/tilepro/feedback.c
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/feedback.c	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/feedback.c	2015-10-26 22:26:56.949170000 -0400
@@ -0,0 +1,859 @@
+#include "config.h"
+#include "system.h"
+#include "coretypes.h"
+#include "tm.h"
+#include "machmode.h"
+#include "output.h"
+#include "expr.h"
+#include "langhooks.h"
+#include "tree-flow.h"
+#include "value-prof.h" /* for is_tree_profile_call () */
+#include "coverage.h"
+#include "toplev.h"
+#include "tilepro-feedback.h"
+#include "feedback-flags.h"
+
+/* Whether to generate some data structures shared by both linker and compiler
+   optimization.  */
+int tile_feedback_generate = 0;
+
+/* Whether the compiler should generate profiling code for compiler
+   optimizations.  */
+int tile_feedback_generate_compiler = 0;
+
+/* Whether the compiler should generate profiling code for linker
+   optimizations.  */
+int tile_feedback_generate_linker = 0;
+
+/* Input file containing profile data.  */
+const char* tile_feedback_use_compiler_file = 0;
+const char* tile_feedback_use_linker_file = 0;
+const char* tile_feedback_use_file = 0;
+
+/* Output directory where profiling information will be stored.  Only used by
+   the linker, and unused by the compiler proper.  */
+const char* tile_feedback_emit_dir = 0;
+
+/* Prefix to strip off of file names for feedback use.  */
+const char* tile_strip_file_prefix = 0;
+
+/* The following is the pass to instrument for tile's linker feedback
+   optimization.  */
+
+static GTY(()) tree tree_tile_feedback_function_entered_fn;
+static GTY(()) tree tree_tile_feedback_function_resumed_fn;
+
+static GTY(()) tree feedback_function_type;
+
+/* Create a string object.  */
+
+static tree
+create_string_object (const char *name, const char *value, tree section)
+{
+  int value_len;
+  char *value_buf;
+  tree string_type;
+  tree string_val;
+  tree string_var;
+
+  /* compute the length of the string contents  */
+  value_len = strlen (value);
+
+  /* copy value to a perminent buffer  */
+  value_buf = XNEWVEC (char, value_len + 1);
+  strcpy (value_buf, value);
+
+  /* create the string type unsigned char [value_len + 1]  */
+  string_type =
+    build_array_type (unsigned_char_type_node,
+		      build_index_type (size_int (value_len + 1)));
+
+  /* create the string value, and make its type string_type  */
+  string_val = build_string (value_len + 1, value_buf);
+  TREE_TYPE (string_val) = string_type;
+
+  /* create the string variable */
+  string_var = build_decl (VAR_DECL, get_identifier (name),
+			   string_type);
+  TREE_STATIC (string_var) = 1;
+  DECL_INITIAL (string_var) = string_val;
+  DECL_SECTION_NAME (string_var) = section;
+
+  assemble_variable (string_var, 0, 0, 0);
+  return string_var;
+}
+
+
+/* Do not instrument any calls that are inserted by the compiler.  FIXME:
+   tile-gcc: this list may not be complete (coverage analysis functions?).  */
+
+static bool
+exclude_feedback_instrument (tree call)
+{
+  return is_tree_profile_call (call)
+    || call == tree_tile_feedback_function_entered_fn
+    || call == tree_tile_feedback_function_resumed_fn;
+}
+
+
+/* Add a field to RECORD_TYPE.  */
+static tree
+declare_field (tree record_type, tree field_type, const char *field_name,
+               tree* fields)
+{
+  tree field = build_decl (FIELD_DECL, get_identifier (field_name),
+                           field_type);
+  DECL_FIELD_CONTEXT (field) = record_type;
+  TREE_CHAIN (field) = *fields;
+  *fields = field;
+  return field;
+}
+
+
+typedef struct tile_field_desc GTY(())
+{
+  const char* name;
+  tree* type_p;
+  unsigned array_size;
+  unsigned size;
+} tile_field_desc;
+
+
+/* A description of the Feedback_Function type.  This must be consistent with
+   files.h in the cache packer.  All the fields are integers or array of
+   integers.  We initialize the integer types statically, but we need to use
+   pointers to types because the types themselves are not yet initialized.
+   The size field is the size of a non-array type, or the element size of the
+   array type.  */
+tile_field_desc tile_feedback_function_desc[] =
+{
+  { "id", &unsigned_type_node, 1, 0 },
+  { "num_bytes", &unsigned_type_node, 1, 0 },
+  { "relative_function_name", &integer_type_node, 1, 0 },
+  { "relative_section_name", &integer_type_node, 1, 0 },
+  { "relative_source_file_name", &integer_type_node, 1, 0 },
+  { "checksum", &unsigned_type_node, 1, 0 },
+  { "gcc_id", &unsigned_type_node, 1, 0 },
+  { "num_counters", &unsigned_type_node, GCOV_COUNTERS, 0 },
+  { "relative_counters", &integer_type_node, GCOV_COUNTERS, 0 },
+  { NULL, NULL, 0, 0 }
+};
+
+
+/* Initialize the globals used by the profiler.  This includes global types as
+   well as profiler specific ELF sections.  */
+static void
+feedback_initialize_globals (void)
+{
+  static bool init = false;
+
+  if (init)
+    return;
+
+  init = true;
+
+  /* Initialize the feedback function type */
+  {
+    int i;
+    tree fftype = lang_hooks.types.make_type (RECORD_TYPE);
+    tree fields = NULL_TREE;
+
+    for (i = 0; tile_feedback_function_desc[i].name != NULL; i++)
+      {
+	const char* name = tile_feedback_function_desc[i].name;
+	tree type = *tile_feedback_function_desc[i].type_p;
+	unsigned array_size = tile_feedback_function_desc[i].array_size;
+
+	tile_feedback_function_desc[i].size =
+	  tree_low_cst (TYPE_SIZE_UNIT (type), 1);
+
+	if (array_size > 1)
+	  {
+	    tree index_type = build_index_type (build_int_cst (NULL_TREE,
+							       array_size));
+	    type = build_array_type (type, index_type);
+	  }
+
+	declare_field (fftype, type, name, &fields);
+      }
+
+    finish_builtin_struct (fftype, "__feedback_function_info_t", fields,
+			   NULL_TREE);
+
+    feedback_function_type = fftype;
+  }
+
+  /* Initialize function prototypes */
+  {
+    tree ff_ptr = build_pointer_type (feedback_function_type);
+
+    tree feedback_fn_type =
+      build_function_type_list (void_type_node, ff_ptr, NULL_TREE);
+
+    tree_tile_feedback_function_entered_fn
+      = build_fn_decl ("__feedback_function_entered", feedback_fn_type);
+
+    tree_tile_feedback_function_resumed_fn
+      = build_fn_decl ("__feedback_function_resumed", feedback_fn_type);
+  }
+
+  /* Initialize the feedback sections */
+  {
+    tree sec_name;
+
+    sec_name = build_string (strlen (".feedback.strings"),
+			     ".feedback.strings");
+
+    get_section (TREE_STRING_POINTER (sec_name),
+		 SECTION_STRINGS | SECTION_OVERRIDE | SECTION_MERGE | 1,
+		 NULL);
+
+    sec_name = build_string (strlen (".feedback.functions"),
+			     ".feedback.functions");
+
+    get_section (TREE_STRING_POINTER (sec_name),
+		 SECTION_WRITE | SECTION_NOTYPE | SECTION_OVERRIDE, NULL);
+  }
+}
+
+
+static void
+feedback_declare_function_variables (tile_feedback_info *info,
+				     const char *fn_name,
+				     const char* sec_name)
+{
+  static int ctr = 0;
+  static tree source_file_var = NULL;
+  tree ffv;
+  char *name;
+  tree strings_sec;
+
+  name = XNEWVEC (char, strlen (fn_name) + 32);
+
+  strings_sec = build_string (strlen (".feedback.strings"),
+			      ".feedback.strings");
+
+  /* initialize the function name */
+  sprintf (name, "%s.function_name.%d", fn_name, ctr++);
+  info->function_name_var =
+    create_string_object (name, fn_name, strings_sec);
+
+  /* initialize the source file name */
+  if (source_file_var == NULL)
+    {
+      sprintf (name, "%s.source_file_name.%d", fn_name, ctr++);
+      source_file_var =
+	create_string_object (name, get_strip_filename (main_input_filename),
+			      strings_sec);
+    }
+  info->source_file_var = source_file_var;
+
+  /* initialize the section name object if the name is known, otherwise just
+     create an unitialized object.  */
+  if (sec_name == NULL)
+    {
+      sprintf (name, "%s.section_name.%d", fn_name, ctr++);
+      info->section_name_var = 
+	build_decl (VAR_DECL, get_identifier (name),
+		    build_array_type (unsigned_char_type_node, NULL));
+      DECL_SECTION_NAME (info->section_name_var) = strings_sec;
+    }
+  else
+    {
+      sprintf (name, "%s.section_name.%d", fn_name, ctr++);
+      info->section_name_var =
+	create_string_object (name, sec_name, strings_sec);
+    }
+
+  /* create the feedback object. */
+  sprintf (name, "%s.feedback.%d", fn_name, ctr++);
+
+  ffv = build_decl (VAR_DECL, get_identifier (name), feedback_function_type);
+  info->feedback_function_var = ffv;
+
+  TREE_STATIC (ffv) = 1;
+  TREE_PUBLIC (ffv) = 0;
+  DECL_ARTIFICIAL (ffv) = 1;
+  DECL_INITIAL (ffv) = NULL;
+
+  DECL_SECTION_NAME (ffv) = 
+    build_string (strlen (".feedback.functions"), ".feedback.functions");
+}
+
+
+/* New call was added, make goto call edges if neccesary.  copied from
+   tree-profile.c  */
+static void
+add_abnormal_goto_call_edges (gimple_stmt_iterator gsi)
+{
+  gimple stmt = gsi_stmt (gsi);
+
+  if (!stmt_can_make_abnormal_goto (stmt))
+    return;
+  if (!gsi_end_p (gsi))
+    split_block (gimple_bb (stmt), stmt);
+
+  make_abnormal_goto_edges (gimple_bb (stmt), true);
+}
+
+
+/* Insert feedback instrumentation for the current function.  */
+static void
+feedback_linker_instrument (tree ffv)
+{
+  gimple_stmt_iterator gsi;
+  edge e;
+  basic_block bb;
+  edge_iterator ei;
+  gimple stmt;
+
+  FOR_EACH_EDGE (e, ei, ENTRY_BLOCK_PTR->succs)
+    {
+      bb = split_edge (e);
+      gsi = gsi_start_bb (bb);
+
+      stmt = gimple_build_call (tree_tile_feedback_function_entered_fn, 1,
+				build_addr (ffv,
+					    current_function_decl));
+      gsi_insert_after (&gsi, stmt, GSI_NEW_STMT);
+      gcc_assert (EDGE_COUNT (bb->succs) == 1);
+      bb = split_edge (EDGE_I (bb->succs, 0));
+      add_abnormal_goto_call_edges (gsi);
+    }
+
+  FOR_EACH_BB (bb)
+    {
+      for (gsi = gsi_start_bb (bb); !gsi_end_p (gsi); gsi_next (&gsi))
+	{
+	  gimple curr = gsi_stmt (gsi);
+	  if (is_gimple_call (curr)
+	      && !exclude_feedback_instrument (gimple_call_fndecl (curr)))
+	    {
+	      gimple stmt = gimple_build_call (
+                tree_tile_feedback_function_resumed_fn, 1,
+		build_addr (ffv, current_function_decl));
+	      gsi_insert_after (&gsi, stmt, GSI_NEW_STMT);
+	    }
+	}
+    }
+}
+
+/* Perform all the work needed to insert profile instrumentation for the
+   current function  */
+static unsigned int
+tile_instrument_function (void)
+{
+  /* Don't profile functions produced at destruction time.  Don't profile if it
+     has been already instrumented either (when OpenMP expansion creates child
+     function from already instrumented body).  */
+  if (cgraph_state == CGRAPH_STATE_FINISHED
+      || cfun->machine->feedback_info.instrumented)
+    return 0;
+
+  feedback_initialize_globals ();
+
+  gcc_assert(cfun->machine);
+
+  feedback_declare_function_variables (&cfun->machine->feedback_info,
+				       current_function_assembler_name (),
+				       NULL);
+
+  if (enable_feedback_generate_linker ())
+    {
+      tree ffv = cfun->machine->feedback_info.feedback_function_var;
+      feedback_linker_instrument (ffv);
+    }
+
+  cfun->machine->feedback_info.instrumented = true;
+
+  return 0;
+}
+
+
+/* Returns whether instrumentation is needed.  */
+static bool
+tile_instrument_gate (void)
+{
+  return enable_feedback_generate ();
+}
+
+
+static void
+assemble_ptr_diff (rtx ptr, rtx base, unsigned int size,
+		   unsigned int align, int force)
+{
+  assemble_integer (gen_rtx_MINUS (Pmode, ptr, base),
+		    size, align, force);
+}
+
+
+static void
+assemble_ptr_diff_char (const char *ptr, const char *base, unsigned int size,
+			unsigned int align, int force)
+{
+  assemble_ptr_diff (gen_rtx_SYMBOL_REF (Pmode, ptr),
+		     gen_rtx_SYMBOL_REF (Pmode, base),
+		     size, align, force);
+}
+
+
+/* Emit the feedback function object to assembly.  */
+static void
+emit_feedback_function_object (const char* fn_name,
+			       tile_feedback_info *info,
+			       struct function_list *fn)
+{
+  int field;
+  unsigned rest_size;
+  tile_field_desc *desc;
+  const char *name;
+  const char *base_name;
+
+  tree ffv = info->feedback_function_var;
+
+  /* Emit the preamble only.  */
+  assemble_variable (ffv, 0, 0, 1);
+
+  field = 0;
+
+  /* id */
+  desc = &tile_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "id") == 0);
+  assemble_zeros (desc->size);
+
+  /* num_bytes */
+  desc = &tile_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "num_bytes") == 0);
+  if (info->end_label[0] != '\0')
+    {
+      assemble_ptr_diff_char (info->end_label, fn_name, desc->size, 1, 1);
+    }
+  else
+    {
+      assemble_zeros (desc->size);
+    }
+
+  /* relative_function_name */
+  desc = &tile_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "relative_function_name") == 0);
+  base_name = IDENTIFIER_POINTER (DECL_NAME (ffv));
+  name = IDENTIFIER_POINTER (DECL_NAME (info->function_name_var));
+  assemble_ptr_diff_char (name, base_name, desc->size, 1, 1);
+
+  /* relative_section_name */
+  desc = &tile_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "relative_section_name") == 0);
+  name = IDENTIFIER_POINTER (DECL_NAME (info->section_name_var));
+  assemble_ptr_diff_char (name, base_name, desc->size, 1, 1);
+
+  /* relative_source_file_name */
+  desc = &tile_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "relative_source_file_name") == 0);
+  name = IDENTIFIER_POINTER (DECL_NAME (info->source_file_var));
+  assemble_ptr_diff_char (name, base_name, desc->size, 1, 1);
+
+  if (enable_feedback_generate_compiler () && fn)
+    {
+      char buf[20];
+      unsigned ctr_base_offset;
+      unsigned i;
+
+      fn->emitted = true;
+
+      /* checksum */
+      desc = &tile_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "checksum") == 0);
+      assemble_integer (GEN_INT (fn->checksum), desc->size, 1, 1);
+
+      /* gcc_id */
+      desc = &tile_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "gcc_id") == 0);
+      assemble_integer (GEN_INT (fn->ident), desc->size, 1, 1);
+
+      desc = &tile_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "num_counters") == 0);
+      for (i = 0; i < desc->array_size; i++)
+	{
+	  /* num_counters */
+	  assemble_integer (GEN_INT (fn->n_ctrs[i]), desc->size, 1, 1);
+	}
+
+      /* relative_counters */
+      desc = &tile_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "relative_counters") == 0);
+      for (i = 0; i < desc->array_size; i++)
+	{
+	  if (fn->n_ctrs[i] > 0)
+	    {
+	      ASM_GENERATE_INTERNAL_LABEL (buf, "LPBX", i + 1);
+	      ctr_base_offset = fn->prg_n_ctrs[i] *
+		(GCOV_TYPE_SIZE / BITS_PER_UNIT);
+	      assemble_ptr_diff (gen_rtx_PLUS (Pmode,
+					       gen_rtx_SYMBOL_REF (Pmode, buf),
+					       GEN_INT (ctr_base_offset)),
+				 gen_rtx_SYMBOL_REF (Pmode, base_name),
+				 desc->size, 1, 1);
+	    }
+	  else
+	    assemble_zeros (desc->size);
+	}
+    }
+
+  /* rest of struct */
+  rest_size = 0;
+  while (tile_feedback_function_desc[field].name != NULL)
+    {
+      rest_size +=
+	tile_feedback_function_desc[field].array_size *
+	tile_feedback_function_desc[field].size;
+      field++;
+    }
+  assemble_zeros (rest_size);
+}
+
+
+/* Finalize and emit the section name object.  We need to do this late, after
+   the section name has been set.  */
+static void
+emit_section_name_object (void)
+{
+  const char *value;
+  int value_len;
+  char *value_buf;
+  tree string_type;
+  tree string_val;
+  tree section_name_var = cfun->machine->feedback_info.section_name_var;
+
+  if (section_name_var == NULL)
+    return;
+
+  value = TREE_STRING_POINTER (DECL_SECTION_NAME (current_function_decl));
+
+  /* compute the length of the string contents */
+  value_len = strlen (value);
+
+  /* copy value to a perminent buffer */
+  value_buf = XNEWVEC (char, value_len + 1);
+  strcpy (value_buf, value);
+
+  /* create the string type unsigned char [value_len + 1] */
+  string_type =
+    build_array_type (unsigned_char_type_node,
+		      build_index_type (size_int (value_len + 1)));
+
+  /* create the string value, and make its type string_type  */
+  string_val = build_string (value_len + 1, value_buf);
+  TREE_TYPE (string_val) = string_type;
+
+  /* update the type of section_name_var */
+  TREE_TYPE (section_name_var) = string_type;
+  layout_decl (section_name_var, 0);
+
+  /* set the initializer of section_name_var */
+  TREE_STATIC (section_name_var) = 1;
+  DECL_INITIAL (section_name_var) = string_val;
+
+  /* output the variable */
+  assemble_variable (section_name_var, 0, 0, 0);
+}
+
+
+static void
+tile_instrument_finish (void)
+{
+  tile_feedback_info *info = &cfun->machine->feedback_info;
+
+  if (info->feedback_function_var != NULL)
+    {
+      const char *fn_name = current_function_assembler_name ();
+
+      emit_feedback_function_object (fn_name, info,
+				     get_function_list (fn_name));
+    }
+
+  emit_section_name_object ();
+}
+
+
+static void
+tile_emit_coverage_data (void)
+{
+  struct function_list *fn;
+
+  if (!enable_feedback_generate_compiler ())
+    {
+      default_emit_coverage_data ();
+      return;
+    }
+
+  build_all_ctr_info_values ();
+
+  /* Emit feedback objects for functions that are not emitted.  */
+  feedback_initialize_globals ();
+
+  for (fn = get_function_list_head (); fn; fn = fn->next)
+    {
+      tile_feedback_info info;
+
+      if (fn->emitted) continue; fn->emitted = true;
+
+      info.end_label[0] = '\0';
+      feedback_declare_function_variables (&info, fn->name, "*none*");
+      emit_feedback_function_object (fn->name, &info, fn);
+    }
+}
+
+
+/* Support for compiler feedback with single-file format.  */
+
+#define FSEEK(_fd, _position, whence, _error_message, _error_arg) \
+     if (fseek(_fd, _position, whence) != 0) \
+           error(_error_message, _error_arg);
+
+#define FREAD(_buffer, _size, _nitems, _fp, _error_message, _error_arg) \
+        if (fread((void *)_buffer, _size, _nitems, _fp) != _nitems) \
+           error(_error_message, _error_arg);
+
+
+static char ERR_POS[] = "error in positioning within %s";
+static char ERR_READ[] = "error in reading from %s";
+
+
+/* Read the main header in the feedback file  */
+
+static void
+profile_get_file_header(FILE *fp, const char *fname, Fb_Hdr *fb_hdr)
+{
+  FSEEK (fp, 0, SEEK_SET, ERR_POS, fname);
+  FREAD (fb_hdr, sizeof(Fb_Hdr), 1, fp,
+	 "error while reading from: %s", fname);
+}
+
+
+/* Read the PU header table; It is assumed that the caller has 
+   allocated the necessary storage in pu_hdr_table.  */
+
+static void
+profile_get_pu_hdr_table(FILE *fp, const char *fname, const Fb_Hdr* fb_hdr,
+			 Pu_Hdr *pu_hdr_table)
+{
+  FSEEK(fp, fb_hdr->fb_pu_hdr_offset, SEEK_SET, ERR_POS, fname);
+  FREAD(pu_hdr_table, sizeof(Pu_Hdr), fb_hdr->fb_pu_hdr_num,
+	fp, ERR_READ, fname);
+}
+
+
+/* Read the string table that holds the names of PU's; It is assumed that the
+   caller has allocated the necessary storage in str_table.  */
+
+static void
+profile_get_str_table(FILE *fp, const char *fname, const Fb_Hdr* fb_hdr,
+		      char *str_table)
+{
+  FSEEK(fp, fb_hdr->fb_str_table_offset, SEEK_SET, ERR_POS, fname);
+  FREAD(str_table, sizeof(char), fb_hdr->fb_str_table_size,
+	fp, ERR_READ, fname);
+}
+
+
+/* Given a PU handle, allocate storage for the profile counters in 
+   PU handle and update it with data from feedback file.  */
+
+static void
+profile_read_counters(gcov_type *counts, size_t num_counters,
+		     long file_offset, FILE *fp, const char *fname)
+{
+  FSEEK(fp, file_offset, SEEK_SET, ERR_POS, fname);
+ 
+  FREAD (counts, sizeof(gcov_type), num_counters, fp,
+	 ERR_READ, fname);
+}
+
+
+/* Read profile counters from a tile feedback file.  */
+
+static void
+tile_initialize_profile_counters (void)
+{
+  const char *fb_name = tile_feedback_use_compiler_file;
+  FILE *fp;
+  Fb_Hdr fb_hdr;
+  Pu_Hdr *pu_hdr_table;
+  char *str_table;
+  htab_t counts_hash = NULL;
+  unsigned i, j;
+  counts_entry_t *all_summable = NULL;
+
+  if (fb_name == NULL)
+    {
+      default_initialize_profile_counters ();
+      return;
+    }
+
+  if ((fp = fopen (fb_name, "r")) == NULL) {
+    error ("unable to open file: %s", fb_name);
+  }
+
+  profile_get_file_header (fp, fb_name, &fb_hdr);
+
+  if (fb_hdr.fb_magic != FEEDBACK_COLLECT_HEADER_MAGIC)
+    {
+      if (fb_hdr.fb_magic == FEEDBACK_HEADER_MAGIC)
+	{
+	  error ("file '%s' is a raw feedback file which must be "
+		 "converted using tile-convert-feedback before it "
+		 "can be used", fb_name);
+	}
+      else
+	{
+	  error ("file '%s' is not a feedback file", fb_name);
+	}
+    }
+
+  if (fb_hdr.fb_version != FEEDBACK_COLLECT_HEADER_CURRENT)
+    {
+      error ("unable to open file with unsupported version number: %s",
+	     fb_name);
+    }
+
+  pu_hdr_table = XCNEWVEC (Pu_Hdr, fb_hdr.fb_pu_hdr_num);
+  profile_get_pu_hdr_table (fp, fb_name, &fb_hdr, pu_hdr_table);
+
+  str_table = XCNEWVEC (char, fb_hdr.fb_str_table_size);
+  profile_get_str_table (fp, fb_name, &fb_hdr, str_table);
+
+  /* Read in the feedback data corresponding to this file.  */
+  for (i = 0; i < fb_hdr.fb_pu_hdr_num; i++)
+    {
+      Pu_Hdr *pu_hdr;
+      const char *pu_name;
+      const char *pu_source_name;
+      long pu_counters_offset;
+      counts_entry_t **slot, *entry, elt;
+      gcov_unsigned_t count;
+
+      pu_hdr = &pu_hdr_table[i];
+      pu_name = str_table + pu_hdr->pu_name_index;
+      pu_source_name = str_table + pu_hdr->pu_source_name_index;
+
+      if (strcmp (pu_source_name, get_strip_filename (main_input_filename)))
+	continue;
+
+      if (counts_hash == NULL)
+	{
+	  counts_hash = create_counts_hash (10);
+	  set_counts_hash (counts_hash);
+	}
+
+      /* Skip over those without a valid gcc_id; those are not instrumented.  */
+      if (pu_hdr->pu_gcc_id == 0)
+	continue;
+
+      elt.name = pu_name;
+      elt.function_id = coverage_checksum_string (0, pu_name);
+
+      for (j = 0; j < GCOV_COUNTERS; j++)
+	{
+	  elt.ctr = j;
+	  count = pu_hdr->pu_num_counter_entries[j];
+
+	  if ((int)count < 0)
+	    error ("corrupted feedback file '%s'", fb_name);
+
+	  if (count > 0)
+	    {
+#ifdef DEBUG
+	      printf ("Name %s Source %s FunctionId %d "
+		      "Ident %d Ctr %d Checksum %d Ncount %d\n",
+		      pu_name, pu_source_name, elt.function_id,
+		      pu_hdr->pu_gcc_id, elt.ctr, pu_hdr->pu_checksum, count);
+#endif
+
+	      slot = (counts_entry_t **)
+		htab_find_slot (counts_hash, &elt, INSERT);
+	      if (*slot)
+		{
+		  if (!warn_coverage)
+		    continue;
+
+		  if (!flag_coverage_permissive)
+		    warning (0, "duplicate counters for function %qs",
+			     pu_name);
+		  else
+		    inform (0, "duplicate counters for function %qs",
+			    pu_name);
+
+		  continue;
+		}
+
+	      *slot = entry = XCNEW (counts_entry_t);
+	      entry->function_id = elt.function_id;
+	      entry->ctr = elt.ctr;
+	      entry->name = pu_name;
+	      entry->ident = pu_hdr->pu_gcc_id;
+	      entry->checksum = pu_hdr->pu_checksum;
+	      entry->summary.num = count;
+	      entry->counts = XCNEWVEC (gcov_type, count);
+
+	      pu_counters_offset = fb_hdr.fb_profile_offset +
+		pu_hdr->pu_file_offset[j];
+
+	      profile_read_counters(entry->counts, count, pu_counters_offset,
+				    fp, fb_name);
+
+#if DEBUG
+	      {
+		unsigned ix;
+		for (ix = 0; ix < count; ix++)
+		  {
+		    printf ("Read counter id %d i %d %lld\n", j, ix,
+			    entry->counts[ix]);
+		  }
+	      }
+#endif
+
+	      if (elt.ctr < GCOV_COUNTERS_SUMMABLE)
+		{
+		  entry->chain = all_summable;
+		  all_summable = entry;
+		}
+	    }
+	}
+    }
+
+  /* Read the summary, and write it to all the relevant entries.  */
+  {
+    counts_entry_t *entry;
+
+    for (entry = all_summable; entry; entry = entry->chain)
+      {
+	entry->summary.runs = fb_hdr.cs_runs;
+	entry->summary.sum_all = fb_hdr.cs_sum_all;
+	entry->summary.run_max = fb_hdr.cs_run_max;
+	entry->summary.sum_max = fb_hdr.cs_sum_max;
+      }
+  }
+
+  fclose (fp);
+  coverage_set_identify_function_by_id (false);
+}
+
+
+#undef TARGET_INITIALIZE_PROFILE_COUNTERS
+#define TARGET_INITIALIZE_PROFILE_COUNTERS tile_initialize_profile_counters
+
+#undef TARGET_EMIT_COVERAGE_DATA
+#define TARGET_EMIT_COVERAGE_DATA tile_emit_coverage_data
+
+#undef TARGET_INSTRUMENT_GATE
+#define TARGET_INSTRUMENT_GATE tile_instrument_gate
+
+#undef TARGET_INSTRUMENT_FUNCTION
+#define TARGET_INSTRUMENT_FUNCTION tile_instrument_function
+
+#undef TARGET_INSTRUMENT_FINISH
+#define TARGET_INSTRUMENT_FINISH tile_instrument_finish
+
+#undef TARGET_HANDLE_OPTION
+#define TARGET_HANDLE_OPTION tile_handle_option
+
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/feedback.h ./gcc/config/tilepro/feedback.h
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/feedback.h	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/feedback.h	2015-10-26 22:26:58.288198000 -0400
@@ -0,0 +1,154 @@
+/*
+ * Copyright 2014 Tilera Corporation. All Rights Reserved.
+ *
+ *   This program is free software; you can redistribute it and/or
+ *   modify it under the terms of the GNU General Public License
+ *   as published by the Free Software Foundation, version 2.
+ *
+ *   This program is distributed in the hope that it will be useful, but
+ *   WITHOUT ANY WARRANTY; without even the implied warranty of
+ *   MERCHANTABILITY OR FITNESS FOR A PARTICULAR PURPOSE, GOOD TITLE or
+ *   NON INFRINGEMENT.  See the GNU General Public License for
+ *   more details.
+ *
+ * Runtime support for the compiler's feedback-based optimization.
+ */
+
+#ifndef __FEEDBACK_H__
+#define __FEEDBACK_H__
+
+#ifdef __ASSEMBLER__
+
+/* FEEDBACK_ENTER is a macro to be called at the very start of any
+ * hand-written assembly function that wants to be instrumented for
+ * cache packing purposes.
+ *
+ * It clobbers r10-r29, as any subroutine call would. This should be OK
+ * since it is being called on entry to an asm procedure, so presumably
+ * those registers are not in use anyway (they are not part of the standard
+ * calling convention).
+ *
+ * A sample call would look like this, and assumes that function
+ * "myfunc" is in section ".text.myfunc", and has a label at the end
+ * of the function called ".Lend_myfunc":
+ *
+ * FEEDBACK_ENTER(myfunc)
+ *
+ * If your function does not have a standard section or end-label
+ * naming, you can use
+ *
+ * FEEDBACK_ENTER_EXPLICIT(myfunc, mysection, mysize)
+ *
+ * If your function calls another function internally, you should place
+ * a macro immediately after return, as follows:
+ *
+ * FEEDBACK_REENTER(myfunc)
+ *
+ * Note that this also clobbers r10-r29, but they should be dead at
+ * this point anyway due to the function call.
+ *
+ * If your function has multiple entry points, you should make one of
+ * them be FEEDBACK_ENTER, and the remainder use FEEDBACK_REENTER.
+ * The distinction is that FEEDBACK_ENTER defines the static data
+ * structures used by both macros.
+ *
+ */
+#ifdef __COLLECT_LINKER_FEEDBACK__
+
+#ifndef __tilegx__
+#define __FEEDBACK_CODE(feedbackfunc)                           \
+        {                                                       \
+        move r10, lr;                                           \
+        moveli r11, lo16(feedbackfunc - 3f);                    \
+        };                                                      \
+        {                                                       \
+        auli r11, r11, ha16(feedbackfunc - 3f);                 \
+        jal plt(__feedback_asm_function_entered);               \
+        };                                                      \
+3:
+#define __FEEDBACK_CODE_SIZE 16
+#else
+#define __FEEDBACK_CODE(feedbackfunc)                           \
+        {                                                       \
+        move r10, lr;                                           \
+        moveli r11, hw2_last(feedbackfunc - 3f);                \
+        };                                                      \
+        shl16insli r11, r11, hw1(feedbackfunc - 3f);            \
+        {                                                       \
+        shl16insli r11, r11, hw0(feedbackfunc - 3f);            \
+        jal plt(__feedback_asm_function_entered);               \
+        };                                                      \
+3:
+#define __FEEDBACK_CODE_SIZE 24
+#endif
+
+#define FEEDBACK_ENTER_EXPLICIT(FUNCNAME, SECNAME, SIZE)        \
+        .pushsection .feedback.strings, "aMS",@progbits,1;      \
+0:      .asciz #FUNCNAME;                                       \
+1:      .asciz #SECNAME;                                        \
+2:      .asciz __FILE__;                                        \
+        .popsection;                                            \
+                                                                \
+        .pushsection .feedback.functions, "aw";                 \
+        .align 4;                                               \
+        /* Define a FeedbackFunction struct. */                 \
+.Lfeedback_function_##FUNCNAME:;                                \
+        .word 0;                                                \
+        .word (SIZE) - 16; /* Subtract code overhead below. */  \
+        .word 0b - .Lfeedback_function_##FUNCNAME;              \
+        .word 1b - .Lfeedback_function_##FUNCNAME;              \
+        .word 2b - .Lfeedback_function_##FUNCNAME;              \
+        .word 0;                                                \
+        .word 0;                                                \
+        .zero 32;                                               \
+        .zero 32;                                               \
+        .popsection;                                            \
+        __FEEDBACK_CODE(.Lfeedback_function_##FUNCNAME)
+
+#define FEEDBACK_ENTER(FUNCNAME) \
+  FEEDBACK_ENTER_EXPLICIT(FUNCNAME, .text.##FUNCNAME, \
+    .Lend_##FUNCNAME - FUNCNAME)
+
+#define FEEDBACK_REENTER(FUNCNAME) \
+  __FEEDBACK_CODE(.Lfeedback_function_##FUNCNAME)
+
+/*
+ * DEPRECATED: Backwards compatible for code from 2.0 and earlier.
+ * Note that you can't use FEEDBACK_REENTER with FEEDBACK_ENTRY.
+ */
+#define FEEDBACK_ENTRY(FUNCNAME, SECNAME, SIZE)                 \
+        .pushsection .feedback.strings, "aMS",@progbits,1;      \
+0:      .asciz FUNCNAME;                                        \
+1:      .asciz SECNAME;                                         \
+2:      .asciz __FILE__;                                        \
+        .popsection;                                            \
+                                                                \
+        .pushsection .feedback.functions, "aw";                 \
+        .align 4;                                               \
+        /* Define a FeedbackFunction struct. */                 \
+99:     .word 0;                                                \
+        .word (SIZE) - 16; /* Subtract code overhead below. */  \
+        .word 0b - 99b;                                         \
+        .word 1b - 99b;                                         \
+        .word 2b - 99b;                                         \
+        .word 0;                                                \
+        .word 0;                                                \
+        .zero 32;                                               \
+        .zero 32;                                               \
+        .popsection;                                            \
+        __FEEDBACK_CODE(99b)
+
+#else  /* !__COLLECT_LINKER_FEEDBACK__ */
+
+/* Not collecting linker feedback, so these are no-ops. */
+#define FEEDBACK_ENTER_EXPLICIT(FUNCNAME, SECNAME, SIZE)
+#define FEEDBACK_ENTER(FUNCNAME)
+#define FEEDBACK_REENTER(FUNCNAME)
+#define FEEDBACK_ENTRY(FUNCNAME, SECNAME, SIZE)
+
+#endif  /* !__COLLECT_LINKER_FEEDBACK__ */
+
+#endif  /* __ASSEMBLER__ */
+
+
+#endif  /* !__FEEDBACK_H__ */
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/atomic.c ./gcc/config/tilepro/libgcc/atomic.c
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/atomic.c	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/libgcc/atomic.c	2015-10-26 22:26:57.453188000 -0400
@@ -0,0 +1,193 @@
+#include "system.h"
+#include "atomic.h"
+
+/* This code should be inlined by the compiler, but for now support
+   it as out-of-line methods in libgcc.  */
+
+#define __sync_fetch_and_do(type, size, opname)          \
+type                                                     \
+__sync_fetch_and_##opname##_##size(type* p, type i)      \
+{                                                        \
+  arch_atomic_write_barrier();				 \
+  type rv = arch_atomic_##opname(p, i);			 \
+  arch_atomic_read_barrier();				 \
+  return rv;						 \
+}
+
+__sync_fetch_and_do (int, 4, add)
+__sync_fetch_and_do (int, 4, sub)
+__sync_fetch_and_do (int, 4, or)
+__sync_fetch_and_do (int, 4, and)
+__sync_fetch_and_do (int, 4, xor)
+__sync_fetch_and_do (int, 4, nand)
+__sync_fetch_and_do (long long, 8, add)
+__sync_fetch_and_do (long long, 8, sub)
+__sync_fetch_and_do (long long, 8, or)
+__sync_fetch_and_do (long long, 8, and)
+__sync_fetch_and_do (long long, 8, xor)
+__sync_fetch_and_do (long long, 8, nand)
+
+#define __sync_do_and_fetch(type, size, opname, op, op2) \
+type                                                     \
+__sync_##opname##_and_fetch_##size(type* p, type i)      \
+{                                                        \
+  arch_atomic_write_barrier();				 \
+  type rv = op2 (arch_atomic_##opname(p, i) op i);	 \
+  arch_atomic_read_barrier();				 \
+  return rv;						 \
+}
+
+__sync_do_and_fetch (int, 4, add, +, )
+__sync_do_and_fetch (int, 4, sub, -, )
+__sync_do_and_fetch (int, 4, or, |, )
+__sync_do_and_fetch (int, 4, and, &, )
+__sync_do_and_fetch (int, 4, xor, |, )
+__sync_do_and_fetch (int, 4, nand, &, ~)
+__sync_do_and_fetch (long long, 8, add, +, )
+__sync_do_and_fetch (long long, 8, sub, -, )
+__sync_do_and_fetch (long long, 8, or, |, )
+__sync_do_and_fetch (long long, 8, and, &, )
+__sync_do_and_fetch (long long, 8, xor, |, )
+__sync_do_and_fetch (long long, 8, nand, &, ~)
+
+#define __sync_exchange_methods(type, size)				\
+type									\
+__sync_val_compare_and_swap_##size(type* ptr, type oldval, type newval)	\
+{									\
+  arch_atomic_write_barrier();						\
+  type retval = arch_atomic_val_compare_and_exchange(ptr, oldval, newval); \
+  arch_atomic_read_barrier();						\
+  return retval;							\
+}									\
+									\
+bool									\
+__sync_bool_compare_and_swap_##size(type* ptr, type oldval, type newval) \
+{									\
+  arch_atomic_write_barrier();						\
+  bool retval = arch_atomic_bool_compare_and_exchange(ptr, oldval, newval); \
+  arch_atomic_read_barrier();						\
+  return retval;							\
+}									\
+									\
+type									\
+__sync_lock_test_and_set_##size(type* ptr, type val)			\
+{									\
+  type retval = arch_atomic_exchange(ptr, val);				\
+  arch_atomic_acquire_barrier_value(retval);				\
+  return retval;							\
+}
+
+__sync_exchange_methods (int, 4)
+__sync_exchange_methods (long long, 8)
+
+#ifdef __LITTLE_ENDIAN__
+#define BIT_OFFSET(n, type) ((n) * 8)
+#else
+#define BIT_OFFSET(n, type) ((4 - sizeof(type) - (n)) * 8)
+#endif
+
+/* Subword methods require the same approach for both TILEPro and
+   TILE-Gx.  We load the background data for the word, insert the
+   desired subword piece, then compare-and-exchange it into place.  */
+#define u8 unsigned char
+#define u16 unsigned short
+
+#define __sync_subword_cmpxchg(type, size)				\
+  									\
+type									\
+__sync_val_compare_and_swap_##size(type* ptr, type guess, type val)	\
+{									\
+  arch_atomic_write_barrier();						\
+  unsigned int *p = (unsigned int *)((unsigned long)ptr & ~3UL);	\
+  const int shift = BIT_OFFSET((unsigned long)ptr & 3UL, type);		\
+  const unsigned int valmask = (1 << (sizeof(type) * 8)) - 1;		\
+  const unsigned int bgmask = ~(valmask << shift);			\
+  unsigned int oldword = *p;						\
+  type oldval = (oldword >> shift) & valmask;				\
+  if (__builtin_expect((oldval == guess), 1)) {				\
+    unsigned int word = (oldword & bgmask) | ((val & valmask) << shift); \
+    oldword = arch_atomic_val_compare_and_exchange(p, oldword, word);	\
+    oldval = (oldword >> shift) & valmask;				\
+  }									\
+  arch_atomic_read_barrier();						\
+  return oldval;							\
+}									\
+									\
+bool									\
+__sync_bool_compare_and_swap_##size(type* ptr, type guess, type val)	\
+{									\
+  type oldval = __sync_val_compare_and_swap_##size(ptr, guess, val);	\
+  return oldval == guess;						\
+}
+
+__sync_subword_cmpxchg (u8, 1)
+__sync_subword_cmpxchg (u16, 2)
+
+/* For the atomic-update subword methods, we use the same approach as
+   above, but we retry until we succeed if the compare-and-exchange
+   fails.  */
+#define __sync_subword(type, proto, top, expr, bottom)			\
+proto									\
+{									\
+  top									\
+  unsigned int *p = (unsigned int *)((unsigned long)ptr & ~3UL);	\
+  const int shift = BIT_OFFSET((unsigned long)ptr & 3UL, type);		\
+  const unsigned int valmask = (1 << (sizeof(type) * 8)) - 1;		\
+  const unsigned int bgmask = ~(valmask << shift);			\
+  unsigned int oldword, xword = *p;					\
+  type val, oldval;							\
+  do {									\
+    oldword = xword;							\
+    oldval = (oldword >> shift) & valmask;				\
+    val = expr;								\
+    unsigned int word = (oldword & bgmask) | ((val & valmask) << shift); \
+    xword = arch_atomic_val_compare_and_exchange(p, oldword, word);	\
+  } while (__builtin_expect(xword != oldword, 0));			\
+  bottom								\
+}
+
+#define __sync_subword_fetch(type, funcname, expr, retval)		\
+  __sync_subword(type,							\
+		 type __sync_ ## funcname(type *ptr, type i),		\
+		 arch_atomic_read_barrier();,				\
+		 expr,							\
+		 arch_atomic_write_barrier(); return retval;)
+
+__sync_subword_fetch (u8, fetch_and_add_1, oldval + i, oldval)
+__sync_subword_fetch (u8, fetch_and_sub_1, oldval - i, oldval)
+__sync_subword_fetch (u8, fetch_and_or_1, oldval | i, oldval)
+__sync_subword_fetch (u8, fetch_and_and_1, oldval & i, oldval)
+__sync_subword_fetch (u8, fetch_and_xor_1, oldval ^ i, oldval)
+__sync_subword_fetch (u8, fetch_and_nand_1, ~(oldval & i), oldval)
+
+__sync_subword_fetch (u16, fetch_and_add_2, oldval + i, oldval)
+__sync_subword_fetch (u16, fetch_and_sub_2, oldval - i, oldval)
+__sync_subword_fetch (u16, fetch_and_or_2, oldval | i, oldval)
+__sync_subword_fetch (u16, fetch_and_and_2, oldval & i, oldval)
+__sync_subword_fetch (u16, fetch_and_xor_2, oldval ^ i, oldval)
+__sync_subword_fetch (u16, fetch_and_nand_2, ~(oldval & i), oldval)
+
+__sync_subword_fetch (u8, add_and_fetch_1, oldval + i, val)
+__sync_subword_fetch (u8, sub_and_fetch_1, oldval - i, val)
+__sync_subword_fetch (u8, or_and_fetch_1, oldval | i, val)
+__sync_subword_fetch (u8, and_and_fetch_1, oldval & i, val)
+__sync_subword_fetch (u8, xor_and_fetch_1, oldval ^ i, val)
+__sync_subword_fetch (u8, nand_and_fetch_1, ~(oldval & i), val)
+
+__sync_subword_fetch (u16, add_and_fetch_2, oldval + i, val)
+__sync_subword_fetch (u16, sub_and_fetch_2, oldval - i, val)
+__sync_subword_fetch (u16, or_and_fetch_2, oldval | i, val)
+__sync_subword_fetch (u16, and_and_fetch_2, oldval & i, val)
+__sync_subword_fetch (u16, xor_and_fetch_2, oldval ^ i, val)
+__sync_subword_fetch (u16, nand_and_fetch_2, ~(oldval & i), val)
+
+#define __sync_subword_lock(type, size)					\
+									\
+__sync_subword(type,							\
+	       type __sync_lock_test_and_set_##size(type* ptr, type nval), \
+	       ,							\
+	       nval,							\
+	       arch_atomic_acquire_barrier_value(oldval); return oldval;)
+
+__sync_subword_lock (u8, 1)
+__sync_subword_lock (u16, 2)
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/atomic.h ./gcc/config/tilepro/libgcc/atomic.h
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/atomic.h	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/libgcc/atomic.h	2015-10-26 22:26:58.193175000 -0400
@@ -0,0 +1,437 @@
+/* Macros for atomic functionality for tile.
+   Copyright (C) 2011-2013 Free Software Foundation, Inc.
+   Contributed by Walter Lee (walt@tilera.com)
+
+   This file is free software; you can redistribute it and/or modify it
+   under the terms of the GNU General Public License as published by the
+   Free Software Foundation; either version 3, or (at your option) any
+   later version.
+
+   This file is distributed in the hope that it will be useful, but
+   WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+   General Public License for more details.
+
+   Under Section 7 of GPL version 3, you are granted additional
+   permissions described in the GCC Runtime Library Exception, version
+   3.1, as published by the Free Software Foundation.
+
+   You should have received a copy of the GNU General Public License and
+   a copy of the GCC Runtime Library Exception along with this program;
+   see the files COPYING3 and COPYING.RUNTIME respectively.  If not, see
+   <http://www.gnu.org/licenses/>.  */
+
+
+/* Provides macros for common atomic functionality.  */
+
+#ifndef _ATOMIC_H_
+#define _ATOMIC_H_
+
+#ifdef __tilegx__
+/* Atomic instruction macros
+
+   The macros provided by atomic.h simplify access to the TILE-Gx
+   architecture's atomic instructions.  The architecture provides a
+   variety of atomic instructions, including "exchange", "compare and
+   exchange", "fetch and ADD", "fetch and AND", "fetch and OR", and
+   "fetch and ADD if greater than or equal to zero".
+
+   No barrier or fence semantics are implied by any of the atomic
+   instructions for manipulating memory; you must specify the barriers
+   that you wish explicitly, using the provided macros.
+
+   Any integral 32- or 64-bit value can be used as the argument
+   to these macros, such as "int", "long long", "unsigned long", etc.
+   The pointers must be aligned to 4 or 8 bytes for 32- or 64-bit data.
+   The "exchange" and "compare and exchange" macros may also take
+   pointer values.  We use the pseudo-type "VAL" in the documentation
+   to indicate the use of an appropriate type.  */
+#else
+/* Atomic instruction macros
+
+   The macros provided by atomic.h simplify access to the Tile
+   architecture's atomic instructions.  Since the architecture
+   supports test-and-set as its only in-silicon atomic operation, many
+   of the operations provided by this header are implemented as
+   fast-path calls to Linux emulation routines.
+
+   Using the kernel for atomic operations allows userspace to take
+   advantage of the kernel's existing atomic-integer support (managed
+   by a distributed array of locks).  The kernel provides proper
+   ordering among simultaneous atomic operations on different cores,
+   and guarantees a process can not be context-switched part way
+   through an atomic operation.  By virtue of sharing the kernel
+   atomic implementation, the userspace atomic operations
+   are compatible with the atomic methods provided by the kernel's
+   futex() syscall API.  Note that these operations never cause Linux
+   kernel scheduling, and are in fact invisible to the kernel; they
+   simply act as regular function calls but with an elevated privilege
+   level.  Note that the kernel's distributed lock array is hashed by
+   using only VA bits from the atomic value's address (to avoid the
+   performance hit of page table locking and multiple page-table
+   lookups to get the PA) and only the VA bits that are below page
+   granularity (to properly lock simultaneous accesses to the same
+   page mapped at different VAs).  As a result, simultaneous atomic
+   operations on values whose addresses are at the same offset on a
+   page will contend in the kernel for the same lock array element.
+
+   No barrier or fence semantics are implied by any of the atomic
+   instructions for manipulating memory; you must specify the barriers
+   that you wish explicitly, using the provided macros.
+
+   Any integral 32- or 64-bit value can be used as the argument
+   to these macros, such as "int", "long long", "unsigned long", etc.
+   The pointers must be aligned to 4 or 8 bytes for 32- or 64-bit data.
+   The "exchange" and "compare and exchange" macros may also take
+   pointer values.  We use the pseudo-type "VAL" in the documentation
+   to indicate the use of an appropriate type.
+
+   The 32-bit routines are implemented using a single kernel fast
+   syscall, as is the 64-bit compare-and-exchange.  The other 64-bit
+   routines are implemented by looping over the 64-bit
+   compare-and-exchange routine, so may be potentially less efficient.  */
+#endif
+
+#ifdef __tilegx__
+#include <arch/spr_def.h>
+#else
+#include <asm/unistd.h>
+#endif
+
+
+/* 32-bit integer compare-and-exchange.  */
+static __inline __attribute__ ((always_inline))
+     int arch_atomic_val_compare_and_exchange_4 (volatile int *mem,
+						 int oldval, int newval)
+{
+#ifdef __tilegx__
+  __insn_mtspr (SPR_CMPEXCH_VALUE, oldval);
+  return __insn_cmpexch4 (mem, newval);
+#else
+  int result;
+  __asm__ __volatile__ ("swint1":"=R00" (result),
+			"=m" (*mem):"R10" (__NR_FAST_cmpxchg), "R00" (mem),
+			"R01" (oldval), "R02" (newval), "m" (*mem):"r20",
+			"r21", "r22", "r23", "r24", "r25", "r26", "r27",
+			"r28", "r29", "memory");
+  return result;
+#endif
+}
+
+/* 64-bit integer compare-and-exchange.  */
+static __inline __attribute__ ((always_inline))
+     long long arch_atomic_val_compare_and_exchange_8 (volatile long long
+						       *mem, long long oldval,
+						       long long newval)
+{
+#ifdef __tilegx__
+  __insn_mtspr (SPR_CMPEXCH_VALUE, oldval);
+  return __insn_cmpexch (mem, newval);
+#else
+  unsigned int result_lo, result_hi;
+  unsigned int oldval_lo = oldval & 0xffffffffu, oldval_hi = oldval >> 32;
+  unsigned int newval_lo = newval & 0xffffffffu, newval_hi = newval >> 32;
+  __asm__ __volatile__ ("swint1":"=R00" (result_lo), "=R01" (result_hi),
+			"=m" (*mem):"R10" (__NR_FAST_cmpxchg64), "R00" (mem),
+			"R02" (oldval_lo), "R03" (oldval_hi),
+			"R04" (newval_lo), "R05" (newval_hi),
+			"m" (*mem):"r20", "r21", "r22", "r23", "r24", "r25",
+			"r26", "r27", "r28", "r29", "memory");
+  return ((long long) result_hi) << 32 | result_lo;
+#endif
+}
+
+/* This non-existent symbol is called for sizes other than "4" and "8",
+   indicating a bug in the caller.  */
+extern int __arch_atomic_error_bad_argument_size (void)
+  __attribute__ ((warning ("sizeof atomic argument not 4 or 8")));
+
+
+#define arch_atomic_val_compare_and_exchange(mem, o, n)                 \
+  __extension__ ({                                                      \
+    (__typeof(*(mem)))(__typeof(*(mem)-*(mem)))                         \
+      ((sizeof(*(mem)) == 8) ?                                          \
+       arch_atomic_val_compare_and_exchange_8(                          \
+         (volatile long long*)(mem), (__typeof((o)-(o)))(o),            \
+         (__typeof((n)-(n)))(n)) :                                      \
+       (sizeof(*(mem)) == 4) ?                                          \
+       arch_atomic_val_compare_and_exchange_4(                          \
+         (volatile int*)(mem), (__typeof((o)-(o)))(o),                  \
+         (__typeof((n)-(n)))(n)) :                                      \
+       __arch_atomic_error_bad_argument_size());                        \
+  })
+
+#define arch_atomic_bool_compare_and_exchange(mem, o, n)                \
+  __extension__ ({                                                      \
+    __typeof(o) __o = (o);                                              \
+    __builtin_expect(                                                   \
+      __o == arch_atomic_val_compare_and_exchange((mem), __o, (n)), 1); \
+  })
+
+
+/* Loop with compare_and_exchange until we guess the correct value.
+   Normally "expr" will be an expression using __old and __value.  */
+#define __arch_atomic_update_cmpxchg(mem, value, expr)                  \
+  __extension__ ({                                                      \
+    __typeof(value) __value = (value);                                  \
+    __typeof(*(mem)) *__mem = (mem), __old = *__mem, __guess;           \
+    do {                                                                \
+      __guess = __old;                                                  \
+      __old = arch_atomic_val_compare_and_exchange(__mem, __old, (expr));    \
+    } while (__builtin_expect(__old != __guess, 0));                    \
+    __old;                                                              \
+  })
+
+#ifdef __tilegx__
+
+/* Generic atomic op with 8- or 4-byte variant.
+   The _mask, _addend, and _expr arguments are ignored on tilegx.  */
+#define __arch_atomic_update(mem, value, op, _mask, _addend, _expr)     \
+  __extension__ ({                                                      \
+    ((__typeof(*(mem)))                                                 \
+     ((sizeof(*(mem)) == 8) ? (__typeof(*(mem)-*(mem)))__insn_##op(     \
+        (volatile void *)(mem),                                         \
+        (long long)(__typeof((value)-(value)))(value)) :                \
+      (sizeof(*(mem)) == 4) ? (int)__insn_##op##4(                      \
+        (volatile void *)(mem),                                         \
+        (int)(__typeof((value)-(value)))(value)) :                      \
+      __arch_atomic_error_bad_argument_size()));                        \
+  })
+
+#else
+
+/* This uses TILEPro's fast syscall support to atomically compute:
+
+   int old = *ptr;
+   *ptr = (old & mask) + addend;
+   return old;
+
+   This primitive can be used for atomic exchange, add, or, and.
+   Only 32-bit support is provided.  */
+static __inline __attribute__ ((always_inline))
+     int
+     __arch_atomic_update_4 (volatile int *mem, int mask, int addend)
+{
+  int result;
+  __asm__ __volatile__ ("swint1":"=R00" (result),
+			"=m" (*mem):"R10" (__NR_FAST_atomic_update),
+			"R00" (mem), "R01" (mask), "R02" (addend),
+			"m" (*mem):"r20", "r21", "r22", "r23", "r24", "r25",
+			"r26", "r27", "r28", "r29", "memory");
+  return result;
+}
+
+/* Generic atomic op with 8- or 4-byte variant.
+   The _op argument is ignored on tilepro.  */
+#define __arch_atomic_update(mem, value, _op, mask, addend, expr)       \
+  __extension__ ({                                                      \
+    (__typeof(*(mem)))(__typeof(*(mem)-*(mem)))                         \
+      ((sizeof(*(mem)) == 8) ?                                          \
+       __arch_atomic_update_cmpxchg((mem), (value), (expr)) :           \
+       (sizeof(*(mem)) == 4) ?                                          \
+       __arch_atomic_update_4((volatile int*)(mem),                     \
+                              (__typeof((mask)-(mask)))(mask),          \
+                              (__typeof((addend)-(addend)))(addend)) :  \
+       __arch_atomic_error_bad_argument_size());                        \
+  })
+
+#endif /* __tilegx__ */
+
+
+#define arch_atomic_exchange(mem, newvalue) \
+  __arch_atomic_update(mem, newvalue, exch, 0, newvalue, __value)
+
+#define arch_atomic_add(mem, value) \
+  __arch_atomic_update(mem, value, fetchadd, -1, value, __old + __value)
+
+#define arch_atomic_sub(mem, value) arch_atomic_add((mem), -(value))
+
+#define arch_atomic_increment(mem) arch_atomic_add((mem), 1)
+
+#define arch_atomic_decrement(mem) arch_atomic_add((mem), -1)
+
+#define arch_atomic_and(mem, mask) \
+  __arch_atomic_update(mem, mask, fetchand, mask, 0, __old & __value)
+
+#define arch_atomic_or(mem, mask) \
+  __arch_atomic_update(mem, mask, fetchor, ~mask, mask, __old | __value)
+
+#define arch_atomic_xor(mem, mask) \
+  __arch_atomic_update_cmpxchg(mem, mask, __old ^ __value)
+
+#define arch_atomic_nand(mem, mask) \
+  __arch_atomic_update_cmpxchg(mem, mask, ~(__old & __value))
+
+#define arch_atomic_bit_set(mem, bit)                                   \
+  __extension__ ({                                                      \
+    __typeof(*(mem)) __mask = (__typeof(*(mem)))1 << (bit);             \
+    __mask & arch_atomic_or((mem), __mask);                             \
+  })
+
+#define arch_atomic_bit_clear(mem, bit)                                 \
+  __extension__ ({                                                      \
+    __typeof(*(mem)) __mask = (__typeof(*(mem)))1 << (bit);             \
+    __mask & arch_atomic_and((mem), ~__mask);                           \
+  })
+
+#ifdef __tilegx__
+/* Atomically store a new value to memory.
+   Note that you can freely use types of any size here, unlike the
+   other atomic routines, which require 32- or 64-bit types.
+   This accessor is provided for compatibility with TILEPro, which
+   required an explicit atomic operation for stores that needed
+   to be atomic with respect to other atomic methods in this header.  */
+#define arch_atomic_write(mem, value) ((void) (*(mem) = (value)))
+#else
+#define arch_atomic_write(mem, value)                                   \
+  do {                                                                  \
+    __typeof(mem) __aw_mem = (mem);                                     \
+    __typeof(value) __aw_val = (value);                                 \
+    unsigned int *__aw_mem32, __aw_intval, __aw_val32, __aw_off, __aw_mask; \
+    __aw_intval = (__typeof((value) - (value)))__aw_val;                \
+    switch (sizeof(*__aw_mem)) {                                        \
+    case 8:                                                             \
+      __arch_atomic_update_cmpxchg(__aw_mem, __aw_val, __value);        \
+      break;                                                            \
+    case 4:                                                             \
+      __arch_atomic_update_4((int *)__aw_mem, 0, __aw_intval);          \
+      break;                                                            \
+    case 2:                                                             \
+      __aw_off = 8 * ((long)__aw_mem & 0x2);                            \
+      __aw_mask = 0xffffU << __aw_off;                                  \
+      __aw_mem32 = (unsigned int *)((long)__aw_mem & ~0x2);             \
+      __aw_val32 = (__aw_intval << __aw_off) & __aw_mask;               \
+      __arch_atomic_update_cmpxchg(__aw_mem32, __aw_val32,              \
+                                   (__old & ~__aw_mask) | __value);     \
+      break;                                                            \
+    case 1:                                                             \
+      __aw_off = 8 * ((long)__aw_mem & 0x3);                            \
+      __aw_mask = 0xffU << __aw_off;                                    \
+      __aw_mem32 = (unsigned int *)((long)__aw_mem & ~0x3);             \
+      __aw_val32 = (__aw_intval << __aw_off) & __aw_mask;               \
+      __arch_atomic_update_cmpxchg(__aw_mem32, __aw_val32,              \
+                                   (__old & ~__aw_mask) | __value);     \
+      break;                                                            \
+    }                                                                   \
+  } while (0)
+#endif
+
+/* Compiler barrier.
+
+   This macro prevents loads or stores from being moved by the compiler
+   across the macro.  Any loaded value that was loaded before this
+   macro must then be reloaded by the compiler.  */
+#define arch_atomic_compiler_barrier() __asm__ __volatile__("" ::: "memory")
+
+/* Full memory barrier.
+
+   This macro has the semantics of arch_atomic_compiler_barrer(), but also
+   ensures that previous stores are visible to other cores, and that
+   all previous loaded values have been placed into their target
+   register on this core.  */
+#define arch_atomic_full_barrier() __insn_mf()
+
+/* Read memory barrier.
+
+   Ensure that all reads by this processor that occurred prior to the
+   read memory barrier have completed, and that no reads that occur
+   after the read memory barrier on this processor are initiated
+   before the barrier.
+
+   On current TILE chips a read barrier is implemented as a full barrier,
+   but this may not be true in later versions of the architecture.
+
+   See also arch_atomic_acquire_barrier() for the appropriate idiom to use
+   to ensure no reads are lifted above an atomic lock instruction.  */
+#define arch_atomic_read_barrier() arch_atomic_full_barrier()
+
+/* Write memory barrier.
+
+   Ensure that all writes by this processor that occurred prior to the
+   write memory barrier have completed, and that no writes that occur
+   after the write memory barrier on this processor are initiated
+   before the barrier.
+
+   On current TILE chips a write barrier is implemented as a full barrier,
+   but this may not be true in later versions of the architecture.
+
+   See also arch_atomic_release_barrier() for the appropriate idiom to use
+   to ensure all writes are complete prior to an atomic unlock instruction.  */
+#define arch_atomic_write_barrier() arch_atomic_full_barrier()
+
+/* Lock acquisition barrier.
+
+   Ensure that no load operations that follow this macro in the
+   program can issue prior to the barrier.  Without such a barrier,
+   the compiler can reorder them to issue earlier, or the hardware can
+   issue them speculatively.  The latter is not currently done in the
+   Tile microarchitecture, but using this operation improves
+   portability to future implementations.
+
+   This operation is intended to be used as part of the "acquire"
+   path for locking, that is, when entering a critical section.
+   This should be done after the atomic operation that actually
+   acquires the lock, and in conjunction with a "control dependency"
+   that checks the atomic operation result to see if the lock was
+   in fact acquired.  See the arch_atomic_read_barrier() macro
+   for a heavier-weight barrier to use in certain unusual constructs,
+   or arch_atomic_acquire_barrier_value() if no control dependency exists.  */
+#define arch_atomic_acquire_barrier() arch_atomic_compiler_barrier()
+
+/* Lock release barrier.
+
+   Ensure that no store operations that precede this macro in the
+   program complete subsequent to the barrier.  Without such a
+   barrier, the compiler can reorder stores to issue later, or stores
+   can be still outstanding in the memory network.
+
+   This operation is intended to be used as part of the "release" path
+   for locking, that is, when leaving a critical section.  This should
+   be done before the operation (such as a store of zero) that
+   actually releases the lock.  */
+#define arch_atomic_release_barrier() arch_atomic_write_barrier()
+
+/* Barrier until the read of a particular value is complete.
+
+   This is occasionally useful when constructing certain locking
+   scenarios.  For example, you might write a routine that issues an
+   atomic instruction to enter a critical section, then reads one or
+   more values within the critical section without checking to see if
+   the critical section was in fact acquired, and only later checks
+   the atomic instruction result to see if the lock was acquired.  If
+   so the routine could properly release the lock and know that the
+   values that were read were valid.
+
+   In this scenario, it is required to wait for the result of the
+   atomic instruction, even if the value itself is not checked.  This
+   guarantees that if the atomic instruction succeeded in taking the lock,
+   the lock was held before any reads in the critical section issued.
+   We mark the macro as being a memory clobber as well, to ensure that
+   the compiler doesn't hoist any reads to before it.  */
+#define arch_atomic_acquire_barrier_value(val) \
+  __asm__ __volatile__("move %0, %0" :: "r"(val) : "memory")
+
+/* Access the given variable in memory exactly once.
+
+   In some contexts, an algorithm may need to force access to memory,
+   since otherwise the compiler may think it can optimize away a
+   memory load or store; for example, in a loop when polling memory to
+   see if another cpu has updated it yet.  Generally this is only
+   required for certain very carefully hand-tuned algorithms; using it
+   unnecessarily may result in performance losses.
+
+   A related use of this macro is to ensure that the compiler does not
+   rematerialize the value of "x" by reloading it from memory
+   unexpectedly; the "volatile" marking will prevent the compiler from
+   being able to rematerialize.  This is helpful if an algorithm needs
+   to read a variable without locking, but needs it to have the same
+   value if it ends up being used several times within the algorithm.
+
+   Note that multiple uses of this macro are guaranteed to be ordered,
+   i.e. the compiler will not reorder stores or loads that are wrapped
+   in arch_atomic_access_once().  */
+#define arch_atomic_access_once(x) (*(volatile __typeof(x) *)&(x))
+
+
+
+#endif /* !_ATOMIC_H_ */
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/milieu.h ./gcc/config/tilepro/libgcc/milieu.h
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/milieu.h	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/libgcc/milieu.h	2015-10-26 22:26:57.466176000 -0400
@@ -0,0 +1,45 @@
+
+/*============================================================================
+
+This C header file is part of the SoftFloat IEC/IEEE Floating-point Arithmetic
+Package, Release 2b.
+
+Written by John R. Hauser.  This work was made possible in part by the
+International Computer Science Institute, located at Suite 600, 1947 Center
+Street, Berkeley, California 94704.  Funding was partially provided by the
+National Science Foundation under grant MIP-9311980.  The original version
+of this code was written as part of a project to build a fixed-point vector
+processor in collaboration with the University of California at Berkeley,
+overseen by Profs. Nelson Morgan and John Wawrzynek.  More information
+is available through the Web page `http://www.cs.berkeley.edu/~jhauser/
+arithmetic/SoftFloat.html'.
+
+THIS SOFTWARE IS DISTRIBUTED AS IS, FOR FREE.  Although reasonable effort has
+been made to avoid it, THIS SOFTWARE MAY CONTAIN FAULTS THAT WILL AT TIMES
+RESULT IN INCORRECT BEHAVIOR.  USE OF THIS SOFTWARE IS RESTRICTED TO PERSONS
+AND ORGANIZATIONS WHO CAN AND WILL TAKE FULL RESPONSIBILITY FOR ALL LOSSES,
+COSTS, OR OTHER PROBLEMS THEY INCUR DUE TO THE SOFTWARE, AND WHO FURTHERMORE
+EFFECTIVELY INDEMNIFY JOHN HAUSER AND THE INTERNATIONAL COMPUTER SCIENCE
+INSTITUTE (possibly via similar legal warning) AGAINST ALL LOSSES, COSTS, OR
+OTHER PROBLEMS INCURRED BY THEIR CUSTOMERS AND CLIENTS DUE TO THE SOFTWARE.
+
+Derivative works are acceptable, even for commercial purposes, so long as
+(1) the source code for the derivative work includes prominent notice that
+the work is derivative, and (2) the source code includes prominent notice with
+these four paragraphs for those parts of this code that are retained.
+
+=============================================================================*/
+
+/*----------------------------------------------------------------------------
+| Include common integer types and flags.
+*----------------------------------------------------------------------------*/
+#include "softtile.h"
+
+/*----------------------------------------------------------------------------
+| Symbolic Boolean literals.
+*----------------------------------------------------------------------------*/
+enum {
+    FALSE = 0,
+    TRUE  = 1
+};
+
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/softdivide.c ./gcc/config/tilepro/libgcc/softdivide.c
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/softdivide.c	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/libgcc/softdivide.c	2015-10-26 22:26:57.468177000 -0400
@@ -0,0 +1,334 @@
+/* Division and remainder routines for Tile.
+ */
+
+
+#include "softtile.h"
+ 
+typedef int32 int32_t;
+typedef uint32 uint32_t;
+typedef int64 int64_t;
+typedef uint64 uint64_t;
+
+/* Raise signal 8 (SIGFPE) with code 1 (FPE_INTDIV).  */
+static inline void
+raise_intdiv (void)
+{
+  asm("{ raise; moveli zero, 8 + (1 << 6) }");
+}
+
+
+#ifndef __tilegx__
+/*__udivsi3 - 32 bit integer unsigned divide  */
+static inline uint32_t __attribute__((always_inline))
+__udivsi3_inline (uint32_t dividend, uint32_t divisor)
+{
+  /* Divide out any power of two factor from dividend and divisor.
+     Note that when dividing by zero the divisor will remain zero,
+     which is all we need to detect that case below.  */
+  const int power_of_two_factor = __insn_ctz (divisor);
+  divisor >>= power_of_two_factor;
+  dividend >>= power_of_two_factor;
+
+  /* Checks for division by power of two or division by zero.  */
+  if (divisor <= 1)
+    {
+      if (divisor == 0)
+	{
+	  raise_intdiv ();
+	  return 0;
+	}
+      return dividend;
+    }
+
+  /* Compute (a / b) by repeatedly finding the largest N
+     such that (b << N) <= a. For each such N, set bit N in the
+     quotient, subtract (b << N) from a, and keep going. Think of this as
+     the reverse of the "shift-and-add" that a multiply does. The values
+     of N are precisely those shift counts.
+    
+     Finding N is easy. First, use clz(b) - clz(a) to find the N
+     that lines up the high bit of (b << N) with the high bit of a.
+     Any larger value of N would definitely make (b << N) > a,
+     which is too big.
+    
+     Then, if (b << N) > a (because it has larger low bits), decrement
+     N by one.  This adjustment will definitely make (b << N) less
+     than a, because a's high bit is now one higher than b's.  */
+
+  /* Precomputing the max_ values allows us to avoid a subtract
+     in the inner loop and just right shift by clz(remainder).  */
+  const int divisor_clz = __insn_clz (divisor);
+  const uint32_t max_divisor = divisor << divisor_clz;
+  const uint32_t max_qbit = 1 << divisor_clz;
+
+  uint32_t quotient = 0;
+  uint32_t remainder = dividend;
+
+  while (remainder >= divisor)
+    {
+      int shift = __insn_clz (remainder);
+      uint32_t scaled_divisor = max_divisor >> shift;
+      uint32_t quotient_bit = max_qbit >> shift;
+
+      int too_big = (scaled_divisor > remainder);
+      scaled_divisor >>= too_big;
+      quotient_bit >>= too_big;
+      remainder -= scaled_divisor;
+      quotient |= quotient_bit;
+    }
+  return quotient;
+}
+#endif /* !__tilegx__ */
+
+
+/* __udivdi3 - 64 bit integer unsigned divide  */
+static inline uint64_t __attribute__((always_inline))
+__udivdi3_inline (uint64_t dividend, uint64_t divisor)
+{
+  /* Divide out any power of two factor from dividend and divisor.
+     Note that when dividing by zero the divisor will remain zero,
+     which is all we need to detect that case below.  */
+  const int power_of_two_factor = __builtin_ctzll (divisor);
+  divisor >>= power_of_two_factor;
+  dividend >>= power_of_two_factor;
+
+  /* Checks for division by power of two or division by zero.  */
+  if (divisor <= 1)
+    {
+      if (divisor == 0)
+	{
+	  raise_intdiv();
+	  return 0;
+	}
+      return dividend;
+    }
+
+#ifndef __tilegx__
+  if (((uint32_t)(dividend >> 32) | ((uint32_t)(divisor >> 32))) == 0)
+    {
+      /* Operands both fit in 32 bits, so use faster 32 bit algorithm.  */
+      return __udivsi3_inline ((uint32_t)dividend, (uint32_t)divisor);
+    }
+#endif /* !__tilegx__ */
+
+  /* See algorithm description in __udivsi3  */
+
+  const int divisor_clz = __builtin_clzll (divisor);
+  const uint64_t max_divisor = divisor << divisor_clz;
+  const uint64_t max_qbit = 1ULL << divisor_clz;
+
+  uint64_t quotient = 0;
+  uint64_t remainder = dividend;
+
+  while (remainder >= divisor)
+    {
+      int shift = __builtin_clzll (remainder);
+      uint64_t scaled_divisor = max_divisor >> shift;
+      uint64_t quotient_bit = max_qbit >> shift;
+
+      int too_big = (scaled_divisor > remainder);
+      scaled_divisor >>= too_big;
+      quotient_bit >>= too_big;
+      remainder -= scaled_divisor;
+      quotient |= quotient_bit;
+    }
+  return quotient;
+}
+
+
+#ifndef __tilegx__
+/* __umodsi3 - 32 bit integer unsigned modulo  */
+static inline uint32_t __attribute__((always_inline))
+__umodsi3_inline (uint32_t dividend, uint32_t divisor)
+{
+  /* Shortcircuit mod by a power of two (and catch mod by zero).  */
+  const uint32_t mask = divisor - 1;
+  if ((divisor & mask) == 0)
+    {
+      if (divisor == 0)
+	{
+	  raise_intdiv ();
+	  return 0;
+	}
+      return dividend & mask;
+    }
+
+  /* We compute the remainder (a % b) by repeatedly subtracting off
+     multiples of b from a until a < b. The key is that subtracting
+     off a multiple of b does not affect the result mod b.
+    
+     To make the algorithm run efficiently, we need to subtract
+     off a large multiple of b at each step. We subtract the largest
+     (b << N) that is <= a.
+    
+     Finding N is easy. First, use clz(b) - clz(a) to find the N
+     that lines up the high bit of (b << N) with the high bit of a.
+     Any larger value of N would definitely make (b << N) > a,
+     which is too big.
+    
+     Then, if (b << N) > a (because it has larger low bits), decrement
+     N by one.  This adjustment will definitely make (b << N) less
+     than a, because a's high bit is now one higher than b's.  */
+  const uint32_t max_divisor = divisor << __insn_clz(divisor);
+
+  uint32_t remainder = dividend;
+  while (remainder >= divisor)
+    {
+      const int shift = __insn_clz (remainder);
+      uint32_t scaled_divisor = max_divisor >> shift;
+      scaled_divisor >>= (scaled_divisor > remainder);
+      remainder -= scaled_divisor;
+    }
+
+  return remainder;
+}
+#endif /* !__tilegx__ */
+
+
+/* __umoddi3 - 64 bit integer unsigned modulo  */
+static inline uint64_t __attribute__((always_inline))
+__umoddi3_inline (uint64_t dividend, uint64_t divisor)
+{
+#ifndef __tilegx__
+  if (((uint32_t)(dividend >> 32) | ((uint32_t)(divisor >> 32))) == 0)
+    {
+      /* Operands both fit in 32 bits, so use faster 32 bit algorithm.  */
+      return __umodsi3_inline ((uint32_t)dividend, (uint32_t)divisor);
+    }
+#endif /* !__tilegx__ */
+
+  /* Shortcircuit mod by a power of two (and catch mod by zero).  */
+  const uint64_t mask = divisor - 1;
+  if ((divisor & mask) == 0)
+    {
+      if (divisor == 0)
+	{
+	  raise_intdiv ();
+	  return 0;
+	}
+      return dividend & mask;
+    }
+
+  /* See algorithm description in __umodsi3  */
+  const uint64_t max_divisor = divisor << __builtin_clzll (divisor);
+
+  uint64_t remainder = dividend;
+  while (remainder >= divisor)
+    {
+      const int shift = __builtin_clzll (remainder);
+      uint64_t scaled_divisor = max_divisor >> shift;
+      scaled_divisor >>= (scaled_divisor > remainder);
+      remainder -= scaled_divisor;
+    }
+
+  return remainder;
+}
+
+
+uint32_t __udivsi3 (uint32_t dividend, uint32_t divisor);
+#ifdef L_tile_udivsi3
+uint32_t
+__udivsi3 (uint32_t dividend, uint32_t divisor)
+{
+#ifndef __tilegx__
+  return __udivsi3_inline (dividend, divisor);
+#else  /* !__tilegx__ */
+  uint64_t n = __udivdi3_inline (((uint64_t)dividend), ((uint64_t)divisor));
+  return (uint32_t)n;
+#endif /* !__tilegx__ */
+}
+#endif
+
+#define ABS(x) ((x) >= 0 ? (x) : -(x))
+
+int32_t __divsi3 (int32_t dividend, int32_t divisor);
+#ifdef L_tile_divsi3
+/* __divsi3 - 32 bit integer signed divide  */
+int32_t
+__divsi3 (int32_t dividend, int32_t divisor)
+{
+#ifndef __tilegx__
+  uint32_t n = __udivsi3_inline (ABS(dividend), ABS(divisor));
+#else  /* !__tilegx__ */
+  uint64_t n = __udivdi3_inline (ABS((int64_t)dividend), ABS((int64_t)divisor));
+#endif /* !__tilegx__ */
+  if ((dividend ^ divisor) < 0)
+    n = -n;
+  return (int32_t)n;
+}
+#endif
+
+
+uint64_t __udivdi3 (uint64_t dividend, uint64_t divisor);
+#ifdef L_tile_udivdi3
+uint64_t
+__udivdi3 (uint64_t dividend, uint64_t divisor)
+{
+  return __udivdi3_inline (dividend, divisor);
+}
+#endif
+
+/*__divdi3 - 64 bit integer signed divide  */
+int64_t __divdi3 (int64_t dividend, int64_t divisor);
+#ifdef L_tile_divdi3
+int64_t
+__divdi3 (int64_t dividend, int64_t divisor)
+{
+  uint64_t n = __udivdi3_inline (ABS(dividend), ABS(divisor));
+  if ((dividend ^ divisor) < 0)
+    n = -n;
+  return (int64_t)n;
+}
+#endif
+
+
+uint32_t __umodsi3 (uint32_t dividend, uint32_t divisor);
+#ifdef L_tile_umodsi3
+uint32_t
+__umodsi3 (uint32_t dividend, uint32_t divisor)
+{
+#ifndef __tilegx__
+  return __umodsi3_inline (dividend, divisor);
+#else  /* !__tilegx__ */
+  return __umoddi3_inline ((uint64_t)dividend, (uint64_t)divisor);
+#endif /* !__tilegx__ */
+}
+#endif
+
+
+/* __modsi3 - 32 bit integer signed modulo  */
+int32_t __modsi3 (int32_t dividend, int32_t divisor);
+#ifdef L_tile_modsi3
+int32_t
+__modsi3 (int32_t dividend, int32_t divisor)
+{
+#ifndef __tilegx__
+  uint32_t remainder = __umodsi3_inline (ABS(dividend), ABS(divisor));
+#else  /* !__tilegx__ */
+  uint64_t remainder = __umoddi3_inline (ABS((int64_t)dividend), ABS((int64_t)divisor));
+#endif /* !__tilegx__ */
+  return (int32_t)((dividend >= 0) ? remainder : -remainder);
+}
+#endif
+
+
+uint64_t __umoddi3 (uint64_t dividend, uint64_t divisor);
+#ifdef L_tile_umoddi3
+uint64_t
+__umoddi3 (uint64_t dividend, uint64_t divisor)
+{
+  return __umoddi3_inline (dividend, divisor);
+}
+#endif
+
+
+/* __moddi3 - 64 bit integer signed modulo  */
+int64_t __moddi3 (int64_t dividend, int64_t divisor);
+#ifdef L_tile_moddi3
+int64_t
+__moddi3 (int64_t dividend, int64_t divisor)
+{
+  uint64_t remainder = __umoddi3_inline (ABS(dividend), ABS(divisor));
+  return (int64_t)((dividend >= 0) ? remainder : -remainder);
+}
+#endif
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/softfloat.c ./gcc/config/tilepro/libgcc/softfloat.c
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilepro/libgcc/softfloat.c	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilepro/libgcc/softfloat.c	2015-10-26 22:26:57.538186000 -0400
@@ -0,0 +1,3260 @@
+/* Softfloat.
+ */
+
+
+/*============================================================================
+
+This C source file is part of the SoftFloat IEC/IEEE Floating-point Arithmetic
+Package, Release 2b.
+
