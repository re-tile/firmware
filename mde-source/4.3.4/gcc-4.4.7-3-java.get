+;; but WITHOUT ANY WARRANTY; without even the implied warranty of
+;; MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+;; GNU General Public License for more details.
+;;
+;; You should have received a copy of the GNU General Public License
+;; along with GCC; see the file COPYING3.  If not see
+;; <http://www.gnu.org/licenses/>.
+
+(define_register_constraint "R00" "R0_REGS"  "r0")
+(define_register_constraint "R01" "R1_REGS"  "r1")
+(define_register_constraint "R02" "R2_REGS"  "r2")
+(define_register_constraint "R03" "R3_REGS"  "r3")
+(define_register_constraint "R04" "R4_REGS"  "r4")
+(define_register_constraint "R05" "R5_REGS"  "r5")
+(define_register_constraint "R06" "R6_REGS"  "r6")
+(define_register_constraint "R07" "R7_REGS"  "r7")
+(define_register_constraint "R08" "R8_REGS"  "r8")
+(define_register_constraint "R09" "R9_REGS"  "r9")
+(define_register_constraint "R10" "R10_REGS" "r10")
+
+(define_constraint "I"
+  "A signed 8 bit constant"
+  (and (match_code "const_int")
+       (match_test "ival >= -128 && ival <= 127")))
+
+(define_constraint "J"
+  "Signed 16-bit integer constant"
+  (and (match_code "const_int")
+       (match_test "ival >= -32768 && ival <= 32767")))
+
+(define_constraint "K"
+  "Unsigned 16-bit integer constant"
+  (and (match_code "const_int")
+       (match_test "(ival >= 0 && ival <= 65535)")))
+
+(define_constraint "L"
+  "Integer constant that fits in one signed byte when incremented"
+  (and (match_code "const_int")
+       (match_test "ival >= -129 && ival <= 126")))
+
+(define_constraint "M"
+  "A bit mask suitable for 'bfins'"
+  (and (match_code "const_int")
+       (match_test "tilegx_bitfield_operand_p (ival, NULL, NULL)")))
+
+(define_constraint "N"
+  "Integer constant that is a byte tiled out eight times"
+  (and (match_code "const_int")
+       (match_test "(ival == (ival & 0xFF) * 0x0101010101010101LL)")))
+
+(define_constraint "O"
+ "The integer zero constant"
+ (and (match_code "const_int")
+      (match_test "ival == 0")))
+
+(define_constraint "P"
+  "Integer constant that is a sign-extended byte tiled out as four shorts"
+  (and (match_code "const_int")
+       (match_test "(ival
+                     == ((trunc_int_for_mode (ival, QImode) & 0xFFFF)
+                         * 0x0001000100010001LL))")))
+
+(define_constraint "Q"
+  "Integer constant that fits in one signed byte when incremented, but not -1"
+  (and (match_code "const_int")
+       (match_test "ival >= -129 && ival <= 126 && ival != -1")))
+
+(define_constraint "S"
+  "Integer constant that has all 1 bits consecutive and starting at bit 0"
+  (and (match_code "const_int")
+       (match_test "ival != 0 && (ival & (ival + 1)) == 0")))
+
+(define_constraint "T"
+  "An unspec wrapper for a symbolc operand"
+  (ior (match_operand 0 "const_last_symbolic_operand")
+       (match_operand 0 "const_symbolic_operand")))
+
+(define_memory_constraint "U"
+  "Non-auto-incrementing memory"
+  (and (match_code "mem")
+       (match_test "GET_RTX_CLASS (GET_CODE (XEXP (op, 0))) != RTX_AUTOINC")))
+
+(define_constraint "W0"
+  "Zero vector constant"
+  (and (match_code "const_vector")
+       (match_test "op == CONST0_RTX (mode)")))
+
+(define_constraint "W2"
+  "A 4-element (2^2) vector constant with identical elements"
+  (and (match_code "const_vector")
+       (match_test "CONST_VECTOR_NUNITS (op) == 4")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 1)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 2)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 3)")))
+
+(define_constraint "W3"
+  "An 8-element (2^3) vector constant with identical elements"
+  (and (match_code "const_vector")
+       (match_test "CONST_VECTOR_NUNITS (op) == 8")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 1)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 2)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 3)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 4)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 5)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 6)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 7)")))
+
+(define_constraint "W4"
+  "A 16-element (2^4) vector constant with identical elements"
+  (and (match_code "const_vector")
+       (match_test "CONST_VECTOR_NUNITS (op) == 16")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 1)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 2)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 3)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 4)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 5)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 6)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 7)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 8)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 9)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 10)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 11)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 12)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 13)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 14)")
+       (match_test "CONST_VECTOR_ELT (op, 0) == CONST_VECTOR_ELT (op, 15)")))
+
+(define_constraint "Z0"
+ "The integer constant 0xffffffff"
+ (and (match_code "const_int")
+      (match_test "ival == 0xffffffff")))
+
+(define_constraint "Z1"
+ "The integer constant 0xffffffff00000000"
+ (and (match_code "const_int")
+      (match_test "ival == (HOST_WIDE_INT)0xffffffff00000000LL")))
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/feedback-flags.h ./gcc/config/tilegx/feedback-flags.h
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/feedback-flags.h	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilegx/feedback-flags.h	2015-10-26 22:26:57.564185000 -0400
@@ -0,0 +1,47 @@
+#ifndef _FEEDBACK_H
+#define _FEEDBACK_H
+
+extern int tilegx_feedback_generate;
+
+extern int tilegx_feedback_generate_compiler;
+
+extern int tilegx_feedback_generate_linker;
+
+extern const char* tilegx_feedback_use_compiler_file;
+extern const char* tilegx_feedback_use_linker_file;
+extern const char* tilegx_feedback_use_file;
+
+extern const char* tilegx_feedback_emit_dir;
+extern const char* tilegx_strip_file_prefix;
+
+static inline bool
+enable_feedback_generate (void)
+{
+  return tilegx_feedback_generate_compiler || tilegx_feedback_generate_linker;
+}
+
+static inline bool
+enable_feedback_generate_compiler (void)
+{
+  return tilegx_feedback_generate_compiler;
+}
+
+static inline bool
+enable_feedback_generate_linker (void)
+{
+  return tilegx_feedback_generate_linker;
+}
+
+static inline bool
+enable_feedback_emit (void)
+{
+  return tilegx_feedback_emit_dir != NULL;
+}
+
+static inline bool
+enable_feedback_use_linker (void)
+{
+  return tilegx_feedback_use_linker_file != NULL;
+}
+
+#endif
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/feedback.c ./gcc/config/tilegx/feedback.c
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/feedback.c	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilegx/feedback.c	2015-10-26 22:26:57.583174000 -0400
@@ -0,0 +1,838 @@
+#include "config.h"
+#include "system.h"
+#include "coretypes.h"
+#include "tm.h"
+#include "machmode.h"
+#include "output.h"
+#include "expr.h"
+#include "langhooks.h"
+#include "tree-flow.h"
+#include "value-prof.h" /* for is_tree_profile_call () */
+#include "coverage.h"
+#include "toplev.h"
+#include "tilegx-feedback.h"
+#include "feedback-flags.h"
+
+/* Whether to generate some data structures shared by both linker and compiler
+   optimization.  */
+int tilegx_feedback_generate = 0;
+
+/* Whether the compiler should generate profiling code for compiler
+   optimizations.  */
+int tilegx_feedback_generate_compiler = 0;
+
+/* Whether the compiler should generate profiling code for linker
+   optimizations.  */
+int tilegx_feedback_generate_linker = 0;
+
+/* Output directory where profiling information will be stored.  Only used by
+   the linker, and unused by the compiler proper.  */
+const char* tilegx_feedback_emit_dir = 0;
+
+/* Input file containing profile data.  */
+const char* tilegx_feedback_use_compiler_file = 0;
+const char* tilegx_feedback_use_linker_file = 0;
+const char* tilegx_feedback_use_file = 0;
+
+/* Prefix to strip off of file names for feedback use.  */
+const char* tilegx_strip_file_prefix = 0;
+
+/* The following is the pass to instrument for tile's linker feedback
+   optimization.  */
+
+static GTY(()) tree tree_tilegx_feedback_function_entered_fn;
+static GTY(()) tree tree_tilegx_feedback_function_resumed_fn;
+
+static GTY(()) tree feedback_function_type;
+
+/* Create a string object.  */
+
+static tree
+create_string_object (const char *name, const char *value, tree section)
+{
+  int value_len;
+  char *value_buf;
+  tree string_type;
+  tree string_val;
+  tree string_var;
+
+  /* compute the length of the string contents  */
+  value_len = strlen (value);
+
+  /* copy value to a perminent buffer  */
+  value_buf = XNEWVEC (char, value_len + 1);
+  strcpy (value_buf, value);
+
+  /* create the string type unsigned char [value_len + 1]  */
+  string_type =
+    build_array_type (unsigned_char_type_node,
+		      build_index_type (size_int (value_len + 1)));
+
+  /* create the string value, and make its type string_type  */
+  string_val = build_string (value_len + 1, value_buf);
+  TREE_TYPE (string_val) = string_type;
+
+  /* create the string variable */
+  string_var = build_decl (VAR_DECL, get_identifier (name),
+			   string_type);
+  TREE_STATIC (string_var) = 1;
+  DECL_INITIAL (string_var) = string_val;
+  DECL_SECTION_NAME (string_var) = section;
+
+  assemble_variable (string_var, 0, 0, 0);
+  return string_var;
+}
+
+
+/* Do not instrument any calls that are inserted by the compiler.  FIXME:
+   tile-gcc: this list may not be complete (coverage analysis functions?).  */
+
+static bool
+exclude_feedback_instrument (tree call)
+{
+  return is_tree_profile_call (call)
+    || call == tree_tilegx_feedback_function_entered_fn
+    || call == tree_tilegx_feedback_function_resumed_fn;
+}
+
+
+/* Add a field to RECORD_TYPE.  */
+static tree
+declare_field (tree record_type, tree field_type, const char *field_name,
+               tree* fields)
+{
+  tree field = build_decl (FIELD_DECL, get_identifier (field_name),
+                           field_type);
+  DECL_FIELD_CONTEXT (field) = record_type;
+  TREE_CHAIN (field) = *fields;
+  *fields = field;
+  return field;
+}
+
+
+typedef struct tilegx_field_desc GTY(())
+{
+  const char* name;
+  tree* type_p;
+  unsigned array_size;
+  unsigned size;
+} tilegx_field_desc;
+
+
+/* A description of the Feedback_Function type.  This must be consistent with
+   files.h in the cache packer.  All the fields are integers or array of
+   integers.  We initialize the integer types statically, but we need to use
+   pointers to types because the types themselves are not yet initialized.
+   The size field is the size of a non-array type, or the element size of the
+   array type.  */
+tilegx_field_desc tilegx_feedback_function_desc[] =
+{
+  { "id", &unsigned_type_node, 1, 0 },
+  { "num_bytes", &unsigned_type_node, 1, 0 },
+  { "relative_function_name", &integer_type_node, 1, 0 },
+  { "relative_section_name", &integer_type_node, 1, 0 },
+  { "relative_source_file_name", &integer_type_node, 1, 0 },
+  { "checksum", &unsigned_type_node, 1, 0 },
+  { "gcc_id", &unsigned_type_node, 1, 0 },
+  { "num_counters", &unsigned_type_node, GCOV_COUNTERS, 0 },
+  { "relative_counters", &integer_type_node, GCOV_COUNTERS, 0 },
+  { NULL, NULL, 0, 0 }
+};
+
+
+/* Initialize the globals used by the profiler.  This includes global types as
+   well as profiler specific ELF sections.  */
+static void
+feedback_initialize_globals (void)
+{
+  static bool init = false;
+
+  if (init)
+    return;
+
+  init = true;
+
+  /* Initialize the feedback function type */
+  {
+    int i;
+    tree fftype = lang_hooks.types.make_type (RECORD_TYPE);
+    tree fields = NULL_TREE;
+
+    for (i = 0; tilegx_feedback_function_desc[i].name != NULL; i++)
+      {
+	const char* name = tilegx_feedback_function_desc[i].name;
+	tree type = *tilegx_feedback_function_desc[i].type_p;
+	unsigned array_size = tilegx_feedback_function_desc[i].array_size;
+
+	tilegx_feedback_function_desc[i].size =
+	  tree_low_cst (TYPE_SIZE_UNIT (type), 1);
+
+	if (array_size > 1)
+	  {
+	    tree index_type = build_index_type (build_int_cst (NULL_TREE,
+							       array_size));
+	    type = build_array_type (type, index_type);
+	  }
+
+	declare_field (fftype, type, name, &fields);
+      }
+
+    finish_builtin_struct (fftype, "__feedback_function_info_t", fields,
+			   NULL_TREE);
+
+    feedback_function_type = fftype;
+  }
+
+  /* Initialize function prototypes */
+  {
+    tree ff_ptr = build_pointer_type (feedback_function_type);
+
+    tree feedback_fn_type =
+      build_function_type_list (void_type_node, ff_ptr, NULL_TREE);
+
+    tree_tilegx_feedback_function_entered_fn
+      = build_fn_decl ("__feedback_function_entered", feedback_fn_type);
+
+    tree_tilegx_feedback_function_resumed_fn
+      = build_fn_decl ("__feedback_function_resumed", feedback_fn_type);
+  }
+
+  /* Initialize the feedback sections */
+  {
+    tree sec_name;
+
+    sec_name = build_string (strlen (".feedback.strings"),
+			     ".feedback.strings");
+
+    get_section (TREE_STRING_POINTER (sec_name),
+		 SECTION_STRINGS | SECTION_OVERRIDE | SECTION_MERGE | 1,
+		 NULL);
+
+    sec_name = build_string (strlen (".feedback.functions"),
+			     ".feedback.functions");
+
+    get_section (TREE_STRING_POINTER (sec_name),
+		 SECTION_WRITE | SECTION_NOTYPE | SECTION_OVERRIDE, NULL);
+  }
+}
+
+
+static void
+feedback_declare_function_variables (tilegx_feedback_info *info,
+				     const char *fn_name,
+				     const char* sec_name)
+{
+  static int ctr = 0;
+  static tree source_file_var = NULL;
+  tree ffv;
+  char *name;
+  tree strings_sec;
+
+  name = XNEWVEC (char, strlen (fn_name) + 32);
+
+  strings_sec = build_string (strlen (".feedback.strings"),
+			      ".feedback.strings");
+
+  /* initialize the function name */
+  sprintf (name, "%s.function_name.%d", fn_name, ctr++);
+  info->function_name_var =
+    create_string_object (name, fn_name, strings_sec);
+
+  /* initialize the source file name */
+  if (source_file_var == NULL)
+    {
+      sprintf (name, "%s.source_file_name.%d", fn_name, ctr++);
+      source_file_var =
+	create_string_object (name, get_strip_filename (main_input_filename),
+			      strings_sec);
+    }
+  info->source_file_var = source_file_var;
+
+  /* initialize the section name object if the name is known, otherwise just
+     create an unitialized object.  */
+  if (sec_name == NULL)
+    {
+      sprintf (name, "%s.section_name.%d", fn_name, ctr++);
+      info->section_name_var = 
+	build_decl (VAR_DECL, get_identifier (name),
+		    build_array_type (unsigned_char_type_node, NULL));
+      DECL_SECTION_NAME (info->section_name_var) = strings_sec;
+    }
+  else
+    {
+      sprintf (name, "%s.section_name.%d", fn_name, ctr++);
+      info->section_name_var =
+	create_string_object (name, sec_name, strings_sec);
+    }
+
+  /* create the feedback object. */
+  sprintf (name, "%s.feedback.%d", fn_name, ctr++);
+
+  ffv = build_decl (VAR_DECL, get_identifier (name), feedback_function_type);
+  info->feedback_function_var = ffv;
+
+  TREE_STATIC (ffv) = 1;
+  TREE_PUBLIC (ffv) = 0;
+  DECL_ARTIFICIAL (ffv) = 1;
+  DECL_INITIAL (ffv) = NULL;
+
+  DECL_SECTION_NAME (ffv) = 
+    build_string (strlen (".feedback.functions"), ".feedback.functions");
+}
+
+
+/* New call was added, make goto call edges if neccesary.  copied from
+   tree-profile.c  */
+static void
+add_abnormal_goto_call_edges (gimple_stmt_iterator gsi)
+{
+  gimple stmt = gsi_stmt (gsi);
+
+  if (!stmt_can_make_abnormal_goto (stmt))
+    return;
+  if (!gsi_end_p (gsi))
+    split_block (gimple_bb (stmt), stmt);
+
+  make_abnormal_goto_edges (gimple_bb (stmt), true);
+}
+
+
+/* Insert feedback instrumentation for the current function.  */
+static void
+feedback_linker_instrument (tree ffv)
+{
+  gimple_stmt_iterator gsi;
+  edge e;
+  basic_block bb;
+  edge_iterator ei;
+  gimple stmt;
+
+  FOR_EACH_EDGE (e, ei, ENTRY_BLOCK_PTR->succs)
+    {
+      bb = split_edge (e);
+      gsi = gsi_start_bb (bb);
+
+      stmt = gimple_build_call (tree_tilegx_feedback_function_entered_fn, 1,
+				build_addr (ffv,
+					    current_function_decl));
+      gsi_insert_after (&gsi, stmt, GSI_NEW_STMT);
+      gcc_assert (EDGE_COUNT (bb->succs) == 1);
+      bb = split_edge (EDGE_I (bb->succs, 0));
+      add_abnormal_goto_call_edges (gsi);
+    }
+
+  FOR_EACH_BB (bb)
+    {
+      for (gsi = gsi_start_bb (bb); !gsi_end_p (gsi); gsi_next (&gsi))
+	{
+	  gimple curr = gsi_stmt (gsi);
+	  if (is_gimple_call (curr)
+	      && !exclude_feedback_instrument (gimple_call_fndecl (curr)))
+	    {
+	      gimple stmt = gimple_build_call (
+                tree_tilegx_feedback_function_resumed_fn, 1,
+		build_addr (ffv, current_function_decl));
+	      gsi_insert_after (&gsi, stmt, GSI_NEW_STMT);
+	    }
+	}
+    }
+}
+
+/* Perform all the work needed to insert profile instrumentation for the
+   current function  */
+static unsigned int
+tilegx_instrument_function (void)
+{
+  /* Don't profile functions produced at destruction time.  Don't profile if it
+     has been already instrumented either (when OpenMP expansion creates child
+     function from already instrumented body).  */
+  if (cgraph_state == CGRAPH_STATE_FINISHED
+      || cfun->machine->feedback_info.instrumented)
+    return 0;
+
+  feedback_initialize_globals ();
+
+  gcc_assert(cfun->machine);
+
+  feedback_declare_function_variables (&cfun->machine->feedback_info,
+				       current_function_assembler_name (),
+				       NULL);
+
+  if (enable_feedback_generate_linker ())
+    {
+      tree ffv = cfun->machine->feedback_info.feedback_function_var;
+      feedback_linker_instrument (ffv);
+    }
+
+  cfun->machine->feedback_info.instrumented = true;
+
+  return 0;
+}
+
+
+/* Returns whether instrumentation is needed.  */
+static bool
+tilegx_instrument_gate (void)
+{
+  return enable_feedback_generate ();
+}
+
+
+static void
+assemble_ptr_diff (rtx ptr, rtx base, unsigned int size,
+		   unsigned int align, int force)
+{
+  assemble_integer (gen_rtx_MINUS (Pmode, ptr, base),
+		    size, align, force);
+}
+
+
+static void
+assemble_ptr_diff_char (const char *ptr, const char *base, unsigned int size,
+			unsigned int align, int force)
+{
+  assemble_ptr_diff (gen_rtx_SYMBOL_REF (Pmode, ptr),
+		     gen_rtx_SYMBOL_REF (Pmode, base),
+		     size, align, force);
+}
+
+
+/* Emit the feedback function object to assembly.  */
+static void
+emit_feedback_function_object (const char* fn_name,
+			       tilegx_feedback_info *info,
+			       struct function_list *fn)
+{
+  int field;
+  unsigned rest_size;
+  tilegx_field_desc *desc;
+  const char *name;
+  const char *base_name;
+
+  tree ffv = info->feedback_function_var;
+
+  /* Emit the preamble only.  */
+  assemble_variable (ffv, 0, 0, 1);
+
+  field = 0;
+
+  /* id */
+  desc = &tilegx_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "id") == 0);
+  assemble_zeros (desc->size);
+
+  /* num_bytes */
+  desc = &tilegx_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "num_bytes") == 0);
+  if (info->end_label[0] != '\0')
+    {
+      assemble_ptr_diff_char (info->end_label, fn_name, desc->size, 1, 1);
+    }
+  else
+    {
+      assemble_zeros (desc->size);
+    }
+
+  /* relative_function_name */
+  desc = &tilegx_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "relative_function_name") == 0);
+  base_name = IDENTIFIER_POINTER (DECL_NAME (ffv));
+  name = IDENTIFIER_POINTER (DECL_NAME (info->function_name_var));
+  assemble_ptr_diff_char (name, base_name, desc->size, 1, 1);
+
+  /* relative_section_name */
+  desc = &tilegx_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "relative_section_name") == 0);
+  name = IDENTIFIER_POINTER (DECL_NAME (info->section_name_var));
+  assemble_ptr_diff_char (name, base_name, desc->size, 1, 1);
+
+  /* relative_source_file_name */
+  desc = &tilegx_feedback_function_desc[field++];
+  gcc_assert (strcmp (desc->name, "relative_source_file_name") == 0);
+  name = IDENTIFIER_POINTER (DECL_NAME (info->source_file_var));
+  assemble_ptr_diff_char (name, base_name, desc->size, 1, 1);
+
+  if (enable_feedback_generate_compiler () && fn)
+    {
+      char buf[20];
+      unsigned ctr_base_offset;
+      unsigned i;
+
+      fn->emitted = true;
+
+      /* checksum */
+      desc = &tilegx_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "checksum") == 0);
+      assemble_integer (GEN_INT (fn->checksum), desc->size, 1, 1);
+
+      /* gcc_id */
+      desc = &tilegx_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "gcc_id") == 0);
+      assemble_integer (GEN_INT (fn->ident), desc->size, 1, 1);
+
+      desc = &tilegx_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "num_counters") == 0);
+      for (i = 0; i < desc->array_size; i++)
+	{
+	  /* num_counters */
+	  assemble_integer (GEN_INT (fn->n_ctrs[i]), desc->size, 1, 1);
+	}
+
+      /* relative_counters */
+      desc = &tilegx_feedback_function_desc[field++];
+      gcc_assert (strcmp (desc->name, "relative_counters") == 0);
+      for (i = 0; i < desc->array_size; i++)
+	{
+	  if (fn->n_ctrs[i] > 0)
+	    {
+	      ASM_GENERATE_INTERNAL_LABEL (buf, "LPBX", i + 1);
+	      ctr_base_offset = fn->prg_n_ctrs[i] *
+		(GCOV_TYPE_SIZE / BITS_PER_UNIT);
+	      assemble_ptr_diff (gen_rtx_PLUS (Pmode,
+					       gen_rtx_SYMBOL_REF (Pmode, buf),
+					       GEN_INT (ctr_base_offset)),
+				 gen_rtx_SYMBOL_REF (Pmode, base_name),
+				 desc->size, 1, 1);
+	    }
+	  else
+	    assemble_zeros (desc->size);
+	}
+    }
+
+  /* rest of struct */
+  rest_size = 0;
+  while (tilegx_feedback_function_desc[field].name != NULL)
+    {
+      rest_size +=
+	tilegx_feedback_function_desc[field].array_size *
+	tilegx_feedback_function_desc[field].size;
+      field++;
+    }
+  assemble_zeros (rest_size);
+}
+
+
+/* Finalize and emit the section name object.  We need to do this late, after
+   the section name has been set.  */
+static void
+emit_section_name_object (void)
+{
+  const char *value;
+  int value_len;
+  char *value_buf;
+  tree string_type;
+  tree string_val;
+  tree section_name_var = cfun->machine->feedback_info.section_name_var;
+
+  if (section_name_var == NULL)
+    return;
+
+  value = TREE_STRING_POINTER (DECL_SECTION_NAME (current_function_decl));
+
+  /* compute the length of the string contents */
+  value_len = strlen (value);
+
+  /* copy value to a perminent buffer */
+  value_buf = XNEWVEC (char, value_len + 1);
+  strcpy (value_buf, value);
+
+  /* create the string type unsigned char [value_len + 1] */
+  string_type =
+    build_array_type (unsigned_char_type_node,
+		      build_index_type (size_int (value_len + 1)));
+
+  /* create the string value, and make its type string_type  */
+  string_val = build_string (value_len + 1, value_buf);
+  TREE_TYPE (string_val) = string_type;
+
+  /* update the type of section_name_var */
+  TREE_TYPE (section_name_var) = string_type;
+  layout_decl (section_name_var, 0);
+
+  /* set the initializer of section_name_var */
+  TREE_STATIC (section_name_var) = 1;
+  DECL_INITIAL (section_name_var) = string_val;
+
+  /* output the variable */
+  assemble_variable (section_name_var, 0, 0, 0);
+}
+
+
+static void
+tilegx_instrument_finish (void)
+{
+  tilegx_feedback_info *info = &cfun->machine->feedback_info;
+
+  if (info->feedback_function_var != NULL)
+    {
+      const char *fn_name = current_function_assembler_name ();
+
+      emit_feedback_function_object (fn_name, info,
+				     get_function_list (fn_name));
+    }
+
+  emit_section_name_object ();
+}
+
+
+static void
+tilegx_emit_coverage_data (void)
+{
+  struct function_list *fn;
+
+  if (!enable_feedback_generate_compiler ())
+    {
+      default_emit_coverage_data ();
+      return;
+    }
+
+  build_all_ctr_info_values ();
+
+  /* Emit feedback objects for functions that are not emitted.  */
+  feedback_initialize_globals ();
+
+  for (fn = get_function_list_head (); fn; fn = fn->next)
+    {
+      tilegx_feedback_info info;
+
+      if (fn->emitted) continue; fn->emitted = true;
+
+      info.end_label[0] = '\0';
+      feedback_declare_function_variables (&info, fn->name, "*none*");
+      emit_feedback_function_object (fn->name, &info, fn);
+    }
+}
+
+
+/* Support for compiler feedback with single-file format.  */
+
+#define FSEEK(_fd, _position, whence, _error_message, _error_arg) \
+     if (fseek(_fd, _position, whence) != 0) \
+           error(_error_message, _error_arg);
+
+#define FREAD(_buffer, _size, _nitems, _fp, _error_message, _error_arg) \
+        if (fread((void *)_buffer, _size, _nitems, _fp) != _nitems) \
+           error(_error_message, _error_arg);
+
+
+static char ERR_POS[] = "error in positioning within %s";
+static char ERR_READ[] = "error in reading from %s";
+
+
+/* Read the main header in the feedback file  */
+
+static void
+profile_get_file_header(FILE *fp, const char *fname, Fb_Hdr *fb_hdr)
+{
+  FSEEK (fp, 0, SEEK_SET, ERR_POS, fname);
+  FREAD (fb_hdr, sizeof(Fb_Hdr), 1, fp,
+	 "error while reading from: %s", fname);
+}
+
+
+/* Read the PU header table; It is assumed that the caller has 
+   allocated the necessary storage in pu_hdr_table.  */
+
+static void
+profile_get_pu_hdr_table(FILE *fp, const char *fname, const Fb_Hdr* fb_hdr,
+			 Pu_Hdr *pu_hdr_table)
+{
+  FSEEK(fp, fb_hdr->fb_pu_hdr_offset, SEEK_SET, ERR_POS, fname);
+  FREAD(pu_hdr_table, sizeof(Pu_Hdr), fb_hdr->fb_pu_hdr_num,
+	fp, ERR_READ, fname);
+}
+
+
+/* Read the string table that holds the names of PU's; It is assumed that the
+   caller has allocated the necessary storage in str_table.  */
+
+static void
+profile_get_str_table(FILE *fp, const char *fname, const Fb_Hdr* fb_hdr,
+		      char *str_table)
+{
+  FSEEK(fp, fb_hdr->fb_str_table_offset, SEEK_SET, ERR_POS, fname);
+  FREAD(str_table, sizeof(char), fb_hdr->fb_str_table_size,
+	fp, ERR_READ, fname);
+}
+
+
+/* Given a PU handle, allocate storage for the profile counters in 
+   PU handle and update it with data from feedback file.  */
+
+static void
+profile_read_counters(gcov_type *counts, size_t num_counters,
+		     long file_offset, FILE *fp, const char *fname)
+{
+  FSEEK(fp, file_offset, SEEK_SET, ERR_POS, fname);
+ 
+  FREAD (counts, sizeof(gcov_type), num_counters, fp,
+	 ERR_READ, fname);
+}
+
+
+/* Read profile counters from a tile feedback file.  */
+
+static void
+tilegx_initialize_profile_counters (void)
+{
+  const char *fb_name = tilegx_feedback_use_compiler_file;
+  FILE *fp;
+  Fb_Hdr fb_hdr;
+  Pu_Hdr *pu_hdr_table;
+  char *str_table;
+  htab_t counts_hash = NULL;
+  unsigned i, j;
+  counts_entry_t *all_summable = NULL;
+
+  if (fb_name == NULL)
+    {
+      default_initialize_profile_counters ();
+      return;
+    }
+
+  if ((fp = fopen (fb_name, "r")) == NULL) {
+    error ("unable to open file: %s", fb_name);
+  }
+
+  profile_get_file_header (fp, fb_name, &fb_hdr);
+
+  if (fb_hdr.fb_magic != FEEDBACK_COLLECT_HEADER_MAGIC)
+    {
+      if (fb_hdr.fb_magic == FEEDBACK_HEADER_MAGIC)
+	{
+	  error ("file '%s' is a raw feedback file which must be "
+		 "converted using tile-convert-feedback before it "
+		 "can be used", fb_name);
+	}
+      else
+	{
+	  error ("file '%s' is not a feedback file", fb_name);
+	}
+    }
+
+  if (fb_hdr.fb_version != FEEDBACK_COLLECT_HEADER_CURRENT)
+    {
+      error ("unable to open file with unsupported version number: %s",
+	     fb_name);
+    }
+
+  pu_hdr_table = XCNEWVEC (Pu_Hdr, fb_hdr.fb_pu_hdr_num);
+  profile_get_pu_hdr_table (fp, fb_name, &fb_hdr, pu_hdr_table);
+
+  str_table = XCNEWVEC (char, fb_hdr.fb_str_table_size);
+  profile_get_str_table (fp, fb_name, &fb_hdr, str_table);
+
+  /* Read in the feedback data corresponding to this file.  */
+  for (i = 0; i < fb_hdr.fb_pu_hdr_num; i++)
+    {
+      Pu_Hdr *pu_hdr;
+      const char *pu_name;
+      const char *pu_source_name;
+      long pu_counters_offset;
+      counts_entry_t **slot, *entry, elt;
+      gcov_unsigned_t count;
+
+      pu_hdr = &pu_hdr_table[i];
+      pu_name = str_table + pu_hdr->pu_name_index;
+      pu_source_name = str_table + pu_hdr->pu_source_name_index;
+
+      if (strcmp (pu_source_name, get_strip_filename (main_input_filename)))
+	continue;
+
+      if (counts_hash == NULL)
+	{
+	  counts_hash = create_counts_hash (10);
+	  set_counts_hash (counts_hash);
+	}
+
+      /* Skip over those without a valid gcc_id; those are not instrumented.  */
+      if (pu_hdr->pu_gcc_id == 0)
+	continue;
+
+      elt.name = pu_name;
+      elt.function_id = coverage_checksum_string (0, pu_name);
+
+      for (j = 0; j < GCOV_COUNTERS; j++)
+	{
+	  elt.ctr = j;
+	  count = pu_hdr->pu_num_counter_entries[j];
+
+	  if ((int)count < 0)
+	    error ("corrupted feedback file '%s'", fb_name);
+
+	  if (count > 0)
+	    {
+	      slot = (counts_entry_t **)
+		htab_find_slot (counts_hash, &elt, INSERT);
+	      if (*slot)
+		{
+		  if (!warn_coverage)
+		    continue;
+
+		  if (!flag_coverage_permissive)
+		    warning (0, "duplicate counters for function %qs",
+			     pu_name);
+		  else
+		    inform (0, "duplicate counters for function %qs",
+			    pu_name);
+
+		  continue;
+		}
+
+	      *slot = entry = XCNEW (counts_entry_t);
+	      entry->function_id = elt.function_id;
+	      entry->ctr = elt.ctr;
+	      entry->name = pu_name;
+	      entry->ident = pu_hdr->pu_gcc_id;
+	      entry->checksum = pu_hdr->pu_checksum;
+	      entry->summary.num = count;
+	      entry->counts = XCNEWVEC (gcov_type, count);
+
+	      pu_counters_offset = fb_hdr.fb_profile_offset +
+		pu_hdr->pu_file_offset[j];
+
+	      profile_read_counters(entry->counts, count, pu_counters_offset,
+				    fp, fb_name);
+
+	      if (elt.ctr < GCOV_COUNTERS_SUMMABLE)
+		{
+		  entry->chain = all_summable;
+		  all_summable = entry;
+		}
+	    }
+	}
+    }
+
+  /* Read the summary, and write it to all the relevant entries.  */
+  {
+    counts_entry_t *entry;
+
+    for (entry = all_summable; entry; entry = entry->chain)
+      {
+	entry->summary.runs = fb_hdr.cs_runs;
+	entry->summary.sum_all = fb_hdr.cs_sum_all;
+	entry->summary.run_max = fb_hdr.cs_run_max;
+	entry->summary.sum_max = fb_hdr.cs_sum_max;
+      }
+  }
+
+  fclose (fp);
+  coverage_set_identify_function_by_id (false);
+}
+
+
+#undef TARGET_INITIALIZE_PROFILE_COUNTERS
+#define TARGET_INITIALIZE_PROFILE_COUNTERS tilegx_initialize_profile_counters
+
+#undef TARGET_EMIT_COVERAGE_DATA
+#define TARGET_EMIT_COVERAGE_DATA tilegx_emit_coverage_data
+
+#undef TARGET_INSTRUMENT_GATE
+#define TARGET_INSTRUMENT_GATE tilegx_instrument_gate
+
+#undef TARGET_INSTRUMENT_FUNCTION
+#define TARGET_INSTRUMENT_FUNCTION tilegx_instrument_function
+
+#undef TARGET_INSTRUMENT_FINISH
+#define TARGET_INSTRUMENT_FINISH tilegx_instrument_finish
+
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/feedback.h ./gcc/config/tilegx/feedback.h
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/feedback.h	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilegx/feedback.h	2015-10-26 22:26:58.288200000 -0400
@@ -0,0 +1,154 @@
+/*
+ * Copyright 2014 Tilera Corporation. All Rights Reserved.
+ *
+ *   This program is free software; you can redistribute it and/or
+ *   modify it under the terms of the GNU General Public License
+ *   as published by the Free Software Foundation, version 2.
+ *
+ *   This program is distributed in the hope that it will be useful, but
+ *   WITHOUT ANY WARRANTY; without even the implied warranty of
+ *   MERCHANTABILITY OR FITNESS FOR A PARTICULAR PURPOSE, GOOD TITLE or
+ *   NON INFRINGEMENT.  See the GNU General Public License for
+ *   more details.
+ *
+ * Runtime support for the compiler's feedback-based optimization.
+ */
+
+#ifndef __FEEDBACK_H__
+#define __FEEDBACK_H__
+
+#ifdef __ASSEMBLER__
+
+/* FEEDBACK_ENTER is a macro to be called at the very start of any
+ * hand-written assembly function that wants to be instrumented for
+ * cache packing purposes.
+ *
+ * It clobbers r10-r29, as any subroutine call would. This should be OK
+ * since it is being called on entry to an asm procedure, so presumably
+ * those registers are not in use anyway (they are not part of the standard
+ * calling convention).
+ *
+ * A sample call would look like this, and assumes that function
+ * "myfunc" is in section ".text.myfunc", and has a label at the end
+ * of the function called ".Lend_myfunc":
+ *
+ * FEEDBACK_ENTER(myfunc)
+ *
+ * If your function does not have a standard section or end-label
+ * naming, you can use
+ *
+ * FEEDBACK_ENTER_EXPLICIT(myfunc, mysection, mysize)
+ *
+ * If your function calls another function internally, you should place
+ * a macro immediately after return, as follows:
+ *
+ * FEEDBACK_REENTER(myfunc)
+ *
+ * Note that this also clobbers r10-r29, but they should be dead at
+ * this point anyway due to the function call.
+ *
+ * If your function has multiple entry points, you should make one of
+ * them be FEEDBACK_ENTER, and the remainder use FEEDBACK_REENTER.
+ * The distinction is that FEEDBACK_ENTER defines the static data
+ * structures used by both macros.
+ *
+ */
+#ifdef __COLLECT_LINKER_FEEDBACK__
+
+#ifndef __tilegx__
+#define __FEEDBACK_CODE(feedbackfunc)                           \
+        {                                                       \
+        move r10, lr;                                           \
+        moveli r11, lo16(feedbackfunc - 3f);                    \
+        };                                                      \
+        {                                                       \
+        auli r11, r11, ha16(feedbackfunc - 3f);                 \
+        jal plt(__feedback_asm_function_entered);               \
+        };                                                      \
+3:
+#define __FEEDBACK_CODE_SIZE 16
+#else
+#define __FEEDBACK_CODE(feedbackfunc)                           \
+        {                                                       \
+        move r10, lr;                                           \
+        moveli r11, hw2_last(feedbackfunc - 3f);                \
+        };                                                      \
+        shl16insli r11, r11, hw1(feedbackfunc - 3f);            \
+        {                                                       \
+        shl16insli r11, r11, hw0(feedbackfunc - 3f);            \
+        jal plt(__feedback_asm_function_entered);               \
+        };                                                      \
+3:
+#define __FEEDBACK_CODE_SIZE 24
+#endif
+
+#define FEEDBACK_ENTER_EXPLICIT(FUNCNAME, SECNAME, SIZE)        \
+        .pushsection .feedback.strings, "aMS",@progbits,1;      \
+0:      .asciz #FUNCNAME;                                       \
+1:      .asciz #SECNAME;                                        \
+2:      .asciz __FILE__;                                        \
+        .popsection;                                            \
+                                                                \
+        .pushsection .feedback.functions, "aw";                 \
+        .align 4;                                               \
+        /* Define a FeedbackFunction struct. */                 \
+.Lfeedback_function_##FUNCNAME:;                                \
+        .word 0;                                                \
+        .word (SIZE) - 16; /* Subtract code overhead below. */  \
+        .word 0b - .Lfeedback_function_##FUNCNAME;              \
+        .word 1b - .Lfeedback_function_##FUNCNAME;              \
+        .word 2b - .Lfeedback_function_##FUNCNAME;              \
+        .word 0;                                                \
+        .word 0;                                                \
+        .zero 32;                                               \
+        .zero 32;                                               \
+        .popsection;                                            \
+        __FEEDBACK_CODE(.Lfeedback_function_##FUNCNAME)
+
+#define FEEDBACK_ENTER(FUNCNAME) \
+  FEEDBACK_ENTER_EXPLICIT(FUNCNAME, .text.##FUNCNAME, \
+    .Lend_##FUNCNAME - FUNCNAME)
+
+#define FEEDBACK_REENTER(FUNCNAME) \
+  __FEEDBACK_CODE(.Lfeedback_function_##FUNCNAME)
+
+/*
+ * DEPRECATED: Backwards compatible for code from 2.0 and earlier.
+ * Note that you can't use FEEDBACK_REENTER with FEEDBACK_ENTRY.
+ */
+#define FEEDBACK_ENTRY(FUNCNAME, SECNAME, SIZE)                 \
+        .pushsection .feedback.strings, "aMS",@progbits,1;      \
+0:      .asciz FUNCNAME;                                        \
+1:      .asciz SECNAME;                                         \
+2:      .asciz __FILE__;                                        \
+        .popsection;                                            \
+                                                                \
+        .pushsection .feedback.functions, "aw";                 \
+        .align 4;                                               \
+        /* Define a FeedbackFunction struct. */                 \
+99:     .word 0;                                                \
+        .word (SIZE) - 16; /* Subtract code overhead below. */  \
+        .word 0b - 99b;                                         \
+        .word 1b - 99b;                                         \
+        .word 2b - 99b;                                         \
+        .word 0;                                                \
+        .word 0;                                                \
+        .zero 32;                                               \
+        .zero 32;                                               \
+        .popsection;                                            \
+        __FEEDBACK_CODE(99b)
+
+#else  /* !__COLLECT_LINKER_FEEDBACK__ */
+
+/* Not collecting linker feedback, so these are no-ops. */
+#define FEEDBACK_ENTER_EXPLICIT(FUNCNAME, SECNAME, SIZE)
+#define FEEDBACK_ENTER(FUNCNAME)
+#define FEEDBACK_REENTER(FUNCNAME)
+#define FEEDBACK_ENTRY(FUNCNAME, SECNAME, SIZE)
+
+#endif  /* !__COLLECT_LINKER_FEEDBACK__ */
+
+#endif  /* __ASSEMBLER__ */
+
+
+#endif  /* !__FEEDBACK_H__ */
diff -r -u -N /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/linux.h ./gcc/config/tilegx/linux.h
--- /home/packages/gcc-4.4.7-3-java/gcc/config/tilegx/linux.h	1969-12-31 19:00:00.000000000 -0500
+++ ./gcc/config/tilegx/linux.h	2015-10-26 22:26:57.588190000 -0400
@@ -0,0 +1,91 @@
+#undef SYSROOT_SUFFIX_SPEC
+#define SYSROOT_SUFFIX_SPEC "%{mbme:/usr/lib/bme;mnewlib:/usr/lib/newlib}"
+
+#undef SYSROOT_HEADERS_SUFFIX_SPEC
+#define SYSROOT_HEADERS_SUFFIX_SPEC SYSROOT_SUFFIX_SPEC
+
+#undef CPP_SPEC
+#define CPP_SPEC \
+  "%{mbme:-D__BME__;mnewlib:-D__NEWLIB__} %{pthread:-D_REENTRANT}"
+
+#undef ASM_SPEC
+#define ASM_SPEC "%(endian_spec) %{m32:--32} %{m64:--64}"
+
+#define GLIBC_DYNAMIC_LINKER32 "/lib32/ld.so.1"
+#define GLIBC_DYNAMIC_LINKER64 "/lib/ld.so.1"
+
+#undef	LINK_SPEC
+#define LINK_SPEC "%(endian_spec) \
+  %{m64:-m elf64tilegx} %{m32:-m elf32tilegx} \
+  %{shared:-shared} \
+  %{!shared: \
+    %{!static: \
+      %{rdynamic:-export-dynamic} \
+      -dynamic-linker \
+        %{ m32: " LINUX_DYNAMIC_LINKER32 "} \
+        %{!m32: " LINUX_DYNAMIC_LINKER64 "}} \
+    %{static:-static}}"
+
+#undef  LIB_SPEC
+#define LIB_SPEC \
+  "%{ffeedback-generate*|ffeedback-emit*:-lgcov -linstr} \
+   %{pthread:-lpthread} \
+   %{shared:-lc} \
+   %{!shared:%{mieee-fp:-lieee} %{profile:-lc_p}%{!profile:-lc}}"
+
+#undef  STARTFILE_SPEC
+#define STARTFILE_SPEC "\
+  %{!shared: %{pg|p|profile:gcrt1.o%s;pie:Scrt1.o%s;:crt1.o%s}} \
+  crti.o%s \
+  %{static:crtbeginT.o%s;shared|pie:crtbeginS.o%s;:crtbegin.o%s} \
+  %{ffeedback-emit*:crtfbi.o%s}"
+
+#undef  ENDFILE_SPEC
+#define ENDFILE_SPEC "\
+  %{ffeedback-emit*:crtfbn.o%s} \
+  %{shared|pie:crtendS.o%s;:crtend.o%s} crtn.o%s"
+
+#undef DRIVER_SELF_SPECS
+#define DRIVER_SELF_SPECS "%{mbme|mnewlib:-static}"
+
+#define MULTILIB_DEFAULTS { "m64" }
+
+#define TARGET_VERSION fprintf (stderr, " (TILE-Gx GNU/Linux with ELF)")
+
+/* The `mcount' subroutine on linux does not need a counter variable
+   allocated for each function.  */
+#define NO_PROFILE_COUNTERS	1
+
+/* Name of the MCOUNT subroutine.  */
+#undef MCOUNT_NAME
+#define MCOUNT_NAME "__mcount"
+
+#undef NEED_INDICATE_EXEC_STACK
+#define NEED_INDICATE_EXEC_STACK 1
+
+#define MD_UNWIND_SUPPORT "config/tilepro/linux-unwind.h"
+
+#ifdef TARGET_LIBC_PROVIDES_SSP
+/* TILE-Gx glibc provides __stack_chk_guard two pointer-size words before
+   tp. */
+#define TARGET_THREAD_SSP_OFFSET (-2 * GET_MODE_SIZE (ptr_mode))
+#endif
+
+/* For __clear_cache in libgcc2.c.  */
+#ifdef IN_LIBGCC2
+
+#include <arch/icache.h>
+
+/* Use the minimum page size of 4K.  Alternatively we can call
+   getpagesize() but it introduces a libc dependence.  */
+#undef CLEAR_INSN_CACHE
+#define CLEAR_INSN_CACHE(beg, end) invalidate_icache (beg, end - beg, 4096)
+
+#else
+
+/* define CLEAR_INSN_CACHE so that gcc knows to expand __builtin__clear_cache
+   to the libraray call.  */
+#undef CLEAR_INSN_CACHE
+#define CLEAR_INSN_CACHE 1
+
+#endif
