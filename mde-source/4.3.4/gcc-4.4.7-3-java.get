 }
 
+/* Update the checksum with the contents of GSI.  The checksum is stored in
+   WIP->info.  */
+static tree
+calculate_checksum_p_stmt (gimple_stmt_iterator *gsi,
+			   bool* handled_ops ATTRIBUTE_UNUSED,
+			   struct walk_stmt_info *wip)
+{
+  unsigned checksum = (int)wip->info;
+  gimple stmt = gsi_stmt (*gsi);
+
+  checksum ^= (int)gimple_code (stmt);
+  checksum = (checksum << 1) | (checksum >> 31);
+
+  wip->info = (void*)checksum;
+
+  return NULL_TREE;
+}
+
+
+/* Update the checksum with the contents of nodep.  The checksum is stored in
+   ((walk_stmt_info*)P)->info.  */
+static tree
+calculate_checksum_p_op (tree *nodep, int *walk_subtrees ATTRIBUTE_UNUSED,
+			 void *p)
+{
+  struct walk_stmt_info *wip = (struct walk_stmt_info *)p;
+  tree node = *nodep;
+  unsigned checksum = (unsigned)wip->info;
+
+  checksum ^= (int)TREE_CODE (node);
+  checksum = (checksum << 1) | (checksum >> 31);
+
+  wip->info = (void*)checksum;
+
+  return NULL_TREE;
+}
+
+
+/* Return the checksum for a function.  Should make sure it is called in the
+   same place in the compilating process, else its value may change!  */
+static unsigned
+compute_checksum_from_contents (void)
+{
+  basic_block bb;
+  struct walk_stmt_info wi;
+
+  memset (&wi, 0, sizeof (wi));
+
+  FOR_EACH_BB (bb)
+    {
+      gimple_seq seq = bb_seq (bb);
+      walk_gimple_seq (seq, calculate_checksum_p_stmt,
+		       calculate_checksum_p_op, &wi);
+    }
+
+  return (unsigned)wi.info;
+}
