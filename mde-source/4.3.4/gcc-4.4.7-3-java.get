+(define_insn "insn_ldnt16_miss_ise1"
+  [(set (match_operand:TI 0 "register_operand" "=r")
+	(unspec:TI
+	 [(unspec:TI
+	   [(mem:TI (match_operand:DI 1 "register_operand" "rO"))]
+	   UNSPEC_NON_TEMPORAL)]
+	 UNSPEC_LATENCY_MISS))]
+  "TARGET_ISE1"
+  "ldnt16\t%0, %r1"
+  [(set_attr "type" "ZX1_miss")])
+
+(define_expand "insn_ldnt16_miss"
+  [(set (match_operand:TI 0 "register_operand" "=r")
+	(unspec:TI [(unspec:TI
+                     [(mem:TI (match_operand 1 "pointer_operand" "rO"))]
+                     UNSPEC_NON_TEMPORAL)]
+                   UNSPEC_LATENCY_MISS))]
+  ""
+{
+  if (TARGET_ISE1)
+    {
+      emit_insn (gen_insn_ldnt16_miss_ise1 (operands[0], operands[1]));
+    }
+  else
+    {
+      rtx dest_lo, dest_hi;
+      rtx addr_lo, addr_hi;
+
+      dest_lo = simplify_gen_subreg (DImode, operands[0], TImode, 0);
+      dest_hi = simplify_gen_subreg (DImode, operands[0], TImode, 8);
+
+      addr_lo = force_reg (Pmode, operands[1]);
+      addr_hi = gen_reg_rtx (Pmode);
+
+      emit_move_insn (addr_hi, gen_rtx_PLUS (Pmode, addr_lo, GEN_INT (8)));
+
+      emit_insn (gen_insn_ldnt_miss (dest_lo, addr_lo));
+      emit_insn (gen_insn_ldnt_miss (dest_hi, addr_hi));
+    }
+
+  DONE;
+})
