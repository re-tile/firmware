+(define_insn "<optab>v8qi3"
+  [(set (match_operand:V8QI 0 "register_operand" "=r,r")
+	(v1op_immed:V8QI
+	 (match_operand:V8QI 1 "reg_or_0_operand" "<comm>rW0,rW0")
+	 (match_operand:V8QI 2 "reg_or_v8s8bit_operand" "W3,rW0")))]
+  ""
+  "@
+   v1<insn>i\t%0, %r1, %j2
+   v1<insn>\t%0, %r1, %r2"
+  [(set_attr "type" "<pipe>,<pipe>")])
