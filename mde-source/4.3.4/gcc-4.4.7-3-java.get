diff -r -u -N /home/packages/gcc-4.4.7-3-java/libmudflap/mf-hooks1-tmc.c ./libmudflap/mf-hooks1-tmc.c
--- /home/packages/gcc-4.4.7-3-java/libmudflap/mf-hooks1-tmc.c	1969-12-31 19:00:00.000000000 -0500
+++ ./libmudflap/mf-hooks1-tmc.c	2015-10-26 22:26:57.930185000 -0400
@@ -0,0 +1,434 @@
+/* Mudflap: narrow-pointer bounds-checking by tree rewriting.
+   Copyright (C) 2012 Free Software Foundation, Inc.
+
+This file is part of GCC.
+
+GCC is free software; you can redistribute it and/or modify it under
+the terms of the GNU General Public License as published by the Free
+Software Foundation; either version 3, or (at your option) any later
+version.
+
+GCC is distributed in the hope that it will be useful, but WITHOUT ANY
+WARRANTY; without even the implied warranty of MERCHANTABILITY or
+FITNESS FOR A PARTICULAR PURPOSE.  See the GNU General Public License
+for more details.
+
+Under Section 7 of GPL version 3, you are granted additional
+permissions described in the GCC Runtime Library Exception, version
+3.1, as published by the Free Software Foundation.
+
+You should have received a copy of the GNU General Public License and
+a copy of the GCC Runtime Library Exception along with this program;
+see the files COPYING3 and COPYING.RUNTIME respectively.  If not, see
+<http://www.gnu.org/licenses/>.  */
+
+#include "config.h"
+
+#ifndef HAVE_SOCKLEN_T
+#define socklen_t int
+#endif
+
+
+/* These attempt to coax various unix flavours to declare all our
+   needed tidbits in the system headers.  */
+#if !defined(__FreeBSD__)  && !defined(__APPLE__)
+#define _POSIX_SOURCE
+#endif /* Some BSDs break <sys/socket.h> if this is defined. */
+#define _GNU_SOURCE
+#define _XOPEN_SOURCE
+#define _BSD_TYPES
+#define __EXTENSIONS__
+#define _ALL_SOURCE
+#define _LARGE_FILE_API
+#define _XOPEN_SOURCE_EXTENDED 1
+
+#include <string.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <sys/time.h>
+#include <sys/types.h>
+#include <unistd.h>
+#include <assert.h>
+#include <errno.h>
+#include <limits.h>
+#include <time.h>
+
+#include "mf-runtime.h"
+#include "mf-impl.h"
+
+#ifdef _MUDFLAP
+#error "Do not compile this file with -fmudflap!"
+#endif
+
+
+/* Support tile's memory routines in tmc.  */
+#if __tile__
+
+typedef struct tmc_alloc_t tmc_alloc_t; /* See <tmc/alloc.h> */
+typedef void* tmc_mspace;               /* See <tmc/mspace.h> */
+
+
+#if PIC
+/* A special bootstrap variant. */
+void *
+__mf_0fn_tmc_alloc_map_at (const tmc_alloc_t* alloc, void *start,
+			   size_t length)
+{
+  abort ();
+  return (void *) -1;
+}
+#endif
+
+
+#undef tmc_alloc_map_at
+WRAPPER(void *, tmc_alloc_map_at, const tmc_alloc_t* alloc,
+	void *start, size_t length)
+{
+  DECLARE(void *, tmc_alloc_map_at, const tmc_alloc_t*, void *, size_t);
+  void *result;
+  BEGIN_PROTECT (tmc_alloc_map_at, alloc, start, length);
+
+  result = CALL_REAL (tmc_alloc_map_at, alloc, start, length);
+
+  /*
+  VERBOSE_TRACE ("tmc_alloc_map_at (%08lx, %08lx, ...) => %08lx\n",
+		 (uintptr_t) start, (uintptr_t) length,
+		 (uintptr_t) result);
+  */
+
+  if (result != NULL)
+    {
+      /* Register each page as a heap object.  Why not register it all
+	 as a single segment?  That's so that a later munmap() call
+	 can unmap individual pages.  XXX: would __MF_TYPE_GUESS make
+	 this more automatic?  */
+      size_t ps = getpagesize ();
+      uintptr_t base = (uintptr_t) result;
+      uintptr_t offset;
+
+      for (offset=0; offset<length; offset+=ps)
+	{
+	  /* XXX: We could map PROT_NONE to __MF_TYPE_NOACCESS. */
+	  /* XXX: Unaccessed HEAP pages are reported as leaks.  Is this
+	     appropriate for unaccessed mmap pages? */
+	  __mf_register ((void *) CLAMPADD (base, offset), ps,
+			 __MF_TYPE_HEAP_I, "tmc_alloc_map page");
+	}
+    }
+
+  return result;
+}
+
+
+#if PIC
+/* A special bootstrap variant. */
+int
+__mf_0fn_tmc_alloc_unmap (void *start, size_t length)
+{
+  abort ();
+  return -1;
+}
+#endif
+
+
+#undef tmc_alloc_unmap
+WRAPPER(int , tmc_alloc_unmap, void *start, size_t length)
+{
+  DECLARE(int, tmc_alloc_unmap, void *, size_t);
+  int result;
+  BEGIN_PROTECT (tmc_alloc_unmap, start, length);
+
+  result = CALL_REAL (tmc_alloc_unmap, start, length);
+
+  /*
+  VERBOSE_TRACE ("tmc_alloc_unmap (%08lx, %08lx, ...) => %08lx\n",
+		 (uintptr_t) start, (uintptr_t) length,
+		 (uintptr_t) result);
+  */
+
+  if (result == 0)
+    {
+      /* Unregister each page as a heap object.  */
+      size_t ps = getpagesize ();
+      uintptr_t base = (uintptr_t) start & (~ (ps - 1)); /* page align */
+      uintptr_t offset;
+
+      for (offset=0; offset<length; offset+=ps)
+	__mf_unregister ((void *) CLAMPADD (base, offset), ps, __MF_TYPE_HEAP_I);
+    }
+  return result;
+}
+
+
+#if PIC
+void *
+__mf_0fn_tmc_mspace_malloc (tmc_mspace mspace, size_t c)
+{
+  abort ();
+  return NULL;
+}
+#endif
+
+
+#undef tmc_mspace_malloc
+WRAPPER(void *, tmc_mspace_malloc, tmc_mspace mspace, size_t c)
+{
+  size_t size_with_crumple_zones;
+  DECLARE(void *, tmc_mspace_malloc, tmc_mspace, size_t);
+  void *result;
+  BEGIN_PROTECT (tmc_mspace_malloc, mspace, c);
+
+  size_with_crumple_zones =
+    CLAMPADD(c,CLAMPADD(__mf_opts.crumple_zone,
+			__mf_opts.crumple_zone));
+  BEGIN_MALLOC_PROTECT ();
+  result = (char *) CALL_REAL (tmc_mspace_malloc, mspace,
+			       size_with_crumple_zones);
+  END_MALLOC_PROTECT ();
+
+  if (LIKELY(result))
+    {
+      result += __mf_opts.crumple_zone;
+      __mf_register (result, c, __MF_TYPE_HEAP, "tmc_mspace_malloc region");
+      /* XXX: register __MF_TYPE_NOACCESS for crumple zones.  */
+    }
+
+  return result;
+}
+
+
+#ifdef PIC
+/* A special bootstrap variant. */
+void *
+__mf_0fn_tmc_mspace_calloc (tmc_mspace mspace, size_t c, size_t n)
+{
+  abort ();
+  return NULL;
+}
+#endif
+
+
+#undef tmc_mspace_calloc
+WRAPPER(void *, tmc_mspace_calloc, tmc_mspace mspace, size_t c, size_t n)
+{
+  size_t size_with_crumple_zones;
+  DECLARE(void *, tmc_mspace_calloc, tmc_mspace, size_t, size_t);
+  DECLARE(void *, tmc_mspace_malloc, tmc_mspace, size_t);
+  DECLARE(void *, memset, void *, int, size_t);
+  char *result;
+  BEGIN_PROTECT (tmc_mspace_calloc, mspace, c, n);
+
+  size_with_crumple_zones =
+    CLAMPADD((c * n), /* XXX: CLAMPMUL */
+	     CLAMPADD(__mf_opts.crumple_zone,
+		      __mf_opts.crumple_zone));
+  BEGIN_MALLOC_PROTECT ();
+  result = (char *) CALL_REAL (tmc_mspace_malloc, mspace,
+			       size_with_crumple_zones);
+  END_MALLOC_PROTECT ();
+
+  if (LIKELY(result))
+    memset (result, 0, size_with_crumple_zones);
+
+  if (LIKELY(result))
+    {
+      result += __mf_opts.crumple_zone;
+      __mf_register (result, c*n /* XXX: clamp */, __MF_TYPE_HEAP_I,
+		     "tmc_mspace_calloc region");
+      /* XXX: register __MF_TYPE_NOACCESS for crumple zones.  */
+    }
+
+  return result;
+}
+
+
+#if PIC
+/* A special bootstrap variant. */
+void *
+__mf_0fn_tmc_mspace_realloc (tmc_mspace mspace, void *buf, size_t c)
+{
+  return NULL;
+}
+#endif
+
+
+#undef tmc_mspace_realloc
+WRAPPER(void *, tmc_mspace_realloc, tmc_mspace mspace, void *buf, size_t c)
+{
+  DECLARE(void * , tmc_mspace_realloc, tmc_mspace, void *, size_t);
+  size_t size_with_crumple_zones;
+  char *base = buf;
+  unsigned saved_wipe_heap;
+  char *result;
+  BEGIN_PROTECT (tmc_mspace_realloc, mspace, buf, c);
+
+  if (LIKELY(buf))
+    base -= __mf_opts.crumple_zone;
+
+  size_with_crumple_zones =
+    CLAMPADD(c, CLAMPADD(__mf_opts.crumple_zone,
+			 __mf_opts.crumple_zone));
+  BEGIN_MALLOC_PROTECT ();
+  result = (char *) CALL_REAL (tmc_mspace_realloc, mspace, base,
+			       size_with_crumple_zones);
+  END_MALLOC_PROTECT ();
+
+  /* Ensure heap wiping doesn't occur during this peculiar
+     unregister/reregister pair.  */
+  LOCKTH ();
+  __mf_set_state (reentrant);
+  saved_wipe_heap = __mf_opts.wipe_heap;
+  __mf_opts.wipe_heap = 0;
+
+  if (LIKELY(buf))
+    __mfu_unregister (buf, 0, __MF_TYPE_HEAP_I);
+  /* NB: underlying region may have been __MF_TYPE_HEAP. */
+
+  if (LIKELY(result))
+    {
+      result += __mf_opts.crumple_zone;
+      __mfu_register (result, c, __MF_TYPE_HEAP_I, "tmc_mspace_realloc region");
+      /* XXX: register __MF_TYPE_NOACCESS for crumple zones.  */
+    }
+
+  /* Restore previous setting.  */
+  __mf_opts.wipe_heap = saved_wipe_heap;
+
+  __mf_set_state (active);
+  UNLOCKTH ();
+
+  return result;
+}
+
+
+#if PIC
+/* A special bootstrap variant. */
+void *
+__mf_0fn_tmc_mspace_memalign (tmc_mspace mspace, size_t al, size_t c)
+{
+  abort ();
+  return NULL;
+}
+#endif
+
+
+#undef tmc_mspace_memalign
+WRAPPER(void *, tmc_mspace_memalign, tmc_mspace mspace, size_t al, size_t c)
+{
+  size_t size_with_crumple_zones;
+  DECLARE(void *, tmc_mspace_memalign, tmc_mspace, size_t, size_t);
+  void *result;
+  BEGIN_PROTECT (tmc_mspace_memalign, mspace, al, c);
+
+  if (__mf_opts.crumple_zone % al != 0)
+    {
+      fprintf (stderr,
+	       "mf error: unsupported tmc_mspace_memalign alignment %u.\n"
+	       "Please add \"-crumple-zone=<n>\" to MUDFLAP_OPTIONS\n"
+	       "environment variable, where <n> is either 0, or it is\n"
+	       "a multiple of all requested alignment.\n", (unsigned)al);
+      exit (1);
+    }
+
+  size_with_crumple_zones =
+    CLAMPADD(c,CLAMPADD(__mf_opts.crumple_zone,
+			__mf_opts.crumple_zone));
+  BEGIN_MALLOC_PROTECT ();
+  result = (char *) CALL_REAL (tmc_mspace_memalign, mspace, al,
+			       size_with_crumple_zones);
+  END_MALLOC_PROTECT ();
+
+  if (LIKELY(result))
+    {
+      result += __mf_opts.crumple_zone;
+      __mf_register (result, c, __MF_TYPE_HEAP, "tmc_mspace_memalign region");
+      /* XXX: register __MF_TYPE_NOACCESS for crumple zones.  */
+    }
+
+  assert (((uintptr_t)result & (al - 1)) == 0);
+
+  return result;
+}
+
+
+#if PIC
+/* A special bootstrap variant. */
+void
+__mf_0fn_tmc_mspace_free (void *buf)
+{
+  abort ();
+  return;
+}
+#endif
+
+#undef tmc_mspace_free
+WRAPPER(void, tmc_mspace_free, void *buf)
+{
+  /* Use a circular queue to delay some number
+     (__mf_opts.free_queue_length) of tmc_mspace_free()s.  */
+  static void *free_queue [__MF_FREEQ_MAX];
+  static unsigned free_ptr = 0;
+  static int freeq_initialized = 0;
+  DECLARE(void, tmc_mspace_free, void *);
+
+  BEGIN_PROTECT (tmc_mspace_free, buf);
+
+  if (UNLIKELY(buf == NULL))
+    return;
+
+  LOCKTH ();
+  if (UNLIKELY(!freeq_initialized))
+    {
+      memset (free_queue, 0,
+		     __MF_FREEQ_MAX * sizeof (void *));
+      freeq_initialized = 1;
+    }
+  UNLOCKTH ();
+
+  __mf_unregister (buf, 0, __MF_TYPE_HEAP_I);
+  /* NB: underlying region may have been __MF_TYPE_HEAP. */
+
+  if (UNLIKELY(__mf_opts.free_queue_length > 0))
+    {
+      char *freeme = NULL;
+      LOCKTH ();
+      if (free_queue [free_ptr] != NULL)
+	{
+	  freeme = free_queue [free_ptr];
+	  freeme -= __mf_opts.crumple_zone;
+	}
+      free_queue [free_ptr] = buf;
+      free_ptr = (free_ptr == (__mf_opts.free_queue_length-1) ? 0 : free_ptr + 1);
+      UNLOCKTH ();
+      if (freeme)
+	{
+	  if (__mf_opts.trace_mf_calls)
+	    {
+	      VERBOSE_TRACE ("freeing deferred pointer %p (crumple %u)\n",
+			     (void *) freeme,
+			     __mf_opts.crumple_zone);
+	    }
+	  BEGIN_MALLOC_PROTECT ();
+	  CALL_REAL (tmc_mspace_free, freeme);
+	  END_MALLOC_PROTECT ();
+	}
+    }
+  else
+    {
+      /* back pointer up a bit to the beginning of crumple zone */
+      char *base = (char *)buf;
+      base -= __mf_opts.crumple_zone;
+      if (__mf_opts.trace_mf_calls)
+	{
+	  VERBOSE_TRACE ("freeing pointer %p = %p - %u\n",
+			 (void *) base,
+			 (void *) buf,
+			 __mf_opts.crumple_zone);
+	}
+      BEGIN_MALLOC_PROTECT ();
+      CALL_REAL (tmc_mspace_free, base);
+      END_MALLOC_PROTECT ();
+    }
+}
+
+#endif /* __tile__ */
