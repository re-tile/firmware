#!/bin/bash -ex

# Run this script to create the corresponding source subdir in the CWD.

me=$(basename $0)
DIR=$(basename $0 .get)
if [ -d $DIR ]; then
    echo "$me: Cannot replace existing directory '$DIR'." >&2
    exit 1
fi

MD5SUM=60e55ac392531bad45ae80769195330c
FROM=http://vault.centos.org/6.4/os/Source/SPackages
ORIG=gcc-4.4.7-3.el6.src.rpm
ODIR=$(pwd)
if [ ! -f $ORIG ]; then
    if [ -n "$DOWNLOAD_CACHE" -a -f "$DOWNLOAD_CACHE/$ORIG" ]; then
        ODIR=$DOWNLOAD_CACHE
    else
        curl -L $FROM/$ORIG > $ORIG.tmp
        mv $ORIG.tmp $ORIG
    fi
fi

if [ $MD5SUM != `md5sum $ODIR/$ORIG | cut -f1 -d' '` ]; then
    echo "$me: Wrong md5sum for '$ORIG'." >&2
    exit 1
fi

# Most of the sources come from the centos SRPM.  However, the SRPM is
# missing a bunch of java files, which we get from the gnu gcc-4.4.7
# tarball.

MD5SUM2=295709feb4441b04e87dea3f1bab4281
FROM2=ftp://prep.ai.mit.edu/pub/gnu/gcc/gcc-4.4.7
ORIG2=gcc-4.4.7.tar.bz2
ODIR2=$(pwd)

if [ ! -f $ORIG2 ]; then
    if [ -n "$DOWNLOAD_CACHE" -a -f "$DOWNLOAD_CACHE/$ORIG2" ]; then
        ODIR2=$DOWNLOAD_CACHE
    else
        curl -L $FROM2/$ORIG2 > $ORIG2.tmp
        mv $ORIG2.tmp $ORIG2
    fi
fi

if [ $MD5SUM2 != `md5sum $ODIR2/$ORIG2 | cut -f1 -d' '` ]; then
    echo "$me: Wrong md5sum for '$ORIG2'." >&2
    exit 1
fi

mkdir -p $DIR/SRPM
cd $DIR/SRPM
rpm2cpio $ODIR/$ORIG | cpio -idv
cd ..
FROM=SRPM

FROM2=$ODIR2

tar --strip-components 1 -xjf $FROM2/gcc-4.4.7.tar.bz2 gcc-4.4.7/libjava
tar --strip-components 1 -xjf $FROM/gcc-4.4.7-20120601.tar.bz2

# The following is copied from the "%prep" step of the SRPM spec file,
# replacing "http://download.savannah.nongnu.org/releases/fastjar/"
# with "$FROM."

patch -p0 < $FROM/gcc44-hack.patch
patch -p0 < $FROM/gcc44-build-id.patch
patch -p0 < $FROM/gcc44-c++-builtin-redecl.patch
patch -p0 < $FROM/gcc44-ia64-libunwind.patch
patch -p0 < $FROM/gcc44-java-nomulti.patch
patch -p0 < $FROM/gcc44-ppc32-retaddr.patch
patch -p0 < $FROM/gcc44-pr33763.patch
patch -p0 < $FROM/gcc44-rh330771.patch
patch -p0 < $FROM/gcc44-i386-libgomp.patch
patch -p0 < $FROM/gcc44-sparc-config-detection.patch
patch -p0 < $FROM/gcc44-libgomp-omp_h-multilib.patch
patch -p0 < $FROM/gcc44-libtool-no-rpath.patch
patch -p0 < $FROM/gcc44-cloog-dl.patch
patch -p0 < $FROM/gcc44-unwind-debug-hook.patch
patch -p0 < $FROM/gcc44-pr38757.patch
patch -p0 < $FROM/gcc44-libstdc++-docs.patch
patch -p0 < $FROM/gcc44-ppc64-aixdesc.patch
patch -p0 < $FROM/gcc44-rh610785.patch
patch -p0 < $FROM/gcc44-rh533181.patch
patch -p0 < $FROM/gcc44-pr48857-test.patch
patch -p0 < $FROM/gcc44-pr43680.patch
patch -p0 < $FROM/gcc44-rh750545.patch
patch -p0 < $FROM/gcc44-pr53199.patch
patch -p0 < $FROM/gcc44-rh801144.patch
patch -p0 < $FROM/gcc44-rh808590.patch
patch -p0 < $FROM/gcc44-rh820281.patch
patch -p0 < $FROM/gcc44-pr54858.patch
patch -p0 < $FROM/gcc44-pr54487.patch
patch -p0 < $FROM/gcc44-rh867878.patch

rm libjava/testsuite/libjava.lang/PR35020*

tar xzf $FROM/fastjar-0.97.tar.gz

patch -p0 < $FROM/fastjar-0.97-segfault.patch
patch -p0 < $FROM/fastjar-0.97-len1.patch
patch -p0 < $FROM/fastjar-0.97-filename0.patch
patch -p0 < $FROM/fastjar-CVE-2010-0831.patch
patch -p0 < $FROM/fastjar-man.patch


echo 'Red Hat 4.4.7-3' > gcc/DEV-PHASE

sed -i '/UInteger Var(dwarf_version)/s/Init(2)/Init(3)/' gcc/common.opt
sed -i 's/\(may be either 2 or 3; the default version is \)2\./\13./' gcc/doc/invoke.texi

cp -a libstdc++-v3/config/cpu/i{4,3}86/atomicity.h

perl -pi -e 's/^all: all-redirect/ifeq (\$(MULTISUBDIR),)\nall: all-redirect\nelse\nall:\n\techo Multilib libjava build disabled\nendif/' libjava/Makefile.in
perl -pi -e 's/^install: install-redirect/ifeq (\$(MULTISUBDIR),)\ninstall: install-redirect\nelse\ninstall:\n\techo Multilib libjava install disabled\nendif/' libjava/Makefile.in
perl -pi -e 's/^check: check-redirect/ifeq (\$(MULTISUBDIR),)\ncheck: check-redirect\nelse\ncheck:\n\techo Multilib libjava check disabled\nendif/' libjava/Makefile.in
perl -pi -e 's/^all: all-recursive/ifeq (\$(MULTISUBDIR),)\nall: all-recursive\nelse\nall:\n\techo Multilib libjava build disabled\nendif/' libjava/Makefile.in
perl -pi -e 's/^install: install-recursive/ifeq (\$(MULTISUBDIR),)\ninstall: install-recursive\nelse\ninstall:\n\techo Multilib libjava install disabled\nendif/' libjava/Makefile.in
perl -pi -e 's/^check: check-recursive/ifeq (\$(MULTISUBDIR),)\ncheck: check-recursive\nelse\ncheck:\n\techo Multilib libjava check disabled\nendif/' libjava/Makefile.in

./contrib/gcc_update --touch

LC_ALL=C sed -i -e 's/\xa0/ /' gcc/doc/options.texi

# End of "%prep" stop copied from the SRPM spec file.

cd ..

rm -rf $DIR/SRPM

# FIXME: Assumes absolute "$0".
cat $0 | patch -d $DIR -p1 -s

exit 0


# The actual Tilera patch starts here.

