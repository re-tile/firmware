+(define_insn "insn_ldnt_miss"
+  [(set (match_operand:DI 0 "register_operand" "=r")
+	(unspec:DI
+	 [(unspec:DI
+	   [(mem:DI (match_operand 1 "pointer_operand" "rO"))]
+	   UNSPEC_NON_TEMPORAL)]
+	 UNSPEC_LATENCY_MISS))]
+  ""
+  "ldnt\t%0, %r1"
+  [(set_attr "type" "ZX1_miss")])
