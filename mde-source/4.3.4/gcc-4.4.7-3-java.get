+}
+#endif
+
+
+#undef memalign
+WRAPPER(void *, memalign, size_t al, size_t c)
+{
+  size_t size_with_crumple_zones;
+  DECLARE(void *, memalign, size_t, size_t);
+  void *result;
+  BEGIN_PROTECT (memalign, al, c);
+
+  if (__mf_opts.crumple_zone % al != 0)
+    {
+      fprintf (stderr,
+	       "mf error: unsupported memalign alignment %u.  Please add\n"
+	       "\"-crumple-zone=<n>\" to MUDFLAP_OPTIONS environment\n"
+	       "variable, where <n> is either 0, or it is a multiple\n"
+	       "of all requested alignment.\n", (unsigned)al);
+      exit (1);
+    }
+
+  size_with_crumple_zones =
+    CLAMPADD(c,CLAMPADD(__mf_opts.crumple_zone,
+			__mf_opts.crumple_zone));
+  BEGIN_MALLOC_PROTECT ();
+  result = (char *) CALL_REAL (memalign, al, size_with_crumple_zones);
+  END_MALLOC_PROTECT ();
+
+  if (LIKELY(result))
+    {
+      result += __mf_opts.crumple_zone;
+      __mf_register (result, c, __MF_TYPE_HEAP, "memalign region");
+      /* XXX: register __MF_TYPE_NOACCESS for crumple zones.  */
+    }
+
+  assert (((uintptr_t)result & (al - 1)) == 0);
+
+  return result;
+}
+
