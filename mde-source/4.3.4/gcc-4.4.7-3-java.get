+(define_expand "return"
+  [(parallel
+    [(return)
+     (use (reg:DI 55))])]
+  "tilegx_can_use_return_insn_p ()"
+  "")
+
+(define_insn "_return"
+  [(return)
+   (use (reg:DI 55))]
+  "reload_completed"
+  "jrp\tlr"
+  [(set_attr "type" "Y1_return")])
