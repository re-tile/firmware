+  [(set_attr "type" "X01,Y2_2cycle,X1_2cycle")])
+  
+(define_insn "zero_extendhisi2"
+  [(set (match_operand:SI 0 "register_operand" "=r,r,r")
+	(zero_extend:SI (match_operand:HI 1 "move_operand" "rO,U,m")))]
+  ""
+  "@
+   mm\t%0, %r1, zero, 0, 15
+   lh_u\t%0, %1
