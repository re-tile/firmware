+PHC_SRC		= dep/phc.c
+endif
+
+ifeq ($(USE_ADJFREQ),y)
+CFLAGS		+= -DUSE_ADJFREQ
+endif
+
+ifeq ($(USE_HW_TS),y)
+CFLAGS		+= -DUSE_HW_TS
+endif
