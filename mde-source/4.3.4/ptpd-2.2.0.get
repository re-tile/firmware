-	tar cvzf $(VERSION).tar.gz -L --exclude .o --exclude Doxygen --exclude .svn --exclude .dep --exclude core $(VERSION)
+	ln -s ../README .)
+	tar cvzf $(VERSION).tar.gz -h --exclude .o --exclude Doxygen --exclude .svn --exclude .dep --exclude core $(VERSION)
