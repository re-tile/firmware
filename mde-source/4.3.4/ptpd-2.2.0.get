 PROG = ptpd2
 SRCS = ptpd.c arith.c bmc.c protocol.c display.c\
-	dep/msg.c dep/net.c dep/servo.c dep/startup.c dep/sys.c dep/timer.c
+	dep/msg.c dep/net.c dep/servo.c dep/startup.c dep/sys.c dep/timer.c \
+	$(PHC_SRC)
 
 OBJS = $(SRCS:.c=.o)
 
@@ -72,6 +95,12 @@
 	$(GTAGS)
 	$(DOXYGEN) Doxyfile
 
+install: all
+	install $(INSTALL_OWNER) -m 0755 $(STRIP) $(PROG) $(BASEDIR)/usr/sbin
+
+uninstall:
+	$(RM) $(BASEDIR)/usr/sbin/$(PROG)
+
 clean:
 	$(RM) $(PROG) $(OBJS) make.out
 
